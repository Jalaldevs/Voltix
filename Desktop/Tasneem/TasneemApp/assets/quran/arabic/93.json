  "id": 93,
  "name": "الضحى",
  "transliteration": "Ad-Duhaa",
  "translation": "The Morning Hours",
  "type": "meccan",
  "total_verses": 11,
  "verses": [
    {
      "id": 1,
      "text": "وَٱلضُّحَىٰ",
      "translation": "By the morning brightness",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "وَٱلَّيۡلِ إِذَا سَجَىٰ",
      "translation": "And [by] the night when it covers with darkness",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "مَا وَدَّعَكَ رَبُّكَ وَمَا قَلَىٰ",
      "translation": "Your Lord has not taken leave of you, [O Muhammad], nor has He detested [you]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "وَلَلۡأٓخِرَةُ خَيۡرٞ لَّكَ مِنَ ٱلۡأُولَىٰ",
      "translation": "And the Hereafter is better for you than the first [life]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "وَلَسَوۡفَ يُعۡطِيكَ رَبُّكَ فَتَرۡضَىٰٓ",
      "translation": "And your Lord is going to give you, and you will be satisfied",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "أَلَمۡ يَجِدۡكَ يَتِيمٗا فَـَٔاوَىٰ",
      "translation": "Did He not find you an orphan and give [you] refuge",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "وَوَجَدَكَ ضَآلّٗا فَهَدَىٰ",
      "translation": "And He found you lost and guided [you]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "وَوَجَدَكَ عَآئِلٗا فَأَغۡنَىٰ",
      "translation": "And He found you poor and made [you] self-sufficient",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 9,
      "text": "فَأَمَّا ٱلۡيَتِيمَ فَلَا تَقۡهَرۡ",
      "translation": "So as for the orphan, do not oppress [him]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 10,
      "text": "وَأَمَّا ٱلسَّآئِلَ فَلَا تَنۡهَرۡ",
      "translation": "And as for the petitioner, do not repel [him]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 11,
      "text": "وَأَمَّا بِنِعۡمَةِ رَبِّكَ فَحَدِّثۡ",
      "translation": "But as for the favor of your Lord, report [it]",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}