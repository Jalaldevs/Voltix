  "id": 75,
  "name": "القيامة",
  "transliteration": "Al-Qiyamah",
  "translation": "The Resurrection",
  "type": "meccan",
  "total_verses": 40,
  "verses": [
    {
      "id": 1,
      "text": "لَآ أُقۡسِمُ بِيَوۡمِ ٱلۡقِيَٰمَةِ",
      "translation": "I swear by the Day of Resurrection",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 2,
      "text": "وَلَآ أُقۡسِمُ بِٱلنَّفۡسِ ٱللَّوَّامَةِ",
      "translation": "And I swear by the reproaching soul [to the certainty of resurrection]",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 3,
      "text": "أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَلَّن نَّجۡمَعَ عِظَامَهُۥ",
      "translation": "Does man think that We will not assemble his bones",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 4,
      "text": "بَلَىٰ قَٰدِرِينَ عَلَىٰٓ أَن نُّسَوِّيَ بَنَانَهُۥ",
      "translation": "Yes. [We are] Able [even] to proportion his fingertips",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 5,
      "text": "بَلۡ يُرِيدُ ٱلۡإِنسَٰنُ لِيَفۡجُرَ أَمَامَهُۥ",
      "translation": "But man desires to continue in sin",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 6,
      "text": "يَسۡـَٔلُ أَيَّانَ يَوۡمُ ٱلۡقِيَٰمَةِ",
      "translation": "He asks, \"When is the Day of Resurrection",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 7,
      "text": "فَإِذَا بَرِقَ ٱلۡبَصَرُ",
      "translation": "So when vision is dazzled",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 8,
      "text": "وَخَسَفَ ٱلۡقَمَرُ",
      "translation": "And the moon darkens",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 9,
      "text": "وَجُمِعَ ٱلشَّمۡسُ وَٱلۡقَمَرُ",
      "translation": "And the sun and the moon are joined",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 10,
      "text": "يَقُولُ ٱلۡإِنسَٰنُ يَوۡمَئِذٍ أَيۡنَ ٱلۡمَفَرُّ",
      "translation": "Man will say on that Day, \"Where is the [place of] escape",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 11,
      "text": "كَلَّا لَا وَزَرَ",
      "translation": "No! There is no refuge",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 12,
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمُسۡتَقَرُّ",
      "translation": "To your Lord, that Day, is the [place of] permanence",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 13,
      "text": "يُنَبَّؤُاْ ٱلۡإِنسَٰنُ يَوۡمَئِذِۭ بِمَا قَدَّمَ وَأَخَّرَ",
      "translation": "Man will be informed that Day of what he sent ahead and kept back",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 14,
      "text": "بَلِ ٱلۡإِنسَٰنُ عَلَىٰ نَفۡسِهِۦ بَصِيرَةٞ",
      "translation": "Rather, man, against himself, will be a witness",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 15,
      "text": "وَلَوۡ أَلۡقَىٰ مَعَاذِيرَهُۥ",
      "translation": "Even if he presents his excuses",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 16,
      "text": "لَا تُحَرِّكۡ بِهِۦ لِسَانَكَ لِتَعۡجَلَ بِهِۦٓ",
      "translation": "Move not your tongue with it, [O Muhammad], to hasten with recitation of the Qur'an",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 17,
      "text": "إِنَّ عَلَيۡنَا جَمۡعَهُۥ وَقُرۡءَانَهُۥ",
      "translation": "Indeed, upon Us is its collection [in your heart] and [to make possible] its recitation",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 18,
      "text": "فَإِذَا قَرَأۡنَٰهُ فَٱتَّبِعۡ قُرۡءَانَهُۥ",
      "translation": "So when We have recited it [through Gabriel], then follow its recitation",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 19,
      "text": "ثُمَّ إِنَّ عَلَيۡنَا بَيَانَهُۥ",
      "translation": "Then upon Us is its clarification [to you]",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 20,
      "text": "كَلَّا بَلۡ تُحِبُّونَ ٱلۡعَاجِلَةَ",
      "translation": "No! But you love the immediate",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 21,
      "text": "وَتَذَرُونَ ٱلۡأٓخِرَةَ",
      "translation": "And leave the Hereafter",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 22,
      "text": "وُجُوهٞ يَوۡمَئِذٖ نَّاضِرَةٌ",
      "translation": "[Some] faces, that Day, will be radiant",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 23,
      "text": "إِلَىٰ رَبِّهَا نَاظِرَةٞ",
      "translation": "Looking at their Lord",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 24,
      "text": "وَوُجُوهٞ يَوۡمَئِذِۭ بَاسِرَةٞ",
      "translation": "And [some] faces, that Day, will be contorted",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 25,
      "text": "تَظُنُّ أَن يُفۡعَلَ بِهَا فَاقِرَةٞ",
      "translation": "Expecting that there will be done to them [something] backbreaking",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 26,
      "text": "كَلَّآ إِذَا بَلَغَتِ ٱلتَّرَاقِيَ",
      "translation": "No! When the soul has reached the collar bones",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 27,
      "text": "وَقِيلَ مَنۡۜ رَاقٖ",
      "translation": "And it is said, \"Who will cure [him]",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 28,
      "text": "وَظَنَّ أَنَّهُ ٱلۡفِرَاقُ",
      "translation": "And the dying one is certain that it is the [time of] separation",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 29,
      "text": "وَٱلۡتَفَّتِ ٱلسَّاقُ بِٱلسَّاقِ",
      "translation": "And the leg is wound about the leg",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 30,
      "text": "إِلَىٰ رَبِّكَ يَوۡمَئِذٍ ٱلۡمَسَاقُ",
      "translation": "To your Lord, that Day, will be the procession",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 31,
      "text": "فَلَا صَدَّقَ وَلَا صَلَّىٰ",
      "translation": "And the disbeliever had not believed, nor had he prayed",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 32,
      "text": "وَلَٰكِن كَذَّبَ وَتَوَلَّىٰ",
      "translation": "But [instead], he denied and turned away",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 33,
      "text": "ثُمَّ ذَهَبَ إِلَىٰٓ أَهۡلِهِۦ يَتَمَطَّىٰٓ",
      "translation": "And then he went to his people, swaggering [in pride]",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 34,
      "text": "أَوۡلَىٰ لَكَ فَأَوۡلَىٰ",
      "translation": "Woe to you, and woe",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 35,
      "text": "ثُمَّ أَوۡلَىٰ لَكَ فَأَوۡلَىٰٓ",
      "translation": "Then woe to you, and woe",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 36,
      "text": "أَيَحۡسَبُ ٱلۡإِنسَٰنُ أَن يُتۡرَكَ سُدًى",
      "translation": "Does man think that he will be left neglected",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 37,
      "text": "أَلَمۡ يَكُ نُطۡفَةٗ مِّن مَّنِيّٖ يُمۡنَىٰ",
      "translation": "Had he not been a sperm from semen emitted",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 38,
      "text": "ثُمَّ كَانَ عَلَقَةٗ فَخَلَقَ فَسَوَّىٰ",
      "translation": "Then he was a clinging clot, and [Allah] created [his form] and proportioned [him]",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 39,
      "text": "فَجَعَلَ مِنۡهُ ٱلزَّوۡجَيۡنِ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ",
      "translation": "And made of him two mates, the male and the female",
      "juz": 29,
      "hizb": 58
    },
    {
      "id": 40,
      "text": "أَلَيۡسَ ذَٰلِكَ بِقَٰدِرٍ عَلَىٰٓ أَن يُحۡـِۧيَ ٱلۡمَوۡتَىٰ",
      "translation": "Is not that [Creator] Able to give life to the dead",
      "juz": 29,
      "hizb": 58
    }
  ],
  "juz_range": [
    29,
    29
  ],
  "hizb_range": [
    58,
    58
  ]
}