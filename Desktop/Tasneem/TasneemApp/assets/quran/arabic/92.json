  "id": 92,
  "name": "الليل",
  "transliteration": "Al-Layl",
  "translation": "The Night",
  "type": "meccan",
  "total_verses": 21,
  "verses": [
    {
      "id": 1,
      "text": "وَٱلَّيۡلِ إِذَا يَغۡشَىٰ",
      "translation": "By the night when it covers",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "وَٱلنَّهَارِ إِذَا تَجَلَّىٰ",
      "translation": "And [by] the day when it appears",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "وَمَا خَلَقَ ٱلذَّكَرَ وَٱلۡأُنثَىٰٓ",
      "translation": "And [by] He who created the male and female",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "إِنَّ سَعۡيَكُمۡ لَشَتَّىٰ",
      "translation": "Indeed, your efforts are diverse",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "فَأَمَّا مَنۡ أَعۡطَىٰ وَٱتَّقَىٰ",
      "translation": "As for he who gives and fears Allah",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "وَصَدَّقَ بِٱلۡحُسۡنَىٰ",
      "translation": "And believes in the best [reward]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "فَسَنُيَسِّرُهُۥ لِلۡيُسۡرَىٰ",
      "translation": "We will ease him toward ease",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "وَأَمَّا مَنۢ بَخِلَ وَٱسۡتَغۡنَىٰ",
      "translation": "But as for he who withholds and considers himself free of need",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 9,
      "text": "وَكَذَّبَ بِٱلۡحُسۡنَىٰ",
      "translation": "And denies the best [reward]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 10,
      "text": "فَسَنُيَسِّرُهُۥ لِلۡعُسۡرَىٰ",
      "translation": "We will ease him toward difficulty",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 11,
      "text": "وَمَا يُغۡنِي عَنۡهُ مَالُهُۥٓ إِذَا تَرَدَّىٰٓ",
      "translation": "And what will his wealth avail him when he falls",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 12,
      "text": "إِنَّ عَلَيۡنَا لَلۡهُدَىٰ",
      "translation": "Indeed, [incumbent] upon Us is guidance",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 13,
      "text": "وَإِنَّ لَنَا لَلۡأٓخِرَةَ وَٱلۡأُولَىٰ",
      "translation": "And indeed, to Us belongs the Hereafter and the first [life]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 14,
      "text": "فَأَنذَرۡتُكُمۡ نَارٗا تَلَظَّىٰ",
      "translation": "So I have warned you of a Fire which is blazing",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 15,
      "text": "لَا يَصۡلَىٰهَآ إِلَّا ٱلۡأَشۡقَى",
      "translation": "None will [enter to] burn therein except the most wretched one",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 16,
      "text": "ٱلَّذِي كَذَّبَ وَتَوَلَّىٰ",
      "translation": "Who had denied and turned away",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 17,
      "text": "وَسَيُجَنَّبُهَا ٱلۡأَتۡقَى",
      "translation": "But the righteous one will avoid it",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 18,
      "text": "ٱلَّذِي يُؤۡتِي مَالَهُۥ يَتَزَكَّىٰ",
      "translation": "[He] who gives [from] his wealth to purify himself",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 19,
      "text": "وَمَا لِأَحَدٍ عِندَهُۥ مِن نِّعۡمَةٖ تُجۡزَىٰٓ",
      "translation": "And not [giving] for anyone who has [done him] a favor to be rewarded",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 20,
      "text": "إِلَّا ٱبۡتِغَآءَ وَجۡهِ رَبِّهِ ٱلۡأَعۡلَىٰ",
      "translation": "But only seeking the countenance of his Lord, Most High",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 21,
      "text": "وَلَسَوۡفَ يَرۡضَىٰ",
      "translation": "And he is going to be satisfied",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}