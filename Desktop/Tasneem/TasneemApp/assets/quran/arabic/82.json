  "id": 82,
  "name": "الإنفطار",
  "transliteration": "Al-Infitar",
  "translation": "The Cleaving",
  "type": "meccan",
  "total_verses": 19,
  "verses": [
    {
      "id": 1,
      "text": "إِذَا ٱلسَّمَآءُ ٱنفَطَرَتۡ",
      "translation": "When the sky breaks apart",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 2,
      "text": "وَإِذَا ٱلۡكَوَاكِبُ ٱنتَثَرَتۡ",
      "translation": "And when the stars fall, scattering",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 3,
      "text": "وَإِذَا ٱلۡبِحَارُ فُجِّرَتۡ",
      "translation": "And when the seas are erupted",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 4,
      "text": "وَإِذَا ٱلۡقُبُورُ بُعۡثِرَتۡ",
      "translation": "And when the [contents of] graves are scattered",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 5,
      "text": "عَلِمَتۡ نَفۡسٞ مَّا قَدَّمَتۡ وَأَخَّرَتۡ",
      "translation": "A soul will [then] know what it has put forth and kept back",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 6,
      "text": "يَـٰٓأَيُّهَا ٱلۡإِنسَٰنُ مَا غَرَّكَ بِرَبِّكَ ٱلۡكَرِيمِ",
      "translation": "O mankind, what has deceived you concerning your Lord, the Generous",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 7,
      "text": "ٱلَّذِي خَلَقَكَ فَسَوَّىٰكَ فَعَدَلَكَ",
      "translation": "Who created you, proportioned you, and balanced you",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 8,
      "text": "فِيٓ أَيِّ صُورَةٖ مَّا شَآءَ رَكَّبَكَ",
      "translation": "In whatever form He willed has He assembled you",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 9,
      "text": "كَلَّا بَلۡ تُكَذِّبُونَ بِٱلدِّينِ",
      "translation": "No! But you deny the Recompense",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 10,
      "text": "وَإِنَّ عَلَيۡكُمۡ لَحَٰفِظِينَ",
      "translation": "And indeed, [appointed] over you are keepers",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 11,
      "text": "كِرَامٗا كَٰتِبِينَ",
      "translation": "Noble and recording",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 12,
      "text": "يَعۡلَمُونَ مَا تَفۡعَلُونَ",
      "translation": "They know whatever you do",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 13,
      "text": "إِنَّ ٱلۡأَبۡرَارَ لَفِي نَعِيمٖ",
      "translation": "Indeed, the righteous will be in pleasure",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 14,
      "text": "وَإِنَّ ٱلۡفُجَّارَ لَفِي جَحِيمٖ",
      "translation": "And indeed, the wicked will be in Hellfire",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 15,
      "text": "يَصۡلَوۡنَهَا يَوۡمَ ٱلدِّينِ",
      "translation": "They will [enter to] burn therein on the Day of Recompense",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 16,
      "text": "وَمَا هُمۡ عَنۡهَا بِغَآئِبِينَ",
      "translation": "And never therefrom will they be absent",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 17,
      "text": "وَمَآ أَدۡرَىٰكَ مَا يَوۡمُ ٱلدِّينِ",
      "translation": "And what can make you know what is the Day of Recompense",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 18,
      "text": "ثُمَّ مَآ أَدۡرَىٰكَ مَا يَوۡمُ ٱلدِّينِ",
      "translation": "Then, what can make you know what is the Day of Recompense",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 19,
      "text": "يَوۡمَ لَا تَمۡلِكُ نَفۡسٞ لِّنَفۡسٖ شَيۡـٔٗاۖ وَٱلۡأَمۡرُ يَوۡمَئِذٖ لِّلَّهِ",
      "translation": "It is the Day when a soul will not possess for another soul [power to do] a thing; and the command, that Day, is [entirely] with Allah",
      "juz": 30,
      "hizb": 59
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    59,
    59
  ]
}