  "id": 100,
  "name": "العاديات",
  "transliteration": "Al-'Adiyat",
  "translation": "The Courser",
  "type": "meccan",
  "total_verses": 11,
  "verses": [
    {
      "id": 1,
      "text": "وَٱلۡعَٰدِيَٰتِ ضَبۡحٗا",
      "translation": "By the racers, panting",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "فَٱلۡمُورِيَٰتِ قَدۡحٗا",
      "translation": "And the producers of sparks [when] striking",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "فَٱلۡمُغِيرَٰتِ صُبۡحٗا",
      "translation": "And the chargers at dawn",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "فَأَثَرۡنَ بِهِۦ نَقۡعٗا",
      "translation": "Stirring up thereby [clouds of] dust",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "فَوَسَطۡنَ بِهِۦ جَمۡعًا",
      "translation": "Arriving thereby in the center collectively",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "إِنَّ ٱلۡإِنسَٰنَ لِرَبِّهِۦ لَكَنُودٞ",
      "translation": "Indeed mankind, to his Lord, is ungrateful",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "وَإِنَّهُۥ عَلَىٰ ذَٰلِكَ لَشَهِيدٞ",
      "translation": "And indeed, he is to that a witness",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "وَإِنَّهُۥ لِحُبِّ ٱلۡخَيۡرِ لَشَدِيدٌ",
      "translation": "And indeed he is, in love of wealth, intense",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 9,
      "text": "۞أَفَلَا يَعۡلَمُ إِذَا بُعۡثِرَ مَا فِي ٱلۡقُبُورِ",
      "translation": "But does he not know that when the contents of the graves are scattered",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 10,
      "text": "وَحُصِّلَ مَا فِي ٱلصُّدُورِ",
      "translation": "And that within the breasts is obtained",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 11,
      "text": "إِنَّ رَبَّهُم بِهِمۡ يَوۡمَئِذٖ لَّخَبِيرُۢ",
      "translation": "Indeed, their Lord with them, that Day, is [fully] Acquainted",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}