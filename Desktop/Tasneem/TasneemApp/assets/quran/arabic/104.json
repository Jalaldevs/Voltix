  "id": 104,
  "name": "الهمزة",
  "transliteration": "Al-Humazah",
  "translation": "The Traducer",
  "type": "meccan",
  "total_verses": 9,
  "verses": [
    {
      "id": 1,
      "text": "وَيۡلٞ لِّكُلِّ هُمَزَةٖ لُّمَزَةٍ",
      "translation": "Woe to every scorner and mocker",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "ٱلَّذِي جَمَعَ مَالٗا وَعَدَّدَهُۥ",
      "translation": "Who collects wealth and [continuously] counts it",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "يَحۡسَبُ أَنَّ مَالَهُۥٓ أَخۡلَدَهُۥ",
      "translation": "He thinks that his wealth will make him immortal",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "كَلَّاۖ لَيُنۢبَذَنَّ فِي ٱلۡحُطَمَةِ",
      "translation": "No! He will surely be thrown into the Crusher",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "وَمَآ أَدۡرَىٰكَ مَا ٱلۡحُطَمَةُ",
      "translation": "And what can make you know what is the Crusher",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "نَارُ ٱللَّهِ ٱلۡمُوقَدَةُ",
      "translation": "It is the fire of Allah, [eternally] fueled",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "ٱلَّتِي تَطَّلِعُ عَلَى ٱلۡأَفۡـِٔدَةِ",
      "translation": "Which mounts directed at the hearts",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "إِنَّهَا عَلَيۡهِم مُّؤۡصَدَةٞ",
      "translation": "Indeed, Hellfire will be closed down upon them",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 9,
      "text": "فِي عَمَدٖ مُّمَدَّدَةِۭ",
      "translation": "In extended columns",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}