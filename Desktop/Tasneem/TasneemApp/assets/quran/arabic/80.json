  "id": 80,
  "name": "عبس",
  "transliteration": "'Abasa",
  "translation": "He Frowned",
  "type": "meccan",
  "total_verses": 42,
  "verses": [
    {
      "id": 1,
      "text": "عَبَسَ وَتَوَلَّىٰٓ",
      "translation": "The Prophet frowned and turned away",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 2,
      "text": "أَن جَآءَهُ ٱلۡأَعۡمَىٰ",
      "translation": "Because there came to him the blind man, [interrupting]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 3,
      "text": "وَمَا يُدۡرِيكَ لَعَلَّهُۥ يَزَّكَّىٰٓ",
      "translation": "But what would make you perceive, [O Muhammad], that perhaps he might be purified",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 4,
      "text": "أَوۡ يَذَّكَّرُ فَتَنفَعَهُ ٱلذِّكۡرَىٰٓ",
      "translation": "Or be reminded and the remembrance would benefit him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 5,
      "text": "أَمَّا مَنِ ٱسۡتَغۡنَىٰ",
      "translation": "As for he who thinks himself without need",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 6,
      "text": "فَأَنتَ لَهُۥ تَصَدَّىٰ",
      "translation": "To him you give attention",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 7,
      "text": "وَمَا عَلَيۡكَ أَلَّا يَزَّكَّىٰ",
      "translation": "And not upon you [is any blame] if he will not be purified",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 8,
      "text": "وَأَمَّا مَن جَآءَكَ يَسۡعَىٰ",
      "translation": "But as for he who came to you striving [for knowledge]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 9,
      "text": "وَهُوَ يَخۡشَىٰ",
      "translation": "While he fears [Allah]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 10,
      "text": "فَأَنتَ عَنۡهُ تَلَهَّىٰ",
      "translation": "From him you are distracted",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 11,
      "text": "كَلَّآ إِنَّهَا تَذۡكِرَةٞ",
      "translation": "No! Indeed, these verses are a reminder",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 12,
      "text": "فَمَن شَآءَ ذَكَرَهُۥ",
      "translation": "So whoever wills may remember it",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 13,
      "text": "فِي صُحُفٖ مُّكَرَّمَةٖ",
      "translation": "[It is recorded] in honored sheets",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 14,
      "text": "مَّرۡفُوعَةٖ مُّطَهَّرَةِۭ",
      "translation": "Exalted and purified",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 15,
      "text": "بِأَيۡدِي سَفَرَةٖ",
      "translation": "[Carried] by the hands of messenger-angels",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 16,
      "text": "كِرَامِۭ بَرَرَةٖ",
      "translation": "Noble and dutiful",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 17,
      "text": "قُتِلَ ٱلۡإِنسَٰنُ مَآ أَكۡفَرَهُۥ",
      "translation": "Cursed is man; how disbelieving is he",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 18,
      "text": "مِنۡ أَيِّ شَيۡءٍ خَلَقَهُۥ",
      "translation": "From what substance did He create him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 19,
      "text": "مِن نُّطۡفَةٍ خَلَقَهُۥ فَقَدَّرَهُۥ",
      "translation": "From a sperm-drop He created him and destined for him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 20,
      "text": "ثُمَّ ٱلسَّبِيلَ يَسَّرَهُۥ",
      "translation": "Then He eased the way for him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 21,
      "text": "ثُمَّ أَمَاتَهُۥ فَأَقۡبَرَهُۥ",
      "translation": "Then He causes his death and provides a grave for him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 22,
      "text": "ثُمَّ إِذَا شَآءَ أَنشَرَهُۥ",
      "translation": "Then when He wills, He will resurrect him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 23,
      "text": "كَلَّا لَمَّا يَقۡضِ مَآ أَمَرَهُۥ",
      "translation": "No! Man has not yet accomplished what He commanded him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 24,
      "text": "فَلۡيَنظُرِ ٱلۡإِنسَٰنُ إِلَىٰ طَعَامِهِۦٓ",
      "translation": "Then let mankind look at his food",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 25,
      "text": "أَنَّا صَبَبۡنَا ٱلۡمَآءَ صَبّٗا",
      "translation": "How We poured down water in torrents",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 26,
      "text": "ثُمَّ شَقَقۡنَا ٱلۡأَرۡضَ شَقّٗا",
      "translation": "Then We broke open the earth, splitting [it with sprouts]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 27,
      "text": "فَأَنۢبَتۡنَا فِيهَا حَبّٗا",
      "translation": "And caused to grow within it grain",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 28,
      "text": "وَعِنَبٗا وَقَضۡبٗا",
      "translation": "And grapes and herbage",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 29,
      "text": "وَزَيۡتُونٗا وَنَخۡلٗا",
      "translation": "And olive and palm trees",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 30,
      "text": "وَحَدَآئِقَ غُلۡبٗا",
      "translation": "And gardens of dense shrubbery",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 31,
      "text": "وَفَٰكِهَةٗ وَأَبّٗا",
      "translation": "And fruit and grass",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 32,
      "text": "مَّتَٰعٗا لَّكُمۡ وَلِأَنۡعَٰمِكُمۡ",
      "translation": "[As] enjoyment for you and your grazing livestock",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 33,
      "text": "فَإِذَا جَآءَتِ ٱلصَّآخَّةُ",
      "translation": "But when there comes the Deafening Blast",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 34,
      "text": "يَوۡمَ يَفِرُّ ٱلۡمَرۡءُ مِنۡ أَخِيهِ",
      "translation": "On the Day a man will flee from his brother",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 35,
      "text": "وَأُمِّهِۦ وَأَبِيهِ",
      "translation": "And his mother and his father",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 36,
      "text": "وَصَٰحِبَتِهِۦ وَبَنِيهِ",
      "translation": "And his wife and his children",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 37,
      "text": "لِكُلِّ ٱمۡرِيٕٖ مِّنۡهُمۡ يَوۡمَئِذٖ شَأۡنٞ يُغۡنِيهِ",
      "translation": "For every man, that Day, will be a matter adequate for him",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 38,
      "text": "وُجُوهٞ يَوۡمَئِذٖ مُّسۡفِرَةٞ",
      "translation": "[Some] faces, that Day, will be bright",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 39,
      "text": "ضَاحِكَةٞ مُّسۡتَبۡشِرَةٞ",
      "translation": "Laughing, rejoicing at good news",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 40,
      "text": "وَوُجُوهٞ يَوۡمَئِذٍ عَلَيۡهَا غَبَرَةٞ",
      "translation": "And [other] faces, that Day, will have upon them dust",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 41,
      "text": "تَرۡهَقُهَا قَتَرَةٌ",
      "translation": "Blackness will cover them",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 42,
      "text": "أُوْلَـٰٓئِكَ هُمُ ٱلۡكَفَرَةُ ٱلۡفَجَرَةُ",
      "translation": "Those are the disbelievers, the wicked ones",
      "juz": 30,
      "hizb": 59
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    59,
    59
  ]
}