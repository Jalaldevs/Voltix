  "id": 103,
  "name": "العصر",
  "transliteration": "Al-'Asr",
  "translation": "The Declining Day",
  "type": "meccan",
  "total_verses": 3,
  "verses": [
    {
      "id": 1,
      "text": "وَٱلۡعَصۡرِ",
      "translation": "By time",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "إِنَّ ٱلۡإِنسَٰنَ لَفِي خُسۡرٍ",
      "translation": "Indeed, mankind is in loss",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّـٰلِحَٰتِ وَتَوَاصَوۡاْ بِٱلۡحَقِّ وَتَوَاصَوۡاْ بِٱلصَّبۡرِ",
      "translation": "Except for those who have believed and done righteous deeds and advised each other to truth and advised each other to patience",
      "juz": 30,
      "hizb": 60
    }
