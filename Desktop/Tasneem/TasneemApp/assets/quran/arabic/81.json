  "id": 81,
  "name": "التكوير",
  "transliteration": "At-Takwir",
  "translation": "The Overthrowing",
  "type": "meccan",
  "total_verses": 29,
  "verses": [
    {
      "id": 1,
      "text": "إِذَا ٱلشَّمۡسُ كُوِّرَتۡ",
      "translation": "When the sun is wrapped up [in darkness]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 2,
      "text": "وَإِذَا ٱلنُّجُومُ ٱنكَدَرَتۡ",
      "translation": "And when the stars fall, dispersing",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 3,
      "text": "وَإِذَا ٱلۡجِبَالُ سُيِّرَتۡ",
      "translation": "And when the mountains are removed",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 4,
      "text": "وَإِذَا ٱلۡعِشَارُ عُطِّلَتۡ",
      "translation": "And when full-term she-camels are neglected",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 5,
      "text": "وَإِذَا ٱلۡوُحُوشُ حُشِرَتۡ",
      "translation": "And when the wild beasts are gathered",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 6,
      "text": "وَإِذَا ٱلۡبِحَارُ سُجِّرَتۡ",
      "translation": "And when the seas are filled with flame",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 7,
      "text": "وَإِذَا ٱلنُّفُوسُ زُوِّجَتۡ",
      "translation": "And when the souls are paired",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 8,
      "text": "وَإِذَا ٱلۡمَوۡءُۥدَةُ سُئِلَتۡ",
      "translation": "And when the girl [who was] buried alive is asked",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 9,
      "text": "بِأَيِّ ذَنۢبٖ قُتِلَتۡ",
      "translation": "For what sin she was killed",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 10,
      "text": "وَإِذَا ٱلصُّحُفُ نُشِرَتۡ",
      "translation": "And when the pages are made public",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 11,
      "text": "وَإِذَا ٱلسَّمَآءُ كُشِطَتۡ",
      "translation": "And when the sky is stripped away",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 12,
      "text": "وَإِذَا ٱلۡجَحِيمُ سُعِّرَتۡ",
      "translation": "And when Hellfire is set ablaze",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 13,
      "text": "وَإِذَا ٱلۡجَنَّةُ أُزۡلِفَتۡ",
      "translation": "And when Paradise is brought near",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 14,
      "text": "عَلِمَتۡ نَفۡسٞ مَّآ أَحۡضَرَتۡ",
      "translation": "A soul will [then] know what it has brought [with it]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 15,
      "text": "فَلَآ أُقۡسِمُ بِٱلۡخُنَّسِ",
      "translation": "So I swear by the retreating stars",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 16,
      "text": "ٱلۡجَوَارِ ٱلۡكُنَّسِ",
      "translation": "Those that run [their courses] and disappear",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 17,
      "text": "وَٱلَّيۡلِ إِذَا عَسۡعَسَ",
      "translation": "And by the night as it closes in",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 18,
      "text": "وَٱلصُّبۡحِ إِذَا تَنَفَّسَ",
      "translation": "And by the dawn when it breathes",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 19,
      "text": "إِنَّهُۥ لَقَوۡلُ رَسُولٖ كَرِيمٖ",
      "translation": "[That] indeed, the Qur'an is a word [conveyed by] a noble messenger",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 20,
      "text": "ذِي قُوَّةٍ عِندَ ذِي ٱلۡعَرۡشِ مَكِينٖ",
      "translation": "[Who is] possessed of power and with the Owner of the Throne, secure [in position]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 21,
      "text": "مُّطَاعٖ ثَمَّ أَمِينٖ",
      "translation": "Obeyed there [in the heavens] and trustworthy",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 22,
      "text": "وَمَا صَاحِبُكُم بِمَجۡنُونٖ",
      "translation": "And your companion is not [at all] mad",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 23,
      "text": "وَلَقَدۡ رَءَاهُ بِٱلۡأُفُقِ ٱلۡمُبِينِ",
      "translation": "And he has already seen Gabriel in the clear horizon",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 24,
      "text": "وَمَا هُوَ عَلَى ٱلۡغَيۡبِ بِضَنِينٖ",
      "translation": "And Muhammad is not a withholder of [knowledge of] the unseen",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 25,
      "text": "وَمَا هُوَ بِقَوۡلِ شَيۡطَٰنٖ رَّجِيمٖ",
      "translation": "And the Qur'an is not the word of a devil, expelled [from the heavens]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 26,
      "text": "فَأَيۡنَ تَذۡهَبُونَ",
      "translation": "So where are you going",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 27,
      "text": "إِنۡ هُوَ إِلَّا ذِكۡرٞ لِّلۡعَٰلَمِينَ",
      "translation": "It is not except a reminder to the worlds",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 28,
      "text": "لِمَن شَآءَ مِنكُمۡ أَن يَسۡتَقِيمَ",
      "translation": "For whoever wills among you to take a right course",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 29,
      "text": "وَمَا تَشَآءُونَ إِلَّآ أَن يَشَآءَ ٱللَّهُ رَبُّ ٱلۡعَٰلَمِينَ",
      "translation": "And you do not will except that Allah wills - Lord of the worlds",
      "juz": 30,
      "hizb": 59
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    59,
    59
  ]
}