  "id": 95,
  "name": "التين",
  "transliteration": "At-Tin",
  "translation": "The Fig",
  "type": "meccan",
  "total_verses": 8,
  "verses": [
    {
      "id": 1,
      "text": "وَٱلتِّينِ وَٱلزَّيۡتُونِ",
      "translation": "By the fig and the olive",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "وَطُورِ سِينِينَ",
      "translation": "And [by] Mount Sinai",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "وَهَٰذَا ٱلۡبَلَدِ ٱلۡأَمِينِ",
      "translation": "And [by] this secure city [Makkah]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "لَقَدۡ خَلَقۡنَا ٱلۡإِنسَٰنَ فِيٓ أَحۡسَنِ تَقۡوِيمٖ",
      "translation": "We have certainly created man in the best of stature",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "ثُمَّ رَدَدۡنَٰهُ أَسۡفَلَ سَٰفِلِينَ",
      "translation": "Then We return him to the lowest of the low",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "إِلَّا ٱلَّذِينَ ءَامَنُواْ وَعَمِلُواْ ٱلصَّـٰلِحَٰتِ فَلَهُمۡ أَجۡرٌ غَيۡرُ مَمۡنُونٖ",
      "translation": "Except for those who believe and do righteous deeds, for they will have a reward uninterrupted",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "فَمَا يُكَذِّبُكَ بَعۡدُ بِٱلدِّينِ",
      "translation": "So what yet causes you to deny the Recompense",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "أَلَيۡسَ ٱللَّهُ بِأَحۡكَمِ ٱلۡحَٰكِمِينَ",
      "translation": "Is not Allah the most just of judges",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}