  "id": 96,
  "name": "العلق",
  "transliteration": "Al-'Alaq",
  "translation": "The Clot",
  "type": "meccan",
  "total_verses": 19,
  "verses": [
    {
      "id": 1,
      "text": "ٱقۡرَأۡ بِٱسۡمِ رَبِّكَ ٱلَّذِي خَلَقَ",
      "translation": "Recite in the name of your Lord who created",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "خَلَقَ ٱلۡإِنسَٰنَ مِنۡ عَلَقٍ",
      "translation": "Created man from a clinging substance",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "ٱقۡرَأۡ وَرَبُّكَ ٱلۡأَكۡرَمُ",
      "translation": "Recite, and your Lord is the most Generous",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "ٱلَّذِي عَلَّمَ بِٱلۡقَلَمِ",
      "translation": "Who taught by the pen",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "عَلَّمَ ٱلۡإِنسَٰنَ مَا لَمۡ يَعۡلَمۡ",
      "translation": "Taught man that which he knew not",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "كَلَّآ إِنَّ ٱلۡإِنسَٰنَ لَيَطۡغَىٰٓ",
      "translation": "No! [But] indeed, man transgresses",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "أَن رَّءَاهُ ٱسۡتَغۡنَىٰٓ",
      "translation": "Because he sees himself self-sufficient",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "إِنَّ إِلَىٰ رَبِّكَ ٱلرُّجۡعَىٰٓ",
      "translation": "Indeed, to your Lord is the return",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 9,
      "text": "أَرَءَيۡتَ ٱلَّذِي يَنۡهَىٰ",
      "translation": "Have you seen the one who forbids",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 10,
      "text": "عَبۡدًا إِذَا صَلَّىٰٓ",
      "translation": "A servant when he prays",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 11,
      "text": "أَرَءَيۡتَ إِن كَانَ عَلَى ٱلۡهُدَىٰٓ",
      "translation": "Have you seen if he is upon guidance",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 12,
      "text": "أَوۡ أَمَرَ بِٱلتَّقۡوَىٰٓ",
      "translation": "Or enjoins righteousness",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 13,
      "text": "أَرَءَيۡتَ إِن كَذَّبَ وَتَوَلَّىٰٓ",
      "translation": "Have you seen if he denies and turns away",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 14,
      "text": "أَلَمۡ يَعۡلَم بِأَنَّ ٱللَّهَ يَرَىٰ",
      "translation": "Does he not know that Allah sees",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 15,
      "text": "كَلَّا لَئِن لَّمۡ يَنتَهِ لَنَسۡفَعَۢا بِٱلنَّاصِيَةِ",
      "translation": "No! If he does not desist, We will surely drag him by the forelock",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 16,
      "text": "نَاصِيَةٖ كَٰذِبَةٍ خَاطِئَةٖ",
      "translation": "A lying, sinning forelock",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 17,
      "text": "فَلۡيَدۡعُ نَادِيَهُۥ",
      "translation": "Then let him call his associates",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 18,
      "text": "سَنَدۡعُ ٱلزَّبَانِيَةَ",
      "translation": "We will call the angels of Hell",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 19,
      "text": "كَلَّا لَا تُطِعۡهُ وَٱسۡجُدۡۤ وَٱقۡتَرِب۩",
      "translation": "No! Do not obey him. But prostrate and draw near [to Allah]",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}