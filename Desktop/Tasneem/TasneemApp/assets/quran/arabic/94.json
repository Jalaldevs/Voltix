  "id": 94,
  "name": "الشرح",
  "transliteration": "Ash-Sharh",
  "translation": "The Relief",
  "type": "meccan",
  "total_verses": 8,
  "verses": [
    {
      "id": 1,
      "text": "أَلَمۡ نَشۡرَحۡ لَكَ صَدۡرَكَ",
      "translation": "Did We not expand for you, [O Muhammad], your breast",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "وَوَضَعۡنَا عَنكَ وِزۡرَكَ",
      "translation": "And We removed from you your burden",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "ٱلَّذِيٓ أَنقَضَ ظَهۡرَكَ",
      "translation": "Which had weighed upon your back",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "وَرَفَعۡنَا لَكَ ذِكۡرَكَ",
      "translation": "And raised high for you your repute",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "فَإِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرًا",
      "translation": "For indeed, with hardship [will be] ease",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "إِنَّ مَعَ ٱلۡعُسۡرِ يُسۡرٗا",
      "translation": "Indeed, with hardship [will be] ease",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "فَإِذَا فَرَغۡتَ فَٱنصَبۡ",
      "translation": "So when you have finished [your duties], then stand up [for worship]",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "وَإِلَىٰ رَبِّكَ فَٱرۡغَب",
      "translation": "And to your Lord direct [your] longing",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
