  "id": 87,
  "name": "الأعلى",
  "transliteration": "Al-A'la",
  "translation": "The Most High",
  "type": "meccan",
  "total_verses": 19,
  "verses": [
    {
      "id": 1,
      "text": "سَبِّحِ ٱسۡمَ رَبِّكَ ٱلۡأَعۡلَى",
      "translation": "Exalt the name of your Lord, the Most High",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 2,
      "text": "ٱلَّذِي خَلَقَ فَسَوَّىٰ",
      "translation": "Who created and proportioned",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 3,
      "text": "وَٱلَّذِي قَدَّرَ فَهَدَىٰ",
      "translation": "And who destined and [then] guided",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 4,
      "text": "وَٱلَّذِيٓ أَخۡرَجَ ٱلۡمَرۡعَىٰ",
      "translation": "And who brings out the pasture",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 5,
      "text": "فَجَعَلَهُۥ غُثَآءً أَحۡوَىٰ",
      "translation": "And [then] makes it black stubble",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 6,
      "text": "سَنُقۡرِئُكَ فَلَا تَنسَىٰٓ",
      "translation": "We will make you recite, [O Muhammad], and you will not forget",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 7,
      "text": "إِلَّا مَا شَآءَ ٱللَّهُۚ إِنَّهُۥ يَعۡلَمُ ٱلۡجَهۡرَ وَمَا يَخۡفَىٰ",
      "translation": "Except what Allah should will. Indeed, He knows what is declared and what is hidden",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 8,
      "text": "وَنُيَسِّرُكَ لِلۡيُسۡرَىٰ",
      "translation": "And We will ease you toward ease",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 9,
      "text": "فَذَكِّرۡ إِن نَّفَعَتِ ٱلذِّكۡرَىٰ",
      "translation": "So remind, if the reminder should benefit",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 10,
      "text": "سَيَذَّكَّرُ مَن يَخۡشَىٰ",
      "translation": "He who fears [Allah] will be reminded",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 11,
      "text": "وَيَتَجَنَّبُهَا ٱلۡأَشۡقَى",
      "translation": "But the wretched one will avoid it",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 12,
      "text": "ٱلَّذِي يَصۡلَى ٱلنَّارَ ٱلۡكُبۡرَىٰ",
      "translation": "[He] who will [enter and] burn in the greatest Fire",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 13,
      "text": "ثُمَّ لَا يَمُوتُ فِيهَا وَلَا يَحۡيَىٰ",
      "translation": "Neither dying therein nor living",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 14,
      "text": "قَدۡ أَفۡلَحَ مَن تَزَكَّىٰ",
      "translation": "He has certainly succeeded who purifies himself",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 15,
      "text": "وَذَكَرَ ٱسۡمَ رَبِّهِۦ فَصَلَّىٰ",
      "translation": "And mentions the name of his Lord and prays",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 16,
      "text": "بَلۡ تُؤۡثِرُونَ ٱلۡحَيَوٰةَ ٱلدُّنۡيَا",
      "translation": "But you prefer the worldly life",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 17,
      "text": "وَٱلۡأٓخِرَةُ خَيۡرٞ وَأَبۡقَىٰٓ",
      "translation": "While the Hereafter is better and more enduring",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 18,
      "text": "إِنَّ هَٰذَا لَفِي ٱلصُّحُفِ ٱلۡأُولَىٰ",
      "translation": "Indeed, this is in the former scriptures",
      "juz": 30,
      "hizb": 60
    },
    {
      "id": 19,
      "text": "صُحُفِ إِبۡرَٰهِيمَ وَمُوسَىٰ",
      "translation": "The scriptures of Abraham and Moses",
      "juz": 30,
      "hizb": 60
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    60,
    60
  ]
}