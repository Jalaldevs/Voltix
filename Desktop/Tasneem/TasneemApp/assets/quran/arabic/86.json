  "id": 86,
  "name": "الطارق",
  "transliteration": "At-Tariq",
  "translation": "The Nightcommer",
  "type": "meccan",
  "total_verses": 17,
  "verses": [
    {
      "id": 1,
      "text": "وَٱلسَّمَآءِ وَٱلطَّارِقِ",
      "translation": "By the sky and the night comer",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 2,
      "text": "وَمَآ أَدۡرَىٰكَ مَا ٱلطَّارِقُ",
      "translation": "And what can make you know what is the night comer",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 3,
      "text": "ٱلنَّجۡمُ ٱلثَّاقِبُ",
      "translation": "It is the piercing star",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 4,
      "text": "إِن كُلُّ نَفۡسٖ لَّمَّا عَلَيۡهَا حَافِظٞ",
      "translation": "There is no soul but that it has over it a protector",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 5,
      "text": "فَلۡيَنظُرِ ٱلۡإِنسَٰنُ مِمَّ خُلِقَ",
      "translation": "So let man observe from what he was created",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 6,
      "text": "خُلِقَ مِن مَّآءٖ دَافِقٖ",
      "translation": "He was created from a fluid, ejected",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 7,
      "text": "يَخۡرُجُ مِنۢ بَيۡنِ ٱلصُّلۡبِ وَٱلتَّرَآئِبِ",
      "translation": "Emerging from between the backbone and the ribs",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 8,
      "text": "إِنَّهُۥ عَلَىٰ رَجۡعِهِۦ لَقَادِرٞ",
      "translation": "Indeed, Allah, to return him [to life], is Able",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 9,
      "text": "يَوۡمَ تُبۡلَى ٱلسَّرَآئِرُ",
      "translation": "The Day when secrets will be put on trial",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 10,
      "text": "فَمَا لَهُۥ مِن قُوَّةٖ وَلَا نَاصِرٖ",
      "translation": "Then man will have no power or any helper",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 11,
      "text": "وَٱلسَّمَآءِ ذَاتِ ٱلرَّجۡعِ",
      "translation": "By the sky which returns [rain]",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 12,
      "text": "وَٱلۡأَرۡضِ ذَاتِ ٱلصَّدۡعِ",
      "translation": "And [by] the earth which cracks open",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 13,
      "text": "إِنَّهُۥ لَقَوۡلٞ فَصۡلٞ",
      "translation": "Indeed, the Qur'an is a decisive statement",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 14,
      "text": "وَمَا هُوَ بِٱلۡهَزۡلِ",
      "translation": "And it is not amusement",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 15,
      "text": "إِنَّهُمۡ يَكِيدُونَ كَيۡدٗا",
      "translation": "Indeed, they are planning a plan",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 16,
      "text": "وَأَكِيدُ كَيۡدٗا",
      "translation": "But I am planning a plan",
      "juz": 30,
      "hizb": 59
    },
    {
      "id": 17,
      "text": "فَمَهِّلِ ٱلۡكَٰفِرِينَ أَمۡهِلۡهُمۡ رُوَيۡدَۢا",
      "translation": "So allow time for the disbelievers. Leave them awhile",
      "juz": 30,
      "hizb": 59
    }
  ],
  "juz_range": [
    30,
    30
  ],
  "hizb_range": [
    59,
    59
  ]
}