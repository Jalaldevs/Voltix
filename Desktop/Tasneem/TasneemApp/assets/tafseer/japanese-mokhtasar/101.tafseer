[
  {
    "text": "大打撃の恐ろしさで、人びとの心が震えおののく時、",
    "ayah": 1,
    "surah": 101
  },
  {
    "text": "この大打撃の恐ろしさで、人びとの心が震えおののく時とは何か。",
    "ayah": 2,
    "surah": 101
  },
  {
    "text": "使徒よ、大打撃の恐ろしさで、人びとの心が震えおののく時が何であるかを、あなたに教えてくれるのは何か。",
    "ayah": 3,
    "surah": 101
  },
  {
    "text": "その日、人びとの心は打撃を受けて、飛び散った蛾のようになり、",
    "ayah": 4,
    "surah": 101
  },
  {
    "text": "また山々は軽く動く梳かれた羊毛のようになってしまう。",
    "ayah": 5,
    "surah": 101
  },
  {
    "text": "その人の秤が善行で重いのなら、",
    "ayah": 6,
    "surah": 101
  },
  {
    "text": "かれは喜びに満ちた楽園の暮らしをするだろう。",
    "ayah": 7,
    "surah": 101
  },
  {
    "text": "だがその人の秤が悪行の方が重いならば、",
    "ayah": 8,
    "surah": 101
  },
  {
    "text": "かれの最後の住まいは地獄。",
    "ayah": 9,
    "surah": 101
  },
  {
    "text": "使徒よ、それが何であるかを、あなたに教えるものは何か。",
    "ayah": 10,
    "surah": 101
  },
  {
    "text": "それは酷い灼熱の火だ。",
    "ayah": 11,
    "surah": 101
  }
]
