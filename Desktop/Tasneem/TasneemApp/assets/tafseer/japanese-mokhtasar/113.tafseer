[
  {
    "text": "使徒よ、言いなさい、黎明の主に、わたしを守るように助けを求める、",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "かれが創られるものの悪から、",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "降りゆく夜のとばりの悪である、有害な動物や盗賊たちから、",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "結び目に息を吹きかける女呪術師の悪から、",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "また、嫉妬する者の嫉妬の悪から。",
    "ayah": 5,
    "surah": 113
  }
]
