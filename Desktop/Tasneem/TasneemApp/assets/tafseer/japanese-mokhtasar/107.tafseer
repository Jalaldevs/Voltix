[
  {
    "text": "あなたは、最後の審判を否定する者を見たか。",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "それは、困っている孤児を追いやり、",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "貧者に食物を与えることを、自分にも他人にも勧めない者。",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "破滅と災いあれ。礼拝しながら、遊ぶ人よ。自分の礼拝に気もそぞろ、時間が過ぎるのを気にしている。",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "破滅と災いあれ。礼拝しながら、遊ぶ人よ。自分の礼拝に気もそぞろ、時間が過ぎるのを気にしている。",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "また人にこれ見よがしに礼拝し、善行に励むが、アッラーのためにするという誠実さがない者。",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "何も難しくないことに、支援を送ることを控える者に。",
    "ayah": 7,
    "surah": 107
  }
]
