[
  {
    "text": "使徒よ、言いなさい。おお不信仰者たちよ、",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "わたしは、あなた方が仕えるものには仕えない。",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "あなた方は、わたしが仕えるものには仕えない。それは、アッラーのみだ。",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "またあなた方が仕えてきたものに、わたしは仕えない。",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "あなた方は、わたしが仕えるものには仕えない。それは、アッラーのみだ。",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "あなた方には、あなた方の宗教があり、わたしには、わたしの宗教がある。",
    "ayah": 6,
    "surah": 109
  }
]
