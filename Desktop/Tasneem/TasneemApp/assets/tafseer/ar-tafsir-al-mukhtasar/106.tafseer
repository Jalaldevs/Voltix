[
  {
    "text": "لأجل عادة قريش وإلْفِهم.",
    "ayah": 1,
    "surah": 106
  },
  {
    "text": "رحلةَ الشتاء إلى اليمن، ورحلة الصيف إلى الشام آمنين.",
    "ayah": 2,
    "surah": 106
  },
  {
    "text": "فليعبدوا الله ربّ هذا البيت الحرام وحده، الذي يسَّر لهم هذه الرحلة، ولا يشركوا به أحدًا.",
    "ayah": 3,
    "surah": 106
  },
  {
    "text": "الذي أطعمهم من جوع، وآمنهم من خوف؛ بما وضع في قلوب العرب من تعظيم الحرم، وتعظيم سكانه.",
    "ayah": 4,
    "surah": 106
  }
]
