[
  {
    "text": "إنا آتيناك - أيها الرسول - الخير الكثير، ومنه نهر الكوثر في الجنة.",
    "ayah": 1,
    "surah": 108
  },
  {
    "text": "فأدّ شكر الله على هذه النعمة، بأن تصلي له وحده وتذبح؛ خلافًا لما يفعله المشركون من التقرّب لأوثانهم بالذبح.",
    "ayah": 2,
    "surah": 108
  },
  {
    "text": "إن مُبْغِضك هو المنقطع عن كل خير المَنْسِي الذي إن ذُكِر ذُكِر بسوء.",
    "ayah": 3,
    "surah": 108
  }
]
