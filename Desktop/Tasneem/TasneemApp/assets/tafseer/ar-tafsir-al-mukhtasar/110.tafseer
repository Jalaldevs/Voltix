[
  {
    "text": "إذا جاء نصر الله لدينك - أيها الرسول - وإعزازه له، وحدث فتح مكة.",
    "ayah": 1,
    "surah": 110
  },
  {
    "text": "ورأيت الناس يدخلون في الإسلام وفدًا بعد وفد.",
    "ayah": 2,
    "surah": 110
  },
  {
    "text": "فاعلم أن ذلك علامة على قرب انتهاء المهمة التي بُعِثْتَ بها، فسبِّح بحمد ربك؛ شكرًا له على نعمة النصر والفتح، واطلب منه المغفرة، إنه كان توابًا يقبل توبة عباده، ويغفر لهم.",
    "ayah": 3,
    "surah": 110
  }
]
