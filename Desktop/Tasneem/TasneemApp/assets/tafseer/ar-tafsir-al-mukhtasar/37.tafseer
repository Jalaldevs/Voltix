    "ayah": 173,
    "surah": 37
  },
  {
    "text": "فأعرض - أيها الرسول - عن هؤلاء المشركين المعاندين إلى مدة يعلمها الله حتى يأتي وقت عذابهم.",
    "ayah": 174,
    "surah": 37
  },
  {
    "text": "وانظرهم حين ينزل بهم العذاب، فسيبصرون حين لا ينفعهم إبصار.",
    "ayah": 175,
    "surah": 37
  },
  {
    "text": "أفيستعجل هؤلاء المشركون بعذاب الله؟!",
    "ayah": 176,
    "surah": 37
  },
  {
    "text": "فإذا نزل عذاب الله بهم فبئس الصباح صباحهم.",
    "ayah": 177,
    "surah": 37
  },
  {
    "text": "وأعرض - أيها الرسول - عنهم حتى يقضي الله بعذابهم.",
    "ayah": 178,
    "surah": 37
  },
  {
    "text": "وانظر فسينظر هؤلاء ما يحل بهم من عذاب الله وعقابه.",
    "ayah": 179,
    "surah": 37
  },
  {
    "text": "تنزه ربك - يا محمد - ربّ القوة، وتقدس عما يصفه به المشركون من صفات النقص.",
    "ayah": 180,
    "surah": 37
  },
  {
    "text": "وتحية الله وثناؤه على رسله الكرام.",
    "ayah": 181,
    "surah": 37
  },
  {
    "text": "والثناء كله لله سبحانه وتعالى، فهو المستحق له، وهو رب العالمين جميعًا، لا رب لهم سواه.",
    "ayah": 182,
    "surah": 37
  }
