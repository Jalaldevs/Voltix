[
  {
    "text": "قل - أيها الرسول -: هو الله المنفرد بالألوهية، لا إله غيره.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "هو السيّد الذي انتهى إليه السُّؤْدَد في صفات الكمال والجمال، الذي تصمد إليه الخلائق.",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "الذي لم يلد أحدًا، ولم يلده أحد، فلا ولد له - سبحانه - ولا والد.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "ولم يكن له مماثل في خلقه.",
    "ayah": 4,
    "surah": 112
  }
]
