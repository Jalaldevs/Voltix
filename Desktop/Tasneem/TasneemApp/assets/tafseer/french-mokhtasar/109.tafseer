[
  {
    "text": "Ô Messager, dis: Ô vous qui mécroyez en Allah,",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "je n’adore pas ni n’adorerai les idoles que vous adorez,",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "et vous n’adorez pas Celui que j’adore, c’est-à-dire Allah Seul.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "Je ne suis pas un adorateur des idoles que vous adorez,",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "ni vous, n’adorez Celui que j’adore, c’est-à-dire Allah Seul.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "Vous avez votre religion que vous avez inventée et j’ai ma religion qu’Allah m’a révélée.",
    "ayah": 6,
    "surah": 109
  }
]
