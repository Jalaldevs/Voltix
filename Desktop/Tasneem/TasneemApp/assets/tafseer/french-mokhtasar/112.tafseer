[
  {
    "text": "Ô Messager, dis: Il est Allah, seul détenteur de la divinité, nul dieu hormis Lui.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "Il est le Seigneur qui détient à la perfection les attributs de la beauté et Celui que les créatures implorent",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "Il est Celui qui n’a jamais engendré personne ni n’a été engendré par quiconque. Il n’a donc ni progéniture ni géniteur.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "Et rien dans Sa création ne Lui est semblable.",
    "ayah": 4,
    "surah": 112
  }
]
