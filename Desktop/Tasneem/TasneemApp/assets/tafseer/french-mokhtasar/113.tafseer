[
  {
    "text": "Ô Messager, dis: Je me prémunis par le Seigneur de l’aube et je cherche refuge auprès de Lui",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "contre le mal des créatures malfaisantes,",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "contre les maux de la nuit provenant des animaux et des voleurs,",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "contre le mal des sorcières qui soufflent dans les nœuds,",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "et contre le mal de l’envieux lorsque son envie le pousse à l’action.",
    "ayah": 5,
    "surah": 113
  }
]
