[
  {
    "text": "Connais-tu celui qui traite de mensonge la Rétribution du Jour de la Résurrection?",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "C’est bien lui qui repousse avec rudesse l’orphelin en lui refusant ce dont il a besoin",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "et qui ne s’incite pas lui-même ni n’incite autrui à nourrir les pauvres.",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "Anéantissement et châtiment donc pour ceux qui prient,",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "tout en étant distraits et ne se souciant pas de respecter l'horaire de la prière,",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "qui prient et œuvrent avec ostentation, sans être sincères envers Allah,",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "et refusent d'aider autrui quand ils n’encourent aucun préjudice à l'aider.",
    "ayah": 7,
    "surah": 107
  }
]
