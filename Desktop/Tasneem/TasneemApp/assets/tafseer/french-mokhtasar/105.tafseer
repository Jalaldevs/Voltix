[
  {
    "text": "Ô Messager, ne sais-tu pas ce que ton Seigneur a fait d’Abrahah et de ses compagnons montés sur des éléphants lorsqu’ils voulurent démolir la Ka’bah?",
    "ayah": 1,
    "surah": 105
  },
  {
    "text": "Il mit à mal leur stratagème et ils ne purent atteindre leur objectif de détourner les gens de la Ka’bah,",
    "ayah": 2,
    "surah": 105
  },
  {
    "text": "en envoyant sur eux des oiseaux qui se sont abattus sur eux volée après volée",
    "ayah": 3,
    "surah": 105
  },
  {
    "text": "et leur lançaient des pierres d’argile durcie.",
    "ayah": 4,
    "surah": 105
  },
  {
    "text": "Allah les rendit alors semblables à des feuilles de blé mâchées et piétinées par des bêtes.",
    "ayah": 5,
    "surah": 105
  }
]
