[
  {
    "text": "L’Heure qui fracasse les cœurs des gens tellement son effroi est grand.",
    "ayah": 1,
    "surah": 101
  },
  {
    "text": "Qu’est-ce cette heure dont le grand effroi fracasse les cœurs des gens?",
    "ayah": 2,
    "surah": 101
  },
  {
    "text": "Ô Messager, Qu’est-ce cette heure dont le grand effroi fracasse les cœurs des gens? Il s’agit du Jour de la Résurrection.",
    "ayah": 3,
    "surah": 101
  },
  {
    "text": "Ce Jour-là, les gens seront tels des papillons éparpillés çà et là",
    "ayah": 4,
    "surah": 101
  },
  {
    "text": "et les montagnes seront semblables à de la laine défaite, tellement elles se déplaceront vite et légèrement.",
    "ayah": 5,
    "surah": 101
  },
  {
    "text": "Celui dont les bonnes œuvres sont plus conséquentes que les mauvaises,",
    "ayah": 6,
    "surah": 101
  },
  {
    "text": "mènera une vie agréable au Paradis.",
    "ayah": 7,
    "surah": 101
  },
  {
    "text": "Quant à celui dont les mauvaises œuvres sont plus conséquentes que les bonnes,",
    "ayah": 8,
    "surah": 101
  },
  {
    "text": "sa demeure et son refuge seront l’Enfer le Jour de la Résurrection.",
    "ayah": 9,
    "surah": 101
  },
  {
    "text": "Ô Messager, sais-tu ce que c’est?",
    "ayah": 10,
    "surah": 101
  },
  {
    "text": "Un Feu à la chaleur très intense.",
    "ayah": 11,
    "surah": 101
  }
]
