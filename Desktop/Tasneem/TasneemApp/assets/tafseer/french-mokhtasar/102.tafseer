[
  {
    "text": "Ô gens, rivaliser en richesse et en progéniture vous distrait d’obéir à Allah,",
    "ayah": 1,
    "surah": 102
  },
  {
    "text": "jusqu’à ce que vous mouriez et entriez dans vos tombes.",
    "ayah": 2,
    "surah": 102
  },
  {
    "text": "Vous n’auriez pas dû être distraits d’obéir à Allah et vous saurez bientôt quelle est la conséquence d’une telle distraction.",
    "ayah": 3,
    "surah": 102
  },
  {
    "text": "Encore une fois, vous le saurez bientôt.",
    "ayah": 4,
    "surah": 102
  },
  {
    "text": "En vérité, si vous étiez persuadés d'être ressuscités auprès d’Allah et d'être rétribués pour vos œuvres, rivaliser en richesse et en progéniture ne vous aurait pas distrait.",
    "ayah": 5,
    "surah": 102
  },
  {
    "text": "Par Allah, vous verrez le Feu le Jour de la Résurrection.",
    "ayah": 6,
    "surah": 102
  },
  {
    "text": "Puis vous le verrez très certainement de vos yeux.",
    "ayah": 7,
    "surah": 102
  },
  {
    "text": "Ensuite, Allah vous questionnera assurément ce Jour-là au sujet de la santé, de la richesse et d’autres bienfaits dont Il vous a fait don.",
    "ayah": 8,
    "surah": 102
  }
]
