[
  {
    "text": "Que celui qui calomnie et diffame les gens soit honni et châtié.",
    "ayah": 1,
    "surah": 104
  },
  {
    "text": "Il amasse des richesses et les compte, n'ayant que cela comme préoccupation,",
    "ayah": 2,
    "surah": 104
  },
  {
    "text": "et croit que les richesses qu’il amasse le sauveront de la mort et le feront vivre éternellement dans le bas monde.",
    "ayah": 3,
    "surah": 104
  },
  {
    "text": "Il n’en sera pas comme se l’imagine cet ignorant. Il sera assurément jeté dans le Feu de l’Enfer qui brise et détruit tout ce qui y est jeté.",
    "ayah": 4,
    "surah": 104
  },
  {
    "text": "Ô Messager, sais-tu ce qu’est ce Feu qui détruit tout ce qui y est jeté?",
    "ayah": 5,
    "surah": 104
  },
  {
    "text": "C’est le Feu attisé d’Allah",
    "ayah": 6,
    "surah": 104
  },
  {
    "text": "qui traverse les corps des gens jusqu’à leurs cœurs.",
    "ayah": 7,
    "surah": 104
  },
  {
    "text": "Il se refermera sur les suppliciés",
    "ayah": 8,
    "surah": 104
  },
  {
    "text": "en longues colonnes de flammes afin qu’ils n’en sortent plus.",
    "ayah": 9,
    "surah": 104
  }
]
