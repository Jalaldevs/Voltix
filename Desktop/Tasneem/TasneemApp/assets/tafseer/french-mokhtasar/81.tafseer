[
  {
    "text": "Lorsque le soleil sera rétréci et obscurci,",
    "ayah": 1,
    "surah": 81
  },
  {
    "text": "que les étoiles tomberont et que leur lueur s’effacera,",
    "ayah": 2,
    "surah": 81
  },
  {
    "text": "que les montagnes seront mises en marche et quitteront leurs emplacements,",
    "ayah": 3,
    "surah": 81
  },
  {
    "text": "que les chamelles sur le point de mettre bas, qui représentent les plus précieux de leurs biens, seront délaissées par leurs propriétaires,",
    "ayah": 4,
    "surah": 81
  },
  {
    "text": "que les animaux féroces seront rassemblés avec les êtres humains dans un même espace,",
    "ayah": 5,
    "surah": 81
  },
  {
    "text": "que les mers seront mises en feu,",
    "ayah": 6,
    "surah": 81
  },
  {
    "text": "que les âmes seront réunies deux à deux par affinité: les libertins avec les libertins et les pieux avec les pieux,",
    "ayah": 7,
    "surah": 81
  },
  {
    "text": "qu’Allah demandera à la fillette enterrée vivante",
    "ayah": 8,
    "surah": 81
  },
  {
    "text": "pour quel crime a-t-elle été tuée?",
    "ayah": 9,
    "surah": 81
  },
  {
    "text": "Lorsque les registres des œuvres des serviteurs seront déployés afin que chacun lise le sien,",
    "ayah": 10,
    "surah": 81
  },
  {
    "text": "que le Ciel sera entamé comme on écorche une brebis,",
    "ayah": 11,
    "surah": 81
  },
  {
    "text": "que la fournaise de l’Enfer sera attisée,",
    "ayah": 12,
    "surah": 81
  },
  {
    "text": "et que le Paradis sera rapproché des pieux.",
    "ayah": 13,
    "surah": 81
  },
  {
    "text": "Chaque âme connaîtra les œuvres qu’elle a présentées lorsque tout cela aura lieu.",
    "ayah": 14,
    "surah": 81
  },
  {
    "text": "Allah prête serment par les astres invisibles qui deviennent visibles lorsque la nuit tombe,",
    "ayah": 15,
    "surah": 81
  },
  {
    "text": "qui se déplacent dans leurs orbites et disparaissent à l'aube, à l’image de gazelles qui regagnent leurs gîtes.",
    "ayah": 16,
    "surah": 81
  },
  {
    "text": "Allah prête aussi serment par la nuit quand elle survient",
    "ayah": 17,
    "surah": 81
  },
  {
    "text": "et par l’aube dont la lumière se diffuse,",
    "ayah": 18,
    "surah": 81
  },
  {
    "text": "que le Coran révélé à Muħammad est assurément la parole d'Allah, transmise par l’Ange digne de confiance à qui Allah l'a confiée.",
    "ayah": 19,
    "surah": 81
  },
  {
    "text": "Cet Ange est doué d’une grande force et a un rang élevé auprès du Seigneur du Trône.",
    "ayah": 20,
    "surah": 81
  },
  {
    "text": "Les habitants du Ciel lui obéissent et il est digne de confiance pour la transmission de la Révélation.",
    "ayah": 21,
    "surah": 81
  },
  {
    "text": "Votre compagnon Muħammad, dont vous connaissez la santé mentale, la loyauté et la véracité n’est pas dément comme vous le prétendez calomnieusement.",
    "ayah": 22,
    "surah": 81
  },
  {
    "text": "Il vit effectivement l’Ange Gabriel sous sa véritable apparence à l’horizon",
    "ayah": 23,
    "surah": 81
  },
  {
    "text": "et il n’est pas avare avec vous de ce qui lui a été ordonné de vous transmettre ni ne reçoit un salaire comme en reçoivent les devins.",
    "ayah": 24,
    "surah": 81
  },
  {
    "text": "Ce Coran n’est pas la parole d’un démon exclu de la miséricorde d’Allah.",
    "ayah": 25,
    "surah": 81
  },
  {
    "text": "Quelle voie suivez-vous donc afin de nier qu’il provienne d’Allah après tous ces arguments?",
    "ayah": 26,
    "surah": 81
  },
  {
    "text": "Ce Coran n’est qu’un rappel et une exhortation adressés aux djinns et aux humains",
    "ayah": 27,
    "surah": 81
  },
  {
    "text": "A ceux parmi vous qui veulent emprunter le droit chemin.",
    "ayah": 28,
    "surah": 81
  },
  {
    "text": "Or vous ne pouvez vouloir être droits, à moins qu’Allah, le Seigneur de toutes les créatures, ne le veuille.",
    "ayah": 29,
    "surah": 81
  }
]
