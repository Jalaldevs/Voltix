[
  {
    "text": "-Ey Peygamber!- De ki: İnsanların Rabbine sığınıyorum ve O'nun himayesi altına giriyorum.",
    "ayah": 1,
    "surah": 114
  },
  {
    "text": "Onların üzerinde dilediği gibi tasarrufta bulunan, O'nun dışında hiçbir hükümdarları bulunmayan insanların hükümdarına,",
    "ayah": 2,
    "surah": 114
  },
  {
    "text": "Hak olan mabuda/ilaha. Onların AllahTeâlâ'dan başka kendisine ibadet edilecek hak mabudu yoktur.",
    "ayah": 3,
    "surah": 114
  },
  {
    "text": "Allah’ın zikrinden gafil oldukları zamanlarda insanlara vesvese veren ve onu zikrettiklerinde ondan uzaklaşan şeytanın şerrinden.",
    "ayah": 4,
    "surah": 114
  },
  {
    "text": "İnsanların kalplerine vesveselerini atan.",
    "ayah": 5,
    "surah": 114
  },
  {
    "text": "O; cinlerden olduğu gibi, insanlardan da olur.",
    "ayah": 6,
    "surah": 114
  }
]
