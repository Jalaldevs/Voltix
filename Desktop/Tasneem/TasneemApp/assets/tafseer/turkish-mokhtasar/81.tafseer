[
  {
    "text": "Güneşin cismi dürülüp, ışığı kaybolduğu zaman.",
    "ayah": 1,
    "surah": 81
  },
  {
    "text": "Yıldızlar ardı ardına dökülüp, ışıkları söndüğü zaman.",
    "ayah": 2,
    "surah": 81
  },
  {
    "text": "Dağlar yerlerinden hareket ettirildiği zaman.",
    "ayah": 3,
    "surah": 81
  },
  {
    "text": "Sahiplerinin kendileri için rekabete girip, övündüğü gebe develeri başıboş bırakıp ihmal ettikleri zaman.",
    "ayah": 4,
    "surah": 81
  },
  {
    "text": "Vahşi hayvanlar bir toprak parçasında insanlarla bir araya toplandığı zaman.",
    "ayah": 5,
    "surah": 81
  },
  {
    "text": "Denizler tutuşturulup bir ateşe döndüğü zaman,",
    "ayah": 6,
    "surah": 81
  },
  {
    "text": "İnsanlar; kendi benzeri kimselerle eşleştirilerek suçlular suçlularla, takva sahipleri de takva sahipleriyle eşleştirildiği zaman.",
    "ayah": 7,
    "surah": 81
  },
  {
    "text": "Allah, diri diri gömülen kız çocuğuna sorduğu zaman.",
    "ayah": 8,
    "surah": 81
  },
  {
    "text": "Seni öldüren kişi hangi suçtan ötürü seni öldürdü (diye)?",
    "ayah": 9,
    "surah": 81
  },
  {
    "text": "Herkes amel defterini okusun diye, kulların amel defterleri açıldığı zaman.",
    "ayah": 10,
    "surah": 81
  },
  {
    "text": "Gökyüzü, derinin koyundan soyulup çıkarıldığı gibi sökülüp atıldığı zaman.",
    "ayah": 11,
    "surah": 81
  },
  {
    "text": "Cehennem ateşi tutuşturulduğu zaman.",
    "ayah": 12,
    "surah": 81
  },
  {
    "text": "Cennet takva sahipleri için yakınlaştırıldığı zaman.",
    "ayah": 13,
    "surah": 81
  },
  {
    "text": "Bütün bunlar olduğu zaman artık herkes o gün için yaptığı amelleri bilecektir.",
    "ayah": 14,
    "surah": 81
  },
  {
    "text": "Allah Teâlâ, gece ortaya çıkmadan önce gizlenen yıldızlara yemin etmiştir.",
    "ayah": 15,
    "surah": 81
  },
  {
    "text": "Sabahın doğuşuyla kaybolan, mağarasına yani yuvasına giren bir ceylan gibi yörüngesinde akıp giden yıldızlara.",
    "ayah": 16,
    "surah": 81
  },
  {
    "text": "Yaklaşmakta olan gecenin başlangıcına ve gitmekte olan gecenin sonuna yemin etmiştir.",
    "ayah": 17,
    "surah": 81
  },
  {
    "text": "Işığı ortaya çıktığında sabaha yemin etmiştir.",
    "ayah": 18,
    "surah": 81
  },
  {
    "text": "Muhammed -sallallahu aleyhi ve sellem-'e inen Kur'an, pek güvenilir bir melek olan Cebrail -aleyhisselam-'ın tebliğ ettiği Allah kelamıdır. Allah Kur'an'ı ona emanet etmiştir.",
    "ayah": 19,
    "surah": 81
  },
  {
    "text": "O, kuvvet sahibidir. Arşın Rabbi olan Allah -Subhânehu ve Teâlâ- katında yüce bir makama sahiptir.",
    "ayah": 20,
    "surah": 81
  },
  {
    "text": "Gökyüzü ahalisi ona itaat eder, ayrıca bildirdiği vahiy konusunda güvenilirdir.",
    "ayah": 21,
    "surah": 81
  },
  {
    "text": "Sürekli yanınızda olan, güvenilirliğini ve doğru sözlü olduğunu bildiğiniz Muhammed -sallallahu aleyhi ve sellem- sizin iftira atıp, iddia ettiğiniz gibi bir deli değildir.",
    "ayah": 22,
    "surah": 81
  },
  {
    "text": "Şüphesiz arkadaşınız, Cebrail’i yaratıldığı surette gökyüzünün ufkunda açıkça gördü.",
    "ayah": 23,
    "surah": 81
  },
  {
    "text": "Arkadaşınız, kendisi aracılığıyla size bildirilmesi emredilmiş olan şeyi tebliğ etmede size karşı cimrilik yapmaz. Kâhinlerin aldığı gibi bir ücret de almaz.",
    "ayah": 24,
    "surah": 81
  },
  {
    "text": "Bu Kur’an, Allah’ın rahmetinden kovulmuş olan şeytanın sözü de değildir.",
    "ayah": 25,
    "surah": 81
  },
  {
    "text": "Bu delillerinden sonra onun Allah Teâlâ tarafından olduğunu inkâr etmek için hangi yola başvuruyorsunuz?",
    "ayah": 26,
    "surah": 81
  },
  {
    "text": "Kur'an, cinler ve insanlar için yalnızca bir öğüt ve nasihattir.",
    "ayah": 27,
    "surah": 81
  },
  {
    "text": "Sizin içinizden hak yolda dosdoğru olmayı dileyen kimseler için.",
    "ayah": 28,
    "surah": 81
  },
  {
    "text": "Bütün varlıkların Rabbi olan Allah dilemedikçe, siz dosdoğru olmayı veya başka bir şeyi dileyemezsiniz.",
    "ayah": 29,
    "surah": 81
  }
]
