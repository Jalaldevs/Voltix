[
  {
    "text": "-Ey Peygamber!- Dehşeti ile bütün insanları kuşatan kıyametin haberi sana geldi mi?",
    "ayah": 1,
    "surah": 88
  },
  {
    "text": "İnsanlar, kıyamet günü ya bedbaht ya da bahtiyar olacaklardır. Bedbaht olanların yüzleri zelil ve korkmuş olacaktır.",
    "ayah": 2,
    "surah": 88
  },
  {
    "text": "Onları çeken zincirlerden ve bağlandıkları prangalardan dolayı yorulup bitkin düşmüştürler.",
    "ayah": 3,
    "surah": 88
  },
  {
    "text": "O yüzler, sıcaklığının ızdırabını çekecekleri çok sıcak olan ateşe gireceklerdir.",
    "ayah": 4,
    "surah": 88
  },
  {
    "text": "Onlara, suyunun sıcaklığı çok aşırı olan bir pınardan su verilecek.",
    "ayah": 5,
    "surah": 88
  },
  {
    "text": "Onlara, en pis yemekler ve kuruduğu zaman zehirli bir hal alan Şibrik adında çok kötü kokulu bitkilerden başka bir yemek verilmeyecektir.",
    "ayah": 6,
    "surah": 88
  },
  {
    "text": "O kendisini yiyen kimseyi beslemediği gibi açlığını da gidermez.",
    "ayah": 7,
    "surah": 88
  },
  {
    "text": "Ve o gün karşılaştıkları nimetlerden dolayı bahtiyar olan kimselerin yüzleri de nimet ve mutluluk içinde sevinçlidir.",
    "ayah": 8,
    "surah": 88
  },
  {
    "text": "Dünyada işlediği salih amellerinden razıdır. Muhakkak ki yaptığı amellerinin mükâfatını kendisi için birikmiş olarak misliyle bulmuştur.",
    "ayah": 9,
    "surah": 88
  },
  {
    "text": "Yeri ve değeri yüksek olan cennettedirler.",
    "ayah": 10,
    "surah": 88
  },
  {
    "text": "Cennette haram olan sözler bir kenara, batıl ve boş olan bir söz dahi işitmezler.",
    "ayah": 11,
    "surah": 88
  },
  {
    "text": "Bu cennetin içinde, cennet ehlinin dilediği yerden akıttıkları ve istedikleri gibi kullandıkları akıcı pınarlar vardır.",
    "ayah": 12,
    "surah": 88
  },
  {
    "text": "Orada yüksek tahtlar/döşekler vardır.",
    "ayah": 13,
    "surah": 88
  },
  {
    "text": "İçmek için hazırlanıp, yerleştirilmiş kadehler vardır.",
    "ayah": 14,
    "surah": 88
  },
  {
    "text": "Ve içinde birbiri ardınca dizilmiş yastıklar vardır.",
    "ayah": 15,
    "surah": 88
  },
  {
    "text": "Orada, her yere yayılıp serilmiş birçok kilimler vardır.",
    "ayah": 16,
    "surah": 88
  },
  {
    "text": "Allah’ın deveyi nasıl yarattığına ve âdemoğlunun hizmetine sunduğuna düşünerek bakmazlar mı?",
    "ayah": 17,
    "surah": 88
  },
  {
    "text": "Ve gökyüzünün nasıl yükseltildiğine, böylece üzerlerine düşmeyen korunaklı bir çatı olduğuna bakmazlar mı?",
    "ayah": 18,
    "surah": 88
  },
  {
    "text": "Ve dağları nasıl diktiğine, insanların sarsılmamaları için onlarla nasıl sabit kılındığına bakmazlar mı?",
    "ayah": 19,
    "surah": 88
  },
  {
    "text": "Ve yeryüzünü nasıl yaydığına, insanların üzerinde karar kılmaları için onu nasıl hazır kıldığına bakmazlar mı?",
    "ayah": 20,
    "surah": 88
  },
  {
    "text": "-Ey Peygamber!- Sen onlara nasihat et ve Allah’ın azabından korkut! Şüphesiz sen, ancak nasihat edersin. Senden yalnızca onlara öğüt vermen istenir. Fakat iman etmeye muvaffak kılınmaları yalnızca Allah Teâlâ’nın elindedir.",
    "ayah": 21,
    "surah": 88
  },
  {
    "text": "Sen onların üzerinde iman etmeleri için kendilerine zorbaca davranan biri değilsin.",
    "ayah": 22,
    "surah": 88
  },
  {
    "text": "Fakat her kim onlara iman etmekten yüz çevirir, Allah ve resulüne kâfir olursa;",
    "ayah": 23,
    "surah": 88
  },
  {
    "text": "Yüce Allah, onu kıyamet günü sonsuza kadar cehennemin içine sokarak ona en büyük azap ile azap edecektir.",
    "ayah": 24,
    "surah": 88
  },
  {
    "text": "Şüphesiz ölümlerinin ardından onların dönüşü bir tek bize olacaktır.",
    "ayah": 25,
    "surah": 88
  },
  {
    "text": "Sonrasında amellerine göre onların hesaplarını görmek sadece bize aittir. Ne senin, ne de senden başka birinin üzerine değildir.",
    "ayah": 26,
    "surah": 88
  }
]
