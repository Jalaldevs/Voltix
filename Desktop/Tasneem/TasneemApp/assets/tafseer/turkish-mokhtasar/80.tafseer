[
  {
    "text": "Rasûlullah -sallallahu aleyhi ve sellem- yüzünü buruşturdu ve arkasını döndü.",
    "ayah": 1,
    "surah": 80
  },
  {
    "text": "Peygamber -sallallahu aleyhi ve sellem- hidayet bulmaları ümidiyle müşriklerin ileri gelenleriyle meşgul olduğu bir esnada, gözleri görmeyen bir kimse olan Abdullah b. Ümmü Mektum, doğru yola hidayet bulmak için geldi. Bu sebeple Peygamber -sallallahu aleyhi ve sellem- yüzünü ekşitti.",
    "ayah": 2,
    "surah": 80
  },
  {
    "text": "-Ey Peygamber!- Ne biliyorsun? Belki de bu âmâ adam günahlarından arınacak.",
    "ayah": 3,
    "surah": 80
  },
  {
    "text": "Veyahut senden duyduğu nasihatlerden öğüt alacak ve onlardan faydalanacaktı.",
    "ayah": 4,
    "surah": 80
  },
  {
    "text": "Fakat sahip olduğu servetinden ötürü, senin getirdiklerine iman etmekten kendini müstağni gören kimseye gelince;",
    "ayah": 5,
    "surah": 80
  },
  {
    "text": "Sen ona dönüyor ve yöneliyorsun.",
    "ayah": 6,
    "surah": 80
  },
  {
    "text": "O, Allah’a tövbe ederek günahlarından temizlenmiyorsa sana ne düşer ki?",
    "ayah": 7,
    "surah": 80
  },
  {
    "text": "Fakat koşarak gelen kimse hayır arayarak sana geldi ise;",
    "ayah": 8,
    "surah": 80
  },
  {
    "text": "Rabbinden korktuğu halde,",
    "ayah": 9,
    "surah": 80
  },
  {
    "text": "Sen; başkasıyla, müşriklerin ileri gelenlerinden biriyle oyalanıyorsun.",
    "ayah": 10,
    "surah": 80
  },
  {
    "text": "Bu iş hiçte öyle değildir. Şüphesiz o, kabul edenler için ancak bir öğüt ve hatırlatmadır.",
    "ayah": 11,
    "surah": 80
  },
  {
    "text": "Kim Allah’ı anmak isterse onu ansın ve bu Kur’an’da bulunan nasihatlerden öğüt alsın.",
    "ayah": 12,
    "surah": 80
  },
  {
    "text": "Bu Kur’an, meleklerin katında bulunan değerli sayfalardadır.",
    "ayah": 13,
    "surah": 80
  },
  {
    "text": "Yüce bir mekâna yükseltilmiş, kendisine hiçbir kir ve leke bulaşmamış, tertemizdir.",
    "ayah": 14,
    "surah": 80
  },
  {
    "text": "O, elçi meleklerin ellerindedir.",
    "ayah": 15,
    "surah": 80
  },
  {
    "text": "Rablerinin katında değerli, pek çok iyi işler yapan ve itaatkâr Melekler.",
    "ayah": 16,
    "surah": 80
  },
  {
    "text": "Kâfir olan insana lanet edilmiştir. İnsan Allah'a karşı ne kadar da çok inkârcıdır!",
    "ayah": 17,
    "surah": 80
  },
  {
    "text": "Allah onu hangi şeyden yarattı da yeryüzünde kibirleniyor ve Allah’ı inkâr ediyor?",
    "ayah": 18,
    "surah": 80
  },
  {
    "text": "Onu, az bir sudan yarattı ve yaradılışını aşama aşama takdir etti.",
    "ayah": 19,
    "surah": 80
  },
  {
    "text": "Sonra ona, bu aşamaların ardından annesinin karnından çıkışı kolaylaştırdı.",
    "ayah": 20,
    "surah": 80
  },
  {
    "text": "Sonra ona, hayatta belli bir ömrü takdir etmesinin ardından onu öldürdü. Ve ona yeniden diriltileceği zamana kadar içinde kalacağı bir kabir kıldı.",
    "ayah": 21,
    "surah": 80
  },
  {
    "text": "Sonra dilediği zaman hesap sormak ve karşılığını vermek üzere onu yeniden diriltecek.",
    "ayah": 22,
    "surah": 80
  },
  {
    "text": "Bu mesele o kâfirin zannettiği gibi değildir. O, Rabbinin üzerine yüklediği hakları yerine getirmediği gibi, Rabbinin ona zorunlu kıldığı farzları da yerine getirmiş değildir.",
    "ayah": 23,
    "surah": 80
  },
  {
    "text": "Yüce Allah'a iman etmeyip kâfir olan insan, yediği yemeğin nasıl hazır hale geldiğine bir baksın!",
    "ayah": 24,
    "surah": 80
  },
  {
    "text": "Suyun aslı, gökyüzünden kuvvetle ve bolca inen yağmurdan gelir.",
    "ayah": 25,
    "surah": 80
  },
  {
    "text": "Sonra toprağı açtık ki böylece bitkiler için yarılıp, açıldı.",
    "ayah": 26,
    "surah": 80
  },
  {
    "text": "Böylece toprakta buğday, mısır ve diğer tahıllardan yetiştirdik.",
    "ayah": 27,
    "surah": 80
  },
  {
    "text": "Ve taze üzüm yetiştirdik. Hayvanlarına yem olması için orada yonca yetiştirdik.",
    "ayah": 28,
    "surah": 80
  },
  {
    "text": "Ve orada zeytinler ve hurmalar yetiştirdik.",
    "ayah": 29,
    "surah": 80
  },
  {
    "text": "Orada çok ağaçlı bahçeler yetiştirdik.",
    "ayah": 30,
    "surah": 80
  },
  {
    "text": "Ve orada meyveler ve hayvanlarınızın otladığı otlaklar yetiştirdik.",
    "ayah": 31,
    "surah": 80
  },
  {
    "text": "Hem sizin, hem de hayvanlarınızın faydalanması için.",
    "ayah": 32,
    "surah": 80
  },
  {
    "text": "Kulakları sağır eden büyük çığlık geldiği zaman ki o, sura ikinci üfleyiştir.",
    "ayah": 33,
    "surah": 80
  },
  {
    "text": "O gün kişi kardeşinden kaçar.",
    "ayah": 34,
    "surah": 80
  },
  {
    "text": "Annesinden ve babasından kaçar.",
    "ayah": 35,
    "surah": 80
  },
  {
    "text": "Karısından ve çocuklarından kaçar.",
    "ayah": 36,
    "surah": 80
  },
  {
    "text": "O günün sıkıntısının şiddeti sebebiyle, onlardan her birini başkalarından alıkoyan bir meşguliyeti vardır.",
    "ayah": 37,
    "surah": 80
  },
  {
    "text": "O gün iyilerin yüzleri ışık saçar.",
    "ayah": 38,
    "surah": 80
  },
  {
    "text": "Yüce Allah’ın kendi rahmetinden onlar için hazırladığı şeylerden ötürü mutlu olup, gülecekler.",
    "ayah": 39,
    "surah": 80
  },
  {
    "text": "Ve o gün kötülerin yüzleri toz toprak içindedir.",
    "ayah": 40,
    "surah": 80
  },
  {
    "text": "O yüzleri bir karanlık kaplayacak.",
    "ayah": 41,
    "surah": 80
  },
  {
    "text": "İşte bu vasıflarla nitelenen o kimseler, küfür ve fücuru bir araya toplamış kimselerdir.",
    "ayah": 42,
    "surah": 80
  }
]
