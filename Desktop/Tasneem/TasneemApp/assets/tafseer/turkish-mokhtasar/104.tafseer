[
  {
    "text": "İnsanların arkasından konuşan ve onlara dil uzatanlara kötü bir akıbet ve şiddetli bir azap vardır.",
    "ayah": 1,
    "surah": 104
  },
  {
    "text": "Onun tek kaygısı mal biriktirmek ve saymaktır. Bunun dışında başka bir kaygısı yoktur.",
    "ayah": 2,
    "surah": 104
  },
  {
    "text": "Topladığı malının, onu ölümden kurtaracağını ve sonsuza kadar dünya hayatında kalacağını zanneder.",
    "ayah": 3,
    "surah": 104
  },
  {
    "text": "Durum hiç de bu cahilin tasavvur ettiği gibi değildir. Elbette o, azabının şiddetinden ötürü içine atılan her şeyi ufalayan ve parçalayan cehennem ateşine atılacak.",
    "ayah": 4,
    "surah": 104
  },
  {
    "text": "-Ey Peygamber!- İçine atılan her şeyi yakıp yıkan bu ateşin ne olduğunu sana ne öğretti?",
    "ayah": 5,
    "surah": 104
  },
  {
    "text": "Şüphesiz o, Allah'ın tutuşturulmuş ateşidir.",
    "ayah": 6,
    "surah": 104
  },
  {
    "text": "O ateş ki; insanların bedenlerinden kalplerine kadar delip geçer.",
    "ayah": 7,
    "surah": 104
  },
  {
    "text": "Şüphesiz o ateş, orada azap görenlerin üzerine kapatılmıştır.",
    "ayah": 8,
    "surah": 104
  },
  {
    "text": "Oradan çıkmamaları için boylu boyunca uzanan sütunlarla üzerleri kapatılmıştır.",
    "ayah": 9,
    "surah": 104
  }
]
