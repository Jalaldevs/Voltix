[
  {
    "text": "Allah, hızlı koşmaları sebebiyle nefesinin sesi işitilene kadar koşan atlara yemin etmiştir.",
    "ayah": 1,
    "surah": 100
  },
  {
    "text": "Ve kuvvetinin şiddetinden ötürü toynakları çakıl taşlarına değdiğinde kıvılcım saçan atlara yemin etmiştir.",
    "ayah": 2,
    "surah": 100
  },
  {
    "text": "Ve sabah vaktinde düşmanlarına baskın yapan atlara yemin etmiştir.",
    "ayah": 3,
    "surah": 100
  },
  {
    "text": "Koşarken toz kaldıran atlara yemin etmiştir.",
    "ayah": 4,
    "surah": 100
  },
  {
    "text": "Süvarileriyle düşman topluluğunun ortasına dalanlara yemin etmiştir.",
    "ayah": 5,
    "surah": 100
  },
  {
    "text": "Şüphesiz insan, Rabbinin kendisinden beklediği iyiliğe çokça engel olur.",
    "ayah": 6,
    "surah": 100
  },
  {
    "text": "Muhakkak insan, kendisinin iyiliğe mani olduğuna elbette şahittir. Apaçık olmasından ötürü bunu inkâr da edemez.",
    "ayah": 7,
    "surah": 100
  },
  {
    "text": "Muhakkak o, mal sevgisindeki aşırılığından dolayı cimrilik eder.",
    "ayah": 8,
    "surah": 100
  },
  {
    "text": "Dünya hayatına aldanmış bu insan, Allah’ın kabirde olan ölüleri diriltip hesaba çekip, karşılıklarını vermek üzere onları yeryüzüne çıkarttığı zaman durumun onların hayal ettiği gibi olmayacağını bilmez mi?",
    "ayah": 9,
    "surah": 100
  },
  {
    "text": "Kalplerde olanlar niyet, inanç ve diğer şeyler ortaya çıkarıldığı ve beyan edildiği zaman.",
    "ayah": 10,
    "surah": 100
  },
  {
    "text": "Şüphesiz Rableri o gün, bütün bunlardan haberdardır. Kullarının yaptıklarından hiçbir şey ona gizli kalmaz. Onlara bütün bunların karşılığını verecektir.",
    "ayah": 11,
    "surah": 100
  }
]
