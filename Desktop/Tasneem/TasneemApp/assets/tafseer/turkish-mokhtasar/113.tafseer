[
  {
    "text": "-Ey Peygamber!- De ki: Sabahın Rabbine sığınırım ve O'nun himayesini isterim.",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "mahlukattan zarar veren şeylerin kötülüklerinden.",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "Gece ortaya çıkan canlıların ve hırsızların kötülüklerinden Allah’a sığınırım.",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "Düğümlere üfleyen büyücü kadınların kötülüklerinden O'na sığınırım.",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "Hasedinin kendisini yapmaya sürüklediği ameli işlediğinde hasetçilerin şerrinden O'na sığınırım.",
    "ayah": 5,
    "surah": 113
  }
]
