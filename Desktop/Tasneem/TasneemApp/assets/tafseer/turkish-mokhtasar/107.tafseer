[
  {
    "text": "Kıyamet gününde karşılıkların verileceğini inkâr edeni bildin mi?",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "İhtiyacından ötürü yetime kaba davranarak kovan da işte odur.",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "Fakir kimseleri doyurmaya ne kendisini, ne de başkalarını teşvik eder.",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "O namaz kılanlar için bir helak ve azap vardır. Onlar ki; oyalanarak namazlarını son vaktine erteleyip umursamadan kılanlardır.",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "O namaz kılanlar için bir helak ve azap vardır. Onlar ki, oyalanarak namazlarını son vaktine erteleyip umursamadan kılanlardır.",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "Onlar, namazları ve amelleriyle gösteriş yaparlar. Amellerini sadece Allah’a halis kılmazlar.",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "Yardım etmenin hiçbir zararı olmadığı basit işlerde dahi başkalarına yardım etmekten geri dururlar.",
    "ayah": 7,
    "surah": 107
  }
]
