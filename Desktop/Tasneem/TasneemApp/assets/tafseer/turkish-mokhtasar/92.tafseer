[
  {
    "text": "Yüce Allah, gökyüzüyle yeryüzünün arasını karanlığıyla kapladığı zaman geceye yemin etmiştir.",
    "ayah": 1,
    "surah": 92
  },
  {
    "text": "Ve ortaya çıkıp göründüğünde gündüze yemin etmiştir.",
    "ayah": 2,
    "surah": 92
  },
  {
    "text": "Yarattığı iki tür üzerine yemin etmiştir. Bu tür erkek ve dişidir.",
    "ayah": 3,
    "surah": 92
  },
  {
    "text": "-Ey insanlar!- Şüphesiz yaptıklarınız birbirinden farklıdır. Bir kısmı cennete girme sebebi olan iyiliklerden, bir kısmı da cehenneme girme sebebi olan kötülüklerdendir.",
    "ayah": 4,
    "surah": 92
  },
  {
    "text": "Kim vermesi gereken zekât, nafaka ve sadakasını verir ve Allah’ın yasakladığı şeylerden sakınırsa.",
    "ayah": 5,
    "surah": 92
  },
  {
    "text": "Yüce Allah’ın kişiye ölümünün ardından vadettiği cenneti tasdik ederse.",
    "ayah": 6,
    "surah": 92
  },
  {
    "text": "Biz de ona, salih ameller işlemeyi ve Allah yolunda infak etmeyi kolaylaştıracağız.",
    "ayah": 7,
    "surah": 92
  },
  {
    "text": "Fakat her kim de malında cimrilik ederse ve üzerine farz olan yerlerde onu harcamaz, malından ötürü Allah’a karşı kendini yeterli görür ve Allah’ın kereminden hiçbir şey istemezse.",
    "ayah": 8,
    "surah": 92
  },
  {
    "text": "Malını Allah yolunda infak etmesine karşılık Allah Teâlâ'nın vadettiği ve kendisinin ardından gelecek olanı ve sevabı yalanlarsa.",
    "ayah": 9,
    "surah": 92
  },
  {
    "text": "Ona; kötü amelleri kolaylaştırıp, hayırlı amelleri zorlaştırırız.",
    "ayah": 10,
    "surah": 92
  },
  {
    "text": "Ölüp cehenneme girdiğinde, cimrilik yaptığı malı ona herhangi bir fayda vermeyecek.",
    "ayah": 11,
    "surah": 92
  },
  {
    "text": "Muhakkak bizim görevimiz, hak yolu batıl yoldan ayırıp beyan etmektir.",
    "ayah": 12,
    "surah": 92
  },
  {
    "text": "Muhakkak ahiret hayatı da dünya hayatı da bize aittir. Buralarda dilediğimiz gibi tasarrufta bulunuruz. Bunu bizden başka hiç kimse yapamaz.",
    "ayah": 13,
    "surah": 92
  },
  {
    "text": "-Ey insanlar!- Allah’a karşı gelmeniz durumunda, tutuşturulmuş ateşe karşı sizi uyardım.",
    "ayah": 14,
    "surah": 92
  },
  {
    "text": "Bu ateşin sıcaklığının ızdırabını, kâfir olan en bahtsız/azgın kimseden başkası çekmeyecektir.",
    "ayah": 15,
    "surah": 92
  },
  {
    "text": "Peygamber -sallallahu aleyhi ve sellem-'in getirdiklerini yalanlamış ve Allah’ın emirlerini yerine getirmekten yüz çevirmiştir.",
    "ayah": 16,
    "surah": 92
  },
  {
    "text": "İnsanların en takvalısı olan Ebu Bekir -radıyallahu anh- oradan uzak tutulacaktır.",
    "ayah": 17,
    "surah": 92
  },
  {
    "text": "Günahlarından temizlenmek için malını iyilik yolunda infak eden.",
    "ayah": 18,
    "surah": 92
  },
  {
    "text": "O; malından infak ettiklerini, birinin ona verdiği bir nimete karşılık olarak, infak etmemiştir.",
    "ayah": 19,
    "surah": 92
  },
  {
    "text": "O kimse infak ettiği malıyla tüm canlıların üzerinde olan Rabbinin vechini isteyip, arzular.",
    "ayah": 20,
    "surah": 92
  },
  {
    "text": "Allah Teâlâ’nın ona vereceği değerli mükâfattan elbette o da razı olacaktır.",
    "ayah": 21,
    "surah": 92
  }
]
