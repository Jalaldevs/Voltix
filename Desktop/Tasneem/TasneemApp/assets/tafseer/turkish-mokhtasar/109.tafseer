[
  {
    "text": "-Ey Peygamber!- De ki: Ey Allah'a karşı kâfir olanlar!",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "Ben, şimdi ve gelecekte sizin ibadet ettiğiniz putlara ibadet etmem.",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "Siz de benim ibadet ettiğim bir tek Allah'a ibadet edecek değilsiniz.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "Ben de sizin ibadet ettiğiniz putlara ibadet edecek değilim.",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "Ve siz de benim ibadet ettiğim bir tek Allah'a ibadet edecek değilsiniz.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "Kendiniz için uydurduğunuz dininiz size, Allah’ın bana indirdiği din ise banadır.",
    "ayah": 6,
    "surah": 109
  }
]
