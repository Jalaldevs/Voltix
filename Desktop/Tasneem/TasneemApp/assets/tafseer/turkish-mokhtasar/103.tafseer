[
  {
    "text": "Allah -Subhânehu ve Teâlâ-, asır/ikindi vaktine yemin etmiştir.",
    "ayah": 1,
    "surah": 103
  },
  {
    "text": "Şüphesiz insan, bir çöküş ve yok oluş içindedir.",
    "ayah": 2,
    "surah": 103
  },
  {
    "text": "Ancak, Allah’a ve resulüne iman eden, salih ameller işleyen, birbirlerine hakkı ve hak üzerinde sabırlı olmayı tavsiye edenler bundan müstesnadır. Bu vasıflarla nitelenen kimseler, dünya ve ahiret hayatlarında kurtuluşa ermiş olanlardır.",
    "ayah": 3,
    "surah": 103
  }
]
