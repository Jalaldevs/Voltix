[
  {
    "text": "-Ey Peygamber!- Muhakkak biz sana birçok hayırlar verdik. Onlardan biri de cennetteki Kevser ırmağıdır.",
    "ayah": 1,
    "surah": 108
  },
  {
    "text": "Öyleyse sen de, putlarına bir yakınlık vesilesi olarak kurban kesen müşriklerin yaptıklarının aksine, bu nimetlerine karşılık bir tek O'nun için namaz kılarak ve bir tek O'nun için kurban keserek Allah Teâlâ'ya şükrünü eda et.",
    "ayah": 2,
    "surah": 108
  },
  {
    "text": "Şüphesiz asıl sana buğuz eden, bütün hayırlardan kesik, adı geçtiğinde kendisinden kötü bir kimse olarak bahsedilen, unutulmuş bir kimsedir.",
    "ayah": 3,
    "surah": 108
  }
]
