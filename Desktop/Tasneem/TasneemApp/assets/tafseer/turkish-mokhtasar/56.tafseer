[
  {
    "text": "Kıyametin kopması kaçınılmazdır.",
    "ayah": 1,
    "surah": 56
  },
  {
    "text": "Dünyada yalanladıkları gibi artık kıyametin kopmasını kimse yalanlayamayacaktır.",
    "ayah": 2,
    "surah": 56
  },
  {
    "text": "Kâfir ve fâcirleri cehenneme koyarak alçaltıcı; Mümin ve takva sahiplerini cennete koyarak yükselticidir.",
    "ayah": 3,
    "surah": 56
  },
  {
    "text": "Yer büyük bir sarsıntı ile sarsıldığında.",
    "ayah": 4,
    "surah": 56
  },
  {
    "text": "Dağlar paramparça olduğu zaman.",
    "ayah": 5,
    "surah": 56
  },
  {
    "text": "Bu paramparça olmaktan dolayı yerinde sebat edemeden toz duman haline geldiği zaman.",
    "ayah": 6,
    "surah": 56
  },
  {
    "text": "O günde sizler üç sınıf olduğunuz zaman.",
    "ayah": 7,
    "surah": 56
  },
  {
    "text": "Sağ taraf ehli öyle kimselerdir ki, imanları sebebiyle kitaplarını sağ taraftan alırlar. Onların makamları ne büyük, ne yüksektir!",
    "ayah": 8,
    "surah": 56
  },
  {
    "text": "Sol taraf ehli öyle kimselerdir ki, kitaplarını sol taraflarından alırlar. Onların makamları ne kötü, ne aşağılıktır!",
    "ayah": 9,
    "surah": 56
  },
  {
    "text": "Dünyada hayır işleme hususunda yarışanlar, ahirette cennete girme hususunda da en önce olanlardır.",
    "ayah": 10,
    "surah": 56
  },
  {
    "text": "İşte onlar, Allah'ın katında yakınlaştırılmış kimselerdir.",
    "ayah": 11,
    "surah": 56
  },
  {
    "text": "Onlar Naim cennetlerindedirler. Çeşitli nimetlerden faydalanmaktadırlar.",
    "ayah": 12,
    "surah": 56
  },
  {
    "text": "Onlar bu ümmetten ve geçmiş ümmetlerden oluşan bir topluluktur.",
    "ayah": 13,
    "surah": 56
  },
  {
    "text": "İnsanların az bir kısmı da ahir zamanda hayırda yarışıp yakınlaştırılmış kimselerdendir.",
    "ayah": 14,
    "surah": 56
  },
  {
    "text": "Altınla dokunmuş tahtlar üzerindedirler.",
    "ayah": 15,
    "surah": 56
  },
  {
    "text": "Karşılıklı oturup bu tahtlara yaslanırlar. Onlardan hiçbiri başkasının ensesine bakmaz.",
    "ayah": 16,
    "surah": 56
  },
  {
    "text": "Kendilerine yaşlılık ve fanilik isabet etmeyen gençler, onlara hizmet etmek için etraflarında dolaşır.",
    "ayah": 17,
    "surah": 56
  },
  {
    "text": "(O hizmetçiler) kulpsuz kadehler, kulplu testiler ve cennetten akıp gelen ve kesintiye uğramayan şaraplarla dolu kadehlerle etraflarında dolaşırlar.",
    "ayah": 18,
    "surah": 56
  },
  {
    "text": "Dünyadaki içkiler gibi değildir. Onu içenin ne başı ağrır, ne de aklı gider.",
    "ayah": 19,
    "surah": 56
  },
  {
    "text": "O hizmetlerinde bulunan gençler, istedikleri meyveler ile etraflarında dolanırlar.",
    "ayah": 20,
    "surah": 56
  },
  {
    "text": "Nefislerinin arzuladığı kuş etleriyle de etraflarında dolanırlar.",
    "ayah": 21,
    "surah": 56
  },
  {
    "text": "Cennette onlar için gözleri iri güzel kadınlar vardır.",
    "ayah": 22,
    "surah": 56
  },
  {
    "text": "Sanki sedefinin içinde saklı inciler gibi.",
    "ayah": 23,
    "surah": 56
  },
  {
    "text": "(Bütün bunlar) dünyada işlemiş oldukları salih amellerin karşılığında mükâfat olarak verilir.",
    "ayah": 24,
    "surah": 56
  },
  {
    "text": "Cennette ne boş bir söz, ne de sahibine günah getirecek söz işitirler.",
    "ayah": 25,
    "surah": 56
  },
  {
    "text": "Meleklerin kendilerine verdiği selam ve birbirleri arasındaki selamlaşmalardan başka bir şey işitmezler.",
    "ayah": 26,
    "surah": 56
  },
  {
    "text": "Sağ taraf ehli; öyle kimselerdir ki, imanları sebebiyle kitapları sağ taraflarından verilir. Allah katında onların makamları ne büyük, ne yücedir!",
    "ayah": 27,
    "surah": 56
  },
  {
    "text": "Dikenleri olmayan ve kimseye eziyet vermeyen sedir ağaçlarında.",
    "ayah": 28,
    "surah": 56
  },
  {
    "text": "Salkımları bir araya toplanmış muz ağaçlarında.",
    "ayah": 29,
    "surah": 56
  },
  {
    "text": "Yok olmayacak devamlı uzun gölgeler vardır.",
    "ayah": 30,
    "surah": 56
  },
  {
    "text": "Durmadan akan sular vardır.",
    "ayah": 31,
    "surah": 56
  },
  {
    "text": "Sınırsız bir çok meyve vardır.",
    "ayah": 32,
    "surah": 56
  },
  {
    "text": "O (meyveler) kesinlikle tükenmez, mevsime ihtiyaç duymazlar. Hangi vakit isterseler bir mani olmadan ulaşırlar.",
    "ayah": 33,
    "surah": 56
  },
  {
    "text": "Tahtların üzerinde yükseltilmiş döşekler içindedirler.",
    "ayah": 34,
    "surah": 56
  },
  {
    "text": "Biz bu zikredilen hurileri alışılmışın dışında yeniden yarattık.",
    "ayah": 35,
    "surah": 56
  },
  {
    "text": "Onları daha önceden el değmemiş bakireler kıldık.",
    "ayah": 36,
    "surah": 56
  },
  {
    "text": "Onları aynı yaşta, eşlerine sevgili kıldık.",
    "ayah": 37,
    "surah": 56
  },
  {
    "text": "Mutluluklarının göstergesi olarak sağ taraf ehli için onları (hurileri) yarattık.",
    "ayah": 38,
    "surah": 56
  },
  {
    "text": "Onlar, geçmiş ümmetlere (gönderilmiş) peygamberlerin topluluklarıdır.",
    "ayah": 39,
    "surah": 56
  },
  {
    "text": "Ümmetlerin sonuncusu Muhammed -sallallahu aleyhi ve sellem-'in ümetinden bir topluluktur.",
    "ayah": 40,
    "surah": 56
  },
  {
    "text": "Sol taraf ehli öyle kimselerdir ki, kitaplarını sol taraflarından verilir. Onların halleri ve akibetleri ne kötüdür!",
    "ayah": 41,
    "surah": 56
  },
  {
    "text": "Sıcaklığı şiddetli olan rüzgârlar ve sıcaklığı şiddetli olan sular içindedirler.",
    "ayah": 42,
    "surah": 56
  },
  {
    "text": "Kapkara duman gölgesinin içindedirler.",
    "ayah": 43,
    "surah": 56
  },
  {
    "text": "Güzel bir esinti de yoktur, güzel bir manzara da yoktur.",
    "ayah": 44,
    "surah": 56
  },
  {
    "text": "Şüphesiz ki onlar, bu azaba uğratılmadan önce dünyada bolluk içinde yaşıyorlardı. Onlar ancak arzularını önemsiyorlardı.",
    "ayah": 45,
    "surah": 56
  },
  {
    "text": "Allah'ı küfretmek ve O'nun dışında putlara ibadet etmekte ısrar ediyorlardı.",
    "ayah": 46,
    "surah": 56
  },
  {
    "text": "Yeniden dirilişi inkâr edip, alay ederek ve bunun olmasını uzak görerek şöyle diyorlardı: \"Ölüp, toprak ve çürümüş kemik yığını haline geldikten sonra yeniden mi diriltileceğiz?\"",
    "ayah": 47,
    "surah": 56
  },
  {
    "text": "\"Bizden önce ölen atalarımız da mı diriltilecekler?\"",
    "ayah": 48,
    "surah": 56
  },
  {
    "text": "-Ey Resul!- Yeniden dirilişi inkâr edene de ki: \"Şüphesiz hem öncekiler, hem sonrakiler (diriltileceklerdir).\"",
    "ayah": 49,
    "surah": 56
  },
  {
    "text": "Hesap ve karşılık için kıyamet gününde bir araya getirileceklerdir.",
    "ayah": 50,
    "surah": 56
  },
  {
    "text": "Sonra siz -Ey yeniden dirilişi yalanlayanlar! Dosdoğru yoldan sapanlar!- Kıyamet günü, meyvelerin en kötüsü ve pisi olan zakkum ağacının meyvesini muhakkak yiyeceksiniz.",
    "ayah": 51,
    "surah": 56
  },
  {
    "text": "Sonra siz -Ey yeniden dirilişi yalanlayanlar! Dosdoğru yoldan sapanlar!- Kıyamet günü, meyvelerin en kötüsü ve pisi olan zakkum ağacının meyvesini muhakkak yiyeceksiniz.",
    "ayah": 52,
    "surah": 56
  },
  {
    "text": "Boş midelerinizi bu ağacın acı (meyvesi) ile dolduracaksınız.",
    "ayah": 53,
    "surah": 56
  },
  {
    "text": "Bunun üzerine de kaynar sudan içeceksiniz.",
    "ayah": 54,
    "surah": 56
  },
  {
    "text": "Sürekli susuzluk hissetme hastalığı sebebi ile devenin çok su içtiği gibi siz de ondan içeceksiniz.",
    "ayah": 55,
    "surah": 56
  },
  {
    "text": "Bu zikredilen acı yemek ve kaynar su, karşılık gününde kendisi ile karşılanacakları ziyafetleridir.",
    "ayah": 56,
    "surah": 56
  },
  {
    "text": "-Ey yalanlayanlar!- Siz yok iken biz sizi yarattık. Öldükten sonra sizi diriltip hayat vereceğimizi tasdik etmeniz gerekmez mi?",
    "ayah": 57,
    "surah": 56
  },
  {
    "text": "-Ey insanlar- Hanımlarınızın rahimlerine döktüğünüz meniyi görmez misiniz?",
    "ayah": 58,
    "surah": 56
  },
  {
    "text": "O meniyi yaratan siz misiniz? Yoksa onu yaratan biz miyiz?",
    "ayah": 59,
    "surah": 56
  },
  {
    "text": "Aranızda ölümü biz takdir ettik. Her birinizin takdir edilmiş bir eceli vardır. Ne öne alınır, ne de gecikir. Biz aciz de değiliz.",
    "ayah": 60,
    "surah": 56
  },
  {
    "text": "Yaratılmış olduğunuz tabiatı tanıyıp, bildiğiniz şeklinizi bilmediğiniz tabiat ve şekilde değiştirip, yaratalım diye.",
    "ayah": 61,
    "surah": 56
  },
  {
    "text": "Sizi ilk olarak nasıl yarattığımızı biliyorsunuz? Sizi ilk olarak yaratanın öldükten sonra yeniden sizi diriltmeye kadir olduğunu bilip ibret almanız gerekmez mi?",
    "ayah": 62,
    "surah": 56
  },
  {
    "text": "Tarlaya ektiğiniz tohumu görmez misiniz?",
    "ayah": 63,
    "surah": 56
  },
  {
    "text": "O tohumu bitiren siz misiniz? Yoksa bitiren biz miyiz?",
    "ayah": 64,
    "surah": 56
  },
  {
    "text": "Bu ekini olgunlaşmaya ve yetişmeye yakın kuru bir çöp yapmayı dileseydik, onu kuru bir çöp yapardık. Ona ne isabet ettiğine dair şaşırıp kalırdınız.",
    "ayah": 65,
    "surah": 56
  },
  {
    "text": "Şöyle dersiniz: \"Harcadığımız şeylerin ziyana uğramasıyla azap ediliyoruz.\"",
    "ayah": 66,
    "surah": 56
  },
  {
    "text": "\"Bilakis biz rızıktan mahrum edildik.\"",
    "ayah": 67,
    "surah": 56
  },
  {
    "text": "Susadığınızda içtiğiniz suyu gördünüz mü?",
    "ayah": 68,
    "surah": 56
  },
  {
    "text": "Gökteki buluttan onu indiren siz misiniz? Yoksa onu indiren biz miyiz?",
    "ayah": 69,
    "surah": 56
  },
  {
    "text": "Eğer bu suyu içme ve sulamada kullanamayacağınız şekilde çok tuzlu yapmak isteseydik, öyle yapardık. Size rahmet olarak bu suyu tatlı bir şekilde indirdiği için Yüce Allah'a şükretmeyecek misiniz?",
    "ayah": 70,
    "surah": 56
  },
  {
    "text": "Kendisinden faydalanmak için tutuşturduğunuz ateşi gördünüz mü?",
    "ayah": 71,
    "surah": 56
  },
  {
    "text": "Yakıp tutuşturduğunuz ağaçları sizler mi yarattınız? Yoksa size olan şefkatimizden dolayı onu yaratan bizler miyiz?",
    "ayah": 72,
    "surah": 56
  },
  {
    "text": "Biz bu ateşi, ahiret ateşini size hatırlatan bir ibret ve sizden yolculuk edenler için bir faydalanma kıldık.",
    "ayah": 73,
    "surah": 56
  },
  {
    "text": "-Ey Resul!- Azim olan Rabbini yakışık olmayan her şeyden tenzih et.",
    "ayah": 74,
    "surah": 56
  },
  {
    "text": "Yüce Allah, yıldızların yer ve yörüngelerine yemin etmiştir.",
    "ayah": 75,
    "surah": 56
  },
  {
    "text": "Gerçekten yıldızların bu yörüngelerine edilen yemin -büyüklüğünü bilirseniz- içinde barındırdığı sayısız ibret ve ayetler bakımından pek büyüktür.",
    "ayah": 76,
    "surah": 56
  },
  {
    "text": "-Ey insanlar!- Size okunan bu Kur'an, içinde barındırdığı büyük faydalar bakımından pek değerli bir Kur'an'dır.",
    "ayah": 77,
    "surah": 56
  },
  {
    "text": "İnsanların gözlerinden gizlenmiş bir kitaptadır ki, o Levh-i Mahfûz'dur.",
    "ayah": 78,
    "surah": 56
  },
  {
    "text": "Ona ancak günah ve kusurlardan temizlenmiş melekler dokunabilir.",
    "ayah": 79,
    "surah": 56
  },
  {
    "text": "Tüm canlıların Rabbi olan Allah tarafından, peygamberi Muhammed -sallallahu aleyhi ve sellem-'e indirilmiştir.",
    "ayah": 80,
    "surah": 56
  },
  {
    "text": "-Ey müşrikler!- Siz; bu sözü (Kur'an'ı) yalanlıyor, tasdik etmiyor musunuz?",
    "ayah": 81,
    "surah": 56
  },
  {
    "text": "Yüce Allah'ın sizi nimetlerle rızıklandırmasına karşılık O'nu yalanlayarak mı şükrediyorsunuz? Yağmurun yağmasını yıldızlara nispet edip; \"Falanca ve filanca yıldız sayesinde bize yağmur verildi mi?\" diyorsunuz.",
    "ayah": 82,
    "surah": 56
  },
  {
    "text": "Can boğaza gelip dayandığında.",
    "ayah": 83,
    "surah": 56
  },
  {
    "text": "O vakit, siz önünüzde can çekişip ölüm döşeğinde olan kişiye bakakalırsınız.",
    "ayah": 84,
    "surah": 56
  },
  {
    "text": "Biz; ilmimiz, kudretimiz ve meleklerimiz ile ölülerinize sizden daha yakınız. Fakat sizler o melekleri görmüyorsunuz.",
    "ayah": 85,
    "surah": 56
  },
  {
    "text": "Madem iddia ettiğiniz gibi işlemiş olduğunuz amellerinizin karşılığını görmek için yeniden diriltilmeyeceksiniz.",
    "ayah": 86,
    "surah": 56
  },
  {
    "text": "Eğer doğru söylüyor iseniz, ölülerinizden çıkan bu ruhu geri çevirsenize! Ancak bunu yapmaya güç yetiremezsiniz.",
    "ayah": 87,
    "surah": 56
  },
  {
    "text": "Eğer ölen kimse hayırda yarışan birisi ise.",
    "ayah": 88,
    "surah": 56
  },
  {
    "text": "Onun için ardında yorgunluk olmayan rahatlık, güzel rızık ve rahmet vardır. Ve onun için canının çektiği şeylerle rızıklandırıldığı cennet vardır.",
    "ayah": 89,
    "surah": 56
  },
  {
    "text": "Eğer ölen kişi sağ taraf ehlinden ise onların durumu için kaygı duyma. Zira onlar için selamet ve güven vardır.",
    "ayah": 90,
    "surah": 56
  },
  {
    "text": "Eğer ölen kişi sağ taraf ehlinden ise onların durumu için kaygı duyma. Zira onlar için selamet ve güven vardır.",
    "ayah": 91,
    "surah": 56
  },
  {
    "text": "Eğer ölen kişi dosdoğru yoldan sapan, Rasûlullah -sallallahu aleyhi ve sellem-'in getirdiklerini yalanlayanlardan ise.",
    "ayah": 92,
    "surah": 56
  },
  {
    "text": "O kişinin karşılanacağı ziyafet alabildiğine kaynar sudur.",
    "ayah": 93,
    "surah": 56
  },
  {
    "text": "Onun için cehennem ateşinde yanmak vardır.",
    "ayah": 94,
    "surah": 56
  },
  {
    "text": "-Ey Resul!- Şüphesiz ki sana bu anlattıklarımız, üzerinde şüphe olmayan hakikatlerdir.",
    "ayah": 95,
    "surah": 56
  },
  {
    "text": "Azim olan Rabbinin adını tespih et ve O'nu bütün noksanlıklardan tenzih et!",
    "ayah": 96,
    "surah": 56
  }
]
