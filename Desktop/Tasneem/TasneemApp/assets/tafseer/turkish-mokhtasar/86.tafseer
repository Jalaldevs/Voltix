[
  {
    "text": "Yüce Allah, gökyüzüne ve gece doğan yıldıza yemin etmiştir.",
    "ayah": 1,
    "surah": 86
  },
  {
    "text": "-Ey Peygamber!- Bu büyük yıldızın durumunu sana ne öğretti?",
    "ayah": 2,
    "surah": 86
  },
  {
    "text": "O, parıldayan ışığıyla gökyüzünü delen bir yıldızdır.",
    "ayah": 3,
    "surah": 86
  },
  {
    "text": "Allah Teâlâ, kıyamet günü hesap vermesi için her bir kişiye amellerini kaydeden bir melek görevlendirmiştir.",
    "ayah": 4,
    "surah": 86
  },
  {
    "text": "Öyleyse insan, Allah’ın kudreti ve insanoğlunun acizliği ortaya çıksın diye Allah'ın onu neyden yarattığını bir düşünsün.",
    "ayah": 5,
    "surah": 86
  },
  {
    "text": "Allah; onu, fışkırarak rahme akıtılan bir sudan yarattı.",
    "ayah": 6,
    "surah": 86
  },
  {
    "text": "Bu su, erkeğin omurilik kemiğiyle göğüs kemiklerinin arasından çıkar.",
    "ayah": 7,
    "surah": 86
  },
  {
    "text": "Allah -Subhânehu ve Teâlâ- onu, bu hakir sudan yaratabiliyorsa, elbette ölümünün ardından hesaba çekmek için onu diri olarak yeniden yaratmaya da kadirdir.",
    "ayah": 8,
    "surah": 86
  },
  {
    "text": "O gün bütün sırlar sınanır, kalplerin gizlediği niyetler, inançlar ve bunların dışında diğer şeyler ortaya çıkarılır ve salih olanlar fasit olanlardan ayrılır.",
    "ayah": 9,
    "surah": 86
  },
  {
    "text": "O gün, insanın Allah’ın azabından imtina edebileceği bir gücü ve kendisine yardım edebilecek hiçbir yardımcısı yoktur.",
    "ayah": 10,
    "surah": 86
  },
  {
    "text": "Allah Teâlâ yağmurlu gökyüzüne yemin etmiştir. Çünkü yağmur, her seferinde o cihetten yağar.",
    "ayah": 11,
    "surah": 86
  },
  {
    "text": "Ve içinde bulunan bitki, ürün/meyve ve ağaçlardan ötürü yarılan toprağa yemin etmiştir.",
    "ayah": 12,
    "surah": 86
  },
  {
    "text": "Şüphesiz Muhammed -sallallahu aleyhi ve sellem-’e indirilmiş olan bu Kur’an, hakkı batıldan ve doğruyu yanlışı birbirinden ayıran bir sözdür.",
    "ayah": 13,
    "surah": 86
  },
  {
    "text": "O, bir eğlence ve yalan değildir, bilakis bir ciddiyet ve gerçektir.",
    "ayah": 14,
    "surah": 86
  },
  {
    "text": "Peygamberlerinin getirdiğini yalanlayanlar, onun davetine engel olmak ve ortadan kaldırmak için bir çok tuzaklar kuruyorlar.",
    "ayah": 15,
    "surah": 86
  },
  {
    "text": "Ve ben de, hak dinin ortaya çıkması ve batılın çürüyüp yok olması için bir tuzak kuruyorum.",
    "ayah": 16,
    "surah": 86
  },
  {
    "text": "-Ey Peygamber!- Bu kâfirlere mühlet ver ve onlara biraz zaman tanı! Onların azap görmesi ve helak olması için acele etme.",
    "ayah": 17,
    "surah": 86
  }
]
