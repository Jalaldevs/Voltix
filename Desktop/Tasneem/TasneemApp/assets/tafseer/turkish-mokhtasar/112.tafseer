[
  {
    "text": "-Ey Peygamber!- De ki: O Allah, ilahlığında tektir. O'ndan başka bir ilah yoktur.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "O, bütün varlıkların kendisine ihtiyaç duyduğu, kemal ve güzellik sıfatlarında ululuğun en son noktasındaki hükümdardır.",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "O, hiç kimseyi doğurmamış, hiç kimse de O'nu doğurmamıştır. Allah - Subhanehu ve Teâlâ-'nın ne bir çocuğu, ne de bir babası vardır.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "Yarattıkları arasında O'nun bir benzeri yoktur.",
    "ayah": 4,
    "surah": 112
  }
]
