[
  {
    "text": "Gökyüzü, meleklerin inişi sebebiyle parçalandığında.",
    "ayah": 1,
    "surah": 82
  },
  {
    "text": "Yıldızlar, saçılarak döküldüğünde.",
    "ayah": 2,
    "surah": 82
  },
  {
    "text": "Denizler birbirine açılıp karıştığında.",
    "ayah": 3,
    "surah": 82
  },
  {
    "text": "İçinde bulunan ölülerin yeniden dirilmesi için kabirlerin toprağı alt üst edildiğinde.",
    "ayah": 4,
    "surah": 82
  },
  {
    "text": "O zaman herkes yapmış olduğu amelleri ve erteleyerek yapmadıklarını bilecektir.",
    "ayah": 5,
    "surah": 82
  },
  {
    "text": "Ey Rabbine kâfir olan insan! Lütfuyla sana zaman verdiği ve seni cezalandırmak için acele etmediği halde, seni Rabbinin emrine muhalif kılan nedir?",
    "ayah": 6,
    "surah": 82
  },
  {
    "text": "Yokluğunun ardından seni var etti, azalarını doğru ve düzgün kıldı.",
    "ayah": 7,
    "surah": 82
  },
  {
    "text": "Seni hangi surette yaratmayı dilediyse, öyle yarattı. Seni; eşek, maymun, köpek veya bunların dışında bir surette yaratmayarak, nimetlendirdi.",
    "ayah": 8,
    "surah": 82
  },
  {
    "text": "-Ey Gafiller!- Bu durum sizin düşündüğünüz gibi değildir. Bilakis siz, karşılıkların görüleceği günü yalanlıyorsunuz. O gün için amel etmiyorsunuz.",
    "ayah": 9,
    "surah": 82
  },
  {
    "text": "Şüphesiz üzerinizde, amellerinizi gözetleyip, kaydeden melekler vardır.",
    "ayah": 10,
    "surah": 82
  },
  {
    "text": "Onlar Yüce Allah’ın katında çok değerli olan kâtiplerdir. Sizlerin amellerini yazmaktadır.",
    "ayah": 11,
    "surah": 82
  },
  {
    "text": "Hangi amelleri yaptığınızı biliyor ve onları yazıyorlar.",
    "ayah": 12,
    "surah": 82
  },
  {
    "text": "Şüphesiz çokça hayırlı amel işleyenler ve ibadet edenler, elbette kıyamet günü devamlı olan nimetler içinde olacaktır.",
    "ayah": 13,
    "surah": 82
  },
  {
    "text": "Günahkârlar ise üzerlerine ateşin tutuşturulduğu cehennemde olacaklardır.",
    "ayah": 14,
    "surah": 82
  },
  {
    "text": "Karşılıkların verileceği gün oraya girerek cehennem ateşinin ızdırabını çekeceklerdir.",
    "ayah": 15,
    "surah": 82
  },
  {
    "text": "Oradan asla ayrılamayacak, bilakis sonsuza kadar kalacaklardır.",
    "ayah": 16,
    "surah": 82
  },
  {
    "text": "-Ey Peygamber!- Din/hesap gününün ne olduğunu sana kim öğretti?",
    "ayah": 17,
    "surah": 82
  },
  {
    "text": "Yine, din/hesap gününün ne olduğunu sana ne öğretti?",
    "ayah": 18,
    "surah": 82
  },
  {
    "text": "O gün kimsenin kimseye fayda vermeye gücü yetmez. O gün bütün emir, kimsenin değil bir tek Allah’ındır ve dilediği gibi tasarrufta bulunur.",
    "ayah": 19,
    "surah": 82
  }
]
