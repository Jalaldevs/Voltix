[
  {
    "text": "Yüce Allah, at yelesi gibi ardı ardına gelen rüzgârlara yemin etmiştir.",
    "ayah": 1,
    "surah": 77
  },
  {
    "text": "Şiddetle esip savuran rüzgârlara yemin etmiştir.",
    "ayah": 2,
    "surah": 77
  },
  {
    "text": "Yağmurları yayan rüzgârlara yemin etmiştir.",
    "ayah": 3,
    "surah": 77
  },
  {
    "text": "Hak ve batılı birbirinden ayıranı indiren meleklere yemin etmiştir.",
    "ayah": 4,
    "surah": 77
  },
  {
    "text": "Vahyi getiren meleklere yemin etmiştir.",
    "ayah": 5,
    "surah": 77
  },
  {
    "text": "Allah’tan insanlara bir ikaz olarak veya Allah’ın azabına karşı insanları korkutmak için vahiyle inerler.",
    "ayah": 6,
    "surah": 77
  },
  {
    "text": "Şüphesiz size vadedilen yeniden diriliş, hesap ve karşılıkların verilmesi kaçınılmaz olarak muhakkak gerçekleşecektir.",
    "ayah": 7,
    "surah": 77
  },
  {
    "text": "Yıldızların parıltısı silinip ışığı kaybolduğu zaman.",
    "ayah": 8,
    "surah": 77
  },
  {
    "text": "Gökyüzü, meleklerin inişi sebebiyle parçalandığı zaman.",
    "ayah": 9,
    "surah": 77
  },
  {
    "text": "Dağlar yerlerinden sökülüp toz tanelerine dönüşünceye kadar paramparça edildiği zaman.",
    "ayah": 10,
    "surah": 77
  },
  {
    "text": "Peygamberler belli bir vakit için toplandığı zaman.",
    "ayah": 11,
    "surah": 77
  },
  {
    "text": "Çok büyük bir gün için, ümmetlerine karşı şahitlikleri ertelenmiştir.",
    "ayah": 12,
    "surah": 77
  },
  {
    "text": "Kulların arasında ayrımın (hükmün) olacağı gün için (ertelenmiştir). Böylece haklı olan haksız olandan ve mutlu olan bedbaht olandan ayrılarak ortaya çıkacaktır.",
    "ayah": 13,
    "surah": 77
  },
  {
    "text": "-Ey Peygamber!- Hüküm gününün ne olduğunu sana ne öğretti?",
    "ayah": 14,
    "surah": 77
  },
  {
    "text": "O gün; helak, azap ve hüsran peygamberlerinin Allah’ın katından getirdiklerini yalanlayan o inkârcıların üzerine olsun!",
    "ayah": 15,
    "surah": 77
  },
  {
    "text": "Biz, Allah'a karşı inkârcı oldukları ve resulleri yalanladıkları zaman geçmiş ümmetleri helak etmedik mi?",
    "ayah": 16,
    "surah": 77
  },
  {
    "text": "Ardından, sonradan gelenleri de o inkârcılara katacağız ve onları helak ettiğimiz gibi onları da helak edeceğiz.",
    "ayah": 17,
    "surah": 77
  },
  {
    "text": "Muhammed -sallallahu aleyhi ve sellem-'in getirdiklerini yalanlayan mücrim kimseleri, o ümmetlerin helak edildiği gibi helak edeceğiz.",
    "ayah": 18,
    "surah": 77
  },
  {
    "text": "O gün; helak, azap ve hüsran Yüce Allah’ın günahkârları cezalandırma vaadini yalanlayanların üzerine olsun!",
    "ayah": 19,
    "surah": 77
  },
  {
    "text": "Ey insanlar! Sizleri meni damlası olan değersiz azıcık bir sudan yaratmadık mı?",
    "ayah": 20,
    "surah": 77
  },
  {
    "text": "Bu değersiz suyu korunaklı bir yer olan kadının rahmine yerleştirmedik mi?",
    "ayah": 21,
    "surah": 77
  },
  {
    "text": "Bilinen bir süre olan hamilelik dönemine kadar.",
    "ayah": 22,
    "surah": 77
  },
  {
    "text": "Biz; doğan çocuğun vasıflarını, boyunu, rengini ve bunlar dışındaki her şeyi takdir ettik. Biz bütün bunları ne güzel takdir ederiz.",
    "ayah": 23,
    "surah": 77
  },
  {
    "text": "O gün; helak, azap ve hüsran Allah’ın kudretini yalanlayanların üzerine olsun!",
    "ayah": 24,
    "surah": 77
  },
  {
    "text": "Biz, yeryüzünü tüm insanları içine alacak bir şekilde yaratmadık mı?",
    "ayah": 25,
    "surah": 77
  },
  {
    "text": "Yeryüzü, üzerinde hayat süren insanları ve toprağa gömülen ölüleri kapsamaktadır.",
    "ayah": 26,
    "surah": 77
  },
  {
    "text": "-Ey insanlar!- Yeryüzünün sarsılmasını önleyen yüksek sabit dağlar yarattık ve sizlere tatlı su verdik. Bunları yaratan sizleri tekrar diriltmekten aciz değildir.",
    "ayah": 27,
    "surah": 77
  },
  {
    "text": "O gün; helak, azap ve hüsran Allah’ın onlara verdiği nimetleri yalanlayanların üzerine olsun!",
    "ayah": 28,
    "surah": 77
  },
  {
    "text": "Peygamberlerinin getirmiş olduklarını yalanlayanlara şöyle denir: \"-Ey yalanlayanlar!- Yalanlayıp durduğunuz azaba girin bakalım!''",
    "ayah": 29,
    "surah": 77
  },
  {
    "text": "Üç kola ayrılmış ateşin dumanının gölgesine doğru yürüyün bakalım!",
    "ayah": 30,
    "surah": 77
  },
  {
    "text": "Orada gölge soğuk değildir. O gölge, ateşin alevinin ve sıcaklığının size ulaşmasını engellemez.",
    "ayah": 31,
    "surah": 77
  },
  {
    "text": "Ateş, kıvılcımlar savurur ve onun her bir kıvılcımının büyüklüğü sanki bir saray kadardır.",
    "ayah": 32,
    "surah": 77
  },
  {
    "text": "Savurduğu kıvılcımlar karanlık ve büyüklük olarak sanki kara develer gibidir.",
    "ayah": 33,
    "surah": 77
  },
  {
    "text": "O gün helak, azap ve hüsran Allah’ın azabını yalanlayanların üzerine olsun!",
    "ayah": 34,
    "surah": 77
  },
  {
    "text": "Kendilerine izin de verilmez ki özür bildirsinler.",
    "ayah": 35,
    "surah": 77
  },
  {
    "text": "Onların küfürleri ve kötülüklerinden ötürü Rablerinden özür dilemelerine dahi izin verilmez ki, O'ndan özür dileyebilsinler.",
    "ayah": 36,
    "surah": 77
  },
  {
    "text": "O gün; helak, azap ve hüsran o gün hakkındaki haberleri yalanlayanların üzerine olsun!",
    "ayah": 37,
    "surah": 77
  },
  {
    "text": "İşte bu, kulların arasının birbirinden ayrılacağı gündür. Sizleri ve geçmiş ümmetleri bir alanda toplarız.",
    "ayah": 38,
    "surah": 77
  },
  {
    "text": "Eğer Allah’ın azabından kurtulmak için kurnazca başvuracağınız bir hileniz varsa, durmayın hile yapın!",
    "ayah": 39,
    "surah": 77
  },
  {
    "text": "O gün; helak, azap ve hüsran ayrım/hüküm gününü yalanlayanların üzerine olsun!",
    "ayah": 40,
    "surah": 77
  },
  {
    "text": "Şüphesiz emirlerini yerine getirip yasaklarından sakınmak suretiyle Rablerinden korkan kimseler cennet ağaçlarının yapraklarının geniş gölgeliklerinde ve akan tatlı su pınarlarında olacaklardır.",
    "ayah": 41,
    "surah": 77
  },
  {
    "text": "Ve de yemeyi arzuladıkları meyvelerin arasındadırlar.",
    "ayah": 42,
    "surah": 77
  },
  {
    "text": "Onlara şöyle denir: “Dünyada yapmış olduğunuz salih ameller sebebi ile, tertemiz yiyeceklerden yiyin ve içinde rahatsız edici bir şey bulunmayan içeceklerden afiyetle için.''",
    "ayah": 43,
    "surah": 77
  },
  {
    "text": "Muhakkak biz, sizi ödüllendirdiğimiz bu mükâfatın aynısıyla, amellerinde ihsan sahibi olan kimseleri de ödüllendireceğiz.",
    "ayah": 44,
    "surah": 77
  },
  {
    "text": "O gün helak, azap ve hüsran; Allah’ın takva sahipleri için hazırladıklarını yalanlayanların üzerine olsun!",
    "ayah": 45,
    "surah": 77
  },
  {
    "text": "Yalanlayanlara da şöyle denir: “Sizler de yiyin ve az bir süre dünya hayatının lezzetlerinden faydalanın bakalım. Kuşkusuz siz, Allah’a karşı olan inkârınız ve resullerini yalanlamanız sebebiyle günahkâr kimselersiniz.''",
    "ayah": 46,
    "surah": 77
  },
  {
    "text": "O gün helak, azap ve hüsran; hesap günü kendilerine verilecek cezaları yalanlayanların üzerine olsun!",
    "ayah": 47,
    "surah": 77
  },
  {
    "text": "O yalanlayanlara; \"Allah için namaz kılınız!” denildiği zaman, O'nun için namaz kılmazlardı.",
    "ayah": 48,
    "surah": 77
  },
  {
    "text": "O gün helak, azap ve hüsran; peygamberlerinin Allah’ın katından getirdiklerini yalanlayan o inkârcıların üzerine olsun!",
    "ayah": 49,
    "surah": 77
  },
  {
    "text": "Onlar, Rablerinden indirilmiş olan bu Kur’an’a iman etmeyeceklerse, ondan başka hangi söze iman edecekler?",
    "ayah": 50,
    "surah": 77
  }
]
