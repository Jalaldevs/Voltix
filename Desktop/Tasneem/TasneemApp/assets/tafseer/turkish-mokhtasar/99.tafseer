[
  {
    "text": "Yeryüzü, kıyamet günü meydana gelecek şiddetli bir sarsıntıyla hareket ettiğinde.",
    "ayah": 1,
    "surah": 99
  },
  {
    "text": "Ve yeryüzü, içinde bulunan ölüleri ve bunun dışındaki şeyleri tekrar çıkardığı zaman.",
    "ayah": 2,
    "surah": 99
  },
  {
    "text": "İnsanoğlu şaşkınlık içinde şöyle der: “Yeryüzünün bu hali de nedir, sarsılıp çalkalanıyor?",
    "ayah": 3,
    "surah": 99
  },
  {
    "text": "O büyük gün, yeryüzü üzerinde hayır ve şer olarak neler yapıldığını haber verecektir.",
    "ayah": 4,
    "surah": 99
  },
  {
    "text": "Çünkü Allah Teâlâ ona bildirmiş ve ona bunu yapmayı emretmiştir.",
    "ayah": 5,
    "surah": 99
  },
  {
    "text": "İnsanlar, yeryüzünün sarsılacağı o büyük gün dünyada yapmış oldukları amellerini görmek için hesaba çekildikleri yerden bölük bölük çıkacaklar.",
    "ayah": 6,
    "surah": 99
  },
  {
    "text": "Kim, küçük bir karınca ağırlığınca hayırlı ve iyi bir amel yapmışsa, onu önünde görecektir.",
    "ayah": 7,
    "surah": 99
  },
  {
    "text": "Kim de küçük bir karınca ağırlığınca kötü bir amel işlemişse, aynı şekilde onu da görecektir.",
    "ayah": 8,
    "surah": 99
  }
]
