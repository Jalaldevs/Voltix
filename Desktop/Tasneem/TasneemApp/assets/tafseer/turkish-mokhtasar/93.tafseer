[
  {
    "text": "Yüce Allah, gündüzün ilk vaktine yemin etmiştir.",
    "ayah": 1,
    "surah": 93
  },
  {
    "text": "Ve karanlığı bürüyüp, insanların hareketleri kesildiğinde geceye yemin etmiştir.",
    "ayah": 2,
    "surah": 93
  },
  {
    "text": "-Ey Peygamber!- Vahiy bir süre kesildiğinde müşriklerin dediği gibi, Rabbin seni ne terk etti ve ne de senden nefret etti.",
    "ayah": 3,
    "surah": 93
  },
  {
    "text": "Ahiret yurdu, içinde bulunan kesintisiz kalıcı nimetlerden ötürü senin için dünya hayatından daha hayırlıdır.",
    "ayah": 4,
    "surah": 93
  },
  {
    "text": "Yüce Allah sana ve ümmetine verdiklerinden razı olana kadar sana ve ümmetine büyük mükâfatlardan verecek.",
    "ayah": 5,
    "surah": 93
  },
  {
    "text": "Seni, küçükken baban ölmüş bir halde buldu ve önce sana merhamet eden deden Abdülmuttalib’i, ardından amcan Ebu Talib’i sana sığınak kıldı.",
    "ayah": 6,
    "surah": 93
  },
  {
    "text": "Seni, kitabın ve imanın ne olduğunu bilmez bir halde buldu da, sana bunlardan bilmediklerini öğretti.",
    "ayah": 7,
    "surah": 93
  },
  {
    "text": "Seni fakir bir halde buldu ve seni zengin kıldı.",
    "ayah": 8,
    "surah": 93
  },
  {
    "text": "Küçük yaşta babasını kaybetmiş kimselere kötü muamele etme ve onları küçümseme.",
    "ayah": 9,
    "surah": 93
  },
  {
    "text": "İhtiyaç sahibi olan dilenciyi de azarlama.",
    "ayah": 10,
    "surah": 93
  },
  {
    "text": "Allah’ın senin üzerine olan nimetlerine şükret ve bunlardan bahset.",
    "ayah": 11,
    "surah": 93
  }
]
