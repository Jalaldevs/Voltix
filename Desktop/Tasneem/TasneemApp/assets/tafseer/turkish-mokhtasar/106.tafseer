[
  {
    "text": "Kureyş'in güvenlik ve esenliği için.",
    "ayah": 1,
    "surah": 106
  },
  {
    "text": "Kışın Yemen’e ve yazın da Şam'a olan güvenli yolculukları için.",
    "ayah": 2,
    "surah": 106
  },
  {
    "text": "Onlara bu yolculuğu kolaylaştıran, Beytü'l-harâm'ın (Kâbe) Rabbi olan bir tek Allah'a ibadet etsinler, O'na hiç kimseyi ortak koşmasınlar.",
    "ayah": 3,
    "surah": 106
  },
  {
    "text": "Onları açken besleyen ve Araplar'ın kalbine yerleştirdiği Harem’i (Kâbe'yi) ve ahalisini tazim etme hissiyle korkudan emin kılan.",
    "ayah": 4,
    "surah": 106
  }
]
