[
  {
    "text": "Ngươi hãy nói - hỡi Thiên Sứ -: Bề tôi cầu xin sự che chở và cứu rỗi từ nơi Thượng Đế của bình minh.",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "Tránh khỏi tất cả mọi điều xấu mà Ngài đã tạo hóa.",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "Và tránh khỏi mọi điều xấu trong đêm tối từ động vật và trộm cướp.",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "Tránh khỏi mọi điều hãm hại của các bùa phép và ma thuật được thổi vào trong những cái gút thắt.",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "Khỏi những sự ganh ghét và hãm hại của người đời khi được Allah ban cho những ân huệ.",
    "ayah": 5,
    "surah": 113
  }
]
