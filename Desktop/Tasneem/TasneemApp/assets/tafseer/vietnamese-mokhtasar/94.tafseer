[
  {
    "text": "TA (Allah) đã mở rộng tấm lòng của Ngươi - Thiên Sứ Muhammad - khiến cho Ngươi yêu thích việc đón nhận lời mặc khải",
    "ayah": 1,
    "surah": 94
  },
  {
    "text": "TA (Allah) đã tha thứ tất cả tội lỗi trước đây cho Ngươi - Thiên Sứ Muhammad -, và loại bỏ khỏi Ngươi gánh nặng của những ngày đã sống trong thời tiền Islam",
    "ayah": 2,
    "surah": 94
  },
  {
    "text": "Điều đã đeo bám Ngươi khiến lưng Ngươi sắp bị gãy.",
    "ayah": 3,
    "surah": 94
  },
  {
    "text": "Và TA đã đưa Ngươi lên cao với danh tiếng và địa vị của Ngươi qua lời Azdan, qua lời Iqamah và qua các điều khác.",
    "ayah": 4,
    "surah": 94
  },
  {
    "text": "Quả thật, sự khó khăn, cơ cực luôn đồng hành cùng sự dễ dàng, rộng mở và lối thoát.",
    "ayah": 5,
    "surah": 94
  },
  {
    "text": "Quả thật, sự khó khăn, cơ cực luôn đồng hành cùng sự dễ dàng, rộng mở và lối thoát. Khi Ngươi biết được điều đó thì Ngươi không còn hoang mang trước việc bị dân chúng của mình cấm cản Ngươi kêu gọi nhân loại đến với Allah.",
    "ayah": 6,
    "surah": 94
  },
  {
    "text": "Cho nên, khi nào Ngươi hoàn thành công việc thì hãy năng nổ hành đạo thờ phượng Thượng Đế của Ngươi Ngươi.",
    "ayah": 7,
    "surah": 94
  },
  {
    "text": "Hãy hướng tấm lòng và khao khát của Người đến Allah duy nhất.",
    "ayah": 8,
    "surah": 94
  }
]
