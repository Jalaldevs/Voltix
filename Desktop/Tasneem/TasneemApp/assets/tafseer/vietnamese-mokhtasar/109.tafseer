[
  {
    "text": "Hãy nói - hỡi Thiên Sứ -: Này hỡi những kẻ phủ nhận Allah!",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "Ta không thờ các pho tượng và các thần linh ngụy tạo mà các ngươi đang thờ phượng, không hiện tại và cũng không tương lai.",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "Và các ngươi cũng không thờ phượng Thượng Đế mà Ta thờ phượng, đó là Allah.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "Và từ nào đến giờ Ta chưa từng thờ phượng các pho tượng cũng như các thần linh ngụy tạo mà các ngươi đã thờ phượng.",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "Và các ngươi cũng không thờ phượng Thượng Đế mà Ta thờ phượng, đó là Allah.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "Các người có tôn giáo mà các người đã sáng tạo, còn Ta có tôn giáo mà Allah đã thiên khải cho Ta.",
    "ayah": 6,
    "surah": 109
  }
]
