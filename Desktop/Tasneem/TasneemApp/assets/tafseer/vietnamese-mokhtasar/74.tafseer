[
  {
    "text": "Hỡi người đang cuộn mình trong chiếc áo của y (tức Thiên Sứ Muhammad)!",
    "ayah": 1,
    "surah": 74
  },
  {
    "text": "Ngươi hãy đứng lên và cảnh báo nhân loại về sự trừng phạt của Allah.",
    "ayah": 2,
    "surah": 74
  },
  {
    "text": "Và Ngươi hãy tôn vinh Thượng Đế của Ngươi.",
    "ayah": 3,
    "surah": 74
  },
  {
    "text": "Và Ngươi hãy tẩy sạch bản thân Ngươi khỏi tội lỗi và tẩy sạch y phục của Ngươi khỏi những vết bẩn.",
    "ayah": 4,
    "surah": 74
  },
  {
    "text": "Và Ngươi hãy tránh xa việc thờ phượng các bục tượng.",
    "ayah": 5,
    "surah": 74
  },
  {
    "text": "Và Ngươi chớ mong Thượng Đế của Ngươi trả ơn cho việc Ngươi làm nhiều việc thiện tốt.",
    "ayah": 6,
    "surah": 74
  },
  {
    "text": "Ngươi hãy kiên nhẫn chịu đựng vì Allah trước những trở ngại và khó khăn.",
    "ayah": 7,
    "surah": 74
  },
  {
    "text": "Khi tiếng Còi thứ hai được hụ lên - tiếng Còi cho sự Phục Sinh.",
    "ayah": 8,
    "surah": 74
  },
  {
    "text": "Đó sẽ là Ngày khắc nghiệt.",
    "ayah": 9,
    "surah": 74
  },
  {
    "text": "Đối với những kẻ vô đức tin nơi Allah và các vị Thiên Sứ của Ngài chắc chắn sẽ không dễ dàng trong Ngày hôm đó.",
    "ayah": 10,
    "surah": 74
  },
  {
    "text": "Hỡi Thiên Sứ Muhammad, Ngươi cứ để mặc TA (Allah) với kẻ mà TA đã tạo y ra trong đơn độc khi sinh ra tức không tiền bạc và không con cái - ý nói ông Al-Waleed bin Al-Mughairah).",
    "ayah": 11,
    "surah": 74
  },
  {
    "text": "Và sau đó TA ban cho y nhiều tiền của.",
    "ayah": 12,
    "surah": 74
  },
  {
    "text": "Và TA đã ban cho y con cái đầy đàn luôn bên cạnh y bì khối tài sản khối tài sản khổng lồ của y.",
    "ayah": 13,
    "surah": 74
  },
  {
    "text": "Và TA đã làm cho y dễ dàng trong cuộc sống, bổng lộc và con cái.",
    "ayah": 14,
    "surah": 74
  },
  {
    "text": "Rồi với sự vô đức tin của y, y còn muốn TA ban thêm cho y nhiều hơn sau khi TA đã ban cho y tất cả những thứ đó.",
    "ayah": 15,
    "surah": 74
  },
  {
    "text": "Sự việc sẽ không như y đã suy nghĩ và mong muốn, quả thật y đã chống đối và phủ nhận các Lời Mặc Khải của TA đã ban xuống cho vị Thiên Sứ của TA.",
    "ayah": 16,
    "surah": 74
  },
  {
    "text": "TA sẽ gây khó khăn cho y từ sự trừng phạt mà y không có khả năng chịu đựng.",
    "ayah": 17,
    "surah": 74
  },
  {
    "text": "Quả thật, kẻ vô đức tin này, kẻ mà đã được ban cho các ân huệ đó suy tính để nói về Qur'an nhằm vô hiệu Nó và y đã mưu đồ trong bản thân y.",
    "ayah": 18,
    "surah": 74
  },
  {
    "text": "Do đó, y chỉ bị nguyền rủa và bị trừng phạt dù có mưu đồ và tính toán ra sao.",
    "ayah": 19,
    "surah": 74
  },
  {
    "text": "Rồi y chỉ bị nguyền rủa và bị trừng phạt dù có mưu đồ và tính toán ra sao.",
    "ayah": 20,
    "surah": 74
  },
  {
    "text": "Rôi y quay lại nhìn để xem xét những gì y nói.",
    "ayah": 21,
    "surah": 74
  },
  {
    "text": "Rồi y cau mày và nhăn mặt khi không tìm thấy điều nào để phỉ báng Qur'an.",
    "ayah": 22,
    "surah": 74
  },
  {
    "text": "Rồi y quay lưng với đức tin Iman và ngạo mạn không chịu theo Thiên Sứ Muhammad.",
    "ayah": 23,
    "surah": 74
  },
  {
    "text": "Y nói: Qur'an được Muhammad mang đến không phải là lời phán của Allah mà thật ra chỉ là bùa mê hoặc được truyền lại từ những người trước.",
    "ayah": 24,
    "surah": 74
  },
  {
    "text": "Y bảo: Qur'an không phải là lời phán của Allah mà thật ra chỉ là lời của con người.",
    "ayah": 25,
    "surah": 74
  },
  {
    "text": "TA (Allah) sẽ đày kẻ bất tin này vào một tầng của Hỏa Ngục, đó là Saqar, để y nếm cái nóng của nó.",
    "ayah": 26,
    "surah": 74
  },
  {
    "text": "Hỡi Muhammad, Ngươi có biết Saqar là gì không?",
    "ayah": 27,
    "surah": 74
  },
  {
    "text": "Saqar là nơi mà lửa của nó sẽ không chừa và bỏ sót bất cứ thứ gì từ cơ thể của người bị trừng phạt trong đó, nó sẽ đốt cháy tất cả thịt và xương, rồi sau đó thịt và xương sẽ trở lại như cũ, sự trừng phạt cứ tiệp tục như thế.",
    "ayah": 28,
    "surah": 74
  },
  {
    "text": "Nó sẽ đốt cháy và làm biến dạng lớp da.",
    "ayah": 29,
    "surah": 74
  },
  {
    "text": "Có mười chín vị Thiên Thần cai quản tầng Saqar.",
    "ayah": 30,
    "surah": 74
  },
  {
    "text": "TA (Allah) đã không chọn bất cứ ai cai quản Hoả Ngục ngoại trừ Thiên Thần bởi con người hoàn toàn bất lực trước Họ. Và TA đã không chọn số lượng của họ như thế này ngoại trừ để thử thách những người vô đức tin nơi Allah để chúng nói những gì đã nói, theo đó TA tăng gấp đôi hình phạt đối với chúng; để người Do Thái được ban cho Tawrah (Kinh Cựu Ước) và người Thiên Chúa được ban cho Injil (Kinh Tân Ước) tin chắc chắn khi Qur'an được ban xuống để xác thực những điều trong hai Kinh Sách đó; để những người đã tin tưởng tăng thêm đức tin khi họ tương đồng với những người Kinh Sách; để xoá sạch sự hoài nghi trong lòng người Do Thái, Thiên Chúa và người có đức tin; và cũng để cho những người còn lưỡng lự về đức tin và người vô đức tin thốt lên: Allah muốn điều gì ở việc đưa ra con số kỳ quặc thế này?! Giống như Ngài muốn làm lầm lạc những kẻ phủ nhận số lượng này đồng thời hướng dẫn những người có đức tin nơi nó. Allah làm ai lầm lạc tùy ý Ngài và hướng dẫn ai tùy ý Ngài. Và không ai biết rõ số lượng quân lính của Ngài nhiều đến cỡ nào ngoại trừ một mình Ngài. Và Hoả Ngục là một sự nhắc nhở con người qua đó họ nhận thức rõ về sự vĩ đại của Allah, Đấng Hiển Vinh.",
    "ayah": 31,
    "surah": 74
  },
  {
    "text": "Thật sự không giống như lời mà một số kẻ thờ đa thần đã khẳng định rằng chúng đủ sức chống lại những vị cai quản Hỏa Ngục. Allah thề bởi mặt trăng.",
    "ayah": 32,
    "surah": 74
  },
  {
    "text": "Allah thề bởi ban đêm khi nó rời đi.",
    "ayah": 33,
    "surah": 74
  },
  {
    "text": "Allah thề bởi bình minh sáng tỏ.",
    "ayah": 34,
    "surah": 74
  },
  {
    "text": "Quả thật, Hỏa Ngục là một đại họa.",
    "ayah": 35,
    "surah": 74
  },
  {
    "text": "Một sự cảnh báo đáng sợ đến loài người.",
    "ayah": 36,
    "surah": 74
  },
  {
    "text": "Hỡi nhân loại, để ai trong các ngươi muốn tiên phong bởi đức tin nơi Allah và làm viện thiện tốt hoặc lùi về phía sau bởi sự vô đức tin và bất tuân Allah.",
    "ayah": 37,
    "surah": 74
  },
  {
    "text": "Mỗi con người sẽ bị nhốt lại trong những việc làm xấu của họ, cho dù họ có làm điều tốt đi chăng nữa thì cũng không thoát khỏi được sự trừng phạt ở Đời Sau.",
    "ayah": 38,
    "surah": 74
  },
  {
    "text": "Ngoại trừ những người có đức tin mới không bị bắt tội bởi những tội lỗi của họ. Chỉ có họ mới được xí xóa tội lỗi bởi những việc làm thiện tốt của họ.",
    "ayah": 39,
    "surah": 74
  },
  {
    "text": "Vào Ngày Phán Xét, ở trong các Ngôi Vườn Thiên Đàng, họ hỏi nhau.",
    "ayah": 40,
    "surah": 74
  },
  {
    "text": "Những người ở trong các Ngôi Vườn Thiên Đàng hỏi nhau về những người vô đức tin, những người đã hủy diệt bản thân họ bởi các việc làm bất tuân của họ.",
    "ayah": 41,
    "surah": 74
  },
  {
    "text": "Những người trong Thiên Đàng hỏi những người trong Hỏa Ngục: điều gì đã đưa các người vào Hỏa Ngục vậy?",
    "ayah": 42,
    "surah": 74
  },
  {
    "text": "Những kẻ vô đức tin trả lời: Bởi vì chúng tôi đã không duy trì lễ nguyện Salah bắt buộc trên cuộc sống trần gian.",
    "ayah": 43,
    "surah": 74
  },
  {
    "text": "Và bởi vì chúng tôi đã không nuôi ăn những người nghèo từ bổng lộc mà Allah đã ban cho chúng tôi.",
    "ayah": 44,
    "surah": 74
  },
  {
    "text": "Và bởi vì chúng tôi đã thường ở cùng với những kẻ sai quấy và chúng tôi đã thường cùng những kẻ lầm lạc nói chuyện tầm phào vô bổ.",
    "ayah": 45,
    "surah": 74
  },
  {
    "text": "Và chúng tôi luôn không tin nơi Ngày Thưởng Phạt.",
    "ayah": 46,
    "surah": 74
  },
  {
    "text": "Chúng tôi cứ vô đức và bất tuân cho tới khi cái chết đến với chúng tôi, và chúng tôi đã không còn cơ hội quay đầu sám hối.",
    "ayah": 47,
    "surah": 74
  },
  {
    "text": "Vào Ngày Phán Xét, sẽ không có một sự can thiệp nào có thể giúp được họ, dù đó là sự can thiệp của các Thiên thần, các vị Nabi hay của những người ngoan đạo đi chăng nữa; bởi lẽ điều kiện được chấp nhận sự can thiệp là sự hài lòng của Allah.",
    "ayah": 48,
    "surah": 74
  },
  {
    "text": "Vậy điều gì đã làm cho những kẻ thờ đa thần này quay lưng với Qur'an kia chứ?",
    "ayah": 49,
    "surah": 74
  },
  {
    "text": "Chúng quay lưng bỏ chạy khỏi Qur'an giống như những con ngựa vằn khiếp đảm.",
    "ayah": 50,
    "surah": 74
  },
  {
    "text": "Tháo chạy trước con sư tử vì khiếp sợ.",
    "ayah": 51,
    "surah": 74
  },
  {
    "text": "Không, mỗi tên trong những kẻ thờ đa thần này muốn ngay trên đầu của chúng có từng tờ Kinh được trải ra thông tin cho chúng biết rằng Muhammad là Thiên Sứ được Alalh phái đến. Đó không phải là do ít bằng chứng hoặc thiếu cơ sở để chứng mình mà thật ra chỉ vì chúng tự cao và ngạo mạn.",
    "ayah": 52,
    "surah": 74
  },
  {
    "text": "Sự việc không phải như thế, nguyên nhân là bởi vì chúng ngoan cố trong sự lầm lạc, bởi vì chúng không tin có sự trừng phạt của Ngày Sau, nên chúng cứ ở trên sự vô đức tin của chúng.",
    "ayah": 53,
    "surah": 74
  },
  {
    "text": "Không, quả thật Qur'an này đây là một sự khuyên răn và nhắc nhở.",
    "ayah": 54,
    "surah": 74
  },
  {
    "text": "Bởi thế, ai muốn thì hãy đọc Qur'an và ghi nhớ những lời khuyên răn và nhắc nhở của Nó.",
    "ayah": 55,
    "surah": 74
  },
  {
    "text": "Và không ai được khuyên răn và nhắc nhở từ Qur'an ngoài trừ những ai mà Allah muốn, Ngài là Đấng phải được kính sợ để thực hiện theo mệnh lệnh của Ngài và tránh xa những điều Ngài nghiêm cấm, và Ngài là Đấng tha thứ các tội lỗi cho đám bề tôi của Ngài khi họ thành tâm quay về sám hối với Ngài.",
    "ayah": 56,
    "surah": 74
  }
]
