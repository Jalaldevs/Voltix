[
  {
    "text": "Allah thề bởi ban đêm khi nó bao trùm trời đất bằng bóng tối của nó.",
    "ayah": 1,
    "surah": 92
  },
  {
    "text": "Ngài thề bởi ban ngày khi nó xuất hiện.",
    "ayah": 2,
    "surah": 92
  },
  {
    "text": "Ngài thề bởi sự tạo hóa ra hai giới đực cái.",
    "ayah": 3,
    "surah": 92
  },
  {
    "text": "Quả thật, việc làm của các ngươi - hỡi con người - khác nhau, có người ngoan đạo sẽ được vào Thiên Đàng và có người làm tội lỗi sẽ bị vào Hỏa Ngục.",
    "ayah": 4,
    "surah": 92
  },
  {
    "text": "Đối với ai cho đi thứ bắt buộc như Zakah, cấp dưỡng, chuộc tội và biết kính sợ mà tránh điều bị Allah cấm.",
    "ayah": 5,
    "surah": 92
  },
  {
    "text": "Và luôn tin tưởng những gì được Allah hứa hẹn ở Đời Sau.",
    "ayah": 6,
    "surah": 92
  },
  {
    "text": "TA sẽ tạo điều kiện dễ dàng cho y trong việc hành đạo và làm việc thiện cũng như chi dùng tiền của cho con đường của Allah.",
    "ayah": 7,
    "surah": 92
  },
  {
    "text": "Đối với ai keo kiệt, ôm lấy tài sản không chịu chi dùng cho những điều bắt buộc đối với bản thân y và tự cho mình đã đầy đủ không cần xin Allah bất cứ gì.",
    "ayah": 8,
    "surah": 92
  },
  {
    "text": "Và bác bỏ những gì được Allah hứa hẹn ở Đời Sau và phần thưởng dành cho tài sản chi dùng vì con đường của Allah.",
    "ayah": 9,
    "surah": 92
  },
  {
    "text": "TA sẽ tạo điều kiện thuận lợi giúp y dễ dàng làm điều xấu những lại rất khó khăn khi làm việc thiện.",
    "ayah": 10,
    "surah": 92
  },
  {
    "text": "Và vào Ngày đó, tài sản và của cải của họ chẳng giúp ích được gì cho họ khi họ bị trừng phạt trong Hỏa Ngục.",
    "ayah": 11,
    "surah": 92
  },
  {
    "text": "Quả thật, bổn phận của TA trình bày rõ ràng con đường Chân Lý và con đường ngụy tạo và lệch lạc.",
    "ayah": 12,
    "surah": 92
  },
  {
    "text": "Chính Ngài mới là Đấng có quyền chi phối thế giới trần gian và Đời Sau. Ngoài Ngài không một ai có thẩm quyền đó cả.",
    "ayah": 13,
    "surah": 92
  },
  {
    "text": "Ta cảnh báo các ngươi - hỡi nhân loại - về ngọn lửa cháy dữ dội dành cho những ai nghịch lại Allah.",
    "ayah": 14,
    "surah": 92
  },
  {
    "text": "Trong Hỏa Ngục, không ai bị đày vào đó ngoài những kẻ bất hạnh, đó là nhóm người vô đức tin.",
    "ayah": 15,
    "surah": 92
  },
  {
    "text": "Đó là những kẻ phủ nhận Thiên Sứ và không phục tùng mệnh lệnh của Allah.",
    "ayah": 16,
    "surah": 92
  },
  {
    "text": "Những ai kính sợ Allah sẽ được Ngài cứu thoát khỏi Hỏa Ngục điển hình như Abu Bakr.",
    "ayah": 17,
    "surah": 92
  },
  {
    "text": "Người đã chi dùng tài sản cho con đường chính nghĩa của Allah để được xóa tội.",
    "ayah": 18,
    "surah": 92
  },
  {
    "text": "Và y bố thí cho người nhưng không mong được bất cứ ai trả ơn mình.",
    "ayah": 19,
    "surah": 92
  },
  {
    "text": "Với tài sản cho đi y chỉ mong được Allah Tối Cao ban thưởng ở Đời Sau.",
    "ayah": 20,
    "surah": 92
  },
  {
    "text": "Đo dó, Allah sẽ làm y toại nguyện hài lòng với những phần thưởng Ngài ban cho.",
    "ayah": 21,
    "surah": 92
  }
]
