[
  {
    "text": "Ngươi có biết ai là những kẻ phủ nhận sự Phục sinh và thưởng phạt không?",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "Đó là những kẻ đối xử tệ bạc với trẻ mồ côi, không thực hiện đúng quyền lợi của trẻ mồ côi.",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "Và những kẻ đã không thúc bản thân mình hay người khác nuôi ăn người túng thiếu.",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "Những người hành lễ Salah đáng bị diệt vong và hình phạt là những người lơ là không chu đáo, không quan tâm đến giờ giấc đến nỗi hành lễ Salah ngoài giờ qui định",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "Những người hành lễ Salah đáng bị diệt vong và hình phạt là những người lơ là không chu đáo, không quan tâm đến giờ giấc đến nỗi hành lễ Salah ngoài giờ qui định",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "Những kẻ mà chúng chỉ muốn khoe cho thiên hạ nhìn thấy lễ nguyện Salah và việc làm thiện tốt của mình, chứ không hoàn toàn thành tâm vì Allah.",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "Và chúng thường không chịu giúp đỡ người khác mặc việc giúp đỡ không gây thiệt hại gì bản thân chúng.",
    "ayah": 7,
    "surah": 107
  }
]
