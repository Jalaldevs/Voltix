[
  {
    "text": "Những kẻ thờ đa thần Quraish đang hỏi nhau về điều gì sau khi Allah gởi Thiên Sứ (cầu xin sự bình an đến Người) của Ngài đến cho họ?!",
    "ayah": 1,
    "surah": 78
  },
  {
    "text": "Chúng đang hỏi nhau về nguồn tin vĩ đại, đó là Qur’an thiêng liêng thông điệp về sự Phục Sinh.",
    "ayah": 2,
    "surah": 78
  },
  {
    "text": "Qur'an là cái khiến họ bất đồng với nhau, họ mô tả Nó là bùa chú hoặc thơ ca hoặc ma thuật hoặc những mẫu chuyện cổ tích.",
    "ayah": 3,
    "surah": 78
  },
  {
    "text": "Không phải như những gì họ đã khẳng định. Rồi đây những kẻ phủ nhận Qur'an sẽ sớm biết hậu quả cho việc phủ nhận của mình.",
    "ayah": 4,
    "surah": 78
  },
  {
    "text": "Rồi đây chúng chắc chắn sẽ sớm biết điều đó.",
    "ayah": 5,
    "surah": 78
  },
  {
    "text": "Chẳng lẽ TA đã không làm cho trái đất bằng phẳng như một tấm thảm ư?",
    "ayah": 6,
    "surah": 78
  },
  {
    "text": "Và TA làm cho những quả núi như những cái trụ cột giữ cho mặt đất không bị lung lay và chấn động.",
    "ayah": 7,
    "surah": 78
  },
  {
    "text": "Và TA đã tạo các ngươi - hỡi con người - thành hai giới nam nữ.",
    "ayah": 8,
    "surah": 78
  },
  {
    "text": "Và TA đã làm giấc ngủ của các ngươi thành một sự nghỉ ngơi cho cơ thể các ngươi, giúp các ngươi duy trì sức khỏe và an nghỉ một cách yên bình.",
    "ayah": 9,
    "surah": 78
  },
  {
    "text": "Và TA đã tạo ra ban đêm như một tấm chăn đắp che phủ các ngươi tựa như quần áo che phần kín của các ngươi.",
    "ayah": 10,
    "surah": 78
  },
  {
    "text": "Và TA đã tạo ra ban ngày để các ngươi tản mát khắp nơi tìm thiên lộc và phúc lợi cho cuộc sống của các ngươi.",
    "ayah": 11,
    "surah": 78
  },
  {
    "text": "Và TA đã dựng bên trên các ngươi bảy tầng trời vững chắc, không bị nứt cũng không bị thủng một lỗ nào.",
    "ayah": 12,
    "surah": 78
  },
  {
    "text": "Và TA đã tạo ra mặt trời như một chiếc đèn mang lại ánh sáng cho các ngươi.",
    "ayah": 13,
    "surah": 78
  },
  {
    "text": "Và TA cho mưa xuống dồi dào từ những đám mây mưa.",
    "ayah": 14,
    "surah": 78
  },
  {
    "text": "Để TA làm mọc ra đủ loại trái hạt và đủ loại cây cối.",
    "ayah": 15,
    "surah": 78
  },
  {
    "text": "Và để TA cho mọc ra cây cối thành những khu vườn xanh tươi và đủ loại cho các ngươi.",
    "ayah": 16,
    "surah": 78
  },
  {
    "text": "Quả thật, Ngày Phân Loại giữa tạo vật là Ngày đã được ấn định không bao giờ được thay đổi.",
    "ayah": 17,
    "surah": 78
  },
  {
    "text": "Ngày đó, khi vị Thiên thần thổi tiếng còi lần hai thì toàn nhân loại lần lượt đứng dậy và đi thành từng đoàn, từng đoàn một.",
    "ayah": 18,
    "surah": 78
  },
  {
    "text": "Các tầng trời được mở ra, chúng trở thành những khe hở và khe nứt như những cánh cửa mở",
    "ayah": 19,
    "surah": 78
  },
  {
    "text": "Và những quả núi kiên cố và vững chắc bị dời đi một cách nhẹ nhàng tưởng chừng trước kia những quả núi đó chỉ là ảo ảnh không thực.",
    "ayah": 20,
    "surah": 78
  },
  {
    "text": "Quả thật, vào Ngày đó, Hỏa Ngục sẽ mai phục.",
    "ayah": 21,
    "surah": 78
  },
  {
    "text": "Dành cho tất cả những kẻ sai quấy và tội lỗi đến cư ngụ.",
    "ayah": 22,
    "surah": 78
  },
  {
    "text": "Tại đó, chúng sẽ ở trong đó đời đời không có ngày trở ra.",
    "ayah": 23,
    "surah": 78
  },
  {
    "text": "Chúng sẽ không tìm thấy được không khí mát lạnh để làm dịu cái nóng thiêu đốt thật dữ dội và càng không tìm được thức uống để giải cơn khát.",
    "ayah": 24,
    "surah": 78
  },
  {
    "text": "Họ sẽ không được cho ăn uống ngoài nước cực sôi và chất mủ hôi tanh chảy ra từ cư dân của Hỏa Ngục.",
    "ayah": 25,
    "surah": 78
  },
  {
    "text": "Đó là kết quả cho những hành động tội lỗi và phủ nhận đức tin của chúng trên thế gian.",
    "ayah": 26,
    "surah": 78
  },
  {
    "text": "Quả thật, trên thế gian trước kia, chúng đã không sợ cái Ngày bị Allah mang chúng ra thanh toán và xét xử này bao giờ, bởi chúng đã không tin vào sự Phục Sinh, giá như chúng biết sợ sự Phục Sinh thì chúng đã tin tưởng và đã ngoan đạo.",
    "ayah": 27,
    "surah": 78
  },
  {
    "text": "Chúng đã phủ nhận những Lời Mặc Khải mà TA đã thiên khải cho Thiên Sứ của TA.",
    "ayah": 28,
    "surah": 78
  },
  {
    "text": "Và tất cả mọi việc làm, mọi hành động đều được TA cho ghi chép vào quyển số một cách đầy đủ và chi tiết.",
    "ayah": 29,
    "surah": 78
  },
  {
    "text": "Do đó, các ngươi – những kẻ ngông cuồng – hãy mãi mãi nếm lấy hình phạt xứng đáng, TA sẽ không bao giờ thêm thắt gì cho các ngươi ngoài sự trừng phạt đau đớn.",
    "ayah": 30,
    "surah": 78
  },
  {
    "text": "Quả thật, những ai kính sợ Thượng Đế của họ bằng việc thực hiện các mệnh lệnh của Ngài và tránh xa các điều cấm của Ngài sẽ giành được thắng lợi, đó là được vào Thiên Đàng.",
    "ayah": 31,
    "surah": 78
  },
  {
    "text": "Với những ngôi vườn cây trái và vườn nho.",
    "ayah": 32,
    "surah": 78
  },
  {
    "text": "Với các trinh nữ đồng trang lứa làm bạn tình.",
    "ayah": 33,
    "surah": 78
  },
  {
    "text": "Với những ly rượu tràn đầy ngon tuyệt.",
    "ayah": 34,
    "surah": 78
  },
  {
    "text": "Trong Thiên Đàng, họ sẽ không còn nghe thấy lời nói sàm bậy hay những lời nói dối lừa gạt lẫn nhau nữa.",
    "ayah": 35,
    "surah": 78
  },
  {
    "text": "Tất cả là phần thưởng đầy đủ mà Allah dành cho những bề tôi ngoan đạo của Ngài.",
    "ayah": 36,
    "surah": 78
  },
  {
    "text": "Ngài là Thượng Đế của các tầng trời, trái đất và mọi vạn vật trong đó, Ngài luôn độ lượng đối với trần gian và Đời Sau, Ngài là Đấng nắm quyền thống trị toàn bộ trời đất, không ai được quyền đôi co ngoại trừ có sự cho phép của Ngài.",
    "ayah": 37,
    "surah": 78
  },
  {
    "text": "Vào Ngày Phán xét, Đại Thiên Thần Jibril và các Thiên thần khác đứng thành hàng ngũ, không ai được phép cầu xin ân xá cho ai ngoại trừ được Đấng Nhân Từ cho phép, và y chỉ nói toàn lời thật tựa như lời Tawhid.",
    "ayah": 38,
    "surah": 78
  },
  {
    "text": "Do đó, nếu ai muốn được cứu rỗi thì hãy chọn lấy con đường quay về với Thượng Đế của y bằng các việc làm ngoan đạo và đức hạnh.",
    "ayah": 39,
    "surah": 78
  },
  {
    "text": "Quả thật, TA đã cảnh báo các ngươi - hỡi con người - về sự trừng phạt đang rất gần, Ngày mà tất cả mọi người sẽ nhìn thấy tất cả việc làm của họ trên thế gian. Và những kẻ vô đức tin luôn khát khao được thoát khỏi hình phạt, họ sẽ nói: Ôi, ước gì mình được biến thành cát bụi giống như loài súc vật khi chúng được lệnh trong Ngày Tận Thế: Hãy trở thành cát bụi.",
    "ayah": 40,
    "surah": 78
  }
]
