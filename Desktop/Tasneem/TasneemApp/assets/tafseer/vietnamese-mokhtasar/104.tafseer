[
  {
    "text": "Những kẻ vu khống và nói xấu người khác sẽ bị nguyền rủa và sẽ bị trừng phạt.",
    "ayah": 1,
    "surah": 104
  },
  {
    "text": "Kẻ chỉ biết lo toan cho việc thu nhặt tiền tài và chỉ biết đếm tiền để xem được bao nhiêu rồi.",
    "ayah": 2,
    "surah": 104
  },
  {
    "text": "Y tưởng rằng bản thân y sẽ được tiền tài đảm bảo được sống mãi ở nơi trần gian, không phải bị chết.",
    "ayah": 3,
    "surah": 104
  },
  {
    "text": "Chắc chắn sẽ không như y đã tưởng. Chắc chắn y sẽ bị đày trong Hỏa Ngục, nó sẽ đập nát và bẻ gãy hết mọi thứ bị quẳng vào nó vì sự hung tợn của nó.",
    "ayah": 4,
    "surah": 104
  },
  {
    "text": "Điều gì cho Ngươi biết - hỡi Thiên Sứ - sự thật về Hutamah?",
    "ayah": 5,
    "surah": 104
  },
  {
    "text": "Đó là ngọn lửa của Allah được đốt cháy lên rất dữ dội.",
    "ayah": 6,
    "surah": 104
  },
  {
    "text": "Để thiêu đốt thân thể đến tận trái tim.",
    "ayah": 7,
    "surah": 104
  },
  {
    "text": "Lửa sẽ bao vây xung quanh chúng.",
    "ayah": 8,
    "surah": 104
  },
  {
    "text": "Và chúng sẽ bị nhốt bên trong các cột lửa không thể thoát ra được.",
    "ayah": 9,
    "surah": 104
  }
]
