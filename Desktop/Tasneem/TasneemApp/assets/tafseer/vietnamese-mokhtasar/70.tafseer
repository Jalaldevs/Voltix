[
  {
    "text": "Một số người trong số những người thờ đa thần đã đòi sự trừng phạt xảy đến với bản thân họ hoặc cộng đồng của họ. Đây là một sự nhạo báng vì không tin sự trừng phạt; và sự trừng phạt chắc chắn sẽ xảy ra vào Ngày Phán Xét.",
    "ayah": 1,
    "surah": 70
  },
  {
    "text": "Những kẻ vô đức tin sẽ không thể tránh khỏi sự trừng phạt này.",
    "ayah": 2,
    "surah": 70
  },
  {
    "text": "(Sự trừng phạt mà họ đòi hỏi) đến từ nơi Allah, Đấng sở hữu sự tối cao với các ân huệ và những phúc lành.",
    "ayah": 3,
    "surah": 70
  },
  {
    "text": "Các Thiên Thần cùng Ruh (Đại Thiên Thần Jibril) đi lên chầu Ngài (Allah) trong một Ngày mà thời gian của nó tương đương năm mươi ngàn năm (thời gian trên cõi trần).",
    "ayah": 4,
    "surah": 70
  },
  {
    "text": "Bởi thế, hỡi Thiên Sứ Muhammad, Ngươi hãy thực sự kiên nhẫn, chớ buồn lo cũng chớ than phiền.",
    "ayah": 5,
    "surah": 70
  },
  {
    "text": "Quả thật, chúng (những kẻ vô đức tin) thấy sự trừng phạt rất xa vời như là một điều không bao giờ xảy ra.",
    "ayah": 6,
    "surah": 70
  },
  {
    "text": "Nhưng TA (Allah) thì thấy sự trừng phạt gần xảy ra và chắc chắn sẽ xảy ra.",
    "ayah": 7,
    "surah": 70
  },
  {
    "text": "Ngày mà bầu trời sẽ giống như đồng, vàng hoặc những kim loại khác được nấu chảy.",
    "ayah": 8,
    "surah": 70
  },
  {
    "text": "Và những quả núi trở nên nhẹ giống như những sợi lông cừu dễ dàng thổi bay đi.",
    "ayah": 9,
    "surah": 70
  },
  {
    "text": "(Ngày Hôm Đó) sẽ không có một người thân quen nào hỏi thăm một người thân quen nào, không ai hỏi ai cả, tất cả đều chỉ bận tâm đến bản thân mình.",
    "ayah": 10,
    "surah": 70
  },
  {
    "text": "Vào Ngày Hôm Đó, tất cả mỗi con người đều nhìn thấy người thân quen của mình. Mặc dù vậy, không ai hỏi thăm ai trong hoàn cảnh đó. Họ chỉ quan tâm đến bản thân mình đến nỗi một người đáng bị vào Hỏa Ngục muốn dâng con cái thay tội cho mình để bản thân mình được thoát tội.",
    "ayah": 11,
    "surah": 70
  },
  {
    "text": "Y muốn dâng cả vợ và anh em của mình để thế mạng cho mình.",
    "ayah": 12,
    "surah": 70
  },
  {
    "text": "Y muốn dâng cả những người thân thuộc đã từng ủng hộ và giúp đỡ y trong hoạn nạn.",
    "ayah": 13,
    "surah": 70
  },
  {
    "text": "Y muốn dâng tất cả mọi thứ trên trái đất từ loài người, loài Jinn và sinh vật khác hầu để bản thân mình được an toàn khỏi sự trừng phạt nơi Hỏa Ngục.",
    "ayah": 14,
    "surah": 70
  },
  {
    "text": "Sự việc sẽ không như những kẻ tội lỗi mong muốn mà Lửa của Hỏa Ngục sẽ tràn ngập thiêu đốt họ.",
    "ayah": 15,
    "surah": 70
  },
  {
    "text": "Sức nóng của lửa Hỏa Ngục làm tróc da đầu.",
    "ayah": 16,
    "surah": 70
  },
  {
    "text": "Lửa Hỏa Ngục sẽ gọi những ai quay lưng với Chân Lý, những ai tránh xa, không tin Nó và không làm theo.",
    "ayah": 17,
    "surah": 70
  },
  {
    "text": "Và những kẻ tom góp tài sản của cải nhưng không chịu chi dùng cho con đường chính nghĩa của Allah.",
    "ayah": 18,
    "surah": 70
  },
  {
    "text": "Quả thật, con người được tạo với bản chất luôn muốn giữ bên mình không muốn chi ra.",
    "ayah": 19,
    "surah": 70
  },
  {
    "text": "Khi gặp điều dữ từ bệnh tật và nghèo khó thì thường ít kiên nhẫn, hay oán than.",
    "ayah": 20,
    "surah": 70
  },
  {
    "text": "Và khi gặp được niềm vui từ sự giàu có và dồi dào của cải thì trở nên keo kiệt, không muốn chi dùng cho chính nghĩa của Allah.",
    "ayah": 21,
    "surah": 70
  },
  {
    "text": "Ngoại trừ những người thực hiện bổn phận lễ nguyện Salah, họ sẽ an toàn khỏi những thuộc tính đáng trách đó.",
    "ayah": 22,
    "surah": 70
  },
  {
    "text": "Những người mà họ luôn gìn giữ bổn phận lễ nguyện Salah của mình, họ không vì những việc khác mà trễ nải lễ nguyện Salah của họ, họ luôn thực hiện nó trong thời gian được quy định.",
    "ayah": 23,
    "surah": 70
  },
  {
    "text": "Những người mà họ luôn chừa một phần tài sản bắt buộc từ nguồn tài sản của mình.",
    "ayah": 24,
    "surah": 70
  },
  {
    "text": "Họ đưa phần tài sản mà họ trích ra đó cho những người nghèo đói và thiếu thốn cả người xin và người không xin họ.",
    "ayah": 25,
    "surah": 70
  },
  {
    "text": "Những người mà họ tin nơi Ngày Phán Xét, Ngày mà Allah sẽ thưởng hoặc phạt tất cả mỗi người một cách thích đáng tùy theo việc làm của họ.",
    "ayah": 26,
    "surah": 70
  },
  {
    "text": "Những người mà họ khiếp sợ sự trừng phạt của Thượng Đế của họ, họ cố gắng làm những điều tốt đẹp và ngoan đạo để tránh (sự phẫn nộ của Ngài).",
    "ayah": 27,
    "surah": 70
  },
  {
    "text": "Quả thật sự trừng phạt của Thượng Đế của họ rất khủng khiếp và đáng sợ mà người có ý thức không nên cảm thấy an toàn trước nó.",
    "ayah": 28,
    "surah": 70
  },
  {
    "text": "Những người mà họ che đậy phần kín của họ và giữ cho nó không phạm Zina (tình dục ngoài hôn nhân).",
    "ayah": 29,
    "surah": 70
  },
  {
    "text": "Họ không bị bắt tội trong hành vi nhục dục của mình với các bà vợ hoặc với các nữ nô lệ nằm dưới quyền của họ.",
    "ayah": 30,
    "surah": 70
  },
  {
    "text": "Ai có hành vi nhục dục với những ai khác ngoài vợ và những nữ nô lệ dưới quyền của họ thì họ là những kẻ vượt mức giới hạn của Allah.",
    "ayah": 31,
    "surah": 70
  },
  {
    "text": "Những người mà họ luôn thực hiện đúng theo sự ủy thác mà mọi người đã ủy thác cho họ từ tài sản cũng như những điều bí mật và những thứ khác; và luôn thực hiện đúng giao ước với mọi người.",
    "ayah": 32,
    "surah": 70
  },
  {
    "text": "Những người mà họ luôn đứng lên làm chứng khi được yêu cầu cho việc đúng và chân lý, họ không bị tác động bởi mối quan hệ bà con thân thích hay sự hận thù trong lòng.",
    "ayah": 33,
    "surah": 70
  },
  {
    "text": "Những người mà họ chu đáo gìn giữ lễ nguyện Salah của họ, họ thực hiện nó đùng giờ giấc quy định, họ tẩy sạch thân thể và thực hiện nó một cách nghiêm trang và không bị phân tâm.",
    "ayah": 34,
    "surah": 70
  },
  {
    "text": "Những người được mô tả với những thuộc tính đó sẽ là những người vinh dự được sống trong các Ngôi Vườn Thiên Đàng, họ sẽ hưởng thụ cuộc sống khoái lạc và tiện nghi trường tồn và sẽ được ngắm nhìn gương mặt của Allah, Đấng Tuyệt Đẹp và Phúc Đức.",
    "ayah": 35,
    "surah": 70
  },
  {
    "text": "Điều gì đã lôi kéo những kẻ thờ đa thần thuộc đám dân của Ngươi chạy nhanh đến trước mặt Ngươi để phủ nhận Ngươi - hỡi Thiên Sứ Muhammad?!",
    "ayah": 36,
    "surah": 70
  },
  {
    "text": "Chúng quay quanh Ngươi, bên phải và bên trái, từng nhóm từng nhóm một.",
    "ayah": 37,
    "surah": 70
  },
  {
    "text": "Há từng tên trong bọn chúng - những kẻ thờ đa thần vô đức tin nơi Allah - mong ước được Allah thu nhận vào Thiên Đàng Hạnh Phúc của Ngài để chúng sống hưởng lạc trường tồn trong đó trong khi chúng vẫn ở trên sự vô đức tin của chúng ư?!",
    "ayah": 38,
    "surah": 70
  },
  {
    "text": "Chắc chắn sự việc sẽ không như chúng tưởng tượng. Quả thật, TA (Allah) đã tạo chúng ra từ thứ mà chúng đều biết rõ. TA thực sự đã tạo chúng ra từ một loại nước đáng khinh (tinh dịch xuất ra từ dương vật của người đàn ông), và chúng thực sự yếu ớt không nắm được bất cứ một điều lợi gì cho bản thân chúng cũng như chẳng có khả năng mang lại tai họa cho ai, vậy tại sao chúng lại tự cao tự đại?!",
    "ayah": 39,
    "surah": 70
  },
  {
    "text": "Allah Tối Cao đã thề với chính Ngài, rằng Ngài là Thượng Đế của các hướng đông và tây, mặt trời, mặt trăng và tất cả hành tinh khác, quả thật, Ngài toàn năng trên tất cả.",
    "ayah": 40,
    "surah": 70
  },
  {
    "text": "Allah là Đấng Toàn Năng trên việc thay thế một nhóm người khác tốt hơn, một nhóm người mà họ sẽ luôn tuân lệnh Ngài. Và không ai có thể ngăn cản Ngài một khi Ngài muốn hủy diệt chúng (những kẻ vô đức tin) và thay thế chúng bởi một nhóm người khác tốt hơn.",
    "ayah": 41,
    "surah": 70
  },
  {
    "text": "Hỡi Thiên Sứ Muhammad, Ngươi cứ để mặc chúng đắm chìm trong sai trái và lầm lạc, cử để mặc chúng vui chơi trong cuộc sống trần gian cho tới khi chúng giáp mặt với Ngày Phục Sinh, Ngài mà chúng đã được hứa trong Qur'an.",
    "ayah": 42,
    "surah": 70
  },
  {
    "text": "Ngày mà họ sẽ đi ra từ mộ của họ một cách hối hả giống như họ tranh nhau chạy đến một mục tiêu đã định sẵn cho họ.",
    "ayah": 43,
    "surah": 70
  },
  {
    "text": "Cặp mắt của họ nhìn xuống đầy hèn hạ trong Ngày Hôm Đó, và đó là Ngày mà họ đã được hứa khi họ còn sống trên thế gian nhưng họ lại không màng quan tâm.",
    "ayah": 44,
    "surah": 70
  }
]
