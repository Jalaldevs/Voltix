[
  {
    "text": "Thời khắc làm kinh hoàng các con tim của con người.",
    "ayah": 1,
    "surah": 101
  },
  {
    "text": "Thời khắc làm các con tim con người phải kinh hoàng là gì vậy?",
    "ayah": 2,
    "surah": 101
  },
  {
    "text": "Điều gì cho Ngươi biết - hỡi Thiên Sứ - về Thời khắc làm các con tim con người phải kinh hoàng đó? Đó chính là Ngày Tận Thế.",
    "ayah": 3,
    "surah": 101
  },
  {
    "text": "Vào Ngày đó, con người hoảng sợ chạy tán loạn như những con bươm bướm bay tứ tán.",
    "ayah": 4,
    "surah": 101
  },
  {
    "text": "Những quả núi sẽ biến mất, hình ảnh của nó giống như những sợi lông cừu bị thổi tung lên và bay mất dạng.",
    "ayah": 5,
    "surah": 101
  },
  {
    "text": "Đối với người nào mà những việc làm thiện tốt của y có trọng lượng nặng hơn việc tội lỗi.",
    "ayah": 6,
    "surah": 101
  },
  {
    "text": "Y sẽ sống một cuộc sống vô cùng hạnh phúc và toại nguyện nơi Thiên Đàng.",
    "ayah": 7,
    "surah": 101
  },
  {
    "text": "Đối với người nào mà những việc làm tội lỗi của y có trọng lượng nặng hơn việc thiện tốt.",
    "ayah": 8,
    "surah": 101
  },
  {
    "text": "Thì chỗ ở của y vào Ngày Tận Thế sẽ là Hỏa Ngục.",
    "ayah": 9,
    "surah": 101
  },
  {
    "text": "Và điều gì cho Ngươi - hỡi Thiên Sứ - biết nó là thứ gì?",
    "ayah": 10,
    "surah": 101
  },
  {
    "text": "Đó là nơi của những ngọn lửa có sức nóng khủng khiếp.",
    "ayah": 11,
    "surah": 101
  }
]
