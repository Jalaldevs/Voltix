[
  {
    "text": "Katakanlah -wahai Rasul-, “Aku bersandar kepada Tuhan manusia dan berlindung kepada-Nya.",
    "ayah": 1,
    "surah": 114
  },
  {
    "text": "Dialah raja seluruh manusia, yang berbuat terhadap manusia sekehendak-Nya, tidak ada raja lain bagi mereka selain-Nya.",
    "ayah": 2,
    "surah": 114
  },
  {
    "text": "Dialah sesembahan mereka yang hak, tidak ada sesembahan lain yang hak bagi mereka selain-Nya.",
    "ayah": 3,
    "surah": 114
  },
  {
    "text": "Aku berlindung kepada-Nya dari kejahatan setan yang menimpakan bisikannya kepada manusia tatkala ia lalai dari zikir kepada Allah dan yang lari dari manusia jika ia mengingat Allah.",
    "ayah": 4,
    "surah": 114
  },
  {
    "text": "Setan itu menimpakan bisikannya ke dalam hati manusia.",
    "ayah": 5,
    "surah": 114
  },
  {
    "text": "Setan itu dari golongan jin dan juga dari golongan manusia.",
    "ayah": 6,
    "surah": 114
  }
]
