[
  {
    "text": "Kebinasaan dan kerugian bagi orang-orang yang curang.",
    "ayah": 1,
    "surah": 83
  },
  {
    "text": "Mereka ialah yang apabila menerima takaran dari orang lain mereka meminta haknya secara sempurna tanpa dikurangi.",
    "ayah": 2,
    "surah": 83
  },
  {
    "text": "Namun, apabila menakar atau menimbang untuk orang lain maka mereka mengurangi timbangan dan takaran. Demikianlah kondisi penduduk Madinah saat Nabi -ṣallallāhu 'alaihi wa sallam- berhijrah kepada mereka.",
    "ayah": 3,
    "surah": 83
  },
  {
    "text": "Apakah orang-orang yang melakukan kemungkaran ini tidak meyakini bahwa mereka akan dibangkitkan kepada Allah?",
    "ayah": 4,
    "surah": 83
  },
  {
    "text": "Yaitu untuk mendapat perhitungan dan pembalasan amalan pada hari yang agung karena di dalamnya terdapat berbagai kesengsaraan dan huru-hara.",
    "ayah": 5,
    "surah": 83
  },
  {
    "text": "Itulah hari manusia berdiri untuk menghadap Tuhan segala makhluk untuk dihisab.",
    "ayah": 6,
    "surah": 83
  },
  {
    "text": "Kenyataannya tidak seperti yang kalian bayangkan, yaitu bahwa tidak ada kebangkitan setelah kematian. Sesungguhnya kitab catatan amalan orang-orang yang durhaka dari golongan orang-orang kafir dan munafik yang sudah pasti merugi itu berada di sijjīn (lapisan tanah terbawah).",
    "ayah": 7,
    "surah": 83
  },
  {
    "text": "Tahukah kamu -wahai Rasul- apa sijjīn itu?!",
    "ayah": 8,
    "surah": 83
  },
  {
    "text": "Yaitu kitab yang tertulis, tidak ada penambahan di dalamnya maupun pengurangan.",
    "ayah": 9,
    "surah": 83
  },
  {
    "text": "Kebinasaan dan kerugian pada hari itu bagi orang-orang yang mendustakan.",
    "ayah": 10,
    "surah": 83
  },
  {
    "text": "Yaitu yang mendustakan adanya Hari Pembalasan, pada Hari itu Allah membalas hamba-hamba atas amal perbuatan mereka di dunia.",
    "ayah": 11,
    "surah": 83
  },
  {
    "text": "Tidaklah mendustakan kedatangan hari tersebut kecuali setiap orang yang melanggar hukum-hukum Allah, lagi banyak dosa.",
    "ayah": 12,
    "surah": 83
  },
  {
    "text": "Jika dibacakan kepadanya ayat-ayat Kami yang diturunkan kepada Rasul Kami, ia berkata, “Ini adalah cerita-cerita umat-umat yang terdahulu, bukan dari sisi Allah.”",
    "ayah": 13,
    "surah": 83
  },
  {
    "text": "Kenyataannya bukan seperti yang dibayangkan oleh orang-orang yang mendustakan ayat-ayat itu. Justru perbuatan maksiat yang pernah mereka lakukan telah mengalahkan dan menutup fungsi akal mereka itu, sehingga mereka tidak bisa melihat kebenaran dengan hati mereka.",
    "ayah": 14,
    "surah": 83
  },
  {
    "text": "Sungguh, mereka akan terhalangi untuk melihat kepada Tuhan mereka pada hari Kiamat.",
    "ayah": 15,
    "surah": 83
  },
  {
    "text": "Kemudian sungguh mereka akan masuk ke dalam neraka, mereka akan menderita karena panasnya.",
    "ayah": 16,
    "surah": 83
  },
  {
    "text": "Kemudian dikatakan kepada mereka pada Hari Kiamat sebagai bentuk hinaan terhadap mereka, “Siksa yang sedang kalian rasakan ini adalah balasan dari pendustaan kalian terhadapnya di dunia ketika Rasul kalian mengabarkannya kepada kalian.”",
    "ayah": 17,
    "surah": 83
  },
  {
    "text": "Sekali-kali tidak, kenyataannya tidak seperti yang kalian bayangkan bahwa tidak ada hari perhitungan dan pembalasan amalan. Sesungguhnya kitab orang-orang yang melakukan ketaatan benar-benar berada di 'illiyyūn.",
    "ayah": 18,
    "surah": 83
  },
  {
    "text": "Tahukah kamu -wahai Rasul- apa 'illiyyūn itu?",
    "ayah": 19,
    "surah": 83
  },
  {
    "text": "Yaitu kitab yang tertulis, tidak ada penambahan di dalamnya maupun pengurangan.",
    "ayah": 20,
    "surah": 83
  },
  {
    "text": "Kitab ini disaksikan oleh para malaikat yang didekatkan ke setiap langit.",
    "ayah": 21,
    "surah": 83
  },
  {
    "text": "Sesungguhnya orang-orang yang memperbanyak ketaatan sungguh berada di dalam kenikmatan abadi pada Hari Kiamat.",
    "ayah": 22,
    "surah": 83
  },
  {
    "text": "Mereka memandang kepada Tuhan mereka dari atas kasur-kasur yang terhiasi dan mereka juga memandang kepada semua yang menyenangkan hati serta menggembirakan mereka.",
    "ayah": 23,
    "surah": 83
  },
  {
    "text": "Jika kamu melihat mereka, maka kamu lihat di wajah-wajah mereka tanda kenikmatan yang indah dan anggun.",
    "ayah": 24,
    "surah": 83
  },
  {
    "text": "Pelayan-pelayan mereka menuangkan khamar yang tercampur di dalam bejananya.",
    "ayah": 25,
    "surah": 83
  },
  {
    "text": "Dari bejana khamar itu, tercium semerbak bau minyak kesturi sampai tetes terakhirnya. Demi mendapatkan ganjaran yang mulia ini, hendaknya orang-orang berlomba-lomba untuk mendapatkannya dengan mengamalkan apa yang diridai Allah dan meninggalkan apa yang dimurkai-Nya.",
    "ayah": 26,
    "surah": 83
  },
  {
    "text": "Minuman yang disegel ini bercampur dengan air dari mata air tasnīm.",
    "ayah": 27,
    "surah": 83
  },
  {
    "text": "Ia adalah mata air di surga tertinggi, orang-orang yang didekatkan kepada Allah meminumnya dalam kondisi bersih dan murni. Demikian pula orang-orang mukmin yang lain meminum darinya, ia bercampur dengan minuman yang lainnya.",
    "ayah": 28,
    "surah": 83
  },
  {
    "text": "Sesungguhnya orang-orang yang durhaka dengan kekufurannya dahulu menertawakan orang-orang yang beriman sebagai bentuk ejekan.",
    "ayah": 29,
    "surah": 83
  },
  {
    "text": "Jika mereka melewati orang-orang yang beriman, mereka saling mengedipkan mata sebagai bentuk hinaan dan celaan.",
    "ayah": 30,
    "surah": 83
  },
  {
    "text": "Jika mereka kembali kepada keluarga mereka, mereka kembali dengan gembira dengan kekufuran mereka dan hinaan mereka terhadap orang-orang yang beriman.",
    "ayah": 31,
    "surah": 83
  },
  {
    "text": "Jika mereka melihat orang-orang Islam, mereka berkata, “Sesungguhnya orang-orang ini benar-benar telah sesat dari jalan kebenaran karena mereka telah meninggalkan agama nenek moyang mereka.”",
    "ayah": 32,
    "surah": 83
  },
  {
    "text": "Padahal, Allah tidak menugaskan mereka untuk mengawasi amal perbuatan kaum muslimin sehingga mereka harus mengatakan perkataan ini.",
    "ayah": 33,
    "surah": 83
  },
  {
    "text": "Oleh sebab itu, pada hari Kiamat nanti orang-orang yang beriman kepada Allah menertawakan orang-orang kafir sebagaimana orang-orang kafir sebelumnya menertawakan mereka di dunia.",
    "ayah": 34,
    "surah": 83
  },
  {
    "text": "Di atas kasur-kasur yang berhias mereka melihat kepada kenikmatan abadi yang disediakan oleh Allah untuk mereka.",
    "ayah": 35,
    "surah": 83
  },
  {
    "text": "Sungguh orang-orang kafir telah mendapatkan balasan dari amal perbuatan yang dahulu mereka lakukan di dunia berupa siksa yang menghinakan.",
    "ayah": 36,
    "surah": 83
  }
]
