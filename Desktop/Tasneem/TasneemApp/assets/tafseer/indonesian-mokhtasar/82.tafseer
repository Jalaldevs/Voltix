[
  {
    "text": "Jika langit telah terbelah untuk turunnya para malaikat melalui celahnya,",
    "ayah": 1,
    "surah": 82
  },
  {
    "text": "jika bintang-bintang telah jatuh berserakan,",
    "ayah": 2,
    "surah": 82
  },
  {
    "text": "jika seluruh lautan telah dibukakan tabirnya sehingga bercampur satu sama lain,",
    "ayah": 3,
    "surah": 82
  },
  {
    "text": "dan jika tanah kuburan telah dibalik agar mayat yang ada di dalamnya dibangkitkan,",
    "ayah": 4,
    "surah": 82
  },
  {
    "text": "pada saat itulah setiap jiwa mengetahui perbuatan yang telah dilakukannya dan yang telah dilalaikannya karena tidak mengamalkannya.",
    "ayah": 5,
    "surah": 82
  },
  {
    "text": "Wahai manusia yang ingkar kepada Tuhanmu! Apa yang membuatmu mengingkari perintah Tuhanmu ketika Dia menunda siksamu dan tidak menyegerakannya karena memuliakan kamu?!",
    "ayah": 6,
    "surah": 82
  },
  {
    "text": "Dialah yang telah menciptakan dirimu yang sebelumnya tidak ada dan menjadikanmu dengan tubuh yang sempurna dan seimbang.",
    "ayah": 7,
    "surah": 82
  },
  {
    "text": "Dalam bentuk apa saja yang Allah menghendaki untuk menciptakanmu, Allah menciptakanmu. Dia telah memberikan kenikmatan kepadamu ketika Dia tidak menciptakanmu dalam bentuk keledai, kera, anjing maupun bentuk lainnya.",
    "ayah": 8,
    "surah": 82
  },
  {
    "text": "Kenyataannya bukan sebagaimana yang kalian bayangkan -wahai orang yang teperdaya-, akan tetapi kalian mendustakan adanya hari Pembalasan sehingga kalian tidak mempersiapkan diri untuk menghadapinya.",
    "ayah": 9,
    "surah": 82
  },
  {
    "text": "Sesungguhnya di sisi kalian terdapat para malaikat yang mengawasi segala perbuatan kalian.",
    "ayah": 10,
    "surah": 82
  },
  {
    "text": "Mereka malaikat yang mulia di sisi Allah, menulis segala amal perbuatan kalian.",
    "ayah": 11,
    "surah": 82
  },
  {
    "text": "Mereka mengetahui perbuatan apa saja yang kalian kerjakan lalu mereka mencatatnya.",
    "ayah": 12,
    "surah": 82
  },
  {
    "text": "Sesungguhnya orang-orang yang banyak mengerjakan kebaikan dan ketaatan pasti berada di dalam kenikmatan abadi pada hari Kiamat.",
    "ayah": 13,
    "surah": 82
  },
  {
    "text": "Sebaliknya, sesungguhnya orang-orang yang durhaka pasti berada di dalam neraka yang menyala atas mereka.",
    "ayah": 14,
    "surah": 82
  },
  {
    "text": "Mereka memasuki neraka itu pada hari Pembalasan, mereka merasa tersiksa karena panasnya.",
    "ayah": 15,
    "surah": 82
  },
  {
    "text": "Mereka sama sekali tidak bisa lepas darinya selamanya, bahkan mereka itu kekal di dalamnya.",
    "ayah": 16,
    "surah": 82
  },
  {
    "text": "Tahukah kamu -wahai Rasul- apa Hari Pembalasan itu?",
    "ayah": 17,
    "surah": 82
  },
  {
    "text": "Kemudian tahukah kamu, apa Hari Pembalasan itu?",
    "ayah": 18,
    "surah": 82
  },
  {
    "text": "Itulah hari saat seseorang tidak bisa menolong orang lain dan segala perkara pada hari itu dalam kekuasaan Allah semata, berbuat sebagaimana yang Dia kehendaki, bukan dalam kekuasaan selain-Nya.",
    "ayah": 19,
    "surah": 82
  }
]
