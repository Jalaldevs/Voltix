[
  {
    "text": "Katakan -wahai Rasul-, “Wahai orang-orang yang kafir kepada Allah!",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "Aku tidak akan menyembah berhala-berhala yang kalian sembah, baik saat ini maupun di masa mendatang.",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "Kalian pun tidak menyembah apa yang aku sembah, yaitu Allah semata.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "Aku sama sekali tidak menyembah berhala-berhala yang kalian sembah.",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "Kalian pun tidak menyembah apa yang aku sembah, yaitu Allah semata.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "Bagi kalian agama kalian yang telah kalian buat-buat untuk diri kalian sendiri dan bagiku agamaku yang diturunkan Allah kepadaku.",
    "ayah": 6,
    "surah": 109
  }
