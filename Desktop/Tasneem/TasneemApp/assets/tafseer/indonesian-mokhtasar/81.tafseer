[
  {
    "text": "Apabila daratan matahari telah digulung dan cahayanya telah hilang,",
    "ayah": 1,
    "surah": 81
  },
  {
    "text": "jika bintang-bintang telah berjatuhan dan hilang cahayanya,",
    "ayah": 2,
    "surah": 81
  },
  {
    "text": "jika gunung-gunung telah digerakkan dari tempatnya,",
    "ayah": 3,
    "surah": 81
  },
  {
    "text": "jika unta-unta bunting yang mereka berlomba untuk memilikinya dibiarkan karena ditinggal oleh pemiliknya,",
    "ayah": 4,
    "surah": 81
  },
  {
    "text": "jika binatang-binatang liar telah dikumpulkan bersama manusia pada satu tempat,",
    "ayah": 5,
    "surah": 81
  },
  {
    "text": "jika lautan telah dinyalakan hingga menjadi api,",
    "ayah": 6,
    "surah": 81
  },
  {
    "text": "jika ruh-ruh telah disandingkan dengan yang semisal dengannya; seorang yang jahat disandingkan dengan yang jahat dan orang yang bertakwa disandingkan dengan yang bertakwa,",
    "ayah": 7,
    "surah": 81
  },
  {
    "text": "jika anak perempuan yang dikubur hidup-hidup ditanya oleh Allah,",
    "ayah": 8,
    "surah": 81
  },
  {
    "text": "\"Karena dosa apa engkau dibunuh oleh orang yang membunuhmu?\",",
    "ayah": 9,
    "surah": 81
  },
  {
    "text": "jika lembaran catatan amal para hamba telah dibuka agar masing-masing bisa membaca catatan amal perbuatannya,",
    "ayah": 10,
    "surah": 81
  },
  {
    "text": "jika langit telah dicabut sebagaimana kulit kambing tercerabut dari tubuhnya,",
    "ayah": 11,
    "surah": 81
  },
  {
    "text": "jika api neraka telah dinyalakan,",
    "ayah": 12,
    "surah": 81
  },
  {
    "text": "dan jika surga telah didekatkan kepada orang-orang yang bertakwa,",
    "ayah": 13,
    "surah": 81
  },
  {
    "text": "Apabila semua peristiwa tersebut sudah terjadi, setiap jiwa mengetahui bekal amalan yang telah dilakukannya untuk menghadapi hari itu.",
    "ayah": 14,
    "surah": 81
  },
  {
    "text": "Allah bersumpah dengan bintang-bintang yang tersembunyi sebelum terbit pada malam hari,",
    "ayah": 15,
    "surah": 81
  },
  {
    "text": "yaitu yang beredar di orbitnya dan terbenam saat datangnya pagi, sebagaimana kijang yang masuk ke dalam sarangnya.",
    "ayah": 16,
    "surah": 81
  },
  {
    "text": "Dia bersumpah dengan awal malam jika datang dan akhir malam ketika pergi.",
    "ayah": 17,
    "surah": 81
  },
  {
    "text": "Dia bersumpah dengan waktu subuh jika mulai menampakkan cahayanya.",
    "ayah": 18,
    "surah": 81
  },
  {
    "text": "Dia bersumpah dengan semua itu bahwa sesungguhnya Al-Qur`ān yang diturunkan kepada Muhammad -ṣallallāhu 'alaihi wa sallam- adalah benar-benar firman Allah yang disampaikan oleh malaikat yang memegang amanat, yaitu Jibril -'alaihissalām- yang diberi amanat oleh Allah.",
    "ayah": 19,
    "surah": 81
  },
  {
    "text": "Dia pemilik kekuatan dan kedudukan agung di sisi Sang Pemilik Arasy -Subḥānahu wa Ta'ālā-.",
    "ayah": 20,
    "surah": 81
  },
  {
    "text": "Dia ditaati oleh para penghuni langit, menunaikan amanat yang dibebankan kepadanya berupa wahyu.",
    "ayah": 21,
    "surah": 81
  },
  {
    "text": "Sungguh, teman kalian, Muhammad -ṣallallāhu 'alaihi wa sallam- yang telah kalian ketahui akalnya, amanatnya, dan kejujurannya, sekali-kali bukanlah orang gila sebagaimana yang kalian tuduhkan kepadanya secara dusta.",
    "ayah": 22,
    "surah": 81
  },
  {
    "text": "Teman kalian ini telah melihat Jibril di ufuk langit yang jelas dalam bentuk asli sebagaimana ia diciptakan.",
    "ayah": 23,
    "surah": 81
  },
  {
    "text": "Bukanlah teman kalian ini sebagai orang bakhil yang enggan untuk menyampaikan kepada kalian apa yang diperintahkan kepadanya untuk disampaikan kepada kalian dan dia juga tidak mengambil upah sebagaimana para dukun mengambil upah.",
    "ayah": 24,
    "surah": 81
  },
  {
    "text": "Bukanlah Al-Qur`ān ini berupa ucapan setan yang terjauhkan dari rahmat Allah.",
    "ayah": 25,
    "surah": 81
  },
  {
    "text": "Lalu alasan apalagi yang akan kalian gunakan untuk mengingkari bahwa Al-Qur`ān ini dari Allah setelah datangnya hujah-hujah ini?!",
    "ayah": 26,
    "surah": 81
  },
  {
    "text": "Tidaklah Al-Qur`ān itu melainkan peringatan dan nasihat bagi jin dan manusia,",
    "ayah": 27,
    "surah": 81
  },
  {
    "text": "yaitu bagi siapa di antara kalian yang ingin istikamah di atas jalan kebenaran.",
    "ayah": 28,
    "surah": 81
  },
  {
    "text": "Namun, tidaklah kalian mampu berkehendak untuk istikamah atau untuk hal lainnya kecuali bila Allah yang merupakan Tuhan segala makhluk berkehendak demikian.",
    "ayah": 29,
    "surah": 81
  }
]
