[
  {
    "text": "Allah bersumpah dengan angin yang beriringan seperti barisan kuda.",
    "ayah": 1,
    "surah": 77
  },
  {
    "text": "Dia bersumpah dengan angin yang berhembus dengan kencang.",
    "ayah": 2,
    "surah": 77
  },
  {
    "text": "Dia bersumpah dengan angin yang menyebarkan hujan.",
    "ayah": 3,
    "surah": 77
  },
  {
    "text": "Dia bersumpah dengan para malaikat yang turun membawa apa yang membedakan antara yang hak dengan yang batil.",
    "ayah": 4,
    "surah": 77
  },
  {
    "text": "Dia bersumpah dengan para malaikat yang turun membawa wahyu.",
    "ayah": 5,
    "surah": 77
  },
  {
    "text": "Para malaikat itu turun membawa wahyu sebagai hujah dari Allah untuk manusia dan peringatan bagi mereka dari siksa Allah.",
    "ayah": 6,
    "surah": 77
  },
  {
    "text": "Sesungguhnya yang dijanjikan kepada kalian yang berupa kebangkitan, perhitungan amal dan pembalasan adalah benar adanya, tidak diragukan.",
    "ayah": 7,
    "surah": 77
  },
  {
    "text": "Apabila bintang-bintang telah dihilangkan cahayanya dan sinarnya telah sirna;",
    "ayah": 8,
    "surah": 77
  },
  {
    "text": "apabila langit telah terbelah agar para malaikat turun melaluinya;",
    "ayah": 9,
    "surah": 77
  },
  {
    "text": "apabila gunung-gunung tercerabut dari tempatnya, lalu dihancurkan hingga menjadi debu;",
    "ayah": 10,
    "surah": 77
  },
  {
    "text": "apabila para rasul telah dikumpulkan pada waktu yang telah ditentukan;",
    "ayah": 11,
    "surah": 77
  },
  {
    "text": "persaksian mereka atas umat-umat mereka ditangguhkan untuk hari yang agung,",
    "ayah": 12,
    "surah": 77
  },
  {
    "text": "yaitu hari penetapan keputusan di antara para hamba, sehingga jelas siapa yang benar dari siapa yang salah, siapa yang bahagia dan siapa yang sengsara.",
    "ayah": 13,
    "surah": 77
  },
  {
    "text": "Tahukah kamu -wahai Rasul- apa hari keputusan itu?",
    "ayah": 14,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 15,
    "surah": 77
  },
  {
    "text": "Bukankah Kami telah membinasakan umat-umat terdahulu saat mereka kafir terhadap Allah dan mendustakan rasul-rasul-Nya?",
    "ayah": 16,
    "surah": 77
  },
  {
    "text": "Kemudian Kami mendatangkan lagi orang-orang yang mendustakan dari kaum yang berikutnya, lalu Kami membinasakan mereka sebagaimana kami membinasakan umat-umat sebelum mereka.",
    "ayah": 17,
    "surah": 77
  },
  {
    "text": "Sebagaimana kehancuran bagi umat-umat itu, Kami juga menghancurkan para pendosa dan orang-orang yang mendustakan apa yang dibawa oleh Muhammad -ṣallallāhu 'alaihi wa sallam-.",
    "ayah": 18,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 19,
    "surah": 77
  },
  {
    "text": "Tidakkah Kami telah menciptakan kalian -wahai manusia- dari air yang hina, yaitu air mani?",
    "ayah": 20,
    "surah": 77
  },
  {
    "text": "Kemudian Kami jadikan air yang hina itu di tempat yang terjaga, yaitu rahim wanita.",
    "ayah": 21,
    "surah": 77
  },
  {
    "text": "Ia terjaga sampai pada masa tertentu, yaitu masa hamil.",
    "ayah": 22,
    "surah": 77
  },
  {
    "text": "Lalu Kami tentukan sifat anak yang dilahirkan, kemampuannya, warna kulitnya, dan lain-lain karena sebaik-baik yang menentukan segala sesuatu adalah Kami.",
    "ayah": 23,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 24,
    "surah": 77
  },
  {
    "text": "Bukankah Kami telah menjadikan bumi sebagai tempat berkumpulnya seluruh manusia?!",
    "ayah": 25,
    "surah": 77
  },
  {
    "text": "Ia menghimpun orang-orang yang masih hidup dari mereka dengan menempati dan membangunnya dan orang-orang yang telah meninggal dari mereka dengan dikubur di dalamnya.",
    "ayah": 26,
    "surah": 77
  },
  {
    "text": "Kami jadikan di bumi itu gunung-gunung yang kokoh nan tinggi guna mencegah bumi dari berguncang dan Kami beri kalian -wahai manusia- minuman dari air yang segar. Maka, siapa yang menciptakan hal itu tidaklah sulit bagi-Nya untuk membangkitkan kalian.",
    "ayah": 27,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 28,
    "surah": 77
  },
  {
    "text": "Lalu dikatakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul mereka, “Pergilah kalian -wahai orang-orang yang mendustakan- menuju siksa yang dulu pernah kalian dustakan.",
    "ayah": 29,
    "surah": 77
  },
  {
    "text": "Pergilah kalian menuju naungan dari asap neraka yang terbagi menjadi tiga cabang.",
    "ayah": 30,
    "surah": 77
  },
  {
    "text": "Di sana tidak ada rasa sejuk naungan dan tidak pula bisa menghalangi dari jilatan dan panasnya neraka terhadap kalian.”",
    "ayah": 31,
    "surah": 77
  },
  {
    "text": "Sesungguhnya neraka itu melemparkan bunga-bunga api, setiap bunga api ukurannya seperti istana.",
    "ayah": 32,
    "surah": 77
  },
  {
    "text": "Seakan-akan bunga api yang terlontar itu baik gelapnya maupun ukurannya seperti unta hitam.",
    "ayah": 33,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 34,
    "surah": 77
  },
  {
    "text": "Inilah hari mereka tidak mampu mengucapkan suatu apa pun.",
    "ayah": 35,
    "surah": 77
  },
  {
    "text": "Tidak pula mereka mendapat izin untuk beralasan kepada Tuhan mereka atas kekufuran dan kejahatan mereka agar alasan mereka diterima.",
    "ayah": 36,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 37,
    "surah": 77
  },
  {
    "text": "Ini adalah hari penentuan keputusan di antara seluruh makhluk. Kami mengumpulkan kalian beserta umat-umat terdahulu dalam satu area datar nan luas.",
    "ayah": 38,
    "surah": 77
  },
  {
    "text": "Jika kalian masih mempunyai tipu daya agar selamat dari siksa Allah, maka tunjukkan tipu daya itu kepadaKu.",
    "ayah": 39,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 40,
    "surah": 77
  },
  {
    "text": "Sesungguhnya orang-orang yang bertakwa kepada Tuhan mereka dengan menaati segala perintah-Nya dan menjauhi segala larangan-Nya berada di bawah naungan pepohonan surga yang rindang dan di sekitar mata air segar yang mengalir.",
    "ayah": 41,
    "surah": 77
  },
  {
    "text": "Mereka juga mendapatkan buah-buahan yang mereka ingin memakannya.",
    "ayah": 42,
    "surah": 77
  },
  {
    "text": "Lalu dikatakan kepada mereka, “Makanlah dari makanan yang baik-baik dan minumlah minuman yang nikmat tanpa ada kotorannya karena adanya amal saleh yang telah kalian lakukan di dunia.”",
    "ayah": 43,
    "surah": 77
  },
  {
    "text": "Seperti balasan yang Kami berikan kepada kalian ini, Kami akan membalas orang-orang yang berbuat baik.",
    "ayah": 44,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 45,
    "surah": 77
  },
  {
    "text": "Lalu dikatakan kepada orang-orang yang mendustakan para rasul, “Makanlah dan bersenang-senanglah dengan kesenangan kehidupan dalam waktu yang pendek di dunia, sesungguhnya dengan kekufuran kalian kepada Allah dan pendustaan kalian terhadap para rasul kalian adalah orang-orang yang berdosa.”",
    "ayah": 46,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 47,
    "surah": 77
  },
  {
    "text": "Jika dikatakan kepada orang-orang yang mendustakan ini, \"Salatlah kalian untuk menghadap Allah\", mereka malah tidak melaksanakan salat untuk-Nya.",
    "ayah": 48,
    "surah": 77
  },
  {
    "text": "Pada hari itu kehancuran, siksa, dan kerugian ditimpakan kepada orang-orang yang mendustakan apa yang dibawa oleh para rasul dari sisi Allah.",
    "ayah": 49,
    "surah": 77
  },
  {
    "text": "Jika mereka tidak beriman kepada Al-Qur`ān yang diturunkan dari sisi Tuhan mereka ini, lantas terhadap perkataan apa selain Al-Qur`ān yang akan mereka imani?!",
    "ayah": 50,
    "surah": 77
  }
]
