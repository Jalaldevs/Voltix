[
  {
    "text": "Allah bersumpah dengan malam apabila menutupi segala yang ada di antara langit dan bumi dengan kegelapannya.",
    "ayah": 1,
    "surah": 92
  },
  {
    "text": "Dia bersumpah dengan siang hari apabila tersingkap dan tampak.",
    "ayah": 2,
    "surah": 92
  },
  {
    "text": "Dia bersumpah dengan dua jenis makhluk-Nya, yaitu lelaki dan perempuan.",
    "ayah": 3,
    "surah": 92
  },
  {
    "text": "Sesungguhnya amal perbuatan kalian -wahai manusia- berbeda-beda, ada yang baik yang merupakan penyebab masuk ke dalam surga dan ada yang buruk yang merupakan penyebab masuk ke dalam neraka.",
    "ayah": 4,
    "surah": 92
  },
  {
    "text": "Adapun orang-orang yang memberikan apa yang seharusnya dia tunaikan berupa zakat, nafkah, dan kafarat, serta meninggalkan apa yang dilarang oleh Allah,",
    "ayah": 5,
    "surah": 92
  },
  {
    "text": "serta membenarkan adanya balasan yang telah dijanjikan oleh Allah,",
    "ayah": 6,
    "surah": 92
  },
  {
    "text": "maka Kami akan memudahkan baginya untuk beramal saleh dan berinfak di jalan Allah.",
    "ayah": 7,
    "surah": 92
  },
  {
    "text": "Adapun orang yang bakhil dengan hartanya dengan tidak menyalurkan apa yang menjadi kewajibannya dan merasa cukup dengan hartanya sehingga tidak membutuhkan Allah, lalu tidak mau memohon karunia dari-Nya,",
    "ayah": 8,
    "surah": 92
  },
  {
    "text": "Dan mendustakan adanya balasan yang telah dijanjikan Allah dan pahala atas menginfakkan hartanya di jalan Allah.",
    "ayah": 9,
    "surah": 92
  },
  {
    "text": "maka Kami mudahkan baginya untuk melakukan keburukan serta Kami sulitkan baginya untuk berbuat baik.",
    "ayah": 10,
    "surah": 92
  },
  {
    "text": "Hartanya yang dia pelitkan itu tidak bermanfaat sedikit pun baginya saat ia telah binasa dan masuk ke dalam neraka.",
    "ayah": 11,
    "surah": 92
  },
  {
    "text": "Sesungguhnya menjadi kewajiban Kami untuk menjelaskan jalan kebenaran dari jalan yang sesat.",
    "ayah": 12,
    "surah": 92
  },
  {
    "text": "Sesungguhnya kepunyaan Kamilah kehidupan akhirat dan kehidupan dunia, Kami berbuat pada keduanya sekehendak Kami, tidak ada seorang pun yang berhak atas hal itu selain Kami.",
    "ayah": 13,
    "surah": 92
  },
  {
    "text": "Oleh sebab itu, Aku mengingatkan kalian -wahai manusia- dengan adanya api neraka yang menyala-nyala jika kalian bermaksiat kepada Allah.",
    "ayah": 14,
    "surah": 92
  },
  {
    "text": "Tidaklah merasakan pedihnya neraka ini kecuali orang yang sengsara, yaitu orang kafir.",
    "ayah": 15,
    "surah": 92
  },
  {
    "text": "Dialah yang mendustakan apa yang dibawa oleh Rasul -Ṣallallāhu 'alaihi wasallam- dan berpaling dari menaati perintah Allah.",
    "ayah": 16,
    "surah": 92
  },
  {
    "text": "Adapun manusia yang paling bertakwa akan dijauhkan dari neraka itu, yaitu Abu Bakar -raḍiyallāhu 'anhu-.",
    "ayah": 17,
    "surah": 92
  },
  {
    "text": "Dialah yang telah menafkahkan hartanya di jalan-jalan kebaikan untuk membersihkan dirinya dari dosa-dosa.",
    "ayah": 18,
    "surah": 92
  },
  {
    "text": "Padahal tidaklah ia menafkahkan apa yang telah dinafkahkan dari hartanya itu untuk membalas kenikmatan yang pernah orang lain berikan kepadanya.",
    "ayah": 19,
    "surah": 92
  },
  {
    "text": "Dia tidak menginginkan dari harta yang dia nafkahkan itu kecuali wajah Tuhannya Yang Mahatinggi di atas makhluk-Nya.",
    "ayah": 20,
    "surah": 92
  },
  {
    "text": "Sungguh, dia pasti akan merasa puas dengan balasan mulia yang diberikan Allah kepadanya.",
    "ayah": 21,
    "surah": 92
  }
]
