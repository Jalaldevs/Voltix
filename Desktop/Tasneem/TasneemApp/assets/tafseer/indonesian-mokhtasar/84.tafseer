[
  {
    "text": "Jika langit telah terbelah untuk menjadi pintu turunnya para malaikat darinya,",
    "ayah": 1,
    "surah": 84
  },
  {
    "text": "lalu langit mendengarkan Tuhannya dengan penuh ketundukan, dan sudah semestinya langit melakukan itu.",
    "ayah": 2,
    "surah": 84
  },
  {
    "text": "juga jika bumi telah diratakan oleh Allah sebagaimana kulit dibentangkan,",
    "ayah": 3,
    "surah": 84
  },
  {
    "text": "serta bumi melemparkan apa yang ada di dalamnya berupa benda berharga dan mayat-mayat, sehingga ia pun menjadi kosong,",
    "ayah": 4,
    "surah": 84
  },
  {
    "text": "lalu ia pun mendengarkan Tuhannya dengan penuh ketundukan dan bumi sudah semestinya melakukan itu.",
    "ayah": 5,
    "surah": 84
  },
  {
    "text": "Wahai manusia, sesungguhnya engkau melakukan perbuatan, yang baik maupun yang buruk, maka engkau akan mendapatinya pada Hari Kiamat agar Allah membalasmu atas perbuatan itu.",
    "ayah": 6,
    "surah": 84
  },
  {
    "text": "Adapun orang yang diberi catatan amal perbuatannya dengan tangan kanannya,",
    "ayah": 7,
    "surah": 84
  },
  {
    "text": "niscaya Allah akan menghisabnya dengan penghisaban yang mudah, yaitu amalnya dipaparkan kepada-Nya tanpa diberikan hukuman.",
    "ayah": 8,
    "surah": 84
  },
  {
    "text": "Lalu dia kembali kepada keluarganya dengan gembira.",
    "ayah": 9,
    "surah": 84
  },
  {
    "text": "Sebaliknya, orang yang diberi catatan amal perbuatannya dengan tangan kirinya dari arah belakang punggungnya,",
    "ayah": 10,
    "surah": 84
  },
  {
    "text": "niscaya ia akan menyerukan kebinasaan untuk dirinya sendiri.",
    "ayah": 11,
    "surah": 84
  },
  {
    "text": "Lalu ia masuk ke dalam neraka Jahanam untuk merasakan siksa panasnya.",
    "ayah": 12,
    "surah": 84
  },
  {
    "text": "Sesungguhnya ia dahulu di dunia bersama kaumnya merasa gembira dengan kekufuran dan kemaksiatan yang dilakukannya.",
    "ayah": 13,
    "surah": 84
  },
  {
    "text": "Ia menganggap bahwa ia tidak mungkin akan kembali pada kehidupan setelah kematiannya.",
    "ayah": 14,
    "surah": 84
  },
  {
    "text": "Tidaklah demikian, sebenarnya Allah pasti mengembalikannya kepada kehidupan sebagaimana Dia menciptakannya pada kali pertama. Sesungguhnya Tuhannya mengetahui perihal dirinya, tidak ada sesuatu pun yang luput dari-Nya, dan Dia akan membalasnya atas perbuatannya itu.",
    "ayah": 15,
    "surah": 84
  },
  {
    "text": "Allah bersumpah dengan cahaya merah yang ada pada ufuk setelah tenggelamnya matahari.",
    "ayah": 16,
    "surah": 84
  },
  {
    "text": "Dia bersumpah dengan malam beserta segala yang terhimpun di dalamnya.",
    "ayah": 17,
    "surah": 84
  },
  {
    "text": "Dia bersumpah dengan bulan apabila telah sempurna dan menjadi purnama.",
    "ayah": 18,
    "surah": 84
  },
  {
    "text": "Dia bersumpah dengan semua itu bahwa kalian -wahai manusia- pasti melewati tahapan demi tahapan, mulai dari setetes mani, lalu segumpal darah, kemudian segumpal daging, lalu menjalani kehidupan, lalu kematian dan kebangkitan kembali.",
    "ayah": 19,
    "surah": 84
  },
  {
    "text": "Mengapa orang-orang kafir itu tidak mau beriman kepada Allah dan hari akhirat?!",
    "ayah": 20,
    "surah": 84
  },
  {
    "text": "Jika dibacakan Al-Qur`ān atas mereka, mereka tidak bersujud kepada Tuhan mereka?!",
    "ayah": 21,
    "surah": 84
  },
  {
    "text": "Bahkan, orang-orang kafir ini mendustakan apa yang dibawa oleh rasul mereka untuk mereka.",
    "ayah": 22,
    "surah": 84
  },
  {
    "text": "Namun, Allah lebih mengetahui apa yang disembunyikan oleh hati mereka, tidak ada sedikit pun amal perbuatan mereka yang luput dari-Nya.",
    "ayah": 23,
    "surah": 84
  },
  {
    "text": "Oleh karena itu, kabarkanlah -wahai Rasul- kepada mereka siksa pedih yang menunggu mereka,",
    "ayah": 24,
    "surah": 84
  },
  {
    "text": "kecuali orang-orang yang beriman kepada Allah dan mengerjakan amal saleh, bagi mereka pahala yang tidak terputus, yaitu surga.",
    "ayah": 25,
    "surah": 84
  }
]
