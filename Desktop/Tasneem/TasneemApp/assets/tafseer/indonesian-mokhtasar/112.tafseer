[
  {
    "text": "Katakanlah -wahai Rasul-, “Dialah Allah Yang Maha Esa dalam sifat ulūhiyah (keilahian), tiada tuhan yang berhak disembah selain-Nya.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "Dialah penguasa yang berada di puncak kesempurnaan dan keindahan, yang menjadi tumpuan semua makhluk.",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "Dia tidak melahirkan sesuatu pun dan tidak pula dilahirkan oleh sesuatu, sehingga Dia -Subḥānahu- tidak mempunyai anak dan tidak pula mempunyai bapak.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "Dia tidak pula ada yang menyamai-Nya dari ciptaan-Nya.”",
    "ayah": 4,
    "surah": 112
  }
]
