[
  {
    "text": "Wajah Rasulullah -ṣallallāhu 'alaihi wa sallam- menjadi masam dan beliau berpaling.",
    "ayah": 1,
    "surah": 80
  },
  {
    "text": "Hal itu karena beliau didatangi Abdullah bin Ummi Maktum, seorang yang buta, untuk meminta petunjuk dari beliau. Dia datang pada saat Rasulullah -ṣallallāhu 'alaihi wa sallam- sedang sibuk dengan para pembesar kaum musyrikin karena berharap mereka bisa mendapat petunjuk.",
    "ayah": 2,
    "surah": 80
  },
  {
    "text": "Tahukah kamu -wahai Rasul- bisa jadi orang buta ini ingin membersihkan diri dari dosa-dosanya,",
    "ayah": 3,
    "surah": 80
  },
  {
    "text": "atau mengambil ibrah dari nasihat-nasihat yang didengarnya darimu lalu dia mendapatkan manfaat darinya?!",
    "ayah": 4,
    "surah": 80
  },
  {
    "text": "Adapun orang yang merasa cukup dengan dirinya sendiri karena memiliki harta dibandingkan iman kepada apa yang engkau bawa,",
    "ayah": 5,
    "surah": 80
  },
  {
    "text": "maka engkau melayaninya dan menemuinya.",
    "ayah": 6,
    "surah": 80
  },
  {
    "text": "Tidaklah engkau mendapatkan mudharat jika ia tidak mau bersuci dari dosa-dosanya dengan bertaubat kepada Allah.",
    "ayah": 7,
    "surah": 80
  },
  {
    "text": "Adapun orang yang bersegera datang kepadamu untuk mencari kebaikan,",
    "ayah": 8,
    "surah": 80
  },
  {
    "text": "sembari merasa takut kepada Tuhannya,",
    "ayah": 9,
    "surah": 80
  },
  {
    "text": "justru engkau mengabaikannya karena sibuk dengan pembesar-pembesar kaum musyrikin.",
    "ayah": 10,
    "surah": 80
  },
  {
    "text": "Seharusnya tidak demikian, sesungguhnya ajaran agama itu adalah nasehat dan peringatan bagi orang yang menerimanya.",
    "ayah": 11,
    "surah": 80
  },
  {
    "text": "Barang siapa ingin mengingat Allah maka dia mengingat Allah dan mendapat pelajaran dari apa yang ada di dalam Al-Qur`ān ini.",
    "ayah": 12,
    "surah": 80
  },
  {
    "text": "Al-Qur`ān ini berada di lembaran-lembaran mulia yang ada pada para malaikat.",
    "ayah": 13,
    "surah": 80
  },
  {
    "text": "Ia ditinggikan di tempat yang tinggi, lagi suci, tidak ada kotoran maupun noda yang mengenainya.",
    "ayah": 14,
    "surah": 80
  },
  {
    "text": "Dia berada di tangan para utusan dari golongan malaikat.",
    "ayah": 15,
    "surah": 80
  },
  {
    "text": "Mereka mulia di sisi Tuhan mereka, banyak melakukan amal kebaikan dan ketaatan.",
    "ayah": 16,
    "surah": 80
  },
  {
    "text": "Terlaknatlah manusia yang kafir, betapa besar kekafirannya terhadap Allah!",
    "ayah": 17,
    "surah": 80
  },
  {
    "text": "Dari apa Allah menciptakannya sehingga ia berbuat kesombongan di bumi dan mengingkari Allah?",
    "ayah": 18,
    "surah": 80
  },
  {
    "text": "Allah menciptakannya dari air yang sedikit, lalu Dia menakdirkan penciptaannya fase demi fase.",
    "ayah": 19,
    "surah": 80
  },
  {
    "text": "Kemudian setelah berbagai fase ini Allah memudahkan baginya untuk keluar dari perut ibunya.",
    "ayah": 20,
    "surah": 80
  },
  {
    "text": "Kemudian setelah Allah menentukan baginya umur kehidupannya, Allah mematikannya dan menjadikan baginya kuburan sebagai tempatnya hingga ia dibangkitkan.",
    "ayah": 21,
    "surah": 80
  },
  {
    "text": "Kemudian jika Allah berkehendak untuk membangkitkannya untuk perhitungan dan pembalasan, maka Allah membangkitkannya.",
    "ayah": 22,
    "surah": 80
  },
  {
    "text": "Tidaklah perkaranya seperti yang disangka oleh orang kafir ini bahwa ia telah menunaikan kewajibannya terhadap Tuhannya, padahal ia tidak menjalankan kewajiban-kewajiban yang telah Allah wajibkan atasnya.",
    "ayah": 23,
    "surah": 80
  },
  {
    "text": "Hendaknya orang yang kafir terhadap Allah itu melihat kepada makanannya, bagaimana ia mendapatkannya?",
    "ayah": 24,
    "surah": 80
  },
  {
    "text": "Asalnya adalah Kami mencurahkan air dari langit dengan menurunkan hujan.",
    "ayah": 25,
    "surah": 80
  },
  {
    "text": "Kemudian Kami belah tanah sehingga tanah terbelah untuk tumbuh-tumbuhan.",
    "ayah": 26,
    "surah": 80
  },
  {
    "text": "Lalu Kami tumbuhkan padanya biji-bijian dari gandum dan tanaman berbiji dan lain-lainnya.",
    "ayah": 27,
    "surah": 80
  },
  {
    "text": "Kami menumbuhkan padanya anggur dan rerumputan basah sebagai makanan ternak mereka.",
    "ayah": 28,
    "surah": 80
  },
  {
    "text": "Kami tumbuhkan padanya pohon zaitun dan kurma.",
    "ayah": 29,
    "surah": 80
  },
  {
    "text": "Kami tumbuhkan padanya berbagai kebun yang banyak pepohonannya.",
    "ayah": 30,
    "surah": 80
  },
  {
    "text": "Kami juga menumbuhkan padanya buah-buahan serta segala yang menjadi makanan hewan ternak kalian.",
    "ayah": 31,
    "surah": 80
  },
  {
    "text": "Semua itu bertujuan agar kalian dan hewan ternak kalian memanfaatkannya.",
    "ayah": 32,
    "surah": 80
  },
  {
    "text": "Lalu jika tiba suara dahsyat yang memekakkan telinga, yaitu tiupan sangkakala kedua,",
    "ayah": 33,
    "surah": 80
  },
  {
    "text": "pada hari itu seseorang lari dari saudaranya,",
    "ayah": 34,
    "surah": 80
  },
  {
    "text": "juga lari dari ibu dan bapaknya,",
    "ayah": 35,
    "surah": 80
  },
  {
    "text": "dan lari dari istri dan anak-anaknya.",
    "ayah": 36,
    "surah": 80
  },
  {
    "text": "Masing-masing saat itu mempunyai perkara yang menjadikannya lupa terhadap orang lain karena dahsyatnya kesulitan pada hari itu.",
    "ayah": 37,
    "surah": 80
  },
  {
    "text": "Wajah-wajah orang yang bahagia pada hari itu tampak bersinar.",
    "ayah": 38,
    "surah": 80
  },
  {
    "text": "Wajah-wajah itu tertawa gembira dengan apa yang telah disediakan oleh Allah dari rahmat-Nya.",
    "ayah": 39,
    "surah": 80
  },
  {
    "text": "Sebaliknya, wajah-wajah orang kafir pada hari itu tertutup debu.",
    "ayah": 40,
    "surah": 80
  },
  {
    "text": "Wajah-wajah itu tertutupi oleh kegelapan.",
    "ayah": 41,
    "surah": 80
  },
  {
    "text": "Orang-orang yang disebutkan dengan ciri-ciri demikian itu adalah orang-orang yang telah menggabungkan antara kekafiran dan kedurhakaan.",
    "ayah": 42,
    "surah": 80
  }
]
