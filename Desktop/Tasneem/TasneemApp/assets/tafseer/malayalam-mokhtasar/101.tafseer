[
  {
    "text": "ഭയാനകത കൊണ്ട് ഹൃദയങ്ങളെ ഭീതിയിലാഴ്ത്തുന്ന സമയം.",
    "ayah": 1,
    "surah": 101
  },
  {
    "text": "ഭയാനകത കൊണ്ട് ഹൃദയങ്ങളെ ഭീതിയിലാഴ്ത്തുന്ന സമയം എന്താകുന്നു?",
    "ayah": 2,
    "surah": 101
  },
  {
    "text": "അല്ലാഹുവിൻ്റെ റസൂലേ! അതിഭീകരത കൊണ്ട് ഹൃദയങ്ങളെ ഭയപ്പെടുത്തുന്ന ഈ സമയം ഏതാണെന്ന് നിനക്ക് അറിയുമോ?! അന്ത്യനാളാകുന്നു അത്.",
    "ayah": 3,
    "surah": 101
  },
  {
    "text": "മനുഷ്യരുടെ ഹൃദയങ്ങളെ അത് ഭീതിയിലാഴ്ത്തുകയും, അവർ അവിടെയും ഇവിടെയുമായി ചിന്നിച്ചിതറിയ പാറ്റകളെ പോലെ ആയിത്തീരുകയും ചെയ്യും.",
    "ayah": 4,
    "surah": 101
  },
  {
    "text": "പർവ്വതങ്ങൾ കടഞ്ഞ കമ്പിളി പോലെ പോലെ -ഭാരമില്ലാതെ ചലിച്ചു കൊണ്ടിരിക്കുന്ന- അവസ്ഥയിലാകും.",
    "ayah": 5,
    "surah": 101
  },
  {
    "text": "എന്നാൽ ഏതൊരാളുടെ നന്മയുടെ ഏടുകൾ അവൻ്റെ തിന്മയുടെ ഏടുകളെക്കാൾ കനം തൂങ്ങിയോ;",
    "ayah": 6,
    "surah": 101
  },
  {
    "text": "അവന് ലഭിക്കുന്ന സ്വർഗത്തിൽ അവൻ തൃപ്തികരമായ ജീവിതം നയിക്കും.",
    "ayah": 7,
    "surah": 101
  },
  {
    "text": "എന്നാൽ ഏതൊരാളുടെ തിന്മയുടെ ഏടുകൾ അവൻ്റെ നന്മയുടെ ഏടുകളെക്കാൾ കനം തൂങ്ങിയോ;",
    "ayah": 8,
    "surah": 101
  },
  {
    "text": "അവൻ്റെ സങ്കേതവും താമസസ്ഥലവും 'ഹാവിയഃ' ആയിരിക്കും.",
    "ayah": 9,
    "surah": 101
  },
  {
    "text": "ഹേ റസൂൽ! 'ഹാവിയഃ' എന്നാൽ എന്താണെന്ന് നിനക്കറിയുമോ?",
    "ayah": 10,
    "surah": 101
  },
  {
    "text": "കടുത്ത ചൂടുള്ള നരഗാഗ്നിയത്രെ അത്.",
    "ayah": 11,
    "surah": 101
  }
]
