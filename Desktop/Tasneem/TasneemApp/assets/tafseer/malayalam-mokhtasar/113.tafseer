[
  {
    "text": "പറയുക; -അല്ലാഹുവിൻ്റെ റസൂലേ!- പുലരിയുടെ രക്ഷിതാവിനെ കൊണ്ട് ഞാൻ അഭയം തേടുകയും, അവനോട് ഞാൻ രക്ഷ ചോദിക്കുകയും ചെയ്യുന്നു.",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "ഉപദ്രവകാരികളായ സൃഷ്ടികളുടെ കെടുതിയിൽ നിന്ന്.",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "രാത്രിയിൽ പുറത്തു വരുന്ന ഉപദ്രവങ്ങളിൽ നിന്നും - വിഷജന്തുക്കൾ, കള്ളന്മാർ തുടങ്ങിയവ - ഞാൻ അല്ലാഹുവിൽ അഭയം തേടുന്നു.",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "കെട്ടുകളിൽ ഊതുന്ന മാരണക്കാരികളായ സ്ത്രീകളുടെ കെടുതിയിൽ നിന്നും.",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "അസൂയക്കാരൻ തൻ്റെ അസൂയ കാരണത്താൽ ചെയ്യുന്ന ഉപദ്രവങ്ങളിൽ നിന്നും.",
    "ayah": 5,
    "surah": 113
  }
]
