[
  {
    "text": "അന്ത്യനാളിൽ പ്രതിഫലം നൽകപ്പെടും എന്നതിനെ കളവാക്കുന്നവനെ നീ അറിഞ്ഞുവോ?",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "അനാഥന് അവൻ്റെ അവകാശം പരുഷമായി തടഞ്ഞു വെക്കുന്നവനാരോ; അവനാണത്.",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "അവൻ സ്വന്തത്തെയോ മറ്റുള്ളവരെയോ പാവപ്പെട്ടവർക്ക് ഭക്ഷണം നൽകാൻ പ്രേരിപ്പിക്കുന്നില്ല.",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "തങ്ങളുടെ നിസ്കാരത്തെ കുറിച്ച് അശ്രദ്ധയിലായവർക്ക് നാശവും ശിക്ഷയും ഉണ്ടാകട്ടെ. നിസ്കാരത്തിൻ്റെ സമയം കഴിഞ്ഞു പോകുന്നതു വരെ അവർ അതിനെ ഗൗനിക്കാതെ വിടുന്നതാണ്.",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "തങ്ങളുടെ നിസ്കാരത്തെ കുറിച്ച് അശ്രദ്ധയിലായവർക്ക് നാശവും ശിക്ഷയും ഉണ്ടാകട്ടെ. നിസ്കാരത്തിൻ്റെ സമയം കഴിഞ്ഞു പോകുന്നതു വരെ അവർ അതിനെ ഗൗനിക്കാതെ വിടുന്നതാണ്.",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "തങ്ങളുടെ നിസ്കാരം കൊണ്ടും, പ്രവർത്തനങ്ങൾ കൊണ്ടും ജനങ്ങളെ കാണിക്കുന്നവർ; തങ്ങളുടെ പ്രവർത്തനങ്ങൾ അവർ അല്ലാഹുവിന് നിഷ്കളങ്കമാക്കുന്നില്ല.",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "ഒരു പ്രയാസവുമില്ലാത്ത, ചെറിയ സഹായങ്ങൾ ചെയ്യുന്നതിൽ നിന്ന് പോലും മറ്റുള്ളവരെ അവർ തടയുകയും ചെയ്യുന്നു.",
    "ayah": 7,
    "surah": 107
  }
]
