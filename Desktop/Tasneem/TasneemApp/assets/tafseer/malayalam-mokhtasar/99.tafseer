[
  {
    "text": "അന്ത്യനാളിൽ ഭൂമി ശക്തമായി പ്രകമ്പനം കൊള്ളിക്കപ്പെടുകയും;",
    "ayah": 1,
    "surah": 99
  },
  {
    "text": "ഭൂമി അതിൻ്റെ ഉള്ളിലുള്ള മൃതദേഹങ്ങളെയും മറ്റും പുറന്തള്ളുകയും ചെയ്താൽ.",
    "ayah": 2,
    "surah": 99
  },
  {
    "text": "പരിഭ്രാന്തിയോടെ മനുഷ്യൻ ചോദിക്കുകയും ചെയ്താൽ: ഭൂമിക്ക് എന്തു സംഭവിച്ചു? എന്തു കൊണ്ടാണതിങ്ങനെ ഇളകുകയും കുലുങ്ങുകയും ചെയ്യുന്നത്?",
    "ayah": 3,
    "surah": 99
  },
  {
    "text": "അന്നേ ദിവസം ഭൂമി അതിൻ്റെ മുകളിൽവെച്ച് നടമാടിയ നന്മ-തിന്മകളെ കുറിച്ച് സംസാരിക്കുന്നതാണ്.",
    "ayah": 4,
    "surah": 99
  },
  {
    "text": "കാരണം അല്ലാഹു അതിന് (അവ) അറിയിച്ചു നൽകുകയും, അപ്രകാരം ചെയ്യാൻ അതിനോട് കൽപ്പിക്കുകയും ചെയ്തിരിക്കുന്നു.",
    "ayah": 5,
    "surah": 99
  },
  {
    "text": "ഭൂമി പ്രകമ്പനം കൊള്ളുന്ന ഭയാനകമായ ആ ദിവസത്തിൽ, ജനങ്ങൾ വിചാരണയുടെ വേദിയിൽ നിന്ന് ഇഹലോകത്ത് തങ്ങൾ പ്രവർത്തിച്ചതെന്തോ, അത് സാക്ഷ്യം വഹിക്കുന്നതിനായി വിവിധ വിഭാഗങ്ങളായി പുറപ്പെടുന്നതാണ്.",
    "ayah": 6,
    "surah": 99
  },
  {
    "text": "അപ്പോൾ ആരെങ്കിലും ഒരു ചെറിയ ഉറുമ്പിൻ്റെ വലുപ്പത്തോളം നന്മയോ സൽകർമ്മമോ ചെയ്തിട്ടുണ്ടെങ്കിൽ അവൻ അത് തൻ്റെ മുന്നിൽ കാണുക തന്നെ ചെയ്യും.",
    "ayah": 7,
    "surah": 99
  },
  {
    "text": "ആരെങ്കിലും ഒരു ചെറിയ ഉറുമ്പിൻ്റെ അത്ര തന്നെ ചെറിയ തിന്മ ചെയ്തിട്ടുണ്ടെങ്കിൽ അതും അവനവിടെ കാണും.",
    "ayah": 8,
    "surah": 99
  }
]
