[
  {
    "text": "ജനങ്ങളെ കുറിച്ച് ധാരാളമായി പരദൂഷണം പറയുകയും, അവരെ കുത്തി പറയുകയും ചെയ്യുന്നവർക്ക് നാശവും കടുത്ത ശിക്ഷയുമുണ്ടാകട്ടെ.",
    "ayah": 1,
    "surah": 104
  },
  {
    "text": "അവൻ്റെ കാര്യമായ ചിന്ത സമ്പത്ത് സ്വരുക്കൂട്ടലും അതെണ്ണി തിട്ടപ്പെടുത്തി വെക്കലുമാണ്. അതല്ലാത്ത മറ്റൊരു ചിന്തയും അവനില്ല.",
    "ayah": 2,
    "surah": 104
  },
  {
    "text": "അവൻ ഒരുമിച്ചു കൂട്ടിയ സമ്പാദ്യം മരണത്തിൽ നിന്ന് അവനെ രക്ഷിക്കുകയും, അങ്ങനെ ഭൂമിയിൽ കാലാകാലം വസിക്കാമെന്നുമാണ് അവൻ ധരിക്കുന്നത്.",
    "ayah": 3,
    "surah": 104
  },
  {
    "text": "ഈ വിഡ്ഡി ധരിച്ചു വെച്ചിരിക്കുന്നത് പോലെയല്ല കാര്യം. കാഠിന്യം കാരണം വന്നു വീഴുന്നതിനെയെല്ലാം തകർക്കുകയും പൊട്ടിച്ചെറിയുകയും ചെയ്യുന്ന, നരകാഗ്നിയിൽ അവൻ വലിച്ചെറിയപ്പെടുക തന്നെ ചെയ്യും.",
    "ayah": 4,
    "surah": 104
  },
  {
    "text": "അല്ലാഹുവിൻ്റെ റസൂലേ! വന്നു വീഴുന്നതിനെയെല്ലാം തകർക്കുകയും പൊട്ടിച്ചെറിയുകയും ചെയ്യുന്ന ഈ നരകാഗ്നി -ഹുത്വമ- എന്താണെന്ന് അങ്ങേക്ക് അറിയുമോ?",
    "ayah": 5,
    "surah": 104
  },
  {
    "text": "കത്തിജ്വലിപ്പിക്കപ്പെട്ട അല്ലാഹുവിൻ്റെ നരഗാഗ്നിയാകുന്നു അത്.",
    "ayah": 6,
    "surah": 104
  },
  {
    "text": "മനുഷ്യരുടെ ശരീരങ്ങൾ കത്തിക്കരിച്ചതിന് ശേഷം അത് അവരുടെ ഹൃദയങ്ങളിലേക്ക് എത്തും.",
    "ayah": 7,
    "surah": 104
  },
  {
    "text": "അതിൽ ശിക്ഷിക്കപ്പെടുന്നവരുടെ മേൽ അടച്ചു മൂടപ്പെട്ട നിലയിലായിരിക്കും അത്.",
    "ayah": 8,
    "surah": 104
  },
  {
    "text": "അതിൽ നിന്ന് പുറത്തു കടക്കാതിരിക്കാൻ നീട്ടിയുണ്ടാക്കപ്പെട്ട തൂണുകളിൽ (ബന്ധിക്കപ്പെടും)",
    "ayah": 9,
    "surah": 104
  }
]
