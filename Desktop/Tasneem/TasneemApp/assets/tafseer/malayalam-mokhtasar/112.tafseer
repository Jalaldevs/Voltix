[
  {
    "text": "പറയുക; -അല്ലാഹുവിൻ്റെ റസൂലേ!- അവനാകുന്നു അല്ലാഹു; ആരാധിക്കപ്പെടാൻ അർഹതയുള്ള ഒരേയൊരുവൻ. അവനല്ലാതെ മറ്റൊരു ആരാധ്യനില്ല.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "പൂർണതയുടെയും ഭംഗിയുടെയും എല്ലാ വിശേഷണങ്ങളും അതിൻ്റെ ഏറ്റവും മഹത്വത്തോടെയും ഉയർച്ചയോടെയും ഉള്ളവനായ 'സയ്യിദ്' ആണ് അല്ലാഹു. എല്ലാ സൃഷ്ടികളും അവനിലേക്ക് ആശ്രയം തേടുന്നു.",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "അവൻ ആർക്കും ജന്മം നൽകിയിട്ടില്ല. ആരുടെയും മകനുമല്ല അവൻ. അവന് സന്താനവുമില്ല; പിതാവുമില്ല.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "അവനോട് തുല്ല്യതയുള്ള ഒരാളും തന്നെ അവൻ്റെ സൃഷ്ടികളിലില്ല.",
    "ayah": 4,
    "surah": 112
  }
]
