[
  {
    "text": "നബി -ﷺ- അവിടുത്തെ മുഖം ചുളിക്കുകയും തിരിഞ്ഞു കളയുകയും ചെയ്തു.",
    "ayah": 1,
    "surah": 80
  },
  {
    "text": "അന്ധനായിരുന്ന അബ്ദുല്ലാഹി ബ്നു ഉമ്മി മക്തൂം ഉപദേശം ആരാഞ്ഞു കൊണ്ട് വന്നതിനാൽ; അദ്ദേഹം വന്ന സമയം മുശ്രിക്കുകളിലെ (ബഹുദൈവാരാധകർ) നേതാക്കന്മാരുമായി നബി -ﷺ- തിരക്കിലായിരുന്നു; അവർ ഈ സന്മാർഗം സ്വീകരിക്കുമെന്ന പ്രതീക്ഷയിൽ.",
    "ayah": 2,
    "surah": 80
  },
  {
    "text": "റസൂലേ! നിനക്ക് എന്തറിയാം?! ഒരു വേള ആ അന്ധൻ തൻ്റെ തിന്മകളിൽ നിന്ന് ശുദ്ധി പ്രാപിച്ചിരുന്നെങ്കിലോ?",
    "ayah": 3,
    "surah": 80
  },
  {
    "text": "അല്ലെങ്കിൽ നിൻ്റെ ഉപദേശങ്ങൾ കേൾക്കുകയും, അതിൽ നിന്ന് ഗുണപാഠം ഉൾക്കൊള്ളുകയും, അതിൽ നിന്ന് അദ്ദേഹത്തിന് ഉപകാരമുണ്ടാവുകയും ചെയ്തേക്കാം.",
    "ayah": 4,
    "surah": 80
  },
  {
    "text": "എന്നാൽ നീ എത്തിച്ചു കൊടുത്ത ഈമാനിന് പകരം തൻ്റെ കയ്യിലുള്ള സമ്പാദ്യം കൊണ്ട് ധന്യത നടിച്ചവനാകട്ടെ;",
    "ayah": 5,
    "surah": 80
  },
  {
    "text": "നീ അവന് മുഖം നൽകുകയും, അവനിൽ കൂടുതൽ ശ്രദ്ധ പതിപ്പിക്കുകയും ചെയ്യുന്നു.",
    "ayah": 6,
    "surah": 80
  },
  {
    "text": "തൻ്റെ തിന്മകളിൽ നിന്ന് അല്ലാഹുവിലേക്ക് പശ്ചാത്തപിച്ചു മടങ്ങിക്കൊണ്ട് അവൻ സ്വയം പരിശുദ്ധി പ്രാപിച്ചിട്ടില്ലെങ്കിൽ നിനക്കെന്താണ് ബാധിക്കാനുള്ളത്?",
    "ayah": 7,
    "surah": 80
  },
  {
    "text": "എന്നാൽ നിൻ്റെ അടുക്കൽ നന്മ അന്വേഷിച്ചു കൊണ്ട് താൽപര്യത്തോടെ വന്നവനാകട്ടെ;",
    "ayah": 8,
    "surah": 80
  },
  {
    "text": "അവനാകട്ടെ; തൻ്റെ രക്ഷിതാവിനെ ഭയക്കുന്നുണ്ട്.",
    "ayah": 9,
    "surah": 80
  },
  {
    "text": "മുശ്രിക്കുകളിലെ (ബഹുദൈവാരാധകർ) നേതാക്കന്മാരെ പരിഗണിച്ചു കൊണ്ട് നീ അവനിൽ നിന്ന് തിരിഞ്ഞു കളയുകയുമാണ്.",
    "ayah": 10,
    "surah": 80
  },
  {
    "text": "എന്നാൽ കാര്യം അങ്ങനെയല്ല. തീർച്ചയായും ഇത് സ്വീകരിക്കുന്നവർക്ക് ഒരു ഉൽബോധനവും ഓർമ്മപ്പെടുത്തലുമാണ്.",
    "ayah": 11,
    "surah": 80
  },
  {
    "text": "ആരെങ്കിലും അല്ലാഹുവിനെ സ്മരിക്കാനും, ഖുർആനിൽ വന്ന ഉപദേശങ്ങളിൽ നിന്ന് ഗുണപാഠം ഉൾക്കൊള്ളാനും ആഗ്രഹിക്കുന്നുവെങ്കിൽ അവൻ അത് ഓർത്തു കൊള്ളട്ടെ.",
    "ayah": 12,
    "surah": 80
  },
  {
    "text": "ഈ ഖുർആൻ മലക്കുകളുടെ അടുക്കൽ ആദരണീയമായ ചില ഏടുകളിലാണ് ഉള്ളത്.",
    "ayah": 13,
    "surah": 80
  },
  {
    "text": "ഉന്നതമായ ഒരിടത്ത് ഉയർച്ചയിൽ, ഒരു മാലിന്യമോ മ്ലേഛതയോ ബാധിക്കാതെ പരിശുദ്ധമായിക്കൊണ്ട്.",
    "ayah": 14,
    "surah": 80
  },
  {
    "text": "മലക്കുകളിലെ സന്ദേശവാഹകരായ ചിലരുടെ കൈകളിലാണ് അതുള്ളത്.",
    "ayah": 15,
    "surah": 80
  },
  {
    "text": "തങ്ങളുടെ റബ്ബിങ്കൽ ആദരണീയരും, ധാരാളം നന്മകളും സൽകർമ്മങ്ങളും പ്രവർത്തിക്കുന്നവർ ആയിട്ടുള്ളവരുടെ.",
    "ayah": 16,
    "surah": 80
  },
  {
    "text": "നിഷേധിയായ മനുഷ്യൻ ശപിക്കപ്പെട്ടിരിക്കുന്നു. അല്ലാഹുവിലുള്ള അവൻ്റെ നിഷേധം എത്ര കഠിനമാണ് !",
    "ayah": 17,
    "surah": 80
  },
  {
    "text": "ഭൂമിയിൽ അഹങ്കാരിക്കാനും അല്ലാഹുവിനെ നിഷേധിക്കാനും മാത്രം എന്തൊരു വസ്തുവിൽ നിന്നാണ് അല്ലാഹു അവനെ സൃഷ്ടിച്ചിരിക്കുന്നത്?!",
    "ayah": 18,
    "surah": 80
  },
  {
    "text": "കുറച്ച് വെള്ളത്തിൽ നിന്നാണ് അവനെ അല്ലാഹു പടച്ചത്. എന്നിട്ട് ഘട്ടംഘട്ടമായി അവൻ്റെ സൃഷ്ടിപ്പിനെ നിർണ്ണയിക്കുകയും ചെയ്തു.",
    "ayah": 19,
    "surah": 80
  },
  {
    "text": "ആ ഘട്ടങ്ങൾക്ക് ശേഷം മാതാവിൻ്റെ ഗർഭപാത്രത്തിൽ നിന്ന് പുറത്തു കടക്കാനുള്ള വഴി അവന് അല്ലാഹു എളുപ്പമാക്കി കൊടുക്കുകയും ചെയ്തു.",
    "ayah": 20,
    "surah": 80
  },
  {
    "text": "ശേഷം ഭൂമിയിൽ ജീവിക്കാനുള്ള ആയുസ്സ് നിശ്ചയിച്ചു നൽകിയതിന് ശേഷം അവനെ അല്ലാഹു മരിപ്പിച്ചു. പുനരുജ്ജീവിപ്പിക്കപ്പെടുന്നത് വരെ നിലകൊള്ളാൻ അവന് ഖബ്റും നിശ്ചയിച്ചു.",
    "ayah": 21,
    "surah": 80
  },
  {
    "text": "ശേഷം അല്ലാഹു ഉദ്ദേശിച്ചാൽ വിചാരണ ചെയ്യുന്നതിനും (പ്രവർത്തനങ്ങൾക്ക്) പ്രതിഫലം നൽകുന്നതിനുമായി അവനെ ഉയർത്തെഴുന്നേൽപ്പിക്കുന്നതാണ്.",
    "ayah": 22,
    "surah": 80
  },
  {
    "text": "എൻ്റെ രക്ഷിതാവിനോട് എനിക്കുള്ള ബാധ്യതയെല്ലാം ഞാൻ നിറവേറ്റി കഴിഞ്ഞിരിക്കുന്നു എന്ന അവൻ്റെ ധാരണ പോലെയല്ല കാര്യം; അല്ലാഹു അവനോട് കൽപ്പിച്ച നിർബന്ധ കർമ്മങ്ങൾ അവൻ നിർവ്വഹിച്ചിട്ടില്ല.",
    "ayah": 23,
    "surah": 80
  },
  {
    "text": "അല്ലാഹുവിൽ അവിശ്വസിച്ച മനുഷ്യൻ അവൻ കഴിക്കുന്ന ഭക്ഷണത്തിലേക്ക് നോക്കട്ടെ. എങ്ങനെയാണ് അതവന് ലഭിച്ചത്?",
    "ayah": 24,
    "surah": 80
  },
  {
    "text": "അതിൻ്റെ ഉത്ഭവം ആകാശത്ത് നിന്ന് ശക്തിയായി പെയ്ത പേമാരിയിൽ നിന്നാണ്.",
    "ayah": 25,
    "surah": 80
  },
  {
    "text": "പിന്നീട് നാം ഭൂമിയെ പിളർത്തുകയും, അതിൽ നിന്ന് സസ്യങ്ങൾ പൊട്ടിമുളക്കുകയും ചെയ്തു.",
    "ayah": 26,
    "surah": 80
  },
  {
    "text": "അങ്ങനെ നാം അതിൽ ധാന്യങ്ങൾ മുളപ്പിച്ചു. അതിൽ ഗോതമ്പും ചോളവും മറ്റുമെല്ലാമുണ്ട്.",
    "ayah": 27,
    "surah": 80
  },
  {
    "text": "അതിൽ നാം മുന്തിരിയും, നിങ്ങളൂടെ കന്നുകാലികൾക്ക് ഭക്ഷണമായി കൊണ്ട് സസ്യങ്ങളും മുളപ്പിച്ചു.",
    "ayah": 28,
    "surah": 80
  },
  {
    "text": "അതിൽ നാം ഒലീവും ഈന്തപ്പനയും മുളപ്പിച്ചു.",
    "ayah": 29,
    "surah": 80
  },
  {
    "text": "അതിൽ നാം ധാരാളം ചെടികളുള്ള പൂന്തോട്ടങ്ങളും മുളപ്പിച്ചു.",
    "ayah": 30,
    "surah": 80
  },
  {
    "text": "അതിൽ പഴവർഗങ്ങൾ മുളപ്പിച്ചു, നിങ്ങളുടെ കന്നുകാലികൾക്ക് മേയാനുള്ള ഭക്ഷണവും നാം മുളപ്പിച്ചു.",
    "ayah": 31,
    "surah": 80
  },
  {
    "text": "നിങ്ങൾക്കും നിങ്ങളുടെ കന്നുകാലികൾക്കും അതിൽ നിന്ന് ഉപകരിക്കുന്നതിന് വേണ്ടി.",
    "ayah": 32,
    "surah": 80
  },
  {
    "text": "എന്നാൽ ചെകിടടിപ്പിക്കുന്ന ഉച്ചത്തിലുള്ള അട്ടഹാസം വന്നു കഴിഞ്ഞാൽ; കാഹളത്തിലുള്ള രണ്ടാമത്തെ ഊത്താണ് അത്.",
    "ayah": 33,
    "surah": 80
  },
  {
    "text": "മനുഷ്യൻ തൻ്റെ സഹോദരനിൽ നിന്ന് ഓടിയകലുന്ന ദിവസം.",
    "ayah": 34,
    "surah": 80
  },
  {
    "text": "തൻ്റെ മാതാവിൽ നിന്നും പിതാവിൽ നിന്നും അവൻ ഓടിരക്ഷപ്പെടും.",
    "ayah": 35,
    "surah": 80
  },
  {
    "text": "അവൻ തൻ്റെ ഭാര്യയിൽ നിന്നും, മക്കളിൽ നിന്നും ഓടി രക്ഷപ്പെടും.",
    "ayah": 36,
    "surah": 80
  },
  {
    "text": "ആ ദിവസത്തിലെ പ്രയാസത്തിൻ്റെ കാഠിന്യത്താൽ ഓരോ മനുഷ്യനും മറ്റുള്ളവരെ കുറിച്ച് ശ്രദ്ധിക്കാൻ സാധിക്കാത്ത വണ്ണം സ്വന്തം വിഷയങ്ങൾ തന്നെയുണ്ടായിരിക്കും.",
    "ayah": 37,
    "surah": 80
  },
  {
    "text": "സൗഭാഗ്യവാന്മാരുടെ മുഖങ്ങൾ അന്നേ ദിവസം പ്രകാശിക്കുന്നതായിരിക്കും.",
    "ayah": 38,
    "surah": 80
  },
  {
    "text": "അല്ലാഹു അവക്ക് വേണ്ടി ഒരുക്കി വെച്ചിട്ടുള്ള അനുഗ്രഹങ്ങൾ കാരണത്താൽ അവ ചിരിയും സന്തോഷവും നിറഞ്ഞു നിൽക്കുന്നതായിരിക്കും.",
    "ayah": 39,
    "surah": 80
  },
  {
    "text": "ദൗർഭാഗ്യവാന്മാരുടെ മുഖങ്ങൾ അന്നേ ദിവസം പൊടി പുരണ്ടതായിരിക്കും.",
    "ayah": 40,
    "surah": 80
  },
  {
    "text": "അവയെ ഇരുട്ട് മൂടിയിരിക്കും.",
    "ayah": 41,
    "surah": 80
  },
  {
    "text": "ഈ പറഞ്ഞ അവസ്ഥയിൽ അകപ്പെടുന്നവർ; ഇസ്ലാമിനെ നിഷേധിക്കലും മ്ലേഛവൃത്തികളും ഒരുമിപ്പിച്ചവരാണവർ.",
    "ayah": 42,
    "surah": 80
  }
]
