[
  {
    "text": "അല്ലാഹുവിൻ്റെ റസൂലേ! പറയുക: അല്ലയോ അല്ലാഹുവിൽ വിശ്വസിക്കാത്തവരേ!",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "ഇന്നോ ഇനിയെന്നെങ്കിലുമോ ഞാൻ നിങ്ങൾ ആരാധിക്കുന്ന വിഗ്രഹങ്ങളെ ആരാധിക്കുകയില്ല.",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "ഞാൻ ആരാധിക്കുന്നതിനെ - അല്ലാഹുവിനെ മാത്രം - നിങ്ങളും ആരാധിക്കുന്നവരല്ല.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "നിങ്ങൾ ആരാധിക്കുന്ന വിഗ്രഹങ്ങളെ ആരാധിക്കുന്നവനുമല്ല ഞാൻ.",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "ഞാൻ ആരാധിക്കുന്നതിനെ - അല്ലാഹുവിനെ മാത്രം - നിങ്ങളും ആരാധിക്കുന്നവരല്ല.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "നിങ്ങൾ സ്വയം പടച്ചുണ്ടാക്കിയ മതം നിങ്ങൾക്കാവാം; എനിക്ക് അല്ലാഹു എൻ്റെ മേൽ അവതരിപ്പിച്ചു തന്ന എൻ്റെ മതം മതി.",
    "ayah": 6,
    "surah": 109
  }
]
