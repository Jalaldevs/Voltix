[
  {
    "text": "Аллоҳ субҳанаҳу ва таоло аср вақтига қасам ичди.",
    "ayah": 1,
    "surah": 103
  },
  {
    "text": "Ҳар бир инсон, шубҳасиз, зарар ва ҳалокатдадир.",
    "ayah": 2,
    "surah": 103
  },
  {
    "text": "Аллоҳга ва пайғамбарига иймон келтирган, солиҳ амаллар қилган ҳамда бир-бирларини ҳаққа ва ҳақ йўлида сабр қилишга чақирган кишиларгина бундан мустаснодир. Улар дунёю охиратда нажот топгувчилардир.",
    "ayah": 3,
    "surah": 103
  }
]
