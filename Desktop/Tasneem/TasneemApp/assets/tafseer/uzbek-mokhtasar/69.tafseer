[
  {
    "text": "Аллоҳ таоло ҳамманинг бошига келувчи қайта тирилишни зикр қиляпти.",
    "ayah": 1,
    "surah": 69
  },
  {
    "text": "Сўнгра: ”Ўша аниқ рўй бергувчи нимадир?” деган савол орқали Қиёматнинг янада буюк эканлигига урғу беради.",
    "ayah": 2,
    "surah": 69
  },
  {
    "text": "Аниқ рўй берувчи нима эканини сиз қаердан ҳам билар эдингиз?",
    "ayah": 3,
    "surah": 69
  },
  {
    "text": "Солиҳ алайҳиссаломнинг Самуд қавми ва Ҳуд алайҳиссаломнинг Од қавми даҳшатларининг шиддатлилигидан одамлар қалбини ларзага солувчи Қиёмат кунига ишонмадилар.",
    "ayah": 4,
    "surah": 69
  },
  {
    "text": "Энди Самуд қавмига келсак, Аллоҳ таоло уларни ўта даҳшатли қичқириқ билан йўқ қилди.",
    "ayah": 5,
    "surah": 69
  },
  {
    "text": "Од қабиласига келсак, Аллоҳ таоло уларни ўта совуқ, шиддатли, қутурган бўрон билан барбод қилди.",
    "ayah": 6,
    "surah": 69
  },
  {
    "text": "Аллоҳ таоло етти кечаю саккиз кундуз давом эттирган бу бўрон уларни бутунлай қириб ташлади. Сиз уларнинг ерда ҳалок бўлиб ётган ҳолатларига назар ташласангиз, худди ерга қулаб, чириб кетган хурмо дарахтларининг илдизларига ўхшаб ётганларини кўрасиз.",
    "ayah": 7,
    "surah": 69
  },
  {
    "text": "Уларга етган бу азобдан кейин тирик қолган бирон жонни кўряпсизми?!",
    "ayah": 8,
    "surah": 69
  },
  {
    "text": "Фиравн ва ундан олдин ўтган қавмлар ҳам, остин-устун қилиб азоб юборилган қишлоқлар, яъни, Лут қавми ҳам ширк ва бошқа гуноҳларни қилган эдилар.",
    "ayah": 9,
    "surah": 69
  },
  {
    "text": "Уларнинг ҳаммаси ўзларига юборилган пайғамбарларига ишонмасдан осийлик қилдилар. Шунда Аллоҳ таоло уларни ортиқ даражада қаттиқ азоблади.",
    "ayah": 10,
    "surah": 69
  },
  {
    "text": "Даҳшатли сув тошқини юз берганида аждодларингизни буйруғимиз билан Нуҳ алайҳиссалом ясаган, сузиб юрувчи кемада қутқардик. Уларнинг қутқарилиши эса сизларнинг ҳам қутқарилишингиз эди.",
    "ayah": 11,
    "surah": 69
  },
  {
    "text": "Кема ва кема ҳодисасини куфр аҳлининг ҳалок бўлиши ва иймон аҳлининг нажот топишига далил-исбот бўладиган ўгит қилдик. Эшитганини англаб оладиганлар эслаб қолишлари учун ҳам шундай қилдик.",
    "ayah": 12,
    "surah": 69
  },
  {
    "text": "Сур чалишга муваккал фаришта Сурни иккинчи марта пуфлаганида;",
    "ayah": 13,
    "surah": 69
  },
  {
    "text": "Ер ва тоғлар ўринларидан кўтарилиб, зарб билан урилиб, бутунлай чилпарчин қилинганида;",
    "ayah": 14,
    "surah": 69
  },
  {
    "text": "Юқорида қайд этилган ишлар содир бўладиган кунда Қиёмат қойим бўлур.",
    "ayah": 15,
    "surah": 69
  },
  {
    "text": "У кунда узоқ вақтлардан бери мустаҳкам турган осмон фаришталар ерга тушиши учун заифлашиб ёрилади.",
    "ayah": 16,
    "surah": 69
  },
  {
    "text": "Осмоннинг чор-атрофида, ҳатто бурчак-бурчакларигача фаришталар турадилар. Ўша куни Парвардигорингизнинг Аршини энг яқин фаришталаридан саккизта улуғ фаришта кўтариб туради.",
    "ayah": 17,
    "surah": 69
  },
  {
    "text": "Эй одамлар, ўша куни сизлар Парвардигорга рўбарў қилинасизлар. Биронта сирингиз У Зотдан махфий қолмайди. Аллоҳ барчасидан Хабардордир.",
    "ayah": 18,
    "surah": 69
  },
  {
    "text": "Номаи аъмоли ўнг қўлидан берилган киши шоду хуррамлигидан: ”Мана олинглар, ўқинглар менинг номаи аъмолимни”, деб юборади.",
    "ayah": 19,
    "surah": 69
  },
  {
    "text": "”Мен дунё ҳаётида қайта тирилишим ва ҳисоб-китоб қилинишимни билган эдим”.",
    "ayah": 20,
    "surah": 69
  },
  {
    "text": "У абадий неъмат кўз олдида намоён бўлгани учун кўнглидагидек, орзу қилганидек ҳаёт кечиради.",
    "ayah": 21,
    "surah": 69
  },
  {
    "text": "Мақом ва мартабаси олий жаннатда бўлади.",
    "ayah": 22,
    "surah": 69
  },
  {
    "text": "Мевалари олгиси келганлар учун жуда яқин бўлади.",
    "ayah": 23,
    "surah": 69
  },
  {
    "text": "Уларга эҳтиром ила: ”Дунё ҳаётида қилиб ўтган солиҳ амалларингиз эвазига озори йўқ егулик ва ичимликлардан хоҳлаганингизча енглар ва ичинглар”, дейилади.",
    "ayah": 24,
    "surah": 69
  },
  {
    "text": "Номаи аъмоли чап қўлидан берилган кимса эса қаттиқ надомат чекиб: ”Азобланишимга сабаб бўлувчи ёмон амалларим битилган бу китоб берилмаса кошкийди”, - деб қолади.",
    "ayah": 25,
    "surah": 69
  },
  {
    "text": "”Жазоим нима эканлигини билмасам кошкийди”.",
    "ayah": 26,
    "surah": 69
  },
  {
    "text": "Менинг дастлабки ўлимим ҳеч қачон қайта тирилмайдиган ўлим бўлганида қанийди.",
    "ayah": 27,
    "surah": 69
  },
  {
    "text": "Мол-давлатим Аллоҳнинг азобидан заррача ҳимоя қилолмади.",
    "ayah": 28,
    "surah": 69
  },
  {
    "text": "Ҳужжат-далилларим, куч-қувватиму обрў-эътиборим барбод бўлди.",
    "ayah": 29,
    "surah": 69
  },
  {
    "text": "”Эй, фаришталар, уларни ушланглар ва қўлларини бўйнига қўшиб кишанланглар”, дейилади.",
    "ayah": 30,
    "surah": 69
  },
  {
    "text": "Кейин уларни жаҳаннам азобини тортишлари учун оловга ташланглар.",
    "ayah": 31,
    "surah": 69
  },
  {
    "text": "”Сўнгра уни етмиш газли занжир билан боғланглар\".",
    "ayah": 32,
    "surah": 69
  },
  {
    "text": "Чунки у Буюк Парвардигорига иймон келтирмаган эди.",
    "ayah": 33,
    "surah": 69
  },
  {
    "text": "Ўзгаларни мискинларга таом беришга ундамаган эди.",
    "ayah": 34,
    "surah": 69
  },
  {
    "text": "Қиёмат куни уни азобдан ҳимоя қиладиган биронта чин дўсти бўлмайди.",
    "ayah": 35,
    "surah": 69
  },
  {
    "text": "У ерда жаҳаннам аҳли баданидан чиққан йирингдан бошқа ҳеч қандай таом йўқдир.",
    "ayah": 36,
    "surah": 69
  },
  {
    "text": "Ўша таомдан гуноҳга ботганлар ва осийларгина ейдилар.",
    "ayah": 37,
    "surah": 69
  },
  {
    "text": "Аллоҳ таоло сизлар кўриб турган нарсаларга қасам ичади.",
    "ayah": 38,
    "surah": 69
  },
  {
    "text": "Сизлар кўрмаётган нарсаларга ҳам қасам ичади.",
    "ayah": 39,
    "surah": 69
  },
  {
    "text": "Қуръон, шак-шубҳасиз, Аллоҳнинг каломидир. Уни улуғ Пайғамбари одамларга ўқиб беради.",
    "ayah": 40,
    "surah": 69
  },
  {
    "text": "У шоирнинг сўзи эмас. Чунки шеърий услубда ёзилмаган. Сизлар жуда кам иймон келтирасизлар.",
    "ayah": 41,
    "surah": 69
  },
  {
    "text": "Биронта коҳиннинг ҳам сўзи эмас. Коҳиннинг сўзи Аллоҳнинг каломидан бутунлай фарқ қилади. Сизлар жуда кам панд-насиҳат, ибрат оласизлар.",
    "ayah": 42,
    "surah": 69
  },
  {
    "text": "Аксинча, у бутун мавжудотлар Парвардигори томонидан нозил қилинган Китобдир.",
    "ayah": 43,
    "surah": 69
  },
  {
    "text": "Агар Муҳаммад алайҳиссалом биз айтмаган сўзни тўқиб айтса,",
    "ayah": 44,
    "surah": 69
  },
  {
    "text": "Биз уни куч-қудратимиз билан ушлаган ва ундан ўч олган бўлар эдик.",
    "ayah": 45,
    "surah": 69
  },
  {
    "text": "Сўнгра унинг юрагига туташган томирини узиб ташлаган бўлар эдик.",
    "ayah": 46,
    "surah": 69
  },
  {
    "text": "Сизлардан биронтангиз уни биздан ҳимоя қила олмайсизлар. Сизларни деб Бизнинг номимиздан гап тўқиши эҳтимолдан жуда йироқдир.",
    "ayah": 47,
    "surah": 69
  },
  {
    "text": "Қуръон шак-шубҳасиз, Аллоҳ таолонинг буйруқларини бажариб, тақиқларидан тийилган тақводорлар учун панд-насиҳатдир.",
    "ayah": 48,
    "surah": 69
  },
  {
    "text": "Сизларнинг орангизда бу Қуръонни ёлғонга чиқараётганлар борлигини аниқ биламиз.",
    "ayah": 49,
    "surah": 69
  },
  {
    "text": "Қуръонни ёлғонга чиқариш қиёмат Куни чексиз ҳасрат-надоматдир.",
    "ayah": 50,
    "surah": 69
  },
  {
    "text": "Албатта Қуръон аниқ ҳақиқатдир. Унинг Аллоҳ томонидан эканида ҳеч қандай шубҳа-гумон йўқдир.",
    "ayah": 51,
    "surah": 69
  },
  {
    "text": "Эй Пайғамбар, буюк Парвардигорингизни нолойиқ нарсалардан покланг ва номини ёд этинг!",
    "ayah": 52,
    "surah": 69
  }
]
