[
  {
    "text": "Di', o Messaggero: \"O voi che non credete in Allāh,",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "io non adorerò, né ora né in futuro, gli idoli che voi adorate,",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "e voi non adorate Colui che io adoro, ovvero Allāh solo,",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "e io non adorerò gli idoli che avete adorato,",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "e voi non adorate Colui che io adoro, ovvero Allāh solo.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "A voi la vostra religione, che avete inventato appositamente per voi stessi, e a me la mia religione, che Allāh mi ha rivelato,",
    "ayah": 6,
    "surah": 109
  }
]
