[
  {
    "text": "Per le abitudini di Ǭura'ish e le loro ricorrenze,",
    "ayah": 1,
    "surah": 106
  },
  {
    "text": "la ricorrenza del loro viaggio invernale in Yemen, e del loro viaggio estivo verso Al-Shām, in tutta sicurezza.",
    "ayah": 2,
    "surah": 106
  },
  {
    "text": "Che adorino Allāh solo, Dio di questa Sacra Casa, Colui che ha agevolato loro questo viaggio, e che non Gli associno nessuno,",
    "ayah": 3,
    "surah": 106
  },
  {
    "text": "Colui che li ha sfamati e che li ha liberati dalla paura, poiché ha posto nel cuore degli Arabi il rispetto del Luogo Sacro e dei suoi abitanti.",
    "ayah": 4,
    "surah": 106
  }
]
