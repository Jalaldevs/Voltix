[
  {
    "text": "Di', o Messaggero: \"Mi rifugio presso il Dio dell'albore e imploro la Sua protezione,",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "dalla parte maligna delle creature,",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "e mi rifugio presso Allāh dal male di ogni belva e dei ladri che si rivelano nella notte,",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "e mi rifugio presso di Lui dal male delle streghe che soffiano sui nodi per praticare magia,",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "e mi rifugio presso di Lui dal male dell'invidioso quando compie qualche atto causato dall'invidia.",
    "ayah": 5,
    "surah": 113
  }
]
