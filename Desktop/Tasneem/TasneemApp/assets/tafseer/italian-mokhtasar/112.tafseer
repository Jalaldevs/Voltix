[
  {
    "text": "Di', o Messaggero: \"Egli è Allāh, L'unico detentore della Divinità, non vi è altra divinità all'infuori di Lui.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "Egli è il Sovrano, Colui che detiene tutti i sublimi e nobili attributi della perfezione e della bellezza, Colui al quale si rivolgono tutte le creature nel momento del bisogno,",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "Colui che non ha generato nessuno e che non è stato generato da nessuno; Egli non ha figli, gloria Sua, né padre,",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "né vi è qualcuno pari a Lui nel Suo Creato.",
    "ayah": 4,
    "surah": 112
  }
]
