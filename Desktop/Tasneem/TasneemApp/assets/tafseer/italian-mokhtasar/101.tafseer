[
  {
    "text": "L'Ora che scuote i cuori della gente per i suoi grandi orrori.",
    "ayah": 1,
    "surah": 101
  },
  {
    "text": "Cos'è quest'Ora che scuote i cuori della gente con i suoi grandi orrori?!",
    "ayah": 2,
    "surah": 101
  },
  {
    "text": "E cosa ne sai, o Messaggero, di cos'è quest'Ora che scuote i cuori della gente con i suoi orrori?! In verità, è il Giorno della Resurrezione.",
    "ayah": 3,
    "surah": 101
  },
  {
    "text": "Il Giorno in cui i cuori della gente verranno scossi e saranno come falene disperse qua e là,",
    "ayah": 4,
    "surah": 101
  },
  {
    "text": "e le montagne saranno soffici come lana colorata, per la loro leggerezza e la facilità con cui verranno spostate.",
    "ayah": 5,
    "surah": 101
  },
  {
    "text": "Quanto a colui il cui peso delle azioni pende verso il bene, rispetto alle sue azioni malvagie,",
    "ayah": 6,
    "surah": 101
  },
  {
    "text": "costui godrà di un'esistenza agiata nel Paradiso,",
    "ayah": 7,
    "surah": 101
  },
  {
    "text": "mentre quanto a colui il cui peso delle azioni penderà verso il male, rispetto alle buone azioni,",
    "ayah": 8,
    "surah": 101
  },
  {
    "text": "la sua dimora e il suo destino, nel Giorno della Resurrezione, sarà l'Inferno.",
    "ayah": 9,
    "surah": 101
  },
  {
    "text": "E cosa ne sai, o Messaggero, di cosa sia?!",
    "ayah": 10,
    "surah": 101
  },
  {
    "text": "È un fuoco ardente.",
    "ayah": 11,
    "surah": 101
  }
]
