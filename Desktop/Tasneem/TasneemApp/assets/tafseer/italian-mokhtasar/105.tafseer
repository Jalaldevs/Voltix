[
  {
    "text": "Non sai, o Messaggero, cosa il tuo Dio ne ha fatto di Abraha e i suoi compagni dell'elefante, quando cercarono di demolire la Ka’bah?!",
    "ayah": 1,
    "surah": 105
  },
  {
    "text": "Allāh vanificò i loro malvagi piani di distruggerla, e non ottennero ciò che desideravano, ovvero sviare la gente della Ka'bah, e non poterono farle nulla di male.",
    "ayah": 2,
    "surah": 105
  },
  {
    "text": "E inviò loro degli uccelli, stormo dopo stormo,",
    "ayah": 3,
    "surah": 105
  },
  {
    "text": "che scagliavano contro di loro pietre di argilla fossile,",
    "ayah": 4,
    "surah": 105
  },
  {
    "text": "e Allāh li rese come erba di campo che le bestie mangiano e calpestano.",
    "ayah": 5,
    "surah": 105
  }
]
