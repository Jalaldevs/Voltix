[
  {
    "text": "Di', o Messaggero: \"Mi affido al Dio degli uomini e imploro la Sua protezione;",
    "ayah": 1,
    "surah": 114
  },
  {
    "text": "il Sovrano degli uomini, che fa di loro ciò che vuole; non hanno altro sovrano all'infuori di Lui.",
    "ayah": 2,
    "surah": 114
  },
  {
    "text": "La loro vera divinità, non vi è altra reale divinità, all'infuori di Lui,",
    "ayah": 3,
    "surah": 114
  },
  {
    "text": "dal male di Satana, che sussurra all'individuo quando non si cura di invocare Allāh, oppure quando tarda a invocarlo,",
    "ayah": 4,
    "surah": 114
  },
  {
    "text": "facendo penetrare i suoi sussurri nel cuore della gente,",
    "ayah": 5,
    "surah": 114
  },
  {
    "text": "sia uomini che Jinn.",
    "ayah": 6,
    "surah": 114
  }
]
