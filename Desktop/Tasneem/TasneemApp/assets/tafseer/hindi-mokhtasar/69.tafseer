[
  {
    "text": "अल्लाह मरणोपरांत दोबारा जीवित होकर उठने की घड़ी का उल्लेख कर हा है, जो सभी लोगों पर घटित होगी।",
    "ayah": 1,
    "surah": 69
  },
  {
    "text": "फिर अल्लाह इस सवाल के द्वारा उसकी महानता और गंभीरता का वर्णन कर रहा है कि : वह होकर रहने वाली क्या चीज़ है?",
    "ayah": 2,
    "surah": 69
  },
  {
    "text": "और आपको किस चीज़ ने ज्ञात कराया कि यह होकर रहने वाली क्या है?",
    "ayah": 3,
    "surah": 69
  },
  {
    "text": "सालेह अलैहिस्सलाम की जाति समूद और हूद अलैहिस्सलाम की जाति आद ने उस क़ियामत को झुठलाया, जो अपनी भयावहता की तीव्रता से लोगों (के दिलों) को खड़खड़ा (दहला) देगी।",
    "ayah": 4,
    "surah": 69
  },
  {
    "text": "जहाँ तक समूद के लोगों की बात है, तो अल्लाह ने उन्हें ऐसी आवाज़ से नष्ट कर दिया, जो तीव्रता और भयावहता में अंत को पहुँच गई थी।",
    "ayah": 5,
    "surah": 69
  },
  {
    "text": "और रही बात आद समुदाय की, तो अल्लाह ने उन्हें बड़ी ठंडी और प्रचंड आँधी से विनष्ट कर दिया।",
    "ayah": 6,
    "surah": 69
  },
  {
    "text": "अल्लाह ने उसे उनपर सात रातों और आठ दिनों की अवधि के लिए भेज दिया, जो उन्हें जड़ से विनष्ट कर रही थी। चुनाँचे आप उन्हें उनके घरों में मृत ज़मीन पर पड़े हुए देखते, गोया कि वे विनष्ट किए जाने के बाद धरती पर गिरे हुए खजूरों के जर्जर तने हों।",
    "ayah": 7,
    "surah": 69
  },
  {
    "text": "तो क्या उनके इस यातना से पीड़ित होने के बाद आपको उनमें से कोई भी प्राणी बाक़ी दिखाई देता है?!",
    "ayah": 8,
    "surah": 69
  },
  {
    "text": "फ़िरऔन और उससे पहले के समुदायों और ऊपर-नीचे उलटकर यातना दी जाने वाली बस्तियों अर्थात लूत अलैहिस्सलाम की जाति के लोगों ने शिर्क एवं अवज्ञा जैसे गलत कार्य किए।",
    "ayah": 9,
    "surah": 69
  },
  {
    "text": "चुनाँचे उनमें से प्रत्येक ने अपने रसूल की अवज्ञा की और उसे झुठलाया, तो अल्लाह ने उनकी उससे कहीं अधिक पकड़ की, जो उनके विनाश के लिए काफ़ी थी।",
    "ayah": 10,
    "surah": 69
  },
  {
    "text": "जब पानी ऊंचाई में अपनी सीमा से ऊपर बढ़ गया, तो हमने उन लोगों को, जिनकी पुश्त में तुम थे, उस बहती नाव में सवार किया, जिसे नूह अलैहिस्सलाम ने हमारे आदेश से बनाया था। तो इस तरह यह तुम्हें सवार करना था।",
    "ayah": 11,
    "surah": 69
  },
  {
    "text": "ताकि हम नाव और उसकी कहानी को एक उपदेश बना दें, जिससे काफ़िरों को नष्ट करने और ईमान वालों को मुक्ति प्रदान करने पर प्रमाण ग्रहण किया जाए और उसे ऐसे कान याद रखें जो सुनी हुई बातों को याद रखने वाले हैं।",
    "ayah": 12,
    "surah": 69
  },
  {
    "text": "फिर जब सूर में फूँक मारने पर नियुक्त फ़रिश्ता एक फूँक मारेगा, और यह दूसरी बार फूँक मारना है।",
    "ayah": 13,
    "surah": 69
  },
  {
    "text": "और धरती तथा पहाड़ों को उठाया जाएगा और दोनों को एक ही बार इस ज़ोर से टकराया जाएगा कि धरती के हिस्से तथा उसके पहाड़ों के हिस्से अलग-अलग हो जाएँगे।",
    "ayah": 14,
    "surah": 69
  },
  {
    "text": "जिस दिन यह सब कुछ होगा, उस दिन क़ियामत आ जाएगी।",
    "ayah": 15,
    "surah": 69
  },
  {
    "text": "और उस दिन आसमान फट जाएगा, ताकि उससे फ़रिश्ते उतर सकें। तो उस दिन वह कमज़ोर होगा, जबकि वह पहले मज़बूत और सुसंगत था।",
    "ayah": 16,
    "surah": 69
  },
  {
    "text": "और फ़रिश्ते उसके किनारों पर होंगे, तथा उस महान दिन में आठ निकटवर्ती फ़रिश्ते आपके पालनहार के अर्श को उठाए हुए होंगे।",
    "ayah": 17,
    "surah": 69
  },
  {
    "text": "उस दिन तुम (ऐ लोगो) अल्लाह के सामने पेश किए जाओगे। तुम्हारी कोई गुप्त बात अल्लाह से छिपी नहीं रहेगी। बल्कि अल्लाह उसके बारे में जानने वाला, उससे अवगत होगा।",
    "ayah": 18,
    "surah": 69
  },
  {
    "text": "फिर रहा वह व्यक्ति, जिसे उसके कर्मों की किताब उसके दाएँ हाथ में दी गई, तो वह खुशी और प्रसन्नता से कहेगा : लो, मेरे कर्मों की किताब पढ़ो।",
    "ayah": 19,
    "surah": 69
  },
  {
    "text": "मैं दुनिया में जानता था और मुझे यक़ीन था कि मैं मरने के बाद पुनर्जीवित कर उठाया जाने वाला हूँ और अपना प्रतिफल पाने वाला हूँ।",
    "ayah": 20,
    "surah": 69
  },
  {
    "text": "अतः वह सुखमय और संतोषजनक जीवन में होगा, क्योंकि उसे स्थायी आनंद दिखाई देगा।",
    "ayah": 21,
    "surah": 69
  },
  {
    "text": "उच्च स्थान एवं प्रतिष्ठा वाली जन्नत में होगा।",
    "ayah": 22,
    "surah": 69
  },
  {
    "text": "जिसके फल, उन्हें खाने वाले से बिल्कुल क़रीब होंगे।",
    "ayah": 23,
    "surah": 69
  },
  {
    "text": "उनके सम्मान में कहा जाएगा : तुमने दुनिया में बीते हुए दिनों में जो अच्छे कर्म करके आगे भेजे थे, उसके बदले में, बिना किसी नुक़सान के खाओ और पियो।",
    "ayah": 24,
    "surah": 69
  },
  {
    "text": "और रहा वह व्यक्ति, जिसे उसका कर्म-पत्र उसके बाएँ हाथ में दिया गया, तो वह पछतावे की तीव्रता से कहेगा : ऐ काश! मुझे मेरा कर्म-पत्र न दिया जाता, क्योंकि उसमें ऐसे बुरे कार्य हैं, जो मुझे यातना का पात्र बनाते हैं।",
    "ayah": 25,
    "surah": 69
  },
  {
    "text": "और काश मैं अपने हिसाब के बारे में कुछ न जानता।",
    "ayah": 26,
    "surah": 69
  },
  {
    "text": "ऐ काश कि वह मौत जो मुझे आई थी, ऐसी मौत होती जिसके बाद मैं कभी उठाया न जाता।",
    "ayah": 27,
    "surah": 69
  },
  {
    "text": "मेरा धन मुझसे अल्लाह की यातना को कुछ भी न टाल सका।",
    "ayah": 28,
    "surah": 69
  },
  {
    "text": "मेरा तर्क और वह शक्ति एवं वैभव जिनपर मैं भरोसा किया करता था, सब कुछ मुझसे जाता रहा।",
    "ayah": 29,
    "surah": 69
  },
  {
    "text": "और कहा जाएगा : (ऐ फ़रिश्तो) उसे पकड़ो और उसके हाथों को उसकी गरदन के साथ जकड़ दो।",
    "ayah": 30,
    "surah": 69
  },
  {
    "text": "फिर उसे आग में डाल दो, ताकि उसकी गर्मी झेलता रहे।",
    "ayah": 31,
    "surah": 69
  },
  {
    "text": "फिर उसे एक ऐसी ज़ंजीर में दाख़िल कर दो, जिसकी लंबाई सत्तर गज़ है।",
    "ayah": 32,
    "surah": 69
  },
  {
    "text": "निश्चय वह सबसे महान अल्लाह पर ईमान नहीं रखता था।",
    "ayah": 33,
    "surah": 69
  },
  {
    "text": "और दूसरों को ग़रीब को खाना खिलाने के लिए प्रोत्साहित नहीं करता था।",
    "ayah": 34,
    "surah": 69
  },
  {
    "text": "अतः क़ियामत के दिन उसका कोई क़रीबी (रिश्तेदार) नहीं है, जो उससे यातना को टाल सके।",
    "ayah": 35,
    "surah": 69
  },
  {
    "text": "और उसके खाने के लिए जहन्नमियों के शरीर से निकले हुए पीप के सिवा कोई भोजन नहीं है।",
    "ayah": 36,
    "surah": 69
  },
  {
    "text": "यह भोजन केवल वही लोग खाते हैं, जो गुनहगार और पापी हैं।",
    "ayah": 37,
    "surah": 69
  },
  {
    "text": "अल्लाह ने उन चीज़ों की क़सम खाई है, जिन्हें तुम देखते हो।",
    "ayah": 38,
    "surah": 69
  },
  {
    "text": "और उन चीज़ों की भी क़सम खाई है, जिन्हें तुम नहीं देखते हो।",
    "ayah": 39,
    "surah": 69
  },
  {
    "text": "निःसंदेह क़ुरआन अल्लाह की वाणी है, जिसे लोगों के सामने उसका सम्मानित रसूल पढ़कर सुनाता है।",
    "ayah": 40,
    "surah": 69
  },
  {
    "text": "यह किसी कवि की वाणी नहीं है। क्योंकि यह कविता के रूप में नहीं है। तुम बहुत कम ईमान लाते हो।",
    "ayah": 41,
    "surah": 69
  },
  {
    "text": "यह किसी काहिन की भी वाणी नहीं है। क्योंकि काहिनों की बात इस क़ुरआन से बिलकुल अलग होती है। तुम बहुत कम शिक्षा ग्रहण करते हो।",
    "ayah": 42,
    "surah": 69
  },
  {
    "text": "बल्कि यह सभी प्राणियों के पालनहार की ओर से उतारा हुआ है।",
    "ayah": 43,
    "surah": 69
  },
  {
    "text": "और यदि मुहम्मद (सल्लल्लाहु अलैहि व सल्लम) हमपर कोई ऐसी बात गढ़कर लगा देते, जो हमने नहीं कही है।",
    "ayah": 44,
    "surah": 69
  },
  {
    "text": "तो निश्चय हम उससे बदला लेते और उसे शक्ति और क्षमता के साथ पकड़ लेते।",
    "ayah": 45,
    "surah": 69
  },
  {
    "text": "फिर निश्चय हम उसकी दिल से मिली हुई नस काट देते।",
    "ayah": 46,
    "surah": 69
  },
  {
    "text": "फिर तुममें से कोई भी हमें उससे रोक नहीं सकता। इसलिए उसका तुम्हारी ख़ातिर हमपर कोई बात गढ़कर लगाना बहुत दूर की बात है।",
    "ayah": 47,
    "surah": 69
  },
  {
    "text": "निःसंदेह क़ुरआन उन लोगों के लिए निश्चय एक उपदेश है, जो अपने पालनहार से, उसके आदेशों का पालन करके और उसकी मना की हुई चीज़ों से बचकर, डरने वाले हैं।",
    "ayah": 48,
    "surah": 69
  },
  {
    "text": "और निःसंदेह हम भली-भाँति जानते हैं कि तुम्हारे अंदर कुछ लोग ऐसे हैं, जो इस क़ुरआन को झुठलाते हैं।",
    "ayah": 49,
    "surah": 69
  },
  {
    "text": "और निःसंदेह क़ुरआन को झुठलाना निश्चित रूप से क़ियामत के दिन बड़े पछतावे का कारण होगा।",
    "ayah": 50,
    "surah": 69
  },
  {
    "text": "और निःसंदेह क़ुरआन बिलकुल विश्वसनीय सत्य है, जिसके अल्लाह की ओर से होने में कोई शक एवं संदेह नहीं है।",
    "ayah": 51,
    "surah": 69
  },
  {
    "text": "तो (ऐ रसूल) आप अपने पालनहार को उस चीज़ से पवित्र ठहराएँ, जो उसके योग्य नहीं है। और अपने महान पालनहार के नाम का जप करें।",
    "ayah": 52,
    "surah": 69
  }
]
