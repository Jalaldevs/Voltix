[
  {
    "text": "Скажи, о Посланник: «Прибегаю к защите Господа утра, и прошу у Него убежища",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "от зла творений, причиняющих вред,",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "и прибегаю к защите Аллаха от зла, которое проявляется ночью от животных и воров,",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "и я прибегаю к Его защите от зла колдунов, поплевывающих на узлы,",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "и я прибегаю к Его защите от зла завистника, когда он поступает в соответствии со своей завистью».",
    "ayah": 5,
    "surah": 113
  }
]
