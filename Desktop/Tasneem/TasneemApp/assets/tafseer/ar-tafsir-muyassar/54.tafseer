[
  {
    "text": "تسمية السورة\n\n• سميت القمر؛ لافتتاحها بحادثة انشقاق القمر، وهي من المعجزات التي أيد الله بها نبينا محمدًا ﷺ.\n\nمن مقاصد السورة\n\n• الإنذار باقتراب القيامة وبما يلقاه الناس حين البعث من الشدائد؛ حين يخرجون من القبور كأنهم جرادٌ منتشرٌ.\n\n• دعوة المشركين إلى الاعتبار والتبصُّر بمشاهدِ التنكيل والتعذيب التي حلَّت بالطغاة المتجبرين في الدنيا؛ لتكذيبهم رسلَ الله، وأنهم سيَلْقون ما لقي أولئك، وتحذيرُهم مما هو أشدُّ من ذلك؛ وهو يوم القيامة وما فيه من أهوالٍ.\n\n[التفسير]\n\nدنت القيامة، وانفلق القمر فلقتين، حين سأل كفار «مكة» النبي ﷺ أن يريهم آية، فدعا الله، فأراهم تلك الآية.",
    "ayah": 1,
    "surah": 54
  },
  {
    "text": "وإن ير المشركون دليلًا وبرهانًا على صدق الرسول محمد ﷺ، يُعرضوا عن الإيمان به وتصديقه مكذبين منكرين، ويقولوا بعد ظهور الدليل: هذا سحر باطل ذاهب مضمحل لا دوام له.",
    "ayah": 2,
    "surah": 54
  },
  {
    "text": "وكذَّبوا النبي ﷺ، واتبعوا ضلالتهم وما دعتهم إليه أهواؤهم من التكذيب، وكلُّ أمر من خير أو شر واقع بأهله يوم القيامة عند ظهور الثواب والعقاب.",
    "ayah": 3,
    "surah": 54
  },
  {
    "text": "ولقد جاء كفار قريش من أنباء الأمم المكذبة برسلها، وما حلَّ بها من العذاب، ما فيه كفاية لردعهم عن كفرهم وضلالهم.",
    "ayah": 4,
    "surah": 54
  },
  {
    "text": "هذا القرآن الذي جاءهم حكمة عظيمة بالغة غايتَها، فأي شيء تغني النذر عن قوم أعرضوا وكذَّبوا بها؟",
    "ayah": 5,
    "surah": 54
  },
  {
    "text": "فأعرض -أيها الرسول- عنهم، وانتظر بهم يومًا عظيمًا. يوم يدعو المَلَك بنفخه في «القَرْن» إلى أمر فظيع منكر، وهو موقف الحساب.",
    "ayah": 6,
    "surah": 54
  },
  {
    "text": "ذليلة أبصارهم يخرجون من القبور كأنهم في انتشارهم وسرعة سيرهم للحساب جرادٌ منتشر في الآفاق، مسرعين إلى ما دُعُوا إليه، يقول الكافرون: هذا يوم عَسِرٌ شديد الهول.",
    "ayah": 7,
    "surah": 54
  },
  {
    "text": "ذليلة أبصارهم يخرجون من القبور كأنهم في انتشارهم وسرعة سيرهم للحساب جرادٌ منتشر في الآفاق، مسرعين إلى ما دُعُوا إليه، يقول الكافرون: هذا يوم عَسِرٌ شديد الهول.",
    "ayah": 8,
    "surah": 54
  },
  {
    "text": "كذَّبت قبل قومك -أيها الرسول- قوم نوح فكذَّبوا عبدنا نوحًا، وقالوا: هو مجنون، وانتهروه متوعدين إياه بأنواع الأذى، إن لم ينته عن دعوته.",
    "ayah": 9,
    "surah": 54
  },
  {
    "text": "فدعا نوح ربه أنِّي ضعيف عن مقاومة هؤلاء، فانتصر لي بعقاب من عندك على كفرهم بك.",
    "ayah": 10,
    "surah": 54
  },
  {
    "text": "فأجبنا دعاءه، ففتحنا أبواب السماء بماء كثير متدفق، وشققنا الأرض عيونًا متفجرة بالماء، فالتقى ماء السماء وماء الأرض على إهلاكهم الذي قدَّره الله لهم؛ جزاء شركهم.",
    "ayah": 11,
    "surah": 54
  },
  {
    "text": "فأجبنا دعاءه، ففتحنا أبواب السماء بماء كثير متدفق، وشققنا الأرض عيونًا متفجرة بالماء، فالتقى ماء السماء وماء الأرض على إهلاكهم الذي قدَّره الله لهم؛ جزاء شركهم.",
    "ayah": 12,
    "surah": 54
  },
  {
    "text": "وحملنا نوحًا ومَن معه على سفينة ذات ألواح ومسامير شُدَّت بها، تجري بمرأى منا وحفظ، وأغرقنا المكذبين؛ جزاء لهم على كفرهم وانتصارًا لنوح عليه السلام. وفي هذه الآية دليل على إثبات صفة العينين لله سبحانه وتعالى، كما يليق به.",
    "ayah": 13,
    "surah": 54
  },
  {
    "text": "وحملنا نوحًا ومَن معه على سفينة ذات ألواح ومسامير شُدَّت بها، تجري بمرأى منا وحفظ، وأغرقنا المكذبين؛ جزاء لهم على كفرهم وانتصارًا لنوح عليه السلام. وفي هذه الآية دليل على إثبات صفة العينين لله سبحانه وتعالى، كما يليق به.",
    "ayah": 14,
    "surah": 54
  },
  {
    "text": "ولقد أبقينا قصة نوح مع قومه عبرة ودليلًا على قدرتنا لمن بعد نوح؛ ليعتبروا ويتعظوا بما حلَّ بهذه الأمة التي كفرت بربها، فهل من متعظ يتعظ؟ فكيف كان عذابي ونذري لمن كفر بي وكذب رسلي، ولم يتعظ بما جاءت به؟ إنه كان عظيمًا مؤلمًا.",
    "ayah": 15,
    "surah": 54
  },
  {
    "text": "ولقد أبقينا قصة نوح مع قومه عبرة ودليلًا على قدرتنا لمن بعد نوح؛ ليعتبروا ويتعظوا بما حلَّ بهذه الأمة التي كفرت بربها، فهل من متعظ يتعظ؟ فكيف كان عذابي ونذري لمن كفر بي وكذب رسلي، ولم يتعظ بما جاءت به؟ إنه كان عظيمًا مؤلمًا.",
    "ayah": 16,
    "surah": 54
  },
  {
    "text": "ولقد سَهَّلْنا لفظ القرآن للتلاوة والحفظ، ومعانيه للفهم والتدبر، لمن أراد أن يتذكر ويعتبر، فهل من متعظ به؟ وفي هذه الآية وما ناظرها من السورة حثٌّ على الاستكثار من تلاوة القرآن وتعلمه وتعليمه.",
    "ayah": 17,
    "surah": 54
  },
  {
    "text": "كذبت عاد هودًا فعاقبناهم، فكيف كان عذابي لهم على كفرهم، ونذري على تكذيب رسولهم، وعدم الإيمان به؟ إنه كان عظيمًا مؤلمًا.",
    "ayah": 18,
    "surah": 54
  },
  {
    "text": "إنّا أرسلنا عليهم ريحًا شديدة البرد، في يوم شؤم مستمر عليهم بالعذاب والهلاك، تقتلع الناس من مواضعهم على الأرض، فترمي بهم على رؤوسهم فتدق أعناقهم، وتفصل رؤوسهم عن أجسادهم، فتتركهم كالنخل المنقلع من أصله.",
    "ayah": 19,
    "surah": 54
  },
  {
    "text": "إنّا أرسلنا عليهم ريحًا شديدة البرد، في يوم شؤم مستمر عليهم بالعذاب والهلاك، تقتلع الناس من مواضعهم على الأرض، فترمي بهم على رؤوسهم فتدق أعناقهم، وتفصل رؤوسهم عن أجسادهم، فتتركهم كالنخل المنقلع من أصله.",
    "ayah": 20,
    "surah": 54
  },
  {
    "text": "فكيف كان عذابي ونذري لمن كفر بي، وكذَّب رسلي ولم يؤمن بهم؟ إنه كان عظيمًا مؤلمًا.",
    "ayah": 21,
    "surah": 54
  },
  {
    "text": "ولقد سَهَّلنا لفظ القرآن للتلاوة والحفظ، ومعانيه للفهم والتدبر، لمن أراد أن يتذكر ويعتبر، فهل من متعظ به؟",
    "ayah": 22,
    "surah": 54
  },
  {
    "text": "كذبت ثمود -وهم قوم صالح- بالآيات التي أُنذِروا بها، فقالوا: أبشرًا منا واحدًا نتبعه نحن الجماعة الكثيرة وهو واحد؟ إنا إذًا لفي بُعْدٍ عن الصواب وجنون.",
    "ayah": 23,
    "surah": 54
  },
  {
    "text": "كذبت ثمود -وهم قوم صالح- بالآيات التي أُنذِروا بها، فقالوا: أبشرًا منا واحدًا نتبعه نحن الجماعة الكثيرة وهو واحد؟ إنا إذًا لفي بُعْدٍ عن الصواب وجنون.",
    "ayah": 24,
    "surah": 54
  },
  {
    "text": "أأنزل عليه الوحي وخُصَّ بالنبوة مِن بيننا، وهو واحد منا؟ بل هو كثير الكذب والتجبر. سَيَرون عند نزول العذاب بهم في الدنيا ويوم القيامة مَنِ الكذاب المتجبر؟",
    "ayah": 25,
    "surah": 54
  },
  {
    "text": "أأنزل عليه الوحي وخُصَّ بالنبوة مِن بيننا، وهو واحد منا؟ بل هو كثير الكذب والتجبر. سَيَرون عند نزول العذاب بهم في الدنيا ويوم القيامة مَنِ الكذاب المتجبر؟",
    "ayah": 26,
    "surah": 54
  },
  {
    "text": "إنا مخرجو الناقة التي سألوها من الصخرة؛ اختبارًا لهم، فانتظر -يا صالح- ما يحلُّ بهم من العذاب، واصطبر على دعوتك إياهم وأذاهم لك.",
    "ayah": 27,
    "surah": 54
  },
  {
    "text": "وأخبرهم أن الماء مقسوم بين قومك والناقة: للناقة يوم، ولهم يوم، كل شِرْب يحضره مَن كانت قسمته، ويُحظر على من ليس بقسمة له.",
    "ayah": 28,
    "surah": 54
  },
  {
    "text": "فنادوا صاحبهم بالحض على عقرها، فتناول الناقة بيده، فنحرها فعاقبْتُهم، فكيف كان عقابي لهم على كفرهم، وإنذاري لمن عصى رسلي؟ إنه كان عظيمًا مؤلمًا.",
    "ayah": 29,
    "surah": 54
  },
  {
    "text": "فنادوا صاحبهم بالحض على عقرها، فتناول الناقة بيده، فنحرها فعاقبْتُهم، فكيف كان عقابي لهم على كفرهم، وإنذاري لمن عصى رسلي؟ إنه كان عظيمًا مؤلمًا.",
    "ayah": 30,
    "surah": 54
  },
  {
    "text": "إنا أرسلنا عليهم جبريلَ، فصاح بهم صيحة واحدة، فبادوا عن آخرهم، فكانوا كالزرع اليابس السريع الانكسار الذي يجعله صاحب الحظيرة سياجًا لحفظ المواشي.",
    "ayah": 31,
    "surah": 54
  },
  {
    "text": "ولقد سَهَّلْنا لفظ القرآن للتلاوة والحفظ، ومعانيه للفهم والتدبر لمن أراد أن يتذكر ويعتبر، فهل مِن متعظ به؟",
    "ayah": 32,
    "surah": 54
  },
  {
    "text": "كذَّبت قوم لوط بآيات الله التي أُنذِروا بها.",
    "ayah": 33,
    "surah": 54
  },
  {
    "text": "إنا أرسلنا عليهم ريحًا شديدة ترميهم بالحجارة إلا آل لوط، نجَّيناهم من العذاب في آخر الليل، نعمة من عندنا عليهم، كما أثبنا لوطًا وآله وأنعمنا عليهم، فأنجيناهم مِن عذابنا، نُثيب مَن آمن بنا وشكرنا.",
    "ayah": 34,
    "surah": 54
  },
  {
    "text": "إنا أرسلنا عليهم ريحًا شديدة ترميهم بالحجارة إلا آل لوط، نجَّيناهم من العذاب في آخر الليل، نعمة من عندنا عليهم، كما أثبنا لوطًا وآله وأنعمنا عليهم، فأنجيناهم مِن عذابنا، نُثيب مَن آمن بنا وشكرنا.",
    "ayah": 35,
    "surah": 54
  },
  {
    "text": "ولقد خوَّف لوط قومه بأس الله وعذابه، فلم يسمعوا له، بل شكُّوا في ذلك، وكذَّبوه.",
    "ayah": 36,
    "surah": 54
  },
  {
    "text": "ولقد طلبوا منه أن يفعلوا الفاحشة بضيوفه من الملائكة، فطمسنا أعينهم فلم يُبصروا شيئًا، فقيل لهم: ذوقوا عذابي وإنذاري الذي أنذركم به لوط عليه السلام.",
    "ayah": 37,
    "surah": 54
  },
  {
    "text": "ولقد جاءهم وقت الصباح عذاب دائم استقر فيهم حتى يُفضي بهم إلى عذاب الآخرة، وذلك العذاب هو رجمهم بالحجارة وقلب قُراهم وجعل أعلاها أسفلها، فقيل لهم: ذوقوا عذابي الذي أنزلته بكم؛ لكفركم وتكذيبكم، وإنذاري الذي أنذركم به لوط عليه السلام.",
    "ayah": 38,
    "surah": 54
  },
  {
    "text": "ولقد جاءهم وقت الصباح عذاب دائم استقر فيهم حتى يُفضي بهم إلى عذاب الآخرة، وذلك العذاب هو رجمهم بالحجارة وقلب قُراهم وجعل أعلاها أسفلها، فقيل لهم: ذوقوا عذابي الذي أنزلته بكم؛ لكفركم وتكذيبكم، وإنذاري الذي أنذركم به لوط عليه السلام.",
    "ayah": 39,
    "surah": 54
  },
  {
    "text": "ولقد سَهَّلْنا لفظ القرآن للتلاوة والحفظ، ومعانيه للفهم والتدبر لمن أراد أن يتذكر، فهل مِن متعظ به؟",
    "ayah": 40,
    "surah": 54
  },
  {
    "text": "ولقد جاء أتباعَ فرعون وقومَه إنذارُنا بالعقوبة لهم على كفرهم.",
    "ayah": 41,
    "surah": 54
  },
  {
    "text": "كذَّبوا بأدلتنا كلها الدالة على وحدانيتنا ونبوة أنبيائنا، فعاقبناهم بالعذاب عقوبة عزيز لا يغالَب، مقتدر على ما يشاء.",
    "ayah": 42,
    "surah": 54
  },
  {
    "text": "أكفاركم -يا معشر قريش- خير مِنَ الذين تقدَّم ذكرهم ممن هلكوا بسبب تكذيبهم، أم لكم براءة مِن عقاب الله في الكتب المنزلة على الأنبياء بالسلامة من العقوبة؟",
    "ayah": 43,
    "surah": 54
  },
  {
    "text": "بل أيقول كفار «مكة»: نحن أولو حزم ورأي وأمرنا مجتمع، فنحن جماعة منتصرة لا يغلبنا من أرادنا بسوء؟",
    "ayah": 44,
    "surah": 54
  },
  {
    "text": "سيهزم جمع كفار «مكة» أمام المؤمنين، ويولُّون الأدبار، وقد حدث هذا يوم «بدر».",
    "ayah": 45,
    "surah": 54
  },
  {
    "text": "والساعة موعدهم الذي يُجازون فيه بما يستحقون، والساعة أعظم وأقسى مما لحقهم من العذاب يوم «بدر».",
    "ayah": 46,
    "surah": 54
  },
  {
    "text": "إن المجرمين في تيه عن الحق وعناء وعذاب. يوم يُجرُّون في النار على وجوههم، ويقال لهم: ذوقوا شدة عذاب جهنم.",
    "ayah": 47,
    "surah": 54
  },
  {
    "text": "إن المجرمين في تيه عن الحق وعناء وعذاب. يوم يُجرُّون في النار على وجوههم، ويقال لهم: ذوقوا شدة عذاب جهنم.",
    "ayah": 48,
    "surah": 54
  },
  {
    "text": "إنّا كل شيء خلقناه بمقدار قدرناه وقضيناه، وسبق علمنا به، وكتابتنا له في اللوح المحفوظ.",
    "ayah": 49,
    "surah": 54
  },
  {
    "text": "وما أمرنا للشيء إذا أردناه إلا أن نقول قولة واحدة وهي «كن»، فيكون كلمح البصر، لا يتأخر طَرْفة عين.",
    "ayah": 50,
    "surah": 54
  },
  {
    "text": "ولقد أهلكنا أشباهكم في الكفر من الأمم الخالية، فهل من متعظ بما حلَّ بهم من النَّكال والعذاب؟",
    "ayah": 51,
    "surah": 54
  },
  {
    "text": "وكل شيء فعله أشباهكم الماضون من خير أو شرٍّ مكتوب في الكتب التي كتبتها الحفظة.",
    "ayah": 52,
    "surah": 54
  },
  {
    "text": "وكل صغير وكبير من أعمالهم مُسَطَّر في صحائفهم، وسيجازون به.",
    "ayah": 53,
    "surah": 54
  },
  {
    "text": "إن المتقين في بساتين عظيمة، وأنهار واسعة يوم القيامة.",
    "ayah": 54,
    "surah": 54
  },
  {
    "text": "في مجلس حق، لا لغو فيه ولا تأثيم عند الله المَلِك العظيم، الخالق للأشياء كلها، المقتدر على كل شيء تبارك وتعالى.",
    "ayah": 55,
    "surah": 54
  }
]
