[
  {
    "text": "تسمية السورة\n\n• سميت الرحمن؛ لافتتاحها بهذا الاسم من أسماء الله الحسنى، وتكرر في السورة التذكير بنعم الله العديدة، وهذه النعم راجعة إلى معنى هذا الاسم الكريم.\n\nمن مقاصد السورة\n\n• ذكر جملةٍ من نِعَم الله وآياته الباهرة، الظاهرة في جميل صنعه وإبداع خلقه وتدبيره للوجود، وكلها من آثار رحمة الله التي أفاض بها على عباده؛ تذكيرًا لهم بواجب الشكر.\n\n• التهديد والوعيد للجنِّ والإنس؛ تمهيدًا لهول يوم القيامة وما يكون فيها من الحساب، وذكرُ ما يكون بعد ذلك من عذاب الأشقياء ونعيم السعداء.\n\n[التفسير]\n\nالرحمن علَّم الإنسان القرآنَ؛ بتيسير تلاوته وحفظه وفهم معانيه.",
    "ayah": 1,
    "surah": 55
  },
  {
    "text": "تسمية السورة\n\n• سميت الرحمن؛ لافتتاحها بهذا الاسم من أسماء الله الحسنى، وتكرر في السورة التذكير بنعم الله العديدة، وهذه النعم راجعة إلى معنى هذا الاسم الكريم.\n\nمن مقاصد السورة\n\n• ذكر جملةٍ من نِعَم الله وآياته الباهرة، الظاهرة في جميل صنعه وإبداع خلقه وتدبيره للوجود، وكلها من آثار رحمة الله التي أفاض بها على عباده؛ تذكيرًا لهم بواجب الشكر.\n\n• التهديد والوعيد للجنِّ والإنس؛ تمهيدًا لهول يوم القيامة وما يكون فيها من الحساب، وذكرُ ما يكون بعد ذلك من عذاب الأشقياء ونعيم السعداء.\n\n[التفسير]\n\nالرحمن علَّم الإنسان القرآنَ؛ بتيسير تلاوته وحفظه وفهم معانيه.",
    "ayah": 2,
    "surah": 55
  },
  {
    "text": "خلق الإنسان، علَّمه البيانَ عمّا في نفسه تمييزًا له عن غيره.",
    "ayah": 3,
    "surah": 55
  },
  {
    "text": "خلق الإنسان، علَّمه البيانَ عمّا في نفسه تمييزًا له عن غيره.",
    "ayah": 4,
    "surah": 55
  },
  {
    "text": "الشمس والقمر يجريان متعاقبَين بحساب متقن، لا يختلف ولا يضطرب.",
    "ayah": 5,
    "surah": 55
  },
  {
    "text": "والنجوم التي في السماء أو النبات الذي يَنجُم ويَطْلُع من الأرض ولا ساق له، وأشجار الأرض التي لها ساق، تعرف ربها وتسجد له، وتنقاد لما سخَّرها له مِن مصالح عباده ومنافعهم.",
    "ayah": 6,
    "surah": 55
  },
  {
    "text": "والسماء رفعها فوق الأرض، ووضع في الأرض العدل الذي أمر به وشرعه لعباده.",
    "ayah": 7,
    "surah": 55
  },
  {
    "text": "لئلا تعتدوا وتخونوا مَن وَزَنتم له، وأقيموا الوزن بالعدل، ولا تُنْقِصوا الميزان إذا وَزَنتم للناس.",
    "ayah": 8,
    "surah": 55
  },
  {
    "text": "لئلا تعتدوا وتخونوا مَن وَزَنتم له، وأقيموا الوزن بالعدل، ولا تُنْقِصوا الميزان إذا وَزَنتم للناس.",
    "ayah": 9,
    "surah": 55
  },
  {
    "text": "والأرض وضعها ومهَّدها؛ ليستقر عليها الخلق. فيها فاكهة والنخل ذات الأوعية التي يكون منها الثمر، وفيها الحب ذو القشر؛ رزقًا لكم ولأنعامكم، وفيها كل نبت طيب الرائحة.",
    "ayah": 10,
    "surah": 55
  },
  {
    "text": "والأرض وضعها ومهَّدها؛ ليستقر عليها الخلق. فيها فاكهة والنخل ذات الأوعية التي يكون منها الثمر، وفيها الحب ذو القشر؛ رزقًا لكم ولأنعامكم، وفيها كل نبت طيب الرائحة.",
    "ayah": 11,
    "surah": 55
  },
  {
    "text": "والأرض وضعها ومهَّدها؛ ليستقر عليها الخلق. فيها فاكهة والنخل ذات الأوعية التي يكون منها الثمر، وفيها الحب ذو القشر؛ رزقًا لكم ولأنعامكم، وفيها كل نبت طيب الرائحة.",
    "ayah": 12,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما الدينية والدنيوية -يا معشر الجن والإنس- تكذِّبان؟ وما أحسن جواب الجن حين تلا عليهم النبي ﷺ هذه السورة، فكلما مَرَّ بهذه الآية، قالوا: «ولا بشيء من آلائك ربَّنا نكذب، فلك الحمد»، وهكذا ينبغي للعبد إذا تليت عليه نعم الله وآلاؤه، أن يُقرَّ بها، ويشكر الله ويحمده عليها.",
    "ayah": 13,
    "surah": 55
  },
  {
    "text": "خلق أبا الإنسان، وهو آدم من طين يابس كالفَخّار، وخلق إبليس، وهو من الجن من لهب النار المختلط بعضه ببعض.",
    "ayah": 14,
    "surah": 55
  },
  {
    "text": "خلق أبا الإنسان، وهو آدم من طين يابس كالفَخّار، وخلق إبليس، وهو من الجن من لهب النار المختلط بعضه ببعض.",
    "ayah": 15,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -يا معشر الإنس والجن- تكذِّبان؟",
    "ayah": 16,
    "surah": 55
  },
  {
    "text": "هو سبحانه وتعالى ربُّ مشرقَي الشمس في الشتاء والصيف، ورب مغربَيها فيهما، فالجميع تحت تدبيره وربوبيته.",
    "ayah": 17,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 18,
    "surah": 55
  },
  {
    "text": "خلط الله ماء البحرين -العذب والمِلْح- متلاقيين، لا فاصل بينهما في مرأى العين، ومع ذلك بينهما حاجز، فلا يطغى أحدهما على الآخر، ويذهب بخصائصه، بل يبقى العذب عذبًا، والمِلْح مِلْحًا مع تلاقيهما.",
    "ayah": 19,
    "surah": 55
  },
  {
    "text": "خلط الله ماء البحرين -العذب والمِلْح- متلاقيين، لا فاصل بينهما في مرأى العين، ومع ذلك بينهما حاجز، فلا يطغى أحدهما على الآخر، ويذهب بخصائصه، بل يبقى العذب عذبًا، والمِلْح مِلْحًا مع تلاقيهما.",
    "ayah": 20,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 21,
    "surah": 55
  },
  {
    "text": "يخرج من البحرين بقدرة الله اللؤلؤ والمَرْجان.",
    "ayah": 22,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 23,
    "surah": 55
  },
  {
    "text": "وله تعالى مِلْك تسخير السفنِ الضخمةِ التي تجري في البحر بمنافع الناس، رافعة سواريها وأشرعتها كالجبال.",
    "ayah": 24,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 25,
    "surah": 55
  },
  {
    "text": "كل مَن على وجه الأرض مِنَ الخلق هالك، ويبقى وجه ربك ذو العظمة والكبرياء والفضل والجود. وفي الآية إثبات صفة الوجه لله تعالى بما يليق به سبحانه، دون تشبيه ولا تكييف.",
    "ayah": 26,
    "surah": 55
  },
  {
    "text": "كل مَن على وجه الأرض مِنَ الخلق هالك، ويبقى وجه ربك ذو العظمة والكبرياء والفضل والجود. وفي الآية إثبات صفة الوجه لله تعالى بما يليق به سبحانه، دون تشبيه ولا تكييف.",
    "ayah": 27,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذبان؟",
    "ayah": 28,
    "surah": 55
  },
  {
    "text": "يسأله مَن في السموات والأرض حاجاتهم، فلا غنى لأحد منهم عنه سبحانه. كل يوم هو في شأن: يُعِز ويُذِلُّ، ويعطي ويَمْنع. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 29,
    "surah": 55
  },
  {
    "text": "يسأله مَن في السموات والأرض حاجاتهم، فلا غنى لأحد منهم عنه سبحانه. كل يوم هو في شأن: يُعِز ويُذِلُّ، ويعطي ويَمْنع. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 30,
    "surah": 55
  },
  {
    "text": "سنفرُغ لحسابكم ومجازاتكم بأعمالكم التي عملتموها في الدنيا، أيها الثقلان -الإنس والجن-، فنعاقب أهل المعاصي، ونُثيب أهل الطاعة. فبأيِّ نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 31,
    "surah": 55
  },
  {
    "text": "سنفرُغ لحسابكم ومجازاتكم بأعمالكم التي عملتموها في الدنيا، أيها الثقلان -الإنس والجن-، فنعاقب أهل المعاصي، ونُثيب أهل الطاعة. فبأيِّ نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 32,
    "surah": 55
  },
  {
    "text": "يا معشر الجن والإنس، إن قَدَرْتم على النفاذ من أمر الله وحكمه هاربين من أطراف السموات والأرض فافعلوا، ولستم قادرين على ذلك إلا بقوة وحجة، وأمر من الله تعالى، وأنّى لكم ذلك، وأنتم لا تملكون لأنفسكم نفعًا ولا ضرًّا؟ فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 33,
    "surah": 55
  },
  {
    "text": "يا معشر الجن والإنس، إن قَدَرْتم على النفاذ من أمر الله وحكمه هاربين من أطراف السموات والأرض فافعلوا، ولستم قادرين على ذلك إلا بقوة وحجة، وأمر من الله تعالى، وأنّى لكم ذلك، وأنتم لا تملكون لأنفسكم نفعًا ولا ضرًّا؟ فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 34,
    "surah": 55
  },
  {
    "text": "يُرْسَل عليكم لهب من نار، ونحاس مذاب يُصَبُّ على رؤوسكم، فلا ينصر بعضكم بعضًا يا معشر الجن والإنس. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 35,
    "surah": 55
  },
  {
    "text": "يُرْسَل عليكم لهب من نار، ونحاس مذاب يُصَبُّ على رؤوسكم، فلا ينصر بعضكم بعضًا يا معشر الجن والإنس. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 36,
    "surah": 55
  },
  {
    "text": "فإذا انشقت السماء وتفطَّرت يوم القيامة، فكانت حمراء كلون الورد، وكالزيت المغلي والرصاص المذاب؛ من شدة الأمر وهول يوم القيامة. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 37,
    "surah": 55
  },
  {
    "text": "فإذا انشقت السماء وتفطَّرت يوم القيامة، فكانت حمراء كلون الورد، وكالزيت المغلي والرصاص المذاب؛ من شدة الأمر وهول يوم القيامة. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 38,
    "surah": 55
  },
  {
    "text": "ففي ذلك اليوم لا تسأل الملائكة المجرمين من الإنس والجن عن ذنوبهم. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 39,
    "surah": 55
  },
  {
    "text": "ففي ذلك اليوم لا تسأل الملائكة المجرمين من الإنس والجن عن ذنوبهم. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 40,
    "surah": 55
  },
  {
    "text": "تَعرِف الملائكةُ المجرمين بعلاماتهم، فتأخذهم بمقدمة رؤوسهم وبأقدامهم، فترميهم في النار.",
    "ayah": 41,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 42,
    "surah": 55
  },
  {
    "text": "يقال لهؤلاء المجرمين -توبيخًا وتحقيرًا لهم-: هذه جهنم التي يكذِّب بها المجرمون في الدنيا: تارة يُعذَّبون في الجحيم، وتارة يُسقون من الحميم، وهو شراب بلغ منتهى الحرارة، يقطِّع الأمعاء والأحشاء.",
    "ayah": 43,
    "surah": 55
  },
  {
    "text": "يقال لهؤلاء المجرمين -توبيخًا وتحقيرًا لهم-: هذه جهنم التي يكذِّب بها المجرمون في الدنيا: تارة يُعذَّبون في الجحيم، وتارة يُسقون من الحميم، وهو شراب بلغ منتهى الحرارة، يقطِّع الأمعاء والأحشاء.",
    "ayah": 44,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 45,
    "surah": 55
  },
  {
    "text": "ولمن اتقى الله من عباده من الإنس والجن، فخاف مقامه بين يديه، فأطاعه وترك معاصيه، جنتان.",
    "ayah": 46,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 47,
    "surah": 55
  },
  {
    "text": "الجنتان ذواتا أغصان نضرة من الفواكه والثمار.",
    "ayah": 48,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 49,
    "surah": 55
  },
  {
    "text": "في هاتين الجنتين عينان من الماء تجريان خلالهما.",
    "ayah": 50,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 51,
    "surah": 55
  },
  {
    "text": "في هاتين الجنتين من كل نوع من الفواكه صنفان.",
    "ayah": 52,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 53,
    "surah": 55
  },
  {
    "text": "وللذين خافوا مقام ربهم جنتان يتنعمون فيهما، متكئين على فرش مبطَّنة من غليظ الديباج، وثمرُ الجنتين قريب إليهم.",
    "ayah": 54,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 55,
    "surah": 55
  },
  {
    "text": "في هذه الفرش زوجات قاصرات أبصارهن على أزواجهن، لا ينظرن إلى غيرهم متعلقات بهم، لم يطأهن إنس قبلهم ولا جان.",
    "ayah": 56,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 57,
    "surah": 55
  },
  {
    "text": "كأن هؤلاء الزوجاتِ من الحور الياقوتُ والمَرْجانُ في صفائهن وجمالهن.",
    "ayah": 58,
    "surah": 55
  },
  {
    "text": "فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 59,
    "surah": 55
  },
  {
    "text": "هل جزاء مَن أحسن بعمله في الدنيا إلا الإحسان إليه بالجنة في الآخرة؟ فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 60,
    "surah": 55
  },
  {
    "text": "هل جزاء مَن أحسن بعمله في الدنيا إلا الإحسان إليه بالجنة في الآخرة؟ فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 61,
    "surah": 55
  },
  {
    "text": "ومن دون الجنتين السابقتين جنتان أخريان. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 62,
    "surah": 55
  },
  {
    "text": "ومن دون الجنتين السابقتين جنتان أخريان. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 63,
    "surah": 55
  },
  {
    "text": "هاتان الجنتان خضراوان، قد اشتدَّتْ خضرتهما حتى مالت إلى السواد. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 64,
    "surah": 55
  },
  {
    "text": "هاتان الجنتان خضراوان، قد اشتدَّتْ خضرتهما حتى مالت إلى السواد. فبأي نِعَم ربكما -أيها الثقلان- تكذِّبان؟",
    "ayah": 65,
    "surah": 55
  },
  {
