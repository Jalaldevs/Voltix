[
  {
    "text": "عذاب سخت و شدید برای کسی‌که بسیار از مردم غیبت و بدگویی کند.",
    "ayah": 1,
    "surah": 104
  },
  {
    "text": "کسی‌که غم و اندوهش جمع‌آوری و شمردن مال است، و غم و اندوه دیگری جز آن ندارد.",
    "ayah": 2,
    "surah": 104
  },
  {
    "text": "گمان می‌کند مالی که فراهم آورده است او را از عذاب مرگ نجات خواهد داد، و در زندگی دنیا جاویدان می‌ماند.",
    "ayah": 3,
    "surah": 104
  },
  {
    "text": "امر آن‌گونه که این جاهل تصور کرده، نیست، به‌طور قطع در آتش جهنم که بر اثر قدرت زیادش هر چیزی را که در آن افکنده شود خرد می‌کند و در هم می‌شکند افکنده خواهد شد.",
    "ayah": 4,
    "surah": 104
  },
  {
    "text": "و -ای رسول- تو چه می‌دانی این آتشی که هر چیزی را در آن افکنده شود خرد می‌کند چیست؟!",
    "ayah": 5,
    "surah": 104
  },
  {
    "text": "به‌راستی‌که آتشِ افروختۀ الله است.",
    "ayah": 6,
    "surah": 104
  },
  {
    "text": "که از بدن‌های مردم به دل‌های‌شان نفوذ می‌کند.",
    "ayah": 7,
    "surah": 104
  },
  {
    "text": "به‌راستی‌که آن آتش، کسانی را که در آن عذاب می‌شوند، از هر طرف محاصره ‌کرده است.",
    "ayah": 8,
    "surah": 104
  },
  {
    "text": "با ستون‌هایی کشیده و طولانی تا از آن خارج نشوند.",
    "ayah": 9,
    "surah": 104
  }
]
