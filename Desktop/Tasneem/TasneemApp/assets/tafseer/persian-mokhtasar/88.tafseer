[
  {
    "text": "- ای رسول- آیا خبر قیامت که هول و هراسش مردم را کاملاً فرا می‌گیرد به تو رسیده است؟!",
    "ayah": 1,
    "surah": 88
  },
  {
    "text": "مردم در روز قیامت یا از بدبختان هستند یا از خوشبختان؛ و چهره‌های بدبختان خوار و افتاده است.",
    "ayah": 2,
    "surah": 88
  },
  {
    "text": "با غل و زنجیرهایی که بسته شده و کشیده می‌شوند خسته و رنجور هستند.",
    "ayah": 3,
    "surah": 88
  },
  {
    "text": "این چهره‌ها در آتشی سوزان که حرارت بی‌رحمانه‌ای دارد وارد می‌شوند.",
    "ayah": 4,
    "surah": 88
  },
  {
    "text": "از چشمه‌هایی با آبی بسیار داغ نوشانده می‌شوند.",
    "ayah": 5,
    "surah": 88
  },
  {
    "text": "طعامی ندارند که از آن تغذیه کنند جز پلیدترین و بدبوترین طعام از گیاهی به نام شِبرِق که وقتی خشک گردد مسموم می‌شود.",
    "ayah": 6,
    "surah": 88
  },
  {
    "text": "که خورنده‌اش نه فربه می‌شود، و نه گرسنگی‌اش برطرف می‌گردد.",
    "ayah": 7,
    "surah": 88
  },
  {
    "text": "و چهره‌های خوشبخت در آن روز به خاطر نعمت‌هایی که با آن روبرو می‌شوند در نعمت و شادمانی و سرور هستند.",
    "ayah": 8,
    "surah": 88
  },
  {
    "text": "از اعمال صالحی که در دنیا انجام داده‌اند راضی هستند؛ زیرا پاداش عمل‌شان را دوبرابر ذخیره‌شده یافته‌اند.",
    "ayah": 9,
    "surah": 88
  },
  {
    "text": "در بهشتی که دارای مکان و جایگاهی مرتفع است.",
    "ayah": 10,
    "surah": 88
  },
  {
    "text": "در بهشت سخن باطل و لغوی نمی‌شنوند؛ چه رسد به شنیدن سخنی حرام.",
    "ayah": 11,
    "surah": 88
  },
  {
    "text": "در این بهشت چشمه‌هایی جاری است که هرگونه بخواهند آنها را جاری می‌کنند، و به مصرف می‌رسانند.",
    "ayah": 12,
    "surah": 88
  },
  {
    "text": "تخت‌هایی بلند در آن است.",
    "ayah": 13,
    "surah": 88
  },
  {
    "text": "و قَدَح‌هایی قرارداده شده و آماده شده برای نوشیدن.",
    "ayah": 14,
    "surah": 88
  },
  {
    "text": "و بالش‌هایی که منظم در پهلوی یکدیگر چیده شده‌اند در آن قرار دارد.",
    "ayah": 15,
    "surah": 88
  },
  {
    "text": "و در آن فرش هایی فراوان و گسترده شده در همه ى جوانب وجود دارد.",
    "ayah": 16,
    "surah": 88
  },
  {
    "text": "پس آیا از روی تأمل به شتر نمی‌نگرند که الله چگونه آن را آفرید، و رام بنی‌آدم کرد؟!",
    "ayah": 17,
    "surah": 88
  },
  {
    "text": "و به آسمان نمی‌نگرند که چگونه آن را بالا برد تا سقفی محفوظ بالای سرشان شد، و بر آنها سقوط نمی‌کند؟!",
    "ayah": 18,
    "surah": 88
  },
  {
    "text": "و به کوه‌ها نمی‌نگرند که چگونه آنها را نصب و زمین را با آن ثابت کرد تا مردم را نلرزاند؟!",
    "ayah": 19,
    "surah": 88
  },
  {
    "text": "و به زمین نمی‌نگرند که چگونه آن را گستراند، و برای اقامت مردم مهیا کرد؟!",
    "ayah": 20,
    "surah": 88
  },
  {
    "text": "پس -ای رسول- اینها را اندرز بده، و از عذاب الله بترسان؛ زیرا تو فقط تذکردهنده هستی، و جز یادآوری آنها از تو خواسته نمی‌شود، اما توفیق آنها به ایمان فقط به دست الله است.",
    "ayah": 21,
    "surah": 88
  },
  {
    "text": "تو بر آنها مسلط نیستی تا آنها را بر ایمان مجبور کنی.",
    "ayah": 22,
    "surah": 88
  },
  {
    "text": "مگر کسی از آنها که از ایمان روی بگرداند، و به الله و رسولش کفر ورزد.",
    "ayah": 23,
    "surah": 88
  },
  {
    "text": "که الله در روز قیامت او را با عذاب بزرگتر عذاب می‌کند یعنی او را وارد جهنم می‌کند که برای همیشه در آن می‌ماند.",
    "ayah": 24,
    "surah": 88
  },
  {
    "text": "به‌راستی‌که بازگشت آنها پس از مرگشان فقط به‌سوی ما است.",
    "ayah": 25,
    "surah": 88
  },
  {
    "text": "سپس به‌راستی‌که حسابرسی آنها بر اعمال‌شان فقط برعهدۀ ما است، نه تو و نه هیچ‌کس دیگری چنین اختیاری ندارد.",
    "ayah": 26,
    "surah": 88
  }
]
