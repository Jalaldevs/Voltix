[
  {
    "text": "آن‌گاه که آسمان برای نزول فرشتگان از آن شکافته شود.",
    "ayah": 1,
    "surah": 82
  },
  {
    "text": "و آن‌گاه که ستارگان پراکنده سقوط کنند.",
    "ayah": 2,
    "surah": 82
  },
  {
    "text": "و آن‌گاه که دریاها بر روی یکدیگر گشوده شوند و در هم آمیزند.",
    "ayah": 3,
    "surah": 82
  },
  {
    "text": "و آن‌گاه که خاک قبرها برای برانگیختن مردگان‌شان زیر و رو شود.",
    "ayah": 4,
    "surah": 82
  },
  {
    "text": "در این هنگام هرکس از اعمالی‌که پیش از وفات فرستاده، و اعمالی‌که به تأخیر انداخته و انجام نداده است آگاه می‌شود.",
    "ayah": 5,
    "surah": 82
  },
  {
    "text": "ای انسان کافر به پروردگارت، چه چیزی تو را واداشت که با فرمان پروردگارت مخالفت کنی آن‌گاه که به تو مهلت داد و به لطف خویش کیفرت را به تعجیل نینداخت؟!",
    "ayah": 6,
    "surah": 82
  },
  {
    "text": "همان ذاتی‌که پس از اینکه نیست بودی تو را پدید آورد، و تو را درست‌اندام و متناسب قرار داد.",
    "ayah": 7,
    "surah": 82
  },
  {
    "text": "و تو را به هر صورتی‌که خواست بیافریند، آفرید، و به تحقیق بر تو نعمت بخشید كه تو را در سیمای خری یا بوزینه‌ای یا سگی یا حیوانی دیگر نیافرید.",
    "ayah": 8,
    "surah": 82
  },
  {
    "text": "- ای فریب‌ خوردگان- امر چنان‌که تصور می‌کنید نیست بلکه شما روز جزا را تکذیب می‌کنید و برایش کار نمی‌کنید.",
    "ayah": 9,
    "surah": 82
  },
  {
    "text": "و به‌راستی‌که فرشتگانی بر شما گمارده شده‌اند که اعمال‌تان را حفظ می‌کنند.",
    "ayah": 10,
    "surah": 82
  },
  {
    "text": "نزد الله گرامی هستند، نویسندگانی هستند که اعمال‌تان را می‌نویسند.",
    "ayah": 11,
    "surah": 82
  },
  {
    "text": "تمام کارهایی را که انجام می‌دهید می‌دانند و آنها را می‌نویسند.",
    "ayah": 12,
    "surah": 82
  },
  {
    "text": "به‌راستی کسانی‌که خیر و طاعت زیادی انجام می‌دهند در روز قیامت در نعمت‌هایی جاویدان هستند.",
    "ayah": 13,
    "surah": 82
  },
  {
    "text": "و به‌راستی‌که گناهکاران در آتشی که بر آنها برافروخته می‌گردد هستند.",
    "ayah": 14,
    "surah": 82
  },
  {
    "text": "در روز جزا وارد آن می‌شوند و از حرارتش رنج می‌برند.",
    "ayah": 15,
    "surah": 82
  },
  {
    "text": "و هرگز از آن دور نمی‌شوند، بلکه در آن جاویدان هستند.",
    "ayah": 16,
    "surah": 82
  },
  {
    "text": "و - ای رسول- تو چه دانی که روز جزا چیست؟!",
    "ayah": 17,
    "surah": 82
  },
  {
    "text": "باز چه دانی که روز جزا چیست؟!",
    "ayah": 18,
    "surah": 82
  },
  {
    "text": "روزی‌که هیچ‌کس نمی‌تواند به هیچ‌کس دیگری نفع رساند، و تمام کارها در آن روز فقط از آنِ الله است، که به هر کاری بخواهد اقدام می‌کند، و غیر از او هیچ‌کس دیگری این حق را ندارد.",
    "ayah": 19,
    "surah": 82
  }
]
