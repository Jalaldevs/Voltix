[
  {
    "text": "آیا کسی را که جزای روز قیامت را تکذیب می‌کند شناختی؟!",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "او همان کسی است که یتیم نیازمند را به شدت می‌راند.",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "و نه خودش و نه دیگران را بر اِطعام فقیر تشویق نمی‌کند.",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "پس نابودی و عذاب بر نمازگزاران باد، کسانی که از ادای نمازشان غافل هستند، و به آن اعتنايى نمی کنند تا وقت آن قضا می شود.",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "پس نابودی و عذاب بر نمازگزاران باد، کسانی که از ادای نمازشان غافل هستند، و به آن اعتنايى نمی کنند تا وقت آن قضا می شود.",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "کسانی‌که با نماز و اعمال‌شان ریا می‌کنند، و عمل را برای الله خالص نمی‌گردانند.",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "و از یاری ‌کردن دیگران با آنچه که در این یاری ‌کردن زیانی متوجه یاری‌رسان نیست خودداری می‌کنند.",
    "ayah": 7,
    "surah": 107
  }
]
