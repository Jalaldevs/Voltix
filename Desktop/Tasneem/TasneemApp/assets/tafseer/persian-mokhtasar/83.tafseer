[
  {
    "text": "نابودی و تباهی باد بر کم‌فروشان.",
    "ayah": 1,
    "surah": 83
  },
  {
    "text": "همان کسانی‌که وقتی از دیگران پیمانه بگیرند حقشان را کامل و بدون کاستی می‌گیرند.",
    "ayah": 2,
    "surah": 83
  },
  {
    "text": "و هرگاه برای مردم پیمانه یا وزن کنند از پیمانه و ترازو می‌کاهند، اهالی مدینه هنگام هجرت پیامبر صلی الله علیه وسلم به‌سوی آنها چنین حالتی داشتند.",
    "ayah": 3,
    "surah": 83
  },
  {
    "text": "اینها که این کار ناپسند را انجام می‌دهند مگر یقین ندارند که به‌سوی الله برانگیخته می‌شوند؟!",
    "ayah": 4,
    "surah": 83
  },
  {
    "text": "برای حسابرسی و جزا در روزی‌که به‌سبب مصیبت‌ها و هراس‌هایی که در آن وجود دارد بزرگ است.",
    "ayah": 5,
    "surah": 83
  },
  {
    "text": "روزی‌که مردم برای حسابرسی در برابر پروردگارِ تمام مخلوقات می‌ایستند.",
    "ayah": 6,
    "surah": 83
  },
  {
    "text": "امر چنان‌که تصور می‌کنید نیست که رستاخیزی پس از مرگ وجود ندارد، به‌راستی‌که نامۀ گناهکاران چه کافر و چه منافق، تباه‌شده در سجّین -زمینی زیرین- قرار دارد.",
    "ayah": 7,
    "surah": 83
  },
  {
    "text": "و - ای رسول- تو چه دانی که سِجّین چیست؟!",
    "ayah": 8,
    "surah": 83
  },
  {
    "text": "کتاب نوشته‌شدۀ آنها است که نه از بین می‌رود، نه بر آن افزوده می‌شود و نه از آن کاسته می‌گردد.",
    "ayah": 9,
    "surah": 83
  },
  {
    "text": "نابودی و تباهی در آن روز برای تکذیب‌ کنندگان باد.",
    "ayah": 10,
    "surah": 83
  },
  {
    "text": "کسانی‌که روز جزا را که الله در آن روز بندگانش را براساس اعمال‌شان در دنیا جزا می‌دهد تکذیب می‌کنند.",
    "ayah": 11,
    "surah": 83
  },
  {
    "text": "و این روز را تکذیب نمی‌کند جز کسی که از حدود الله بگذرذ، و بسیار گناهکار باشد.",
    "ayah": 12,
    "surah": 83
  },
  {
    "text": "وقتی آیات نازل‌شدۀ ما بر رسول‌مان بر او خوانده شود می‌گوید: این افسانه‌های امت‌های پیشین است، و از جانب الله نیست.",
    "ayah": 13,
    "surah": 83
  },
  {
    "text": "امر چنان‌که این تکذیب‌ کنندگان تصور کردند نیست، بلکه گناهانی را که انجام می‌دادند بر عقل‌شان غلبه یافته و آن را پوشانده است، پس حق را با دل‌های‌شان نمی‌بینند.",
    "ayah": 14,
    "surah": 83
  },
  {
    "text": "آنها به‌طور قطع در روز قیامت از رویت پروردگارشان محروم هستند.",
    "ayah": 15,
    "surah": 83
  },
  {
    "text": "آن‌گاه به یقین وارد جهنم شوند، و از حرارتش رنج برند.",
    "ayah": 16,
    "surah": 83
  },
  {
    "text": "سپس برای سرزنش آنها در روز قیامت به آنها گفته می‌شود: این عذابی که با آن روبرو شدید همان چیزی است که آن را در دنیا تکذیب می‌کردید آن‌گاه که رسول‌تان شما را از آن خبر می‌داد.",
    "ayah": 17,
    "surah": 83
  },
  {
    "text": "امر چنان‌که تصور می‌کنید که هیچ حساب و جزایی وجود ندارد نیست، به‌راستی‌که اهل طاعت در عِلّیُّون هستند.",
    "ayah": 18,
    "surah": 83
  },
  {
    "text": "و - ای رسول- تو چه می‌دانی که علّیّون چیست؟!",
    "ayah": 19,
    "surah": 83
  },
  {
    "text": "کتاب نوشته‌شدۀ آنها است که نه از بین می‌رود، نه بر آن افزوده می‌شود و نه از آن کاسته می‌گردد.",
    "ayah": 20,
    "surah": 83
  },
  {
    "text": "فرشتگان مقرب هر آسمان این کتاب را می‌آورند.",
    "ayah": 21,
    "surah": 83
  },
  {
    "text": "به تحقیق کسانی‌که طاعات زیادی انجام داده‌اند در روز قیامت در نعمت‌هایی جاویدان هستند.",
    "ayah": 22,
    "surah": 83
  },
  {
    "text": "بر تخت‌هایی آراسته به‌سوی پروردگارشان، و به هر چیزی‌که وجودشان را به وجد آورد و آنها را شاد گرداند می‌نگرند.",
    "ayah": 23,
    "surah": 83
  },
  {
    "text": "هرگاه به آنها بنگری خرمی و شادابی و نشاط در اثرِ زندگی در ناز و نعمت را در چهره‌های‌شان خواهی دید.",
    "ayah": 24,
    "surah": 83
  },
  {
    "text": "خدمتکاران‌شان آنها را از شرابی که بر ظرفش مُهر نهاده شده است می‌نوشانند.",
    "ayah": 25,
    "surah": 83
  },
  {
    "text": "بوی مشک، بی‌نهایت از آن پخش می‌شود، و برای این پاداش گرامی، باید مسابقه ‌دهندگان، با عمل به آنچه الله را راضی می‌سازد، و ترک آنچه او تعالی را به خشم می‌آورد، با هم مسابقه دهند.",
    "ayah": 26,
    "surah": 83
  },
  {
    "text": "این شراب مُهر نهاده‌شده با چشمۀ تسنیم آمیخته می‌شود.",
    "ayah": 27,
    "surah": 83
  },
  {
    "text": "که چشمه‌ای در بالاترین بهشت است که مقربان صاف و خالص از آن می‌نوشند، و سایر مؤمنان از آمیزه‌ای از آن و غیر آن می‌نوشند.",
    "ayah": 28,
    "surah": 83
  },
  {
    "text": "به‌راستی کسانی‌که با کفر خویش گناه می‌کردند از روی تمسخر به مؤمنان می‌خندیدند.",
    "ayah": 29,
    "surah": 83
  },
  {
    "text": "و هرگاه بر مؤمنان می‌گذشتند از روی تمسخر و استهزا با چشم و ابرو به یکدیگر اشاره می‌کردند.",
    "ayah": 30,
    "surah": 83
  },
  {
    "text": "و هرگاه نزد خانوادهای خود بازمی‌گشتند، به سبب کفر و تسمخرِ مؤمنان، خوشحال و شادمان بازمی‌گشتند.",
    "ayah": 31,
    "surah": 83
  },
  {
    "text": "و هرگاه مسلمانان را مشاهده می‌کردند می‌گفتند: به‌راستی‌که اینها گمراهان از راه حق هستند، که دین پدران‌شان را رها کردند.",
    "ayah": 32,
    "surah": 83
  },
  {
    "text": "درحالی‌که الله آنها را بر حفظ اعمال مؤمنان نگماشته بود تا این سخن را بگویند.",
    "ayah": 33,
    "surah": 83
  },
  {
    "text": "اما در روز قیامت کسانی‌که به الله ایمان آوردند به کفار می‌خندند همان‌گونه که کافران در دنیا بر آنها می‌خندیدند.",
    "ayah": 34,
    "surah": 83
  },
  {
    "text": "بر تخت‌هایی آراسته به نعمت‌های جاویدانی که الله برای‌شان آماده ساخته است می‌نگرند.",
    "ayah": 35,
    "surah": 83
  },
  {
    "text": "به تحقیق که کافران در قبال اعمالی‌که در دنیا انجام دادند با عذابی خوارکننده مجازات شده‌اند.",
    "ayah": 36,
    "surah": 83
  }
]
