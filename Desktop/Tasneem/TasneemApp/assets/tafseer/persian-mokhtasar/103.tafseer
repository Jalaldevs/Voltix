[
  {
    "text": "الله متعال به وقت عصر سوگند یاد فرموده است.",
    "ayah": 1,
    "surah": 103
  },
  {
    "text": "که انسان واقعا در نقصان و نابودی است.",
    "ayah": 2,
    "surah": 103
  },
  {
    "text": "مگر کسانی‌که به الله و رسولش ایمان آورده‌اند، و اعمال صالح انجام داده‌اند، و یکدیگر را به حق، و به صبر بر اجرای حق سفارش کرده‌اند؛ که صاحبان این صفات، در زندگی دنیا و آخرت نجات یافته‌ هستند.",
    "ayah": 3,
    "surah": 103
  }
]
