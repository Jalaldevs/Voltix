[
  {
    "text": "الله به شهر حرمت‌دار یعنی مکۀ مکرّمه سوگند یاد فرمود.",
    "ayah": 1,
    "surah": 90
  },
  {
    "text": "و تو - ای رسول- آنچه را تو در این شهر انجام دهی؛ چه قتل کسی‌که مستحق قتل باشد، و چه اسیرکردن کسی‌که مستحق اسارت باشد، برایت حلال است.",
    "ayah": 2,
    "surah": 90
  },
  {
    "text": "و الله به پدر انسان‌ها، و به فرزندانی که از او به وجود آمدند سوگند یاد فرمود.",
    "ayah": 3,
    "surah": 90
  },
  {
    "text": "به تحقیق که انسان به‌سبب سختی‌هایی که در دنیا متحمل می‌شود، در رنج و مشقت است.",
    "ayah": 4,
    "surah": 90
  },
  {
    "text": "آیا انسان گمان می‌کند که هرگاه مرتکب گناهان شود کسی بر او دست نمی‌یابد، و از او انتقام نمی‌گیرد، حتی پروردگارش که او را آفریده است؟!",
    "ayah": 5,
    "surah": 90
  },
  {
    "text": "می‌گوید: توده‌ای انبوه از مال انفاق کردم.",
    "ayah": 6,
    "surah": 90
  },
  {
    "text": "آیا این کسی‌که به آنچه انفاق کرده فخرفروشی می‌کند می‌پندارد که الله او را نمی‌بیند؟! و او را در مالش مورد محاسبه قرار نمی‌دهد؛ که آن را از کجا کسب کرده است؟ و در چه مواردی هزینه کرده است؟!",
    "ayah": 7,
    "surah": 90
  },
  {
    "text": "آیا دو چشم به او نداده‌ایم که با آنها می‌بیند؟!",
    "ayah": 8,
    "surah": 90
  },
  {
    "text": "و زبان و دو لب که با آنها سخن می‌گوید؟!",
    "ayah": 9,
    "surah": 90
  },
  {
    "text": "و راه خیر، و راه باطل را به او نشناسانده‌ایم؟!",
    "ayah": 10,
    "surah": 90
  },
  {
    "text": "و او باید مانعی را که میان او و بهشت فاصله می‌اندازد بپیماید و از آن بگذرد.",
    "ayah": 11,
    "surah": 90
  },
  {
    "text": "و -ای رسول- تو چه می‌دانی مانعی که باید از آن بگذرد تا وارد بهشت شود چیست؟!",
    "ayah": 12,
    "surah": 90
  },
  {
    "text": "آزاد کردن برده‌ مرد یا برده زن است.",
    "ayah": 13,
    "surah": 90
  },
  {
    "text": "یا اینکه در زمان قحطی که طعام در آن کمیاب می‌شود طعام دهد.",
    "ayah": 14,
    "surah": 90
  },
  {
    "text": "طفلی را که پدرش را از دست داده، و با او رابطۀ خویشاوندی دارد.",
    "ayah": 15,
    "surah": 90
  },
  {
    "text": "یا فقیری را که هیچ مالی ندارد.",
    "ayah": 16,
    "surah": 90
  },
  {
    "text": "افزون بر این موارد، از کسانی باشد که به الله ایمان آورده‌اند، و یکدیگر را به صبر بر طاعات و صبر در مقابل گناهان و صبر بر مصیبت، و مهربانی بر بندگان الله سفارش کرده‌اند.",
    "ayah": 17,
    "surah": 90
  },
  {
    "text": "اینها که صفات مذکور را دارند یاران دست‌راست هستند.",
    "ayah": 18,
    "surah": 90
  },
  {
    "text": "و کسانی‌که به آیات نازل‌شدۀ ما بر رسول‌مان کفر ورزیده‌اند همان‌ها یاران دست‌چپ هستند.",
    "ayah": 19,
    "surah": 90
  },
  {
    "text": "در روز قیامت در آتشی که آنها را از اطراف محاصره ‌کرده عذاب می‌شوند.",
    "ayah": 20,
    "surah": 90
  }
]
