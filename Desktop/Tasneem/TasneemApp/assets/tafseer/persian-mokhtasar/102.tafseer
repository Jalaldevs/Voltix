[
  {
    "text": "- ای مردم- بالیدن به اموال و فرزندان، شما را از طاعت الله بازداشت.",
    "ayah": 1,
    "surah": 102
  },
  {
    "text": "تا اینکه مُردید و وارد قبرهای‌تان شدید.",
    "ayah": 2,
    "surah": 102
  },
  {
    "text": "سزاوار نبود که فخرفروشی به اموال و فرزندان، شما را از طاعت الله بازدارد، به‌زودی سرانجام این سرگرمی را خواهید دانست.",
    "ayah": 3,
    "surah": 102
  },
  {
    "text": "باز هم سرانجام آن را خواهید دانست.",
    "ayah": 4,
    "surah": 102
  },
  {
    "text": "اگر واقعاً و به یقین می‌دانستید که به‌سوی الله برانگیخته می‌شوید، و شما را در قبال اعمال‌تان جزا خواهد داد؛ به‌طور قطع به بالیدن به اموال و فرزندان سرگرم نمی‌شدید.",
    "ayah": 5,
    "surah": 102
  },
  {
    "text": "به الله سوگند که به‌طور قطع در روز قیامت جهنم را می‌بینید.",
    "ayah": 6,
    "surah": 102
  },
  {
    "text": "باز هم در حقیقت آن را به صورت یقینی و بدون هیچ تردیدی می‌بینید.",
    "ayah": 7,
    "surah": 102
  },
  {
    "text": "آن‌گاه به‌طور قطع الله در آن روز در مورد سلامتی و ثروت و سایر نعمت‌هایی که به شما ارزانی داشته است از شما می‌پرسد.",
    "ayah": 8,
    "surah": 102
  }
]
