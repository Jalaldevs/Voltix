[
  {
    "text": "- ای رسول- بگو: به پروردگار صبح پناه می‌برم، و از او تعالی یاری می‌خواهم.",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "از شر مخلوقاتی که آزار می‌رسانند.",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "و از شرهایی که شب‌هنگام از جنبندگان و دزدان آشکار می‌گردد به الله پناه می‌برم.",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "و از شر زنان ساحری که در گره‌ها می‌دمند به او تعالی پناه می‌برم.",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "و از شر حسود آن‌گاه که حسد ورزد، با آنچه که حسد را به خودش بازمی‌گرداند به او تعالی پناه می‌برم.",
    "ayah": 5,
    "surah": 113
  }
]
