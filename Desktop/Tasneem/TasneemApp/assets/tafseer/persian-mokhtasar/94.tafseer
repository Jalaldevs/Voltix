[
  {
    "text": "به راستى كه تو را دل گشاده كرديم و دریافت وحی را برايت خوشايند ساختیم.",
    "ayah": 1,
    "surah": 94
  },
  {
    "text": "گناهان گذشته شما را آمرزیدیم و سنگینی باری که از ایام جاهلیت بر تو بود، برداشتیم.",
    "ayah": 2,
    "surah": 94
  },
  {
    "text": "همان گناهی که تو را رنج می‌داد تا جایی‌که نزدیک بود کمرت را بشکند.",
    "ayah": 3,
    "surah": 94
  },
  {
    "text": "و یادت را برای تو بالا بردیم، که در اذان و اقامه و غیر این دو یاد می‌شوی.",
    "ayah": 4,
    "surah": 94
  },
  {
    "text": "به راستى كه همراه با هر سختی و تنگنايى، آسانی و گشایشى وجود دارد.",
    "ayah": 5,
    "surah": 94
  },
  {
    "text": "به راستی که همراه با هر سختی و تنگنايى، آسانی و گشایشى وجود دارد. پس اگر اين امر را درک كردى، نباید آزار قومت تو را بترساند و تو را از دعوت به سوی الله متعال بازدارد.",
    "ayah": 6,
    "surah": 94
  },
  {
    "text": "پس هرگاه از اعمالت فارغ شدی و از آنها دست کشیدی در عبادت پروردگارت بکوش.",
    "ayah": 7,
    "surah": 94
  },
  {
    "text": "و فقط به‌سوی الله تمایل و قصد کن.",
    "ayah": 8,
    "surah": 94
  }
]
