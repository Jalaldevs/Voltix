[
  {
    "text": "- ای رسول- ما به تو خیر زیادی، از جمله رود کوثر در بهشت دادیم.",
    "ayah": 1,
    "surah": 108
  },
  {
    "text": "پس در قبال این نعمت شکر الله را به جای آور، یعنی فقط برای او نماز بگزار و قربانی کن؛ برخلاف مشرکان که برای تقرب به بت‌های‌شان ذبح می‌کنند.",
    "ayah": 2,
    "surah": 108
  },
  {
    "text": "همانا کینه‌توزِ تو خودش از هر خیری بریده شده است و فراموش‌شده‌ای است که اگر یاد شود به بدی یاد می‌شود.",
    "ayah": 3,
    "surah": 108
  }
]
