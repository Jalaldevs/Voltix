[
  {
    "text": "الله به بادهایی که مانند یال اسب پیاپی می‌وزند سوگند یاد فرمود:",
    "ayah": 1,
    "surah": 77
  },
  {
    "text": "و به بادهای سخت وزنده سوگند یاد فرمود:",
    "ayah": 2,
    "surah": 77
  },
  {
    "text": "و به بادهایی که باران را می‌گسترانند سوگند یاد فرمود.",
    "ayah": 3,
    "surah": 77
  },
  {
    "text": "و به فرشتگانی که آنچه را میان حق و باطل جدایی می‌اندازد نازل می‌کنند سوگند یاد فرمود.",
    "ayah": 4,
    "surah": 77
  },
  {
    "text": "و به فرشتگانی که وحی را فرود می‌آورند سوگند یاد فرمود.",
    "ayah": 5,
    "surah": 77
  },
  {
    "text": "وحی را هشداری از جانب الله برای مردم، و بیم‌دادن مردم از عذاب او تعالی فرو می‌فرستند.",
    "ayah": 6,
    "surah": 77
  },
  {
    "text": "که رستاخیز و حسابرسی و جزایی که به آن وعده داده می‌شوید به‌طور قطع و بدون تردید واقع خواهد شد.",
    "ayah": 7,
    "surah": 77
  },
  {
    "text": "پس وقتی نور ستارگان محو شده و از بین برود.",
    "ayah": 8,
    "surah": 77
  },
  {
    "text": "و آن‌گاه که آسمان شکافته شود تا فرشتگان از آن فرود آیند.",
    "ayah": 9,
    "surah": 77
  },
  {
    "text": "و آن‌گاه که کوه‌ها از جای خویش کنده و متلاشی و به گرد و خاک تبدیل شوند.",
    "ayah": 10,
    "surah": 77
  },
  {
    "text": "و آن‌گاه که رسولان برای وقت مشخصی گرد آورده شوند.",
    "ayah": 11,
    "surah": 77
  },
  {
    "text": "برای روزی بزرگ که برای گواهی بر امت‌های‌شان تعیین شده است.",
    "ayah": 12,
    "surah": 77
  },
  {
    "text": "برای روز داوری میان بندگان، که حق‌دار از ناحق، و خوشبخت از بدبخت مشخص می‌شود.",
    "ayah": 13,
    "surah": 77
  },
  {
    "text": "و - ای رسول- تو چه می‌دانی که روز داوری چیست؟!",
    "ayah": 14,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر تکذیب ‌کنندگانی باد که آنچه را رسولان از جانب الله آوردند تکذیب می‌کنند.",
    "ayah": 15,
    "surah": 77
  },
  {
    "text": "مگر امت‌های پیشین را وقتی به الله کفر ورزیدند و رسولانش را تکذیب کردند نابود نکردیم؟!",
    "ayah": 16,
    "surah": 77
  },
  {
    "text": "و تکذیب‌ کنندگان بعدی را نیز همانند آنها و در پی آنها نابود کردیم.",
    "ayah": 17,
    "surah": 77
  },
  {
    "text": "مانند نابودکردن آن امت‌ها، مجرمان تکذیب‌ کننده به رسالت محمد صلی الله علیه وسلم را نابود می‌کنیم.",
    "ayah": 18,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر تکذیب ‌کنندگان وعید الله به مجازات مجرمان باد.",
    "ayah": 19,
    "surah": 77
  },
  {
    "text": "- ای مردم- مگر شما را از آبی پست و اندک یعنی نطفه نیافریدیم.",
    "ayah": 20,
    "surah": 77
  },
  {
    "text": "پس آن آب پست را در مکانی حفاظت‌شده یعنی رحم زن قرار دادیم.",
    "ayah": 21,
    "surah": 77
  },
  {
    "text": "تا زمانی مشخص یعنی مدت حمل.",
    "ayah": 22,
    "surah": 77
  },
  {
    "text": "سپس صفت و اندازه و رنگ و سایر خصوصیات نوزاد را فراهم آوردیم، پس ما برای تمام این موارد توانایان بسیار خوبی هستیم.",
    "ayah": 23,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و زیان در آن روز بر تکذیب ‌کنندگانِ قدرت الله باد.",
    "ayah": 24,
    "surah": 77
  },
  {
    "text": "آیا زمین را گردآورندۀ تمام مردم قرار ندادیم.",
    "ayah": 25,
    "surah": 77
  },
  {
    "text": "که زندگان‌شان را با سکونت و آبادانی آن، و مردگان‌شان را با دفن در خود گرد می‌آورد.",
    "ayah": 26,
    "surah": 77
  },
  {
    "text": "و کوه‌هایی استوار و بلند در آن قرار دادیم، که آن را از لرزیدن محافظت می‌کنند، و - ای مردم- آبی گوارا به شما نوشاندیم. و ذاتی‌که این موارد را آفریده باشد از برانگیختن شما ناتوان نیست.",
    "ayah": 27,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر کسانی ‌باد که نعمت‌های الله بر خودشان را انکار می‌کنند.",
    "ayah": 28,
    "surah": 77
  },
  {
    "text": "و به کسانی‌که آنچه را رسولان‌شان آوردند تکذیب کردند گفته می‌شود: - ای تکذیب‌ کنندگان- به‌سوی عذابی که آن را تکذیب می‌کردید بروید.",
    "ayah": 29,
    "surah": 77
  },
  {
    "text": "به‌سوی سایه‌بانی از دود آتش که به سه شاخه جدا شده است بروید.",
    "ayah": 30,
    "surah": 77
  },
  {
    "text": "نه خنکیِ سایه را دارد، و نه مانع رسیدن سوزش و حرارتِ آتش به شما می‌شود.",
    "ayah": 31,
    "surah": 77
  },
  {
    "text": "به‌راستی‌که آتش جهنم، آتشپاره‌هایی می‌افکند، که هر یک از آنها از نظر بزرگی مانند کاخی است.",
    "ayah": 32,
    "surah": 77
  },
  {
    "text": "این پاره‌های آتش، گویی در سیاهی و ضخامت مانند شترانی سیاه هستند.",
    "ayah": 33,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر تکذیب‌ کنندگان عذاب الله باد.",
    "ayah": 34,
    "surah": 77
  },
  {
    "text": "در این روز هیچ سخنی نمی‌گویند.",
    "ayah": 35,
    "surah": 77
  },
  {
    "text": "و به آنها اجازه داده نمی‌شود که از کفر و گناهان‌شان به‌سوی پروردگارشان پوزش بخواهند.",
    "ayah": 36,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر تکذیب ‌کنندگانِ اخبارِ آن روز باد.",
    "ayah": 37,
    "surah": 77
  },
  {
    "text": "این روزِ داوری بین مخلوقات است، که شما و امت‌های پیشین را در یک میدانِ هموار گرد می‌آوریم.",
    "ayah": 38,
    "surah": 77
  },
  {
    "text": "پس اگر حیله‌ای دارید که برای نجات از عذاب الله با آن چاره‌جویی کنید پس علیه من به‌کار گیرید.",
    "ayah": 39,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر تکذیب‌ کنندگانِ روز داوری باد.",
    "ayah": 40,
    "surah": 77
  },
  {
    "text": "به‌راستی‌، کسانی که با اجرای اوامر و اجتناب از نواهیِ پروردگارشان پرهیزگاری می‌کنند، در سایه‌های درختان سبز و خرم و تازۀ بهشت و چشمه‌های آب گوارا و جاری، هستند.",
    "ayah": 41,
    "surah": 77
  },
  {
    "text": "و در میان هر میوه‌ای که خواهان خوردن آن باشند.",
    "ayah": 42,
    "surah": 77
  },
  {
    "text": "و به آنها گفته می‌شود: به‌سبب اعمال صالحی که در دنیا انجام می‌دادید، از پاکیزه‌ها بخورید، و نوشیدنی گوارایی که هیچ ناگواری‌ای در آن نیست بنوشید.",
    "ayah": 43,
    "surah": 77
  },
  {
    "text": "همانا مانند این جزا که به شما جزا دادیم نیکوکاران را جزا می‌دهیم.",
    "ayah": 44,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی باد در آن روز بر تکذیب ‌کنندگانِ نعمت‌های که الله برای پرهیزگاران آماده ساخته است.",
    "ayah": 45,
    "surah": 77
  },
  {
    "text": "و به تکذیب‌ کنندگان گفته می‌شود: زمانی اندک در دنیا بخورید و از خوشی‌های زندگی بهره‌مند شوید. به‌راستی‌که شما به‌سبب کفر به الله و تکذیب رسولانش مجرم هستید.",
    "ayah": 46,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی در آن روز بر تکذیب‌ کنندگانِ جزا در روز قیامت باد.",
    "ayah": 47,
    "surah": 77
  },
  {
    "text": "و هرگاه به این تکذیب ‌کنندگان گفته شود: برای الله نماز بگزارید برای او تعالی نماز نمی‌گزارند.",
    "ayah": 48,
    "surah": 77
  },
  {
    "text": "نابودی و عذاب و تباهی باد در آن روز بر منکِرانی که آنچه را رسولان از جانب الله آورده‌اند تکذیب می‌کنند.",
    "ayah": 49,
    "surah": 77
  },
  {
    "text": "وقتی به این قرآنِ نازل‌شده از جانب پروردگارشان ایمان نیاوردند پس به کدام سخن دیگری ایمان خواهند آورد؟!",
    "ayah": 50,
    "surah": 77
  }
]
