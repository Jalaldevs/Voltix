[
  {
    "text": "- ای رسول- آنچه را الله به تو وحی می‌کند، با آغاز نام پروردگارت که تمام مخلوقات را آفرید، بخوان.",
    "ayah": 1,
    "surah": 96
  },
  {
    "text": "انسان را پس از اینکه نطفه بود از تکه خونی بسته آفرید.",
    "ayah": 2,
    "surah": 96
  },
  {
    "text": "- ای رسول- آنچه را الله به تو وحی می‌کند بخوان، پروردگار تو بخشنده‌ترین است و هیچ‌کس مانند او بخشنده نیست، زیرا او تعالی سخاوت و دَهِش زیادی دارد.",
    "ayah": 3,
    "surah": 96
  },
  {
    "text": "همان ذاتی‌که به وسیلۀ قلم خط و نوشتن را آموخت.",
    "ayah": 4,
    "surah": 96
  },
  {
    "text": "چیزهایی را که انسان نمی‌دانست به او آموخت.",
    "ayah": 5,
    "surah": 96
  },
  {
    "text": "انسان بدکار مانند ابوجهل به‌طور قطع از حدود الله می‌گذرد.",
    "ayah": 6,
    "surah": 96
  },
  {
    "text": "زیرا به‌سبب مال و مقامی که دارد خودش را بی‌نیاز می‌بیند.",
    "ayah": 7,
    "surah": 96
  },
  {
    "text": "- ای انسان- قطعاً بازگشت در روز قیامت فقط به‌سوی پروردگارت است آن‌گاه هرکس را به آنچه که استحقاقش را دارد جزا می‌دهد.",
    "ayah": 8,
    "surah": 96
  },
  {
    "text": "آیا عجیب‌تر از کار ابوجهل که بازمی‌داشت دیده‌ای.",
    "ayah": 9,
    "surah": 96
  },
  {
    "text": "بندۀ ما محمد صلی الله علیه وسلم را آن‌گاه که کنار کعبه نماز می‌گزارد.",
    "ayah": 10,
    "surah": 96
  },
  {
    "text": "به من خبر بده اگر این بازداشته‌شده، بر هدایت و بصیرتی از جانب پروردگارش باشد؟!",
    "ayah": 11,
    "surah": 96
  },
  {
    "text": "یا مردم را به تقوای الله با اجرای اوامر و اجتناب از نواهی‌اش فرمان دهد، آیا چنین کسی بازداشته می‌شود؟!",
    "ayah": 12,
    "surah": 96
  },
  {
    "text": "به من خبر بده اگر این بازدارنده، آنچه را رسول صلی الله علیه وسلم نزدش آورده است تکذیب کند و از آن روی گردانَد، آیا از الله نمی‌ترسد؟!",
    "ayah": 13,
    "surah": 96
  },
  {
    "text": "آیا بازدارندۀ این بنده از نماز ندانسته است که هر کاری انجام دهد الله می‌بیند، و ذره‌ای از اعمالش بر او پوشیده نمی‌ماند؟!",
    "ayah": 14,
    "surah": 96
  },
  {
    "text": "امر آن‌گونه که این جاهل تصور می‌کند نیست، اگر از آزار و تکذیب بندۀ ما دست نکشد، به‌طور قطع موی جلو سرش را به شدت می‌گیریم و به‌سوی جهنم می‌کشانیم.",
    "ayah": 15,
    "surah": 96
  },
  {
    "text": "صاحب آن موی جلوی سرِ دروغگو در سخن، و خطاکار در فعل.",
    "ayah": 16,
    "surah": 96
  },
  {
    "text": "پس باید وقتی موی جلوی سرش به‌سوی آتش کشیده می‌شود دوستان و همنشینانش را بخواند و از آنها یاری بجوید تا او را از عذاب نجات دهند.",
    "ayah": 17,
    "surah": 96
  },
  {
    "text": "ما هم به‌زودی فرشتگان سخت‌گیر و خشن که مامور جهنم هستند و در هیچ‌یک از فرامین الله از او تعالی نافرمانی نمی‌کنند، و آنچه را فرمان یابند انجام می‌دهند می‌خوانیم، پس باید بنگرد کدام‌یک از این دو گروه قوی‌تر و تواناتر است.",
    "ayah": 18,
    "surah": 96
  },
  {
    "text": "امر چنان‌که این ستمکار پنداشته نیست که می‌تواند آسیبی به تو برساند، پس نه در امر و نه در نهی از او اطاعت نکن، و برای الله سجده بگزار، و با طاعات به‌سوی او نزدیکی بجوی، زیرا طاعات به‌سوی او نزدیک می‌سازند.",
    "ayah": 19,
    "surah": 96
  }
]
