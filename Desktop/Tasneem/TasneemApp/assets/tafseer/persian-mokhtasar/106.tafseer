[
  {
    "text": "به خاطر عادت و خوگرفتن قریش.",
    "ayah": 1,
    "surah": 106
  },
  {
    "text": "به سفر ایمن زمستانی به‌سوی یمن، و سفر ایمن تابستانی به‌سوی شام.",
    "ayah": 2,
    "surah": 106
  },
  {
    "text": "پس باید الله پروردگار این خانۀ حرمت‌دار را که سفر مذکور را برای‌شان آسان کرد، به یگانگی عبادت کنند و هیچ‌کس را با او شریک نگردانند.",
    "ayah": 3,
    "surah": 106
  },
  {
    "text": "همان ذاتی‌که با حرمت‌دار کردن حرم و ساکنانش در دل عرب‌ها، ساکنانش را در گرسنگی غذا داد، و از ترس ایمن کرد.",
    "ayah": 4,
    "surah": 106
  }
]
