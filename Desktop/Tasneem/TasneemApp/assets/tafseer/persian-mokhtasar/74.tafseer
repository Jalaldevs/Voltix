[
  {
    "text": "ای کسی‌که خودش را با لباسش پوشانیده (یعنی پیامبر صلی الله علیه وسلم ).",
    "ayah": 1,
    "surah": 74
  },
  {
    "text": "برخیز و از عذاب الله بترسان.",
    "ayah": 2,
    "surah": 74
  },
  {
    "text": "و پروردگارت را بزرگ شمار.",
    "ayah": 3,
    "surah": 74
  },
  {
    "text": "و نفس خویش را از گناهان و لباست را از نجاست‌ها پاک کن.",
    "ayah": 4,
    "surah": 74
  },
  {
    "text": "و از عبادت بت‌ها دوری گزین.",
    "ayah": 5,
    "surah": 74
  },
  {
    "text": "و به سبب بزرگ پنداشتن عمل نیک خود، بر پروردگارت منت نگذار.",
    "ayah": 6,
    "surah": 74
  },
  {
    "text": "و در برابر آزارهایی که با آنها روبرو می‌شوی به خاطر الله شکیبایی کن.",
    "ayah": 7,
    "surah": 74
  },
  {
    "text": "پس آن‌گاه که برای بار دوم در صور دمیده شود.",
    "ayah": 8,
    "surah": 74
  },
  {
    "text": "آن روز، روزی سخت است.",
    "ayah": 9,
    "surah": 74
  },
  {
    "text": "بر کافران به الله و رسولش آسان نیست.",
    "ayah": 10,
    "surah": 74
  },
  {
    "text": "- ای رسول- مرا با کسی‌که او را در شکم مادرش تک و تنها بدون مال یا فرزند آفریدم (یعنی ولید بن مُغِیره) واگذار.",
    "ayah": 11,
    "surah": 74
  },
  {
    "text": "و مال زیادی برایش قرار دادم.",
    "ayah": 12,
    "surah": 74
  },
  {
    "text": "و پسرانی برایش قرار دادم که همراهش حاضر هستند و در محافل با او حضور دارند و به خاطر مال زیادش در هیچ سفری از او جدا نمی‌شوند.",
    "ayah": 13,
    "surah": 74
  },
  {
    "text": "و در زندگی و روزی و فرزند از هر نظر برایش گستراندم.",
    "ayah": 14,
    "surah": 74
  },
  {
    "text": "باز هم با وجود کفرش به من طمع دارد که پس از اینکه تمام این موارد را به او دادم برایش بیفزایم.",
    "ayah": 15,
    "surah": 74
  },
  {
    "text": "امر آن‌گونه که تصور کرد نیست، زیرا او ستیزه‌جو و تکذیب‌ کنندۀ آیاتی است که بر رسول مان نازل کردیم.",
    "ayah": 16,
    "surah": 74
  },
  {
    "text": "به‌زودی عذابی سخت بر دوش او می‌گذارم که توان تحملش را ندارد.",
    "ayah": 17,
    "surah": 74
  },
  {
    "text": "همانا این کافر که نعمت‌های مذکور را به او ارزانی داشتم برای ابطال آنچه قرآن در مورد او می‌گوید اندیشید، و طرحی در ذهنش آماده کرد.",
    "ayah": 18,
    "surah": 74
  },
  {
    "text": "نفرین و عذاب بر او باد چگونه ارزیابی کرد.",
    "ayah": 19,
    "surah": 74
  },
  {
    "text": "باز هم نفرین و عذاب بر او باد، چگونه سنجید و ارزیابی کرد.",
    "ayah": 20,
    "surah": 74
  },
  {
    "text": "دوباره در آنچه که می‌گوید نگریست و اندیشید.",
    "ayah": 21,
    "surah": 74
  },
  {
    "text": "سپس چون چیزی نیافت که با آن بر قرآن عیب وارد کند چهره در هم کشید و خشم کرد.",
    "ayah": 22,
    "surah": 74
  },
  {
    "text": "سپس از ایمان روی گرداند و از پیروی پیامبر صلی الله علیه وسلم خودداری کرد.",
    "ayah": 23,
    "surah": 74
  },
  {
    "text": "پس گفت: این چیزی که محمد آورده است سخن الله نیست، بلکه سحری است که از دیگران روایت می‌کند.",
    "ayah": 24,
    "surah": 74
  },
  {
    "text": "کلام الله نیست، بلکه کلام انسان است.",
    "ayah": 25,
    "surah": 74
  },
  {
    "text": "به‌زودی این کافر را در یکی از طبقات جهنم، یعنی سَقَر که گرمایی کشنده دارد وارد می‌کنم.",
    "ayah": 26,
    "surah": 74
  },
  {
    "text": "و - ای محمد- تو چه می‌دانی که سَقَر چیست؟!",
    "ayah": 27,
    "surah": 74
  },
  {
    "text": "از عذاب‌شدۀ در خویش چیزی باقی نمی‌گذارد مگر اینکه او را فرا می‌گیرد، و رها نمی‌کند، سپس همان‌گونه که بود بازمی‌گردد، سپس بر او فرود می‌آید، و به همین ترتیب ادامه دارد.",
    "ayah": 28,
    "surah": 74
  },
  {
    "text": "پوست‌ها را سخت می‌سوزاند و تغییر می‌دهد.",
    "ayah": 29,
    "surah": 74
  },
  {
    "text": "بر آن نوزده فرشته گمارده شده است، که خزانه‌دارانش هستند.",
    "ayah": 30,
    "surah": 74
  },
  {
    "text": "و ما مأموران دوزخ را تنها از میان فرشتگان بر گزیده ایم، و انسان توانایی مقابله با آن ها را ندارد، و تعداد آن ها را جز آزمایشی برای کسانی که به الله کفر ورزیده اند، قرار ندادیم؛ تا در مورد آن ها هر چه كه می خواهند بگویند و در نهایت عذاب بر آنان دوچندان می شود، و تا یهود که تورات، و نصاری که انجیل به آن ها داده شده، اطمینان حاصل کنند که قرآن، تصدیق کننده ی آنچه مى باشد در کتاب هایشان است. همچنین مؤمنان زمانی که این (موضوع مورد) توافق را می بینند، ایمانشان افزايش يابد و یهود، نصاری و مؤمنان (در حق بودنش) شک و تردیدی نکنند، و تا کسانی که در دل هایشان بيمارى و ترديد وجود دارد و همچنين کافران، بگویند: الله با تعیین این عدد عجیب چه چیزی را اراده کرده است؟! همچنان که الله متعال تکذیب کننده ی این عدد را گمراه، و تصدیق کننده ی آن را مورد هدایت قرار داده است؛ هر کس را بخواهد گمراه و هر کس را بخواهد هدایت می دهد. به علت كثرت و فراوانی، کسی جز پروردگار از (انواع و ماهیت) لشکریانش آگاه نیست، و دوزخ جز اندرزى براى مردمان نيست تا با آن به بزرگی الله متعال پی ببرند.",
    "ayah": 31,
    "surah": 74
  },
  {
    "text": "سخن آن‌گونه نیست که یکی از مشرکان ادعا می‌کند یارانش برای چیره‌شدن بر خزانه‌داران جهنم کافی هستند. الله به ماه سوگند یاد فرمود.",
    "ayah": 32,
    "surah": 74
  },
  {
    "text": "و به شب آن‌گاه که پشت کند سوگند یاد فرمود.",
    "ayah": 33,
    "surah": 74
  },
  {
    "text": "و به صبح آن‌گاه که روشنایی آورد سوگند یاد فرمود.",
    "ayah": 34,
    "surah": 74
  },
  {
    "text": "که آتش جهنم به‌طور قطع یکی از بلایای بزرگ است.",
    "ayah": 35,
    "surah": 74
  },
  {
    "text": "وسیلۀ تهدید و ترساندن مردم است.",
    "ayah": 36,
    "surah": 74
  },
  {
    "text": "- ای مردم- برای هرکس از شما که بخواهد با ایمان به الله و عمل صالح پیشی جوید، یا با کفر و گناهان عقب بکشد.",
    "ayah": 37,
    "surah": 74
  },
  {
    "text": "هرکس در قبال اعمالی‌که کسب کرده گرفتار است. پس یا اعمالش او را نابود می‌کند، یا او را از نابودی می‌رهاند و نجات می‌دهد.",
    "ayah": 38,
    "surah": 74
  },
  {
    "text": "مگر مؤمنان که در قبال گناهان‌شان مواخذه نمی‌شوند، بلکه به‌سبب اعمال صالحی که دارند مورد عفو قرار می‌گیرند.",
    "ayah": 39,
    "surah": 74
  },
  {
    "text": "و آنها روز قیامت در بهشت‌هایی هستند و از یکدیگر می‌پرسند.",
    "ayah": 40,
    "surah": 74
  },
  {
    "text": "در مورد کافران که خودشان را با گناهانی که انجام دادند نابود کردند.",
    "ayah": 41,
    "surah": 74
  },
  {
    "text": "به آنها می‌گویند: چه چیزی شما را وارد جهنم کرد؟",
    "ayah": 42,
    "surah": 74
  },
  {
    "text": "کافران این‌گونه به آنها پاسخ می‌دهند: از کسانی‌که نماز واجب را در زندگی دنیا برپا می‌داشتند نبودیم.",
    "ayah": 43,
    "surah": 74
  },
  {
    "text": "و از آنچه که الله به ما عطا کرده بود به فقیر اطعام نمی‌کردیم.",
    "ayah": 44,
    "surah": 74
  },
  {
    "text": "و همراه پیروان باطل بودیم که هرجا می‌گشتند با آنها می‌گشتیم، و با گمراهان و فریب ‌خوردگان سخن می‌گفتیم.",
    "ayah": 45,
    "surah": 74
  },
  {
    "text": "و روز جزا را تکذیب می‌کردیم.",
    "ayah": 46,
    "surah": 74
  },
  {
    "text": "و به تکذیب روز جزا ادامه دادیم تا مرگ ما را فرا گرفت، آن‌گاه میان ما و توبه مانع ایجاد کرد.",
    "ayah": 47,
    "surah": 74
  },
  {
    "text": "پس شفاعت شفاعتگران، اعم از فرشتگان و پیامبران و صالحان در روز قیامت به آنان سودی نمی رساند؛ چرا که یکی از شروط پذیرش شفاعت، رضایت از شفاعت شده است.",
    "ayah": 48,
    "surah": 74
  },
  {
    "text": "چه چیزی باعث رویگردانی این مشرکان از قرآن شد؟!",
    "ayah": 49,
    "surah": 74
  },
  {
    "text": "گویی در رویگردانی و فرار از قرآن، گورخرانی بسیار رمنده هستند.",
    "ayah": 50,
    "surah": 74
  },
  {
    "text": "که از شیری به‌سبب ترس از آن می‌گریزند.",
    "ayah": 51,
    "surah": 74
  },
  {
    "text": "بلکه هر یک از این مشرکان می‌خواهد نامه‌ای برایش ارسال شود که به او خبر می‌دهد محمد رسولی از جانب الله است، و سبب این امر کمبود و ضعف دلایل و حجت‌ها نیست، بلکه فقط ستیزه‌جویی و تکبر است.",
    "ayah": 52,
    "surah": 74
  },
  {
    "text": "چنین نیست، بلکه سبب استمرار گمراهی آنها این است که به عذاب آخرت ایمان نمی‌آورند، و بر کفرشان باقی می‌مانند.",
    "ayah": 53,
    "surah": 74
  },
  {
    "text": "بدانید که این قرآن اندرز و یادآوری است.",
    "ayah": 54,
    "surah": 74
  },
  {
    "text": "پس هرکس که بخواهد می‌تواند قرآن را بخواند و از آن اندرز گیرد.",
    "ayah": 55,
    "surah": 74
  },
  {
    "text": "و پند نمی‌گیرند مگر اینکه الله بخواهد پند بگیرند. او سبحانه سزاوار است که با امتثال اوامر و اجتناب از نواهی‌اش از او ترسیده شود، و سزاوار است که گناهان بندگانش را آن‌گاه که به‌سوی او توبه کنند بیامرزد.",
    "ayah": 56,
    "surah": 74
  }
]
