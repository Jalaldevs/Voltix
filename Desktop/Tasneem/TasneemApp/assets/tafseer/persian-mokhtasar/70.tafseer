[
  {
    "text": "یکی از مشرکان از روی استهزاء خواست که عذاب بر او و قومش واقع شود اگر این عذاب حاصل می‌شود، درحالی‌که این عذاب در روز قیامت واقع می‌شود.",
    "ayah": 1,
    "surah": 70
  },
  {
    "text": "برای کافران به الله؛ و کسی نیست که این عذاب را بازگرداند.",
    "ayah": 2,
    "surah": 70
  },
  {
    "text": "از جانب الله که دارای علوّ و درجات و بخشش‌ها و نعمت‌های بزرگ و نیکو است.",
    "ayah": 3,
    "surah": 70
  },
  {
    "text": "در روز قیامت که روزی طولانی و به اندازۀ پنجاه هزار سال است، فرشتگان و جبرئیل در آن درجات به‌سوی او بالا می‌روند.",
    "ayah": 4,
    "surah": 70
  },
  {
    "text": "پس - ای رسول- بدون بی‌قراری و گله‌مندی صبر کن.",
    "ayah": 5,
    "surah": 70
  },
  {
    "text": "زیرا آنها این عذاب را دور و وقوع آن را محال می‌دانند.",
    "ayah": 6,
    "surah": 70
  },
  {
    "text": "و ما آن را بدون تردید نزدیک و واقع‌شدنی می‌دانیم.",
    "ayah": 7,
    "surah": 70
  },
  {
    "text": "روزی‌که آسمان مانند مس و طلا و سایر فلزهای گداخته‌شده مذاب می‌شود.",
    "ayah": 8,
    "surah": 70
  },
  {
    "text": "و کوه‌ها از نظر سبکی مانند پشم‌ها می‌شوند.",
    "ayah": 9,
    "surah": 70
  },
  {
    "text": "و هیچ خویشاوندی از حال خویشاوندش نمی‌پرسد، زیرا هرکس به خویشتن مشغول است.",
    "ayah": 10,
    "surah": 70
  },
  {
    "text": "هر انسانی به خویشاوندش نشان داده می‌شود و بر او پوشیده نمی‌ماند، با این وجود به‌سبب هراس زیاد، هیچ‌کس از هیچ‌کس دیگر نمی‌پرسد، و کسی‌که مستحق جهنم است دوست دارد که به جای خویش فرزندانش را برای عذاب پیش کند.",
    "ayah": 11,
    "surah": 70
  },
  {
    "text": "و همسر و برادرش را فدیه دهد.",
    "ayah": 12,
    "surah": 70
  },
  {
    "text": "و فامیل‌های نزدیکش را فدیه بدهد، همان کسانی‌که در سختی‌ها کنارش بودند.",
    "ayah": 13,
    "surah": 70
  },
  {
    "text": "و تمام انسان‌ها و جن‌ها و هر آنچه را در روی زمین است فدیه بدهد، تا رها شود و از عذاب جهنم نجات یابد.",
    "ayah": 14,
    "surah": 70
  },
  {
    "text": "امر چنانکه این جنایتکار آرزو می‌کند نیست، زیرا آتش آخرت زبانه و شعله می‌کشد.",
    "ayah": 15,
    "surah": 70
  },
  {
    "text": "از حرارت و اشتعال زیاد پوست سر را به شدت برمی‌کند.",
    "ayah": 16,
    "surah": 70
  },
  {
    "text": "هرکس را که از حق روی گردانده، و از آن دور شده است و به آن ایمان نیاورده و عمل نکرده است.",
    "ayah": 17,
    "surah": 70
  },
  {
    "text": "و مال جمع کرده، و در انفاق از آن در راه الله بخل ورزیده است فرا می‌خواند.",
    "ayah": 18,
    "surah": 70
  },
  {
    "text": "به‌راستی‌که انسان بسیار حریص آفریده شده است.",
    "ayah": 19,
    "surah": 70
  },
  {
    "text": "هرگاه آسیبی همچون بیماری یا فقر به او رسد کم‌صبر است.",
    "ayah": 20,
    "surah": 70
  },
  {
    "text": "و هرگاه فراخ‌حالی و ثروت که می‌پسندد به او رسد، برای بخشش آن در راه الله بسیار منع‌کننده است.",
    "ayah": 21,
    "surah": 70
  },
  {
    "text": "جز نمازگزاران، که از این صفات نکوهیده پاک هستند.",
    "ayah": 22,
    "surah": 70
  },
  {
    "text": "همان کسانی‌که بر نمازشان مواظبت می‌کنند، و از آن غافل نمی‌شوند، و آن را در وقتی که برایش مشخص شده است برپا می‌دارند.",
    "ayah": 23,
    "surah": 70
  },
  {
    "text": "و همان کسانی‌که سهمی مشخص و مفروض در اموال‌شان است.",
    "ayah": 24,
    "surah": 70
  },
  {
    "text": "و آن را به کسی‌که از آنها تقاضا کند، و به کسی‌که از آنها تقاضا نکند و به هر سببی از روزی محروم شده است می‌پردازند.",
    "ayah": 25,
    "surah": 70
  },
  {
    "text": "و همان کسانی‌که روز قیامت را تصدیق می‌کنند، روزی‌که الله هرکس را متناسب با عملش جزا می‌دهد.",
    "ayah": 26,
    "surah": 70
  },
  {
    "text": "و همان کسانی‌که با وجود اعمال صالحی که پیش فرستاده‌اند از عذاب پروردگارشان می‌ترسند.",
    "ayah": 27,
    "surah": 70
  },
  {
    "text": "به‌راستی‌که عذاب پروردگارشان امر ترسناکی است که هیچ عاقلی از آن ایمن نیست.",
    "ayah": 28,
    "surah": 70
  },
  {
    "text": "و همان کسانی‌که عورت‌های‌شان را با پوشاندن و دورکردن از فواحش حفظ می‌کنند.",
    "ayah": 29,
    "surah": 70
  },
  {
    "text": "مگر از همسران‌شان یا کنیزانی که در اختیار دارند، که در بهره ‌بردن از آنها از طریق جماع یا غير آن مورد سرزنش نیستند.",
    "ayah": 30,
    "surah": 70
  },
  {
    "text": "پس کسانی‌که بهره ‌بردن از غیر همسران و کنیزان را بجویند، اینها همان متجاوزان از حدود الله هستند.",
    "ayah": 31,
    "surah": 70
  },
  {
    "text": "و همان‌ها که از اموال و اسرار و سایر اموری که بر آن امین قرار داده شده‌اند، و از پیمان‌های‌شان که با مردم پیمان بسته‌اند محافظت می‌کنند، و در امانت‌های‌شان خیانت نمی‌کنند، و پیمان‌های‌شان را نمی‌شکنند.",
    "ayah": 32,
    "surah": 70
  },
  {
    "text": "و کسانی که بر ادای شهادت هایشان به طور شایسته، متعهد هستند و خویشاوندی و دشمنی در اداى آن تأثیرى نمى گذارد.",
    "ayah": 33,
    "surah": 70
  },
  {
    "text": "و همان‌ها که با ادای نمازهای‌شان در وقت مخصوص آن، و با طهارت و طمأنینه، بر نمازها مداومت می‌کنند، و هیچ‌چیز آنها را از نماز غافل نمی‌سازد.",
    "ayah": 34,
    "surah": 70
  },
  {
    "text": "کسانی‌که صفات مذکور را دارند، به‌سبب نعمت‌هایی جاویدان، و نگاه کردن به وجه گرامی الله که به آن می‌رسند در بهشت‌ها مورد اکرام و احترام هستند.",
    "ayah": 35,
    "surah": 70
  },
  {
    "text": "- ای رسول- به چه سبب این مشرکان شتابان به‌سوی تو می‌آیند و تو را تکذیب می‌کنند؟!",
    "ayah": 36,
    "surah": 70
  },
  {
    "text": "گروه گروه تو را از راست و چپ احاطه می‌کنند.",
    "ayah": 37,
    "surah": 70
  },
  {
    "text": "آیا هر یک از آنها آرزو دارد که الله او را وارد بهشت پرنعمت کند، و از نعمت‌هایی جاویدانش برخوردار شود، درحالی‌که بر کفرش باقی است؟!",
    "ayah": 38,
    "surah": 70
  },
  {
    "text": "امر آن‌گونه که تصور کردند نیست؛ زیرا ما آنها را از آنچه می‌شناسند آفریدیم. به تحقیق آنها را از آب پستی آفریده‌ایم، پس آنها ضعیفانی هستند که مالک هیچ سود و زیانی برای خودشان نیستند، پس چگونه تکبر می‌ورزند؟!",
    "ayah": 39,
    "surah": 70
  },
  {
    "text": "الله متعال به ذات بزرگوارشان که پروردگار مشرق ها و مغرب های خورشید و ماه و سایر ستارگان هستند، سوگند یاد فرموده که ما توانا هستیم.",
    "ayah": 40,
    "surah": 70
  },
  {
    "text": "از نابودی آنها و آوردن کسانی دیگر به جای آنها که از الله فرمان‌برداری کنند، ناتوان نیستیم، و هرگاه این کار را اراده کنیم مغلوب نمی‌شویم.",
    "ayah": 41,
    "surah": 70
  },
  {
    "text": "پس - ای رسول- آنها را واگذار تا در باطل و گمراهی خویش غوطه‌ور شوند، و در زندگی دنیا بازی کنند تا اینکه روز قیامت را که در قرآن به آن وعده داده شده‌اند ملاقات کنند.",
    "ayah": 42,
    "surah": 70
  },
  {
    "text": "روزی‌که شتابان از قبرهای‌شان خارج می‌شوند گویی به‌سوی پرچمی با هم مسابقه می‌دهند.",
    "ayah": 43,
    "surah": 70
  },
  {
    "text": "درحالی‌که چشمان‌شان فرو افتاده، و ذلتی آنها را می‌پوشاند، این همان روزی است که در دنیا به آن وعده داده می‌شدند، اما اهمیتی به آن نمی‌دادند.",
    "ayah": 44,
    "surah": 70
  }
]
