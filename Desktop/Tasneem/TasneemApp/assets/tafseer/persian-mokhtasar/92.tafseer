[
  {
    "text": "الله به شب آن‌گاه که میان آسمان وزمین را با تاریکی‌اش می‌پوشاند سوگند یاد فرمود.",
    "ayah": 1,
    "surah": 92
  },
  {
    "text": "و به روز آن‌گاه که آشکار و نمایان شود سوگند یاد فرمود.",
    "ayah": 2,
    "surah": 92
  },
  {
    "text": "و به دو نوع آفرینش خویش: نر و ماده سوگند یاد کرد.",
    "ayah": 3,
    "surah": 92
  },
  {
    "text": "که - ای مردم- به‌طور قطع اعمال مختلفی دارید، یعنی بخشی از آن نیکی‌ها است که سبب ورود به بهشت هستند، و برخی دیگر بدی‌ها است که سبب ورود به جهنم هستند.",
    "ayah": 4,
    "surah": 92
  },
  {
    "text": "اما کسی‌که زکات و نفقه و کفاره‌ای را که بخشش آن برایش لازم است پرداخت، و از آنچه الله از آن نهی فرموده پرهیزگاری کرد.",
    "ayah": 5,
    "surah": 92
  },
  {
    "text": "و عوضی را که الله به او وعده داده است تصدیق کرد.",
    "ayah": 6,
    "surah": 92
  },
  {
    "text": "به‌زودی عمل صالح، و انفاق در راه الله را بر او آسان خواهیم کرد.",
    "ayah": 7,
    "surah": 92
  },
  {
    "text": "و اما کسی‌که در مالش بخل ورزید و آن را در راهی که بخشش مال برایش واجب است نبخشید، و به‌سبب مال خویش از الله احساس بی‌نیازی کرد و چیزی از فضل او تعالی از الله درخواست نکرد.",
    "ayah": 8,
    "surah": 92
  },
  {
    "text": "و عوض و پاداش انفاق مالش در راه الله را که الله به او وعده داده است تکذیب کرد.",
    "ayah": 9,
    "surah": 92
  },
  {
    "text": "به‌زودی انجام کار شر را بر او آسان خواهیم کرد، و انجام کار خیر را بر او سخت خواهیم گرداند.",
    "ayah": 10,
    "surah": 92
  },
  {
    "text": "و آن‌گاه که نابود شود، و وارد جهنم شود، مالش که با آن بخل ورزید ذره‌ای او را بی‌نیاز نمی‌سازد.",
    "ayah": 11,
    "surah": 92
  },
  {
    "text": "برعهدۀ ما است که راه حق را از باطل آشکار کنیم.",
    "ayah": 12,
    "surah": 92
  },
  {
    "text": "و به یقین که زندگی آخرت و زندگی دنیا از آنِ ما است، که هرگونه بخواهیم در این دو تصرف می‌کنیم، و هیچ‌کس غیر از ما چنین اختیاری ندارد.",
    "ayah": 13,
    "surah": 92
  },
  {
    "text": "پس - ای مردم- شما را از آتشی ترساندم که اگر شما از الله نافرمانی کنید شعله‌ور می‌شود.",
    "ayah": 14,
    "surah": 92
  },
  {
    "text": "گرمای این آتش فقط بدبخت‌ترین یعنی کافر را رنج می‌دهد.",
    "ayah": 15,
    "surah": 92
  },
  {
    "text": "کسی‌که آنچه را رسول صلی الله علیه وسلم آورد تکذیب کرد، و از اجرای امر الله روی گرداند.",
    "ayah": 16,
    "surah": 92
  },
  {
    "text": "و باتقواترین مردمان كه ابوبکر -رضی الله عنه- است، از آن دور نگه داشته خواهد شد.",
    "ayah": 17,
    "surah": 92
  },
  {
    "text": "کسی‌که مالش را در راه‌های نیک انفاق می‌کند تا از گناهان پاکیزه شود.",
    "ayah": 18,
    "surah": 92
  },
  {
    "text": "آن قسمت از مالش را که می‌بخشد به این منظور نمی‌بخشد تا نعمتی را که کسی به او بخشیده است جبران کند.",
    "ayah": 19,
    "surah": 92
  },
  {
    "text": "بلکه در آن قسمت از مالش که می‌بخشد فقط وجه پروردگارش را که بر مخلوقاتش برتر است می‌خواهد.",
    "ayah": 20,
    "surah": 92
  },
  {
    "text": "و به‌طور قطع به‌زودی از پاداشی گرامی‌ که الله به او عطا می‌کند راضی خواهد شد.",
    "ayah": 21,
    "surah": 92
  }
]
