[
  {
    "text": "اللهِ رحمان (دارای رحمت گسترده).",
    "ayah": 1,
    "surah": 55
  },
  {
    "text": "قرآن را با ساده‌ کردن حفظ آن، وآسان‌سازی فهم معانی‌اش به انسان آموخت.",
    "ayah": 2,
    "surah": 55
  },
  {
    "text": "و انسان را درست‌اندام، و با تصویری نیکو آفرید.",
    "ayah": 3,
    "surah": 55
  },
  {
    "text": "به او آموخت که چگونه آنچه را در ضمیر خویش دارد با گفتن و نوشتن بیان کند.",
    "ayah": 4,
    "surah": 55
  },
  {
    "text": "خورشید و ماه را اندازه کرد؛ که به حساب پایداری حرکت می‌کنند؛ تا مردم شمار سال‌ها و حساب را بدانند.",
    "ayah": 5,
    "surah": 55
  },
  {
    "text": "و گیاهان بدون ساقه و درخت، برای الله سبحانه درحالی‌که فرمانبر و تسلیم او هستند سجده می‌کنند.",
    "ayah": 6,
    "surah": 55
  },
  {
    "text": "و آسمان را سقفی برای زمین بر فراز آن بالا برد، و عدالت را در زمین استوار کرد، و بندگانش را به آن فرمان داد.",
    "ayah": 7,
    "surah": 55
  },
  {
    "text": "عدالت را استوار کرد تا - ای مردم- ستم روا ندارید و در وزن و پیمانه خیانت نکنید.",
    "ayah": 8,
    "surah": 55
  },
  {
    "text": "و وزن را میان یکدیگر به انصاف برپا دارید، و هرگاه برای دیگران پیمانه یا وزن می‌کنید از وزن و پیمانه نکاهید.",
    "ayah": 9,
    "surah": 55
  },
  {
    "text": "و زمین را برای آرام‌ گرفتنِ مخلوقات بر روی آن آماده ساخت.",
    "ayah": 10,
    "surah": 55
  },
  {
    "text": "در آن درختانی است که میوه‌های گوناگونی ثمر می‌دهند، و نخل‌های دارای غلاف‌های شکوفه که خرما در آن است.",
    "ayah": 11,
    "surah": 55
  },
  {
    "text": "و در آن دانه‌هایی دارای کاه مانند گندم و جو، و گیاهانی که از بوی آن خود را خوشبو می‌کنید، وجود دارد.",
    "ayah": 12,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 13,
    "surah": 55
  },
  {
    "text": "آدم علیه السلام را از گِلی خشک که صدایی طنین‌دار مانند گِل پخته‌شده‌ از آن شنیده می‌شود آفرید.",
    "ayah": 14,
    "surah": 55
  },
  {
    "text": "و پدر جنیان را از زبانۀ خالصی از دود آفرید.",
    "ayah": 15,
    "surah": 55
  },
  {
    "text": "پس- ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 16,
    "surah": 55
  },
  {
    "text": "پروردگار دو مشرق و دو مغرب خورشید در زمستان و تابستان.",
    "ayah": 17,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 18,
    "surah": 55
  },
  {
    "text": "الله دو دریای شور و شیرین را به گونه‌ای در هم آمیخت که چشم آن را می‌بیند که به هم برخورد می‌کنند.",
    "ayah": 19,
    "surah": 55
  },
  {
    "text": "میان آن دو دریا مانعی است که هر یک از آن دو را بازمی‌دارد از اینکه بر دیگری طغیان کند تا دریای شیرین، شیرین و دریای شور، شور بماند.",
    "ayah": 20,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 21,
    "surah": 55
  },
  {
    "text": "از هر دو دریا مرواریدهای بزرگ و کوچک استخراج می‌شود.",
    "ayah": 22,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 23,
    "surah": 55
  },
  {
    "text": "و تصرف در کشتی‌های همچون کوه‌ها که در دریاها روان هستند، فقط برای او تعالی است.",
    "ayah": 24,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 25,
    "surah": 55
  },
  {
    "text": "تمام مخلوقاتی که بر روی زمین هستند بدون تردید نابود می‌شوند.",
    "ayah": 26,
    "surah": 55
  },
  {
    "text": "و - ای رسول- وجه پروردگار صاحب عظمتِ تو، و نیکوکار و بخشنده بر بندگانش، باقی می‌ماند و هرگز فنایی به او نمی‌رسد.",
    "ayah": 27,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 28,
    "surah": 55
  },
  {
    "text": "تمام فرشتگانی که در آسمان‌ها، و تمام جن‌ها و انسان‌هایی که در زمین هستند؛ نیازهای‌شان را از او می‌خواهند، او تعالی هر روز به یکی از کارهای بندگانش؛ از زنده‌کردن و میراندن و روزی و سایر امور می‌پردازد.",
    "ayah": 29,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 30,
    "surah": 55
  },
  {
    "text": "- ای گروه انس و جن- به زودی به حساب شما خواهیم پرداخت آن‌گاه هرکس را به پاداش یا کیفری که استحقاقش را دارد جزا می‌دهیم.",
    "ayah": 31,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 32,
    "surah": 55
  },
  {
    "text": "و در روز قیامت آن‌گاه که جنیان و انسان‌ها گرد آورده شوند الله می‌فرماید: ای گروه جن و انس، اگر می‌توانید گریزگاهی در یکی از نواحی آسمان‌ها و زمین برای خودتان بیابید پس این کار را بکنید، در صورتی‌که این کار را جز به زور و بَیّنه‌ای، هرگز نخواهید توانست انجام دهید، و کجا این امکان برای‌تان وجود دارد؟",
    "ayah": 33,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 34,
    "surah": 55
  },
  {
    "text": "- ای گروه انس و جن- زبانه‌ای از آتش بدون دود، و دودی بدون زبانه بر شما فرستاده می‌شود، و نمی‌توانید از آن جلوگیری کنید.",
    "ayah": 35,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 36,
    "surah": 55
  },
  {
    "text": "پس آن‌گاه که آسمان برای نزول فرشتگان از آن بشکافد و رنگش در درخشندگی مانند روغن قرمز شود.",
    "ayah": 37,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 38,
    "surah": 55
  },
  {
    "text": "در آن روز بزرگ هیچ انسان و جنی از گناهان‌شان مورد سوال قرار نمی‌گیرد؛ چون الله به اعمال‌شان آگاهی دارد.",
    "ayah": 39,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 40,
    "surah": 55
  },
  {
    "text": "مجرمان در روز قیامت با نشانه‌های‌شان یعنی سیاهی چهره‌ها و کبودی چشمان‌شان شناخته می‌شوند، و موی جلوی سرشان به پاهای‌شان بسته می‌شود و به جهنم افکنده می‌شوند.",
    "ayah": 41,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 42,
    "surah": 55
  },
  {
    "text": "و از روی توبیخ به آنها گفته می‌شود: این همان جهنمی است که مجرمان در دنیا آن را تکذیب می‌کردند، امّا اکنون در برابر چشمان‌شان است و نمی‌توانند آن را انکار کنند.",
    "ayah": 43,
    "surah": 55
  },
  {
    "text": "میان آن و آب بسیار داغ سرگردان هستند.",
    "ayah": 44,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 45,
    "surah": 55
  },
  {
    "text": "و برای کسی‌که از ایستادن در برابر پروردگارش در آخرت بترسد و ایمان آوَرَد و عمل صالح انجام دهد، دو باغ است.",
    "ayah": 46,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 47,
    "surah": 55
  },
  {
    "text": "و این دو باغ، شاخه‌هایی بزرگ و تر و تازه و ثَمَردهنده دارند.",
    "ayah": 48,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 49,
    "surah": 55
  },
  {
    "text": "در این دو باغ دو چشمه است که آب آنها در این دو باغ جاری است.",
    "ayah": 50,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 51,
    "surah": 55
  },
  {
    "text": "در این دو باغ از هر میوۀ لذیذی دو گونه است.",
    "ayah": 52,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 53,
    "surah": 55
  },
  {
    "text": "بر فرش‌هایی که آستری آنها از ابریشم کلفت است تکیه زده‌اند، و ثمرها و میوه‌هایی که از آن دو باغ به دست می‌آید چنان نزدیک است که ایستاده و نشسته و تکیه‌زده به آن دسترسی دارند.",
    "ayah": 54,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 55,
    "surah": 55
  },
  {
    "text": "در آن باغ‌ها زنانی هستند که فقط به شوهران‌شان چشم دوخته‌اند، و قبل از شوهران‌شان هیچ انسان و جنی دوشیزگی آنها را از بین نبرده است.",
    "ayah": 56,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 57,
    "surah": 55
  },
  {
    "text": "گویی در زیبایی و درخشندگی یاقوت و مرجان هستند.",
    "ayah": 58,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 59,
    "surah": 55
  },
  {
    "text": "جزای کسی‌که به نیکی از پروردگارش فرمان‌برداری کند چیست جز اینکه الله پاداش نیکی به او دهد؟!",
    "ayah": 60,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 61,
    "surah": 55
  },
  {
    "text": "و غیر از دو باغ مذکور دو باغ دیگر است.",
    "ayah": 62,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 63,
    "surah": 55
  },
  {
    "text": "که رنگ سبزشان تشدید یافته است.",
    "ayah": 64,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 65,
    "surah": 55
  },
  {
    "text": "در این دو باغ دو چشمه هستند که آب زیادی فوران می‌کنند، و فوران آب‌شان قطع نمی‌شود.",
    "ayah": 66,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 67,
    "surah": 55
  },
  {
    "text": "در این دو باغ میوۀ فراوان و نخل بزرگ و انار است.",
    "ayah": 68,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 69,
    "surah": 55
  },
  {
    "text": "در این دو باغ زنانی خوش‌اخلاق و زیبارو هستند.",
    "ayah": 70,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 71,
    "surah": 55
  },
  {
    "text": "حورانی پرده‌نشین در خیمه‌ها برای حفاظت از آنها.",
    "ayah": 72,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 73,
    "surah": 55
  },
  {
    "text": "قبل از شوهران‌شان هیچ انسان و جنی به آنها نزدیک نشده است.",
    "ayah": 74,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 75,
    "surah": 55
  },
  {
    "text": "بر بالش‌هایی پوشیده‌شده با روپوش سبز، و فرش‌هایی زیبا تکیه زده‌اند.",
    "ayah": 76,
    "surah": 55
  },
  {
    "text": "پس - ای گروه جن و انس- کدام‌یک از نعمت‌های فراوان الله بر خودتان را تکذیب می‌کنید؟!",
    "ayah": 77,
    "surah": 55
  },
  {
    "text": "بزرگ و زیاد است خیر نام پروردگارت که دارای شُکوه و احسان و بخشش بر بندگانش است.",
    "ayah": 78,
    "surah": 55
  }
]
