[
  {
    "text": "- ای رسول- وقتی یاری الله برای دینت و گرامی‌ داشتن آن توسط او تعالی فرا رسد، و مکه فتح شود.",
    "ayah": 1,
    "surah": 110
  },
  {
    "text": "و ببینی که مردم گروه گروه در اسلام وارد می‌شوند.",
    "ayah": 2,
    "surah": 110
  },
  {
    "text": "بدان که این امر، نشانۀ نزدیکی پایان وظیفه‌ای است که به آن مبعوث شده‌ای، پس برای شکرگزاری در قبال نعمت فتح و پیروزی، پروردگارت را ستایش کن، و از او تعالی آمرزش بخواه؛ زیرا او ذات توبه‌پذیری است که توبۀ بندگانش را می‌پذیرد، و آنها را می‌آمرزد.",
    "ayah": 3,
    "surah": 110
  }
]
