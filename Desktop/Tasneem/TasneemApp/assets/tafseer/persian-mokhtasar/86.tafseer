[
  {
    "text": "الله به آسمان و به ستاره‌ای که شبانه وارد می‌شود سوگند یاد فرمود.",
    "ayah": 1,
    "surah": 86
  },
  {
    "text": "و - ای رسول- در مورد این ستارۀ بزرگ چه می‌دانی؟!",
    "ayah": 2,
    "surah": 86
  },
  {
    "text": "همان ستاره‌ای که با نور درخشانش آسمان را روشن می‌کند.",
    "ayah": 3,
    "surah": 86
  },
  {
    "text": "که هیچ نفسی نیست مگر اینکه الله فرشته‌ای بر او گماشته که اعمالش را برای حساب در روز قیامت بر او حفظ می‌کند.",
    "ayah": 4,
    "surah": 86
  },
  {
    "text": "پس انسان باید بیندیشد که الله او را از چه آفریده؛ تا قدرت الله و ناتوانی انسان برایش آشکار گردد.",
    "ayah": 5,
    "surah": 86
  },
  {
    "text": "الله او را از آبی جهنده که در رحم ریخته می‌شود آفریده است.",
    "ayah": 6,
    "surah": 86
  },
  {
    "text": "این آب از بین ستون فقرات پشت و استخوان‌های سینه درمی‌آید.",
    "ayah": 7,
    "surah": 86
  },
  {
    "text": "به‌راستی‌که او سبحانه- چون انسان را از این آب پست آفرید- بر برانگیختن او پس از مرگش به صورت زنده برای حسابرسی و جزا توانا است.",
    "ayah": 8,
    "surah": 86
  },
  {
    "text": "روزی‌که نهان‌ها فاش می‌شود، آن‌گاه نیات و عقاید و سایر مواردی که پنهان می‌کردند آشکار می‌گردد، و صالح و فاسدشان از یکدیگر مشخص می‌شود.",
    "ayah": 9,
    "surah": 86
  },
  {
    "text": "پس در آن روز برای انسان هیچ قدرتی نیست که با آن از عذاب الله جلوگیری کند و هیچ یاوری ندارد که به او یاری رساند.",
    "ayah": 10,
    "surah": 86
  },
  {
    "text": "الله به آسمانِ دارای باران سوگند یاد فرمود؛ زیرا باران از سمت آسمان به صورت پیاپی فرود می‌آید.",
    "ayah": 11,
    "surah": 86
  },
  {
    "text": "و به زمین که به‌سبب گیاهان و میوه‌ها و درختانی که در آن است می‌شکافد سوگند یاد فرمود.",
    "ayah": 12,
    "surah": 86
  },
  {
    "text": "که این قرآن نازل‌شده بر محمد صلی الله علیه وسلم به‌طور قطع سخنی است که میان حق و باطل، و راست و دروغ داوری می‌کند.",
    "ayah": 13,
    "surah": 86
  },
  {
    "text": "و بازی و باطل نیست، بلکه جدی و حقیقت است.",
    "ayah": 14,
    "surah": 86
  },
  {
    "text": "به‌راستی کسانی‌که آنچه را رسول‌شان آورد تکذیب می‌کنند بسیار نیرنگ می‌زنند تا دعوتش را بازگردانند، و باطل کنند.",
    "ayah": 15,
    "surah": 86
  },
  {
    "text": "و من نیز برای اظهار دین و ردّ باطل تدبیر می‌کنم.",
    "ayah": 16,
    "surah": 86
  },
  {
    "text": "پس - ای رسول- اندکی به این کافران مهلت بده، و در عذاب و نابودی آنها شتاب نکن.",
    "ayah": 17,
    "surah": 86
  }
]
