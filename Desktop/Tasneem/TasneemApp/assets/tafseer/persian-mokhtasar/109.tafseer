[
  {
    "text": "- ای رسول- بگو: ای کافرانِ به الله.",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "نه اکنون و نه در آینده بت‌هایی را که عبادت می‌کنید عبادت نمی‌کنم.",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "و شما نیز آنچه را که من عبادت می‌کنم، یعنی الله را به یگانگی عبادت نمی‌کنید.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "و نه من بت‌هایی را که شما عبادت کردید عبادت می‌کنم.",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "و نه شما آنچه را من عبادت می‌کنم، یعنی الله را به یگانگی، عبادت می‌کنید.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "برای شما دین خودتان است که آن را برای خویش ساختید، و برای من دین خودم که الله آن را بر من فرو فرستاده است.",
    "ayah": 6,
    "surah": 109
  }
]
