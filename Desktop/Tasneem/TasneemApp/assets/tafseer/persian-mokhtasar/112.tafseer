[
  {
    "text": "- ای رسول- بگو: او الله یگانه در الوهیت است، و هیچ معبود برحقی جز او نیست.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "همان والامقامی که بزرگی در صفات کمال و جمال به او ختم می‌شود، ذاتی‌که تمام مخلوقات به او نیازمندند.",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "ذاتی‌که هیچ‌کس را نزاده، و هیچ‌کس او را نزاده است، یعنی او - سبحانه- نَه فرزندی دارد؛ و نَه پدری.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "و هیچ همتایی در آفرینش ندارد.",
    "ayah": 4,
    "surah": 112
  }
]
