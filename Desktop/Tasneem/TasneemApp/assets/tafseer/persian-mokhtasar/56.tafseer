[
  {
    "text": "آن‌گاه که قیامت بدون تردید برپا شود.",
    "ayah": 1,
    "surah": 56
  },
  {
    "text": "هیچ‌کس یافت نشود که آن را تکذیب کند چنان‌که در دنیا تکذیب می‌شد.",
    "ayah": 2,
    "surah": 56
  },
  {
    "text": "پایین‌آورندۀ کافران بدکار با وارد کردن آنها در جهنم، و بالابرندۀ مؤمنان پرهیزگار با وارد کردن آنها در بهشت است.",
    "ayah": 3,
    "surah": 56
  },
  {
    "text": "آن‌گاه که زمین با حرکت سختی لرزانده شود.",
    "ayah": 4,
    "surah": 56
  },
  {
    "text": "و کوه‌ها به شدت متلاشی شوند.",
    "ayah": 5,
    "surah": 56
  },
  {
    "text": "و بر اثر متلاشی‌ شدن، به گرد و خاکی پراکنده که هیچ قراری ندارد تبدیل شوند.",
    "ayah": 6,
    "surah": 56
  },
  {
    "text": "و شما در آن روز سه گروه می‌شوید:",
    "ayah": 7,
    "surah": 56
  },
  {
    "text": "یاران دست‌راست، همان کسانی‌که نامه‌های‌شان را با دست راست خویش می‌گیرند، چه جایگاه بالا و بزرگی دارند!",
    "ayah": 8,
    "surah": 56
  },
  {
    "text": "و یاران دست‌چپ، همان کسانی‌که نامه‌های‌شان را با دست چپ خویش می‌گیرند، چه جایگاه پست و بدی دارند!",
    "ayah": 9,
    "surah": 56
  },
  {
    "text": "و همان پیشی‌گیرندگان با انجام کارهای نیک در دنیا، در آخرت پیشی‌گیرندگان برای ورود به بهشت هستند.",
    "ayah": 10,
    "surah": 56
  },
  {
    "text": "اینها همان مقربان نزد الله هستند.",
    "ayah": 11,
    "surah": 56
  },
  {
    "text": "در بهشت‌هایی پر نعمت، که از انواع نعمت‌ها بهره‌مند می‌شوند.",
    "ayah": 12,
    "surah": 56
  },
  {
    "text": "گروهی از این امت و از امت‌های پیشین.",
    "ayah": 13,
    "surah": 56
  },
  {
    "text": "و اندکی از مردم در آخرت، از زمره ی سبقت گیرندگانِ مقرب هستند.",
    "ayah": 14,
    "surah": 56
  },
  {
    "text": "بر تخت‌هایی بافته‌شده از طلا.",
    "ayah": 15,
    "surah": 56
  },
  {
    "text": "درحالی‌که رو در روی یکدیگر قرار دارند، و هیچ‌یک از آنها به پشت دیگری نگاه نمی‌کند، بر این تخت‌ها تکیه زده هستند.",
    "ayah": 16,
    "surah": 56
  },
  {
    "text": "برای خدمت به آنها پسرانی که نه سالخورده می‌شوند و نه فنا می‌گردند گردشان می‌گردند.",
    "ayah": 17,
    "surah": 56
  },
  {
    "text": "پیاله‌هایی بدون دسته، و کوزه‌هایی دسته‌دار، و جام‌هایی از شراب جاری در بهشت که هرگز قطع نمی‌شود بر گردشان می‌چرخانند.",
    "ayah": 18,
    "surah": 56
  },
  {
    "text": "مانند خمر دنیا نیست، یعنی نوشندۀ آن نه دچار سردرد می‌شود، و نه عقلش تباه می‌گردد.",
    "ayah": 19,
    "surah": 56
  },
  {
    "text": "و میوه‌هایی که اختیار کنند، این پسران بر گرد آنها می‌گردانند.",
    "ayah": 20,
    "surah": 56
  },
  {
    "text": "و گوشت پرنده از آنچه بخواهند پیرامون آنها می‌چرخانند.",
    "ayah": 21,
    "surah": 56
  },
  {
    "text": "و در بهشت زنانی گشاده‌چشم در زیبایی دارند.",
    "ayah": 22,
    "surah": 56
  },
  {
    "text": "گویی مانند مروارید محافظت‌شده در صدف هستند.",
    "ayah": 23,
    "surah": 56
  },
  {
    "text": "پاداشی برای آنها در قبال اعمال صالحی که در دنیا انجام می‌دادند است.",
    "ayah": 24,
    "surah": 56
  },
  {
    "text": "در بهشت نه سخن زشتی می‌شنوند، و نه سخنی که گناهی به صاحبش می‌رساند.",
    "ayah": 25,
    "surah": 56
  },
  {
    "text": "جز سلام فرشتگان بر آنان، و سلام بر یکدیگر، چیز دیگری را نمی شنوند.",
    "ayah": 26,
    "surah": 56
  },
  {
    "text": "و اصحاب يمين -آن كسانى که نامه ی اعمالشان به دست راستشان داده می شود- چه جایگاه و مقام بالایی نزد الله دارند!",
    "ayah": 27,
    "surah": 56
  },
  {
    "text": "در درخت سدری که خارهایش بریده شده است، و هیچ آزاری در آن نیست.",
    "ayah": 28,
    "surah": 56
  },
  {
    "text": "و در درختان موز انبوهی که در کنار یکدیگر به ردیف چیده شده‌اند.",
    "ayah": 29,
    "surah": 56
  },
  {
    "text": "و سایۀ کشیده‌شده و پایداری که پایان نمی‌یابد.",
    "ayah": 30,
    "surah": 56
  },
  {
    "text": "و آب روانی که نمی‌ایستد.",
    "ayah": 31,
    "surah": 56
  },
  {
    "text": "و میوه‌های فراوانی که قابل شمارش نیست.",
    "ayah": 32,
    "surah": 56
  },
  {
    "text": "هرگز از آنها قطع نمی‌شود، یعنی موسم (فصل خاصی) ندارند، و در هر وقت که آنها را بخواهند هیچ مانعی جلوی آن را نمی‌گیرد.",
    "ayah": 33,
    "surah": 56
  },
  {
    "text": "و فرش‌هایی برافراشته و بزرگ که بر روی تخت‌ها قرار می‌گیرند.",
    "ayah": 34,
    "surah": 56
  },
  {
    "text": "به‌راستی‌که ما حوران مذکور را به روشی غیر عادی پدید آوردیم.",
    "ayah": 35,
    "surah": 56
  },
  {
    "text": "و آنها را دوشیزگانی که از قبل لمس نشده‌اند گردانیدیم.",
    "ayah": 36,
    "surah": 56
  },
  {
    "text": "شوهردوست، و هم سن و سال.",
    "ayah": 37,
    "surah": 56
  },
  {
    "text": "آنها را برای یاران دست‌راست پدید آوردیم کسانی‌که دست‌راست ‌بودن، نشانۀ خوشبختی‌شان به شمار می‌رود.",
    "ayah": 38,
    "surah": 56
  },
  {
    "text": "آنها گروهی از امت‌های پیامبران پیشین.",
    "ayah": 39,
    "surah": 56
  },
  {
    "text": "و گروهی از امت محمد صلی الله علیه وسلم یعنی آخرین امت هستند.",
    "ayah": 40,
    "surah": 56
  },
  {
    "text": "و اصحاب شمال -آنان که نامه ی اعمالشان به دست چپشان داده می شود- چه حال و عاقبت بدی دارند!",
    "ayah": 41,
    "surah": 56
  },
  {
    "text": "در میان بادهایی بسیار سوزان، و آبی بسیار داغ.",
    "ayah": 42,
    "surah": 56
  },
  {
    "text": "و در سایۀ دود سیاهی.",
    "ayah": 43,
    "surah": 56
  },
  {
    "text": "که نه نسیم خوشی دارد، و نه منظر نیکویی.",
    "ayah": 44,
    "surah": 56
  },
  {
    "text": "به‌راستی‌که آنها قبل از اینکه به عذاب برسند در دنیا از نعمت و رفاه برخوردار بودند، و هیچ غم و اندوهی جز شهوات‌شان نداشتند.",
    "ayah": 45,
    "surah": 56
  },
  {
    "text": "و بر کفر به الله و عبادت بت‌ها به جای او تعالی مصمّم بودند.",
    "ayah": 46,
    "surah": 56
  },
  {
    "text": "و رستاخیز را انکار می‌کردند و از روی استهزا و بعید دانستن آن می‌گفتند: آیا پس از اینکه مُردیم و خاک و استخوان‌هایی پوسیده شدیم برانگیخته می‌شویم؟!",
    "ayah": 47,
    "surah": 56
  },
  {
    "text": "آیا پدران نخستین ما که قبل از ما مرده‌اند برانگیخته می‌شوند؟!",
    "ayah": 48,
    "surah": 56
  },
  {
    "text": "- ای رسول- به این منکران رستاخیز بگو: به‌راستی‌که مردم نخستین و متأخّر.",
    "ayah": 49,
    "surah": 56
  },
  {
    "text": "به‌طور قطع برای حسابرسی و جزا در روز قیامت گرد آورده خواهند شد.",
    "ayah": 50,
    "surah": 56
  },
  {
    "text": "سپس شما -ای کسانی که معاد را تکذیب کرده و از راه راست گمراه شده اید- به طور قطع در روز قیامت از میوه ی درخت زقوم، که بدترین و پلیدترین میوه است، خواهید خورد.",
    "ayah": 51,
    "surah": 56
  },
  {
    "text": "سپس شما -ای کسانی که معاد را تکذیب کرده و از راه راست گمراه شده اید- به طور قطع در روز قیامت از میوه ی درخت زقوم، که بدترین و پلیدترین میوه است، خواهید خورد.",
    "ayah": 52,
    "surah": 56
  },
  {
    "text": "و شکم‌های خالی‌تان را از آن درخت تلخ پر خواهید کرد.",
    "ayah": 53,
    "surah": 56
  },
  {
    "text": "و بر روی آن از آب بسیار سوزان خواهید نوشید.",
    "ayah": 54,
    "surah": 56
  },
  {
    "text": "و همانند نوشیدن آب زیاد شتر به‌سبب بیماری هُیام، زیاد از آن می‌نوشید.",
    "ayah": 55,
    "surah": 56
  },
  {
    "text": "این طعام تلخ و آب سوزان همان پذیرایی آنها است که در روز جزا با آن مورد استقبال قرار می‌گیرند.",
    "ayah": 56,
    "surah": 56
  },
  {
    "text": "- ای تکذیب ‌کنندگان- ما شما را از نیستی آفریدیم. پس آیا تصدیق نمی‌کنید که ما شما را پس از مرگ‌تان زنده مبعوث خواهیم کرد؟!",
    "ayah": 57,
    "surah": 56
  },
  {
    "text": "پس آیا - ای مردم- منی‌ای را که در رحم‌های زنان‌تان می‌افکنید دیده‌اید؟!",
    "ayah": 58,
    "surah": 56
  },
  {
    "text": "آیا شما آن منی را می‌آفرینید، یا ما هستیم که آن را می‌آفرینیم؟!",
    "ayah": 59,
    "surah": 56
  },
  {
    "text": "ما هستیم که مرگ را میان شما مقدر کرده‌ایم، یعنی برای هر یک از شما اجلی است که نه بر آن جلو و نه از آن به تاخیر می‌افتند، و ما ناتوان نیستیم.",
    "ayah": 60,
    "surah": 56
  },
  {
    "text": "بر اینکه آفرینش و تصویری که بر آن هستید و آن را شناخته‌اید تغییر دهیم، و شما را در آفرینش و تصویری که نمی‌شناسید پدید آوریم.",
    "ayah": 61,
    "surah": 56
  },
  {
    "text": "و در حقیقت دانسته‌اید که بار اول چگونه شما را آفریدیم، پس آیا پند نمی‌گیرید، و نمی‌دانید ذاتی‌که شما را برای بار اول آفرید بر برانگیختن شما پس از مرگ‌تان توانا است؟!",
    "ayah": 62,
    "surah": 56
  },
  {
    "text": "پس آیا بذری را که در زمین می‌افشانید دیده‌اید؟!",
    "ayah": 63,
    "surah": 56
  },
  {
    "text": "آیا شما هستید که آن بذر را می‌رویانید، یا ما هستیم که آن را می‌رویانیم؟!",
    "ayah": 64,
    "surah": 56
  },
  {
    "text": "اگر بخواهیم آن کِشت را خشکیده و متلاشی‌شده قرار دهیم به‌طور قطع آن را پس از اینکه به پختگی و رسیدن نزدیک شد خشک و متلاشی می‌کنیم، آن‌گاه از حالتی که پیدا کرده است، شگفت‌زده می‌شوید.",
    "ayah": 65,
    "surah": 56
  },
  {
    "text": "می گویید: به راستی ما به خاطر زیان آنچه كه هزینه کرده ایم، عذاب داده مى شويم.",
    "ayah": 66,
    "surah": 56
  },
  {
    "text": "بلکه ما از رزق و روزی محروم هستیم.",
    "ayah": 67,
    "surah": 56
  },
  {
    "text": "آیا آبی را که هنگام تشنگی از آن می‌نوشید ندیده‌اید؟!",
    "ayah": 68,
    "surah": 56
  },
  {
    "text": "آیا شما آن را از ابرِ آسمان فرو فرستادید، یا ما هستیم که آن را نازل کردیم؟!",
    "ayah": 69,
    "surah": 56
  },
  {
    "text": "اگر بخواهیم این آب را بسیار شور قرار دهیم که هرگز قابل آشامیدن و آبیاری نباشد به‌طور قطع آن را بسیار شور می‌گردانیم. پس چرا از الله به خاطر نزول آب شیرین بر اساس رحمتی به شما، سپاسگزاری نمی‌کنید.",
    "ayah": 70,
    "surah": 56
  },
  {
    "text": "آیا آتشی که آن را برای منافع خویش برمی‌افروزید دیده‌اید؟!",
    "ayah": 71,
    "surah": 56
  },
  {
    "text": "آیا شما هستید که درختی را که از آن آتش افروخته می‌شود پدید آورده‌اید، یا ما هستیم که آن را از روی مهربانی به شما پدید آورده‌ایم؟!",
    "ayah": 72,
    "surah": 56
  },
  {
    "text": "ما این آتش را یادآوری برای‌تان قرار دادیم که آتش آخرت را به یاد شما می‌آورد، و آن را منفعتی برای مسافران شما قرار دادیم.",
    "ayah": 73,
    "surah": 56
  },
  {
    "text": "پس - ای رسول- پروردگار عظیم خویش را از آنچه که سزاوارش نیست منزه بدان.",
    "ayah": 74,
    "surah": 56
  },
  {
    "text": "الله به مکان‌ها و محل‌های فرودآمدن ستارگان سوگند یاد فرمود.",
    "ayah": 75,
    "surah": 56
  },
  {
    "text": "و به‌راستی‌که سوگند به این محل‌های فرودآمدن - اگر بزرگی‌اش را بدانید- بزرگ است؛ چون نشانه‌ها و پندهایی غیر قابل شمارش دارد.",
    "ayah": 76,
    "surah": 56
  },
  {
    "text": "- ای مردم- به‌راستی‌که قرآن خوانده‌شده بر شما، به‌سبب منافع بزرگی که در آن وجود دارد قرآنی کریم است.",
    "ayah": 77,
    "surah": 56
  },
  {
    "text": "در کتابی حفاظت‌شده از چشمان مردم، یعنی لوح محفوظ قرار دارد.",
    "ayah": 78,
    "surah": 56
  },
  {
    "text": "که جز فرشتگان پاکیزه از گناهان و عیوب به آن دسترسی ندارند.",
    "ayah": 79,
    "surah": 56
  },
  {
    "text": "از جانب پروردگار مخلوقات بر پیامبرش محمد صلی الله علیه وسلم نازل شده است.",
    "ayah": 80,
    "surah": 56
  },
  {
    "text": "پس - ای مشرکان- آیا شما این سخن را تکذیب کرده و تصدیق نمی‌کنید؟!",
    "ayah": 81,
    "surah": 56
  },
  {
    "text": "و آیا به جای اینکه در قبال نعمت‌هایی که الله به شما ارزانی داشته از او تعالی سپاسگزاری کنید این سخن را تکذیب می‌کنید، و باران را به تقابل ستارگان نسبت می‌دهید، و می‌گویید: به‌سبب طلوع یا غروب فلان ستاره بر ما باران بارید؟!",
    "ayah": 82,
    "surah": 56
  },
  {
    "text": "پس چرا آن‌گاه که روح به گلوگاه می‌رسد،",
    "ayah": 83,
    "surah": 56
  },
  {
    "text": "و شما در آن وقت به شخصی که جانش در برابر شما کنده می‌شود می‌نگرید،",
    "ayah": 84,
    "surah": 56
  },
  {
    "text": "و ما با علم و قدرت و فرشتگان خویش از شما به مُردۀ شما نزدیک‌تر هستیم، اما شما این فرشتگان را مشاهده نمی‌کنید.",
    "ayah": 85,
    "surah": 56
  },
  {
    "text": "پس چرا - اگر چنان‌که ادعا می‌کنید، برای مجازات در برابر اعمال‌تان مبعوث نمی‌شوید-",
    "ayah": 86,
    "surah": 56
  },
  {
    "text": "این روح را که از مُردۀ شما خارج می‌شود برنمی‌گردانید اگر راست می‌گویید؟! و قادر بر این کار نیستید.",
    "ayah": 87,
    "surah": 56
  },
  {
    "text": "اما اگر مُرده از پیشی‌گیرندگان به نیکی‌ها باشد،",
    "ayah": 88,
    "surah": 56
  },
  {
    "text": "راحتی‌ای که پس از آن رنجی نیست، و روزی‌ای پاکیزه، و رحمت، و بهشتی که در آن به آنچه که نفسش می‌خواهد برخوردار می‌شود خواهد داشت.",
    "ayah": 89,
    "surah": 56
  },
  {
    "text": "و اما اگر مُرده از یاران دست‌راستی باشد،",
    "ayah": 90,
    "surah": 56
  },
  {
    "text": "غم و اندوهی بر آنها نیست، زیرا سلامتی و امنیت برای‌شان است.",
    "ayah": 91,
    "surah": 56
  },
  {
    "text": "و اما اگر مُرده از تکذیب ‌کنندگانِ آنچه رسول صلی الله علیه وسلم آورد و از گمراهان از راه راست باشد.",
    "ayah": 92,
    "surah": 56
  },
  {
    "text": "با آبی بسیار سوزان مورد استقبال قرار می‌گیرد.",
    "ayah": 93,
    "surah": 56
  },
  {
    "text": "و با آتش جهنم می‌سوزد.",
    "ayah": 94,
    "surah": 56
  },
  {
    "text": "- ای رسول- به‌راستی این موضوع که آن را برایت حکایت کردیم، همان حقیقت و امری یقینی است که هیچ تردیدی در آن راه ندارد.",
    "ayah": 95,
    "surah": 56
  },
  {
    "text": "پس نام پروردگار بزرگت را منزه بدان، و او را از کاستی‌ها پاک شمار.",
    "ayah": 96,
    "surah": 56
  }
]
