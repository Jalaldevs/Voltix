[
  {
    "text": "الله به خورشید، و به وقت بالا رفتنش پس از طلوع از مشرق، سوگند یاد فرمود.",
    "ayah": 1,
    "surah": 91
  },
  {
    "text": "و به ماه آن‌گاه که پس از غروب خورشید اثرش را دنبال کند سوگند یاد فرمود.",
    "ayah": 2,
    "surah": 91
  },
  {
    "text": "و به روز آن‌گاه که با نور خویش آنچه را بر روی زمین است آشکار گرداند سوگند یاد فرمود.",
    "ayah": 3,
    "surah": 91
  },
  {
    "text": "و به شب آن‌گاه که چهرۀ زمین را بپوشاند و تاریک گردد سوگند یاد فرمود.",
    "ayah": 4,
    "surah": 91
  },
  {
    "text": "و به آسمان، و به بنای استوار و مستحکم آن سوگند یاد فرمود.",
    "ayah": 5,
    "surah": 91
  },
  {
    "text": "و به زمین، و به گستردگی آن، تا مردم بر روی آن سکونت کنند سوگند یاد فرمود.",
    "ayah": 6,
    "surah": 91
  },
  {
    "text": "و به تمام نفس‌ها، و به آفرینش آراسته و درست آن توسط الله سوگند یاد فرمود.",
    "ayah": 7,
    "surah": 91
  },
  {
    "text": "سپس بدون آموزش، شر و خیر را برایش فهماند تا از شر پرهیز کند، و خیر را به جای آورد.",
    "ayah": 8,
    "surah": 91
  },
  {
    "text": "قطعاً هرکس که نفسش را با آراستن به فضایل، و خالی‌ کردن از رذیلت‌ها پاک کند به رستگاری مورد نظرش دست می‌یابد.",
    "ayah": 9,
    "surah": 91
  },
  {
    "text": "و هرکس که نفسش را در معصیت‌ها و گناهان پنهان و آلوده کند زیان می‌کند.",
    "ayah": 10,
    "surah": 91
  },
  {
    "text": "ثمود به‌سبب گذشتن از حد در ارتکاب معصیت‌ها و گناهان، پیامبرشان صالح علیه السلام را تکذیب کردند.",
    "ayah": 11,
    "surah": 91
  },
  {
    "text": "آن‌گاه که بدبخت‌ترین آنها پس از دعوت قومش برخاست.",
    "ayah": 12,
    "surah": 91
  },
  {
    "text": "و رسول‌ الله صالح علیه السلام به آنها گفت: ماده‌شتر الله را با نوبت آب‌خوردنش در روزی‌که برایش مشخص شده رها کنید، و آسیبی به او نرسانید.",
    "ayah": 13,
    "surah": 91
  },
  {
    "text": "اما رسول‌شان را در مورد ماده‌شتر تکذیب کردند و بدبخت‌ترین قوم با رضایت آنها ماده‌شتر را کشت، پس آنها نیز در گناه شریک بودند. آن‌گاه الله به‌سبب گناهان‌شان عذابش را بر آنها فرود آورد، و آنها را با فریادی نابود گردانید، و با این کیفر آنها را با خاک یکسان کرد.",
    "ayah": 14,
    "surah": 91
  },
  {
    "text": "الله عذاب نابودکننده را بر آنها فرود آورد بدون اینکه او سبحانه از پیامدهای این عذاب بترسد.",
    "ayah": 15,
    "surah": 91
  }
]
