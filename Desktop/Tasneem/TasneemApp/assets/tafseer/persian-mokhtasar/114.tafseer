[
  {
    "text": "- ای رسول- بگو: به پروردگار مردم پناه می‌برم، و از او یاری می‌جویم.",
    "ayah": 1,
    "surah": 114
  },
  {
    "text": "پادشاه مردم، که هر کاری بخواهد در مورد آنها انجام می‌دهد، و هیچ صاحب اختیاری جز او ندارند.",
    "ayah": 2,
    "surah": 114
  },
  {
    "text": "معبود حقیقی آنها، که هیچ معبود برحقی جز او ندارند.",
    "ayah": 3,
    "surah": 114
  },
  {
    "text": "از شر شیطان که هرگاه انسان از یاد الله غافل شود وسوسه‌اش را به او می‌رساند و هنگامی‌که انسان الله را به یاد آورد از او بازپس می‌رود.",
    "ayah": 4,
    "surah": 114
  },
  {
    "text": "وسوسه‌اش را به دل‌های مردم می‌رساند.",
    "ayah": 5,
    "surah": 114
  },
  {
    "text": "و همانطور که شیطان جنی وجود دارد، شیطان انسی نیز می‌باشد.",
    "ayah": 6,
    "surah": 114
  }
]
