[
  {
    "text": "آن‌گاه که زمین در روز قیامت به شدت لرزانده شود.",
    "ayah": 1,
    "surah": 99
  },
  {
    "text": "و زمین، مردگان و هر چیز دیگری را که در شکم خویش دارد بیرون افکنَد.",
    "ayah": 2,
    "surah": 99
  },
  {
    "text": "و انسان حیران و سرگردان بگوید: زمین را چه شده است که تکان می‌خورد و می‌لرزد؟!",
    "ayah": 3,
    "surah": 99
  },
  {
    "text": "در آن روز بزرگ زمین از هر خیر و شری که بر روی آن انجام شده است خبر می‌دهد.",
    "ayah": 4,
    "surah": 99
  },
  {
    "text": "زیرا الله او را از آن آگاه کرده و او را بر این کار فرمان داده است.",
    "ayah": 5,
    "surah": 99
  },
  {
    "text": "در آن روز بزرگ که زمین در آن می‌لرزد مردم گروه گروه از جایگاه حسابرسی بیرون می‌آیند تا اعمال‌شان را که در دنیا انجام داده‌اند مشاهده کنند.",
    "ayah": 6,
    "surah": 99
  },
  {
    "text": "آن‌گاه هرکس هم‌وزن مورچه‌ای کوچک، از اعمال خیر و نیک انجام داده باشد آن را در مقابل خویش می‌بیند.",
    "ayah": 7,
    "surah": 99
  },
  {
    "text": "و همچنين هر کس هم وزن مورچه ى کوچکى اعمال بد انجام داده باشد (سزای) آن را می بیند.",
    "ayah": 8,
    "surah": 99
  }
]
