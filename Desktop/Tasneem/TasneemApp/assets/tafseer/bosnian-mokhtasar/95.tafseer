[
  {
    "text": "Allah se kune smokvom i mjestom gdje ona raste, i maslinom i mjestom gdje ona raste, u Palestini u kojoj je kao poslanik bio Isa, alejhi selam.",
    "ayah": 1,
    "surah": 95
  },
  {
    "text": "I kune se brdom Sinaj na kojem je Allah dozvao svoga Vjerovjesnika, Musaa, alejhi selam.",
    "ayah": 2,
    "surah": 95
  },
  {
    "text": "I kune se svetim gradom Mekkom u kojem je siguran svako onaj ko u njega uđe i u koji je poslao Muhammeda, sallallahu alejhi ve sellem.",
    "ayah": 3,
    "surah": 95
  },
  {
    "text": "Mi smo čovjeka stvorili kao stvorenja najboljeg i najskladnijeg oblika.",
    "ayah": 4,
    "surah": 95
  },
  {
    "text": "Zatim dajemo da na dunjaluku ostari i da nema koristi od svoga tijela, kao što od njega nema koristi kada mu se iskvari priroda i završi u Vatri.",
    "ayah": 5,
    "surah": 95
  },
  {
    "text": "Izuzimaju se oni koji vjeruju u Allaha i rade dobra djela, jer oni, i kada ostare, njih čeka neprekidna nagrada, tj. Džennet, s obzrom da su se trudili da ne iskvare svoju zdravu prirodu.",
    "ayah": 6,
    "surah": 95
  },
  {
    "text": "Šta te navodi, o čovječe, da negiraš Dan obračuna, nagrade i kazne, nakon što si vidio mnogo znakova Njegove moći?",
    "ayah": 7,
    "surah": 95
  },
  {
    "text": "Zar Allah, time što je dao Sudnji dan, nije sudija najpravedniji? Zar misli da će Allah ostaviti svoje robove uzalud i da neće suditi među njima, pa dobročinitelja nagraditi, a griješnika kazniti?",
    "ayah": 8,
    "surah": 95
  }
]
