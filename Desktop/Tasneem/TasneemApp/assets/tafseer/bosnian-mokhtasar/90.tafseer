[
  {
    "text": "Allah Uzvišeni kune se Svetim gradom, časnom Mekkom.",
    "ayah": 1,
    "surah": 90
  },
  {
    "text": "Tebi je, o Poslaniče, dopušteno sve u ovom gradu, da pogubiš onoga ko zaslužuje pogubljenje i da zarobiš onoga ko to zaslužuje.",
    "ayah": 2,
    "surah": 90
  },
  {
    "text": "I Allah se kune ocem čovječanstva i kune se njegovim potomcima.",
    "ayah": 3,
    "surah": 90
  },
  {
    "text": "Mi smo stvorili čovjeka da je je u naporu i poteškoćama, zbog nedaća koje ga prate na ovom dunjaluku.",
    "ayah": 4,
    "surah": 90
  },
  {
    "text": "Zar misli čovjek, kada čini grijehe, da mu niko ništa ne može i da ga neće kazniti, pa makar to bio i Gospodar njegov koji ga je stvorio?",
    "ayah": 5,
    "surah": 90
  },
  {
    "text": "On govori: Potrošio sam mnogo imetka nagomilanog.",
    "ayah": 6,
    "surah": 90
  },
  {
    "text": "Zar ovaj koji se hvališe trošenjem imetka, misli da ga Allah vidi i da pred Njim neće polagati račun kako je stekao imetak i gdje ga je potrošio?",
    "ayah": 7,
    "surah": 90
  },
  {
    "text": "Zar mu nismo podarili dva oka kojima gleda?",
    "ayah": 8,
    "surah": 90
  },
  {
    "text": "i zar mu nismo dali jezik i dvije usne pomoću kojih govori?",
    "ayah": 9,
    "surah": 90
  },
  {
    "text": "i zar mu nismo pojasnili koji je to put dobra, a koji put zla?",
    "ayah": 10,
    "surah": 90
  },
  {
    "text": "Od njega se traži da uspon koji ga odvaja od Dženneta, savlada i pređe.",
    "ayah": 11,
    "surah": 90
  },
  {
    "text": "A šta ti misliš, o Poslaniče: šta je to uspon koji se mora preći da bi se ušlo u Džennet?",
    "ayah": 12,
    "surah": 90
  },
  {
    "text": "to znači da se rob, bio muško ili žensko, oslobodi.",
    "ayah": 13,
    "surah": 90
  },
  {
    "text": "ili da se, kada je glad i kada je manjak hrane, nahrani",
    "ayah": 14,
    "surah": 90
  },
  {
    "text": "siroče, tj. dijete koje je ostalo bez oca, a koje je dio rodbine.",
    "ayah": 15,
    "surah": 90
  },
  {
    "text": "ili siromaha koji ne posjeduje ništa.",
    "ayah": 16,
    "surah": 90
  },
  {
    "text": "a pored toga da je od onih koji u Allaha vjeruju, koji jedni drugima strpljenje preporučuju, kako u pokornosti tako i u ostavljanju grijeha i u iskušenjima, te jedni drugima preporučuju da budu milostivi prema Allahovim robovima.",
    "ayah": 17,
    "surah": 90
  },
  {
    "text": "Oni koji budu imali ove osobine, biće sretnici.",
    "ayah": 18,
    "surah": 90
  },
  {
    "text": "Oni koji budu poricali istinitost naših ajeta koje objavljujemo našem Poslaniku, biće nesretni.",
    "ayah": 19,
    "surah": 90
  },
  {
    "text": "iznad njih će, na Sudnjem danu, vatra zatvorena biti, i u njoj će se kažnjavati.",
    "ayah": 20,
    "surah": 90
  }
]
