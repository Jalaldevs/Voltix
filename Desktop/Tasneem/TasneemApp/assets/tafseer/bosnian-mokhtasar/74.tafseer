[
  {
    "text": "O ti koji si prekriven svojom odjećom (odnosi se na Poslanika, sallallahu alejhi ve sellem).",
    "ayah": 1,
    "surah": 74
  },
  {
    "text": "Digni se i opominji na Allahovu kaznu.",
    "ayah": 2,
    "surah": 74
  },
  {
    "text": "I slavi svoga Gospodara.",
    "ayah": 3,
    "surah": 74
  },
  {
    "text": "Očisti sebe od grijeha i odjeću od nečistoće.",
    "ayah": 4,
    "surah": 74
  },
  {
    "text": "Udalji se od obožavanja kipova.",
    "ayah": 5,
    "surah": 74
  },
  {
    "text": "Ne prigovaraj svome Gospodaru, tražeći za svoja dobra djela više.",
    "ayah": 6,
    "surah": 74
  },
  {
    "text": "U ime Allaha budi strpljiv na nedaćama koje te prate.",
    "ayah": 7,
    "surah": 74
  },
  {
    "text": "Kada se u rog puhne po drugi put.",
    "ayah": 8,
    "surah": 74
  },
  {
    "text": "To je veoma težak dan.",
    "ayah": 9,
    "surah": 74
  },
  {
    "text": "Onima koji ne vjeruju u Allaha i poslanike taj dan neće biti lahak.",
    "ayah": 10,
    "surah": 74
  },
  {
    "text": "O Poslaniče, ostavi Mene i onoga kojeg sam stvorio samog u stomaku, nije imao ni imetka ni djece. Ovdje se misli na Velida b. Mugiru.",
    "ayah": 11,
    "surah": 74
  },
  {
    "text": "Dao sam mu mnogo imetka.",
    "ayah": 12,
    "surah": 74
  },
  {
    "text": "I dao sam mu sinove koji su bili s njim, nisu se od njega na putovanju odvajali, jer je imao mnogo imetka.",
    "ayah": 13,
    "surah": 74
  },
  {
    "text": "Život sam mu veoma olakšao, darujući mu opskrbu i djecu.",
    "ayah": 14,
    "surah": 74
  },
  {
    "text": "I onda, pored svoga nevjerovanja i svega što sam mu dao, žudi da mu još dadnem.",
    "ayah": 15,
    "surah": 74
  },
  {
    "text": "Nije tako kao što on misli i zamišlja. On je inadžija prema našim ajetima koje objavljujemo našem Poslaniku i poriče ih.",
    "ayah": 16,
    "surah": 74
  },
  {
    "text": "Opteretit ću ga teškom kaznom koju neće moći podnijeti.",
    "ayah": 17,
    "surah": 74
  },
  {
    "text": "Ovaj nevjernik kojem sam dao mnoge blagodati razmišljao je šta da kaže o Kur'anu kako bi ga negirao i u sebi je računao i razmišljao o tome.",
    "ayah": 18,
    "surah": 74
  },
  {
    "text": "Biće proklet i kažnjen kako je proračunao.",
    "ayah": 19,
    "surah": 74
  },
  {
    "text": "Zatim, proklet će biti i kažnjen kako je proračunao.",
    "ayah": 20,
    "surah": 74
  },
  {
    "text": "Zatim je ponovo sagledao i razmišljao šta će kazati.",
    "ayah": 21,
    "surah": 74
  },
  {
    "text": "Zatim se naljutio i lice mu se namrštilo kada je vidio da nema ništa čime bi osporio ispravnost Kur'ana.",
    "ayah": 22,
    "surah": 74
  },
  {
    "text": "Zatim se od vjerovanja okrenuo i oholo odbio slijeđenje Poslanika, sallallahu alejhi ve sellem.",
    "ayah": 23,
    "surah": 74
  },
  {
    "text": "Pa je rekao: Ovo što donosi Muhammed nije Allahov govor, nego je to sihr koji prenosi od drugih.",
    "ayah": 24,
    "surah": 74
  },
  {
    "text": "Ovo nije Allahov govor, nego ljudski.",
    "ayah": 25,
    "surah": 74
  },
  {
    "text": "Ovog nevjernika uvest ću u dio Džehennema, u Sekar da vrelinu njegovu osjeti.",
    "ayah": 26,
    "surah": 74
  },
  {
    "text": "O Muhammede, otkud znaš šta je Sekar?",
    "ayah": 27,
    "surah": 74
  },
  {
    "text": "Neće ostaviti ni jedan dio onoga ko se kažnjava, a da ga neće obuhvatiti, a zatim će se opet vratiti kao što je i bio, potom ponovo doći i tako u nedogled.",
    "ayah": 28,
    "surah": 74
  },
  {
    "text": "Veoma će žestoko pržiti i boju kože mijenjati.",
    "ayah": 29,
    "surah": 74
  },
  {
    "text": "Nad tim džehennemom biće devetnaest meleka, koji će ga čuvati.",
    "ayah": 30,
    "surah": 74
  },
  {
    "text": "Čuvarima Vatre postavili smo samo meleke i ljudi nemaju snage da se s njima nose. Njihov broj smo dali samo kao vid iskušenja onima koji u Allaha ne vjeruju, kako bi rekli ono što su rekli, pa da im se kazna poveća; da se Jevreji kojima je dat Tevrat i kršćani kojima je dat Indžil, uvjere u Kur'an koji potvrđuje ono što je u knjigama njihovim objavljeno; da se vjernicima vjerovanje poveća kada saznaju da se sljedbenici Knjige s njima slažu; da Jevreji, kršćani i vjernici ne sumnjaju i da oni koji nemaju čvrsto vjerovanje i nevjernici, kažu: \"Šta je Allah želio ovim čudnim brojem?\" Kao što Allah u zabludi ostavlja onoga ko negira ovaj broj, i kao što upućuje onoga ko u njega vjeruje, tako isto u zabludi ostavlja koga hoće i na pravi put upućuje koga hoće. Broj Allahove vojske ne zna niko osim Njega. Vatra je samo opomena za ljude da bi znali Allahovu veličinu.",
    "ayah": 31,
    "surah": 74
  },
  {
    "text": "Nije kao što misle neki mušrici da je dovoljno da njegovi drugovi savladaju čuvare vatre. Allah se kune Mjesecom.",
    "ayah": 32,
    "surah": 74
  },
  {
    "text": "Kunem se noći kada ode i nestane.",
    "ayah": 33,
    "surah": 74
  },
  {
    "text": "I kunem se zorom kada nastane i svjetlost se pojavi.",
    "ayah": 34,
    "surah": 74
  },
  {
    "text": "Džehennemska vatra je jedna velika nedaća.",
    "ayah": 35,
    "surah": 74
  },
  {
    "text": "Njome se ljudi opominju i straše.",
    "ayah": 36,
    "surah": 74
  },
  {
    "text": "onome između vas, o ljudi, koji hoće naprijed ići, vjerujući u Allaha i radeći dobra djela ili zaostati, negirajući Allaha i griješenjem.",
    "ayah": 37,
    "surah": 74
  },
  {
    "text": "Svaka duša će za svoja djela odgovoriti, pa će, ili biti kažnjena zbog njih ili će se spasiti kazne i propasti.",
    "ayah": 38,
    "surah": 74
  },
  {
    "text": "osim vjernika koji neće biti kažnjeni zbog grijeha, jer će se preko njihovih gijeha preći zbog dobrih djela koja su činili.",
    "ayah": 39,
    "surah": 74
  },
  {
    "text": "Oni će na Sudnjem danu, u Džennetu, jedni druge pitati",
    "ayah": 40,
    "surah": 74
  },
  {
    "text": "o nevjernicima koju su sami sebe doveli u propast, čineći grijehe.",
    "ayah": 41,
    "surah": 74
  },
  {
    "text": "Reći će im: Šta je razlog vašeg ulaska u Džehennem?",
    "ayah": 42,
    "surah": 74
  },
  {
    "text": "Nevjernici će odgovoriti: Nismo bili od onih koji su na dunjaluku obavezne namaze obavljali.",
    "ayah": 43,
    "surah": 74
  },
  {
    "text": "Nismo iz onoga što nam je Allah dao siromahe hranili.",
    "ayah": 44,
    "surah": 74
  },
  {
    "text": "Sa pobornicima neistine družili smo se i gdje god su i oni, i mi smo bili, i pričali smo sa onima koji su zalutali.",
    "ayah": 45,
    "surah": 74
  },
  {
    "text": "Negirali smo Dan u kojem će svako dobiti ono što je zaslužio.",
    "ayah": 46,
    "surah": 74
  },
  {
    "text": "U tom poricanju smo ustrajavali sve dok nam smrt nije stigla i nismo imali mogućnost da se pokajemo.",
    "ayah": 47,
    "surah": 74
  },
  {
    "text": "Njima na Sudnjem danu neće koristiti zauzimanje meleka, vjerovjesnika i dobrih ljudi, jer je jedan od uslova prihvatanja zauzimanja, zadovoljstvo sa onim za koga se zagovara.",
    "ayah": 48,
    "surah": 74
  },
  {
    "text": "Šta je razlog pa se ovi mušrici okreću od Kur'ana.",
    "ayah": 49,
    "surah": 74
  },
  {
    "text": "U svome okretanju i bježanju od istine, oni su poput divljih magaraca.",
    "ayah": 50,
    "surah": 74
  },
  {
    "text": "koji bježe preplašeni od lavova.",
    "ayah": 51,
    "surah": 74
  },
  {
    "text": "Svaki od ovih mušrika hoće da se probudi i pored sebe nađe knjigu u kojoj piše da je Muhammed Allahov poslanik. Oni to ne traže zbog pomanjkanja dokaza i njihove slabosti nego zbog svog inata i oholosti.",
    "ayah": 52,
    "surah": 74
  },
  {
    "text": "Nije tako, nego je razlog ustrajavanja u zabludi to što ne vjeurju u ahiretsku kaznu.",
    "ayah": 53,
    "surah": 74
  },
  {
    "text": "Kur'an je zaista poruka, upozorenje i opomena.",
    "ayah": 54,
    "surah": 74
  },
  {
    "text": "Onaj ko želi da Kur'an čita i da se njime koristi, on će to shvatiti kao opomenu.",
    "ayah": 55,
    "surah": 74
  },
  {
    "text": "Njime će se opomenuti samo oni koje Allah bude htio da se opomenu. Allah je jedini zaslužan da Ga se boji kroz činjenje naredbi i ostavljanje zabrana i On jedini prašta grijehe onima koji se pokaju.",
    "ayah": 56,
    "surah": 74
  }
]
