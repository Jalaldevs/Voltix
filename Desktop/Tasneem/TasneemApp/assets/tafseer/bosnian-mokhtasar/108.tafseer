[
  {
    "text": "Mi smo ti, o Poslaniče, dali mnogo dobro, a u njega se ubraja i rijeka Kevser u Džennetu.",
    "ayah": 1,
    "surah": 108
  },
  {
    "text": "Budi zahvalan na tim blagodatima, klanjajući samo Njemu i prinoseći žrtvu, za razliku od mušrika koji su žrtve prinosili svojim kipovima.",
    "ayah": 2,
    "surah": 108
  },
  {
    "text": "Onaj ko tebe mrzi uskraćen je svakog dobra, bće bez spomena, a i ako se spomene, to će biti po zlu.",
    "ayah": 3,
    "surah": 108
  }
]
