[
  {
    "text": "Allah se kune početkom dana.",
    "ayah": 1,
    "surah": 93
  },
  {
    "text": "I kune se noći kada spusti svoju tamu i ljude se u njoj smire.",
    "ayah": 2,
    "surah": 93
  },
  {
    "text": "Nije te tvoj Gospodar, o Poslaniče, ni ostavio niti si mu postao mrzak, kao što to tvrde mušrici, kada su uvidjeli da Objava nije dolazila jedno vrijeme.",
    "ayah": 3,
    "surah": 93
  },
  {
    "text": "Onaj svijet za tebe je bolji od ovog, jer se na onome svijetu nalaze trajne i neprekidne blagodati.",
    "ayah": 4,
    "surah": 93
  },
  {
    "text": "Allah će tebi i tvome ummetu dati veliku i vrijednu nagradu, kako bi ti bio zadovoljan onim što je tebi i tvome ummetu darovano.",
    "ayah": 5,
    "surah": 93
  },
  {
    "text": "Uistinu, bio si dijete, koje je ostalo i bez oca i bez majke, pa ti je On pružio zaštitu, kada je brigu o tebi preuzeo djed ti Abdul-Muttalib, a nakon njega tvoj amidža Ebu Talib.",
    "ayah": 6,
    "surah": 93
  },
  {
    "text": "I našao te je, a nisi znao za knjigu i vjeru, pa te je On podučio onome što nisi znao.",
    "ayah": 7,
    "surah": 93
  },
  {
    "text": "i našao te je kao siromaha, pa te je neovisnim učinio.",
    "ayah": 8,
    "surah": 93
  },
  {
    "text": "i ne odnosi se ružno prema onome ko je ostao kao dijete bez oca i ne ponižavaj ga.",
    "ayah": 9,
    "surah": 93
  },
  {
    "text": "Nemoj odbiti onoga ko zbog potrebe nešto traži.",
    "ayah": 10,
    "surah": 93
  },
  {
    "text": "Budi zahvalan na onome što ti je Allah kao blagodat dao i o tome pričaj.",
    "ayah": 11,
    "surah": 93
  }
]
