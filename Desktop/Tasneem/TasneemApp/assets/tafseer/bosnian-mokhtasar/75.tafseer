[
  {
    "text": "Allah se kune Sudnjim danom, kada će ljudi stajati pred Gospodarem svijetova.",
    "ayah": 1,
    "surah": 75
  },
  {
    "text": "I kune se dobrom dušom koja sebe kori jer je nemarna prema dobrim djelima i jer čini loša djela. Ovim se kune kao vid potvde da će ljudi biti proživljeni radi obračuna i nagrade ili kazne.",
    "ayah": 2,
    "surah": 75
  },
  {
    "text": "Zar čovjek misli da kosti njegove nakon smrti nećemo sakupiti, kako bismo ga oživjeli?",
    "ayah": 3,
    "surah": 75
  },
  {
    "text": "Možemo to da učinimo, da ih skupimo i da jagodice njegovih prstiju vratimo u prvobitno stanje.",
    "ayah": 4,
    "surah": 75
  },
  {
    "text": "Čovjek želi, negirajući proživljenje, da nastavi s griješenjem, bez ustručavanja.",
    "ayah": 5,
    "surah": 75
  },
  {
    "text": "On se zapitkuje kada će Sudnji dan, smatrajući da je to nešto nemoguće i da je daleko.",
    "ayah": 6,
    "surah": 75
  },
  {
    "text": "Kada pogled ostane zbunjen, gledajući u ono što je poricao.",
    "ayah": 7,
    "surah": 75
  },
  {
    "text": "I nestane mjesečeve svjetlosti.",
    "ayah": 8,
    "surah": 75
  },
  {
    "text": "Kada Sunce i Mjesec postanu spojeni.",
    "ayah": 9,
    "surah": 75
  },
  {
    "text": "Čovjek griješnik toga Dana pitat će gdje je izlaz?",
    "ayah": 10,
    "surah": 75
  },
  {
    "text": "Toga Dana neće se imati gdje pobjeći i griješnik neće moći spas naći, niti će imati zaštitnika.",
    "ayah": 11,
    "surah": 75
  },
  {
    "text": "O Poslaniče, tvome Gospodaru tog Dana biće povratak radi obračuna, nagrade ili kazne.",
    "ayah": 12,
    "surah": 75
  },
  {
    "text": "Na taj Dan čovjeku će se kazati šta je od djela činio, a šta je izostavio.",
    "ayah": 13,
    "surah": 75
  },
  {
    "text": "Čovjek će tada protiv sebe svjedočiti i njegovi organi će o grijesima njegovim kazivati.",
    "ayah": 14,
    "surah": 75
  },
  {
    "text": "I opravdanja kojim će se pravdati da nije grijehe radio, neće mu koristiti.",
    "ayah": 15,
    "surah": 75
  },
  {
    "text": "O Poslaniče, ne pomjeraj svoj jezik da što brže učiš Kur'an.",
    "ayah": 16,
    "surah": 75
  },
  {
    "text": "Mi ćemo ga u tvojim prsima skupiti i na jeziku tvome njegove učenje učvrstiti.",
    "ayah": 17,
    "surah": 75
  },
  {
    "text": "Kada ti naš izaslanik Džibril uči Kur'an, ti šuti i pomno slušaj učenje njegovo.",
    "ayah": 18,
    "surah": 75
  },
  {
    "text": "A Mi ćemo ga poslije tebi protumačiti.",
    "ayah": 19,
    "surah": 75
  },
  {
    "text": "Nije tačan govor onih koji negiraju proživljenje. Vi znate da je onaj ko je u mogućnosti da vas iz ničega stvori, u mogućnosti i da vas nakon smrti oživi, ali razlog vašeg poricanja jeste ljubav prema dunjaluku koji brzo prolazi.",
    "ayah": 20,
    "surah": 75
  },
  {
    "text": "I zapostavljate onaj svijet do kojeg vodi pokoravanje Allahu i napuštanje Njegovih zabrana.",
    "ayah": 21,
    "surah": 75
  },
  {
    "text": "Lica onih koji su bili vjernici, toga dana biće sretna i osvijetljena.",
    "ayah": 22,
    "surah": 75
  },
  {
    "text": "Ona će gledati u lice svoga Gospodara, uživajući u tome.",
    "ayah": 23,
    "surah": 75
  },
  {
    "text": "Lica nevjernika toga Dana biće nesretna i crna.",
    "ayah": 24,
    "surah": 75
  },
  {
    "text": "Uvjerena da će ih zadesiti velika i žestoka kazna i patnja.",
    "ayah": 25,
    "surah": 75
  },
  {
    "text": "Nije tačno da mušrici neće biti oživljeni i kažnjeni, kao što misle. Kada duša nekog od njih dođe do vrha prsa, do ključne kosti...",
    "ayah": 26,
    "surah": 75
  },
  {
    "text": "Neki ljudi su drugima govorili: Ko će mu pomoći, možda se izliječi?",
    "ayah": 27,
    "surah": 75
  },
  {
    "text": "I on bude uvjeren da se sa ovim svijetom rastaje i da mu smrt dolazi.",
    "ayah": 28,
    "surah": 75
  },
  {
    "text": "I u tom trenu skupe se nedaće, kad dolazi kraj ovog i početak onog života.",
    "ayah": 29,
    "surah": 75
  },
  {
    "text": "Kada se to desi, umrli će odveden biti svome Gospodaru.",
    "ayah": 30,
    "surah": 75
  },
  {
    "text": "Nevjernik nije vjerovao u ono što je donio Poslanik i nije radi Allaha klanjao.",
    "ayah": 31,
    "surah": 75
  },
  {
    "text": "Međutim, on je poricao i negirao, te se od istine sa kojom je došao Poslanik, okretao.",
    "ayah": 32,
    "surah": 75
  },
  {
    "text": "Zatim je ovaj nevjernik išao svojoj porodici, oholo hodeći po Zemlji.",
    "ayah": 33,
    "surah": 75
  },
  {
    "text": "Allah prijeti nevjerniku Svojom kaznom i upozorava ga da je ona blizu.",
    "ayah": 34,
    "surah": 75
  },
  {
    "text": "Zatim je ponovio ovu prijetnju kao vid potvrde, rekavši: I još jednom: Teško tebi! Teško tebi!",
    "ayah": 35,
    "surah": 75
  },
  {
    "text": "Zar čovjek misli da će sam sebi biti prepušten i da neće odgovoriti?",
    "ayah": 36,
    "surah": 75
  },
  {
    "text": "Zar čovjek nije bio kap sjemena koja se ubaci u rodnicu?",
    "ayah": 37,
    "surah": 75
  },
  {
    "text": "Zatim je bio komad ugruška, a nakon toga ga Allah stvorio i skladnim ga učinio.",
    "ayah": 38,
    "surah": 75
  },
  {
    "text": "Zatim je u stvorio mušku i žensku vrstu.",
    "ayah": 39,
    "surah": 75
  },
  {
    "text": "Zar onaj koji je stvorio čovjeka od kapi sjemena i ugruška, nije u stanju da oživi mrtve radi obračuna. On je to u mogućnosti.",
    "ayah": 40,
    "surah": 75
  }
]
