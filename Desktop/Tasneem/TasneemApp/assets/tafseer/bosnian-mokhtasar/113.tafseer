[
  {
    "text": "O Poslaniče, reci: Tražim zaštitu kod Gospodara jutra.",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "od zla kojeg čine stvorenja i njihovih uznemiravanja.",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "I kod Allaha tražim spas od zla koje se pojavljuje noću, u vidu životinja i lopova.",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "I kod njega tražim spas od sihirbasica koje pušu u čvorove.",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "I kod Njega tražim spas od zla zavidnika koji radi ono iz čega proizlazi zavist.",
    "ayah": 5,
    "surah": 113
  }
]
