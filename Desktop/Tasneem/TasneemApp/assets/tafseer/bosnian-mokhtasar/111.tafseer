[
  {
    "text": "Neka propadnu ruke Ebu Leheba, amidže Poslanika, sallallahu alejhi ve sellem, sina Abdul-Muttaliba, i propao je zbog svojih postupaka, jer je uznemiravao Poslanika, sallallahu alejhi ve sellem.",
    "ayah": 1,
    "surah": 111
  },
  {
    "text": "Šta će mu koristiti njegov imetak i djeca? Neće ga sačuvati kazne, niti će mu donijeti milost.",
    "ayah": 2,
    "surah": 111
  },
  {
    "text": "Na sudnjem danu ući će u vatru rasplamsalu i osjetiti njenu vrelinu.",
    "ayah": 3,
    "surah": 111
  },
  {
    "text": "U Vatru će ući i njegova žena Ummu Džemil koja je uznemiravala Poslanika, sallallahu alejhi ve sellem, bacajući trnje po putu kojim je išao.",
    "ayah": 4,
    "surah": 111
  },
  {
    "text": "Na vratu njenom biće uže kojim će biti vođena u Vatru.",
    "ayah": 5,
    "surah": 111
  }
]
