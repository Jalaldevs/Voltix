[
  {
    "text": "Milostivi koji posjeduje ogromnu milost.",
    "ayah": 1,
    "surah": 55
  },
  {
    "text": "On ljude poučava Kur'anu, tako što olakšava njegovo pamćenje i razumijevanje značenja.",
    "ayah": 2,
    "surah": 55
  },
  {
    "text": "On je čovjeka skladnim stvorio i oblik mu uljepšao",
    "ayah": 3,
    "surah": 55
  },
  {
    "text": "Uči ga kako da se izrazi o svojim osjećanjima, kako da to kaže i napiše.",
    "ayah": 4,
    "surah": 55
  },
  {
    "text": "On je odredio putanju Sunca i Mjeseca, koji plove po savršeno preciziranom proračunu, kako bi ljudi znali broj godina i kako bi se poučili računanju vremena.",
    "ayah": 5,
    "surah": 55
  },
  {
    "text": "I trava, a i drveće koja nema stabla, čine sedždu i padaju ničice Allahu Uzvišenom, pokorni i potčinjeni Njemu.",
    "ayah": 6,
    "surah": 55
  },
  {
    "text": "I nebo je iznad Zemlje kao njen svod postavio, a na Zemlji je mjerilo pravde odredio i robovima naredio da pravedni budu.",
    "ayah": 7,
    "surah": 55
  },
  {
    "text": "Odredio je mjerilo pravde, kako ne biste, o ljudi, prelazili tu granicu i varali prilikom mjerenja i vaganja.",
    "ayah": 8,
    "surah": 55
  },
  {
    "text": "Pravedno među vama mjerite, prilikom mjerenja i vaganja drugima, ne zakidajte",
    "ayah": 9,
    "surah": 55
  },
  {
    "text": "Zemlju je učinio pogodnom za život stvorenja na njoj.",
    "ayah": 10,
    "surah": 55
  },
  {
    "text": "na njoj ima drveća koje daje voće i na njoj ima palmi s plodom u čaškama.",
    "ayah": 11,
    "surah": 55
  },
  {
    "text": "Na njoj ima i žitarica sa slamom, poput ječma i pšenice, a ima i cvijeća kojeg koristite za mirisanje.",
    "ayah": 12,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 13,
    "surah": 55
  },
  {
    "text": "Stvorio je Adema od suhe ilovače od koje se čuje zvuk, poput kuhane gline.",
    "ayah": 14,
    "surah": 55
  },
  {
    "text": "Praoca džina stvorio je od vatrenog plamena čistog od dima.",
    "ayah": 15,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 16,
    "surah": 55
  },
  {
    "text": "Gospodara dva mjesta sa kojih Sunce izlazi i dva mjesta na kojima zalazi, zimi i ljeti.",
    "ayah": 17,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 18,
    "surah": 55
  },
  {
    "text": "Allah je dao da se dva mora, slano i slatko dodiruju i da se, prema onome što oči vide, spajaju.",
    "ayah": 19,
    "surah": 55
  },
  {
    "text": "Između ta dva mora je pregrada koja spriječava da se miješaju, tako da slano more ostaje slano, a slatko ostaje slatko.",
    "ayah": 20,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 21,
    "surah": 55
  },
  {
    "text": "Iz ova dva mora vade se veliki i mali biseri.",
    "ayah": 22,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 23,
    "surah": 55
  },
  {
    "text": "Samo On jedini upravlja lađama koje morem plove poput planina.",
    "ayah": 24,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 25,
    "surah": 55
  },
  {
    "text": "Sve što se nalazi na zemlji od stvorenja, nestat će, bez imalo sumnje.",
    "ayah": 26,
    "surah": 55
  },
  {
    "text": "Ostat će samo lice tvoga Gospodara, o Poslaniče, koje je veličanstveno i plemenito prema svojim stvorenjima. Ono nikada neće nestati.",
    "ayah": 27,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 28,
    "surah": 55
  },
  {
    "text": "Njemu se obraćaju i mole Ga svi meleki koji su na nebesima, i džini i ljudi koji su na Zemlji, i od Njega traže da im ispuni njihove potrebe. Svakog dana On se zanima onim što je za robove vezano, poput oživljavanja, usmrćivanja, opskrbljivanja i dr.",
    "ayah": 29,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 30,
    "surah": 55
  },
  {
    "text": "Mi ćemo se posvetiti vašem obračunu, o ljudi i džinni, pa ćemo svakog nagraditi, odnosno kazniti, shodno onome što zaslužuje.",
    "ayah": 31,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 32,
    "surah": 55
  },
  {
    "text": "Na Sudnjem danu, kada Allah skupi ljude i džinne, kazat će im: O skupino džina i ljudi, ako možete da sebi nađete izlaz kroz neki od slojeva nebesa i Zemlje, onda učinite to. To nećete moći učiniti bez velike snage, a odakle vam snaga?",
    "ayah": 33,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 34,
    "surah": 55
  },
  {
    "text": "Na vas će se, o ljudi i džinni, poslati vatreni plamen bez dima i dim bez plamena i vi se od toga neće moći sačuvati.",
    "ayah": 35,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 36,
    "surah": 55
  },
  {
    "text": "Kada se nebo otvori kako bi meleki sišli, pa bude cvenkaste boje poput masnoće rastopljene.",
    "ayah": 37,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 38,
    "surah": 55
  },
  {
    "text": "Toga velikog dana, ljudi i džini neće biti pitani o svojim grijesima, jer Allah već zna za njihova djela.",
    "ayah": 39,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 40,
    "surah": 55
  },
  {
    "text": "Na Sudnjem danu griješnici će biti prepoznatljivi po crnilu lica i plavilu očiju. Njihove kike spojiće se stopalima i biće bačeni u Džehennem.",
    "ayah": 41,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 42,
    "surah": 55
  },
  {
    "text": "Kao vid ukora, kazat će im se: Ovo je Džehennem kojeg ste, o griješnici, poricali na dunjaluku. On će biti pred njihovim očima i oni ga tada neće moći negirati.",
    "ayah": 43,
    "surah": 55
  },
  {
    "text": "Kretat će se između Vatre i veoma vrele vode.",
    "ayah": 44,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 45,
    "surah": 55
  },
  {
    "text": "Onoga ko bude strahovao od stajanja pred svojim Gospodarom, vjerovao i dobra djela radio, čekaju dvije džennetske bašče.",
    "ayah": 46,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 47,
    "surah": 55
  },
  {
    "text": "ta dva perivoja džennetska biće puna stabala granatih i velikih, s plodovima.",
    "ayah": 48,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 49,
    "surah": 55
  },
  {
    "text": "U ta dva perivoja nalaze se dva izvora čija voda teče među njima.",
    "ayah": 50,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 51,
    "surah": 55
  },
  {
    "text": "U ta dva perivoja biće od svakog voća po dvije vrste.",
    "ayah": 52,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 53,
    "surah": 55
  },
  {
    "text": "Odmarat će se na posteljini od kadife, a plodovi i voće u oba perivoja biće dostupni i u blizini onoga ko ih želi uzeti, bilo da stoji, sjedi ili je naslojen.",
    "ayah": 54,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 55,
    "surah": 55
  },
  {
    "text": "U njima će biti žene koje preda se gledaju, odnosno neće gledati osim u svoje muževe, one koje su nevine, i koje prije njihovih muževa, ni čovjek ni džin nije dodirnuo.",
    "ayah": 56,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 57,
    "surah": 55
  },
  {
    "text": "kao da su one dragulj i merdžan po svojoj ljepoti i čistoti.",
    "ayah": 58,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 59,
    "surah": 55
  },
  {
    "text": "Onome ko čini dobro, pokoravajući se svome Gospodaru, Allah će dobrim uzvratiti.",
    "ayah": 60,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 61,
    "surah": 55
  },
  {
    "text": "Ispod ta dva perivoja koja se spominju, biće još dva.",
    "ayah": 62,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 63,
    "surah": 55
  },
  {
    "text": "čije je zelenilo jako.",
    "ayah": 64,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 65,
    "surah": 55
  },
  {
    "text": "U ta dva perivoja biće dva izvora sa kojih voda jako prska, čije prskanje neće prestati.",
    "ayah": 66,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 67,
    "surah": 55
  },
  {
    "text": "U ta dva perivoja će biti mnogo voća i velikih palmi i šipaka,",
    "ayah": 68,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 69,
    "surah": 55
  },
  {
    "text": "U ovim džennetskim perivojima živjet će žene, lijepog morala i lijepih izgleda.",
    "ayah": 70,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 71,
    "surah": 55
  },
  {
    "text": "Hurija prekrivenih u šatorima, čime će biti čuvane.",
    "ayah": 72,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 73,
    "surah": 55
  },
  {
    "text": "Prije njihovih muževa nije ih dodirnuo niko od ljudi, niti od džina.",
    "ayah": 74,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 75,
    "surah": 55
  },
  {
    "text": "Biće naslonjeni na naslonjačima zelenim i ćilimima čarobno lijepim.",
    "ayah": 76,
    "surah": 55
  },
  {
    "text": "Pa koje mnogobrojne blagodati koje vam je Allah dao - o ljudi i džinni - poričete?",
    "ayah": 77,
    "surah": 55
  },
  {
    "text": "Uzvišeno je i puno dobra ime Gospodara tvoga, Veličanstvenog i Plemenitog, koji je dobročinitelj prema Svojim robovima.",
    "ayah": 78,
    "surah": 55
  }
]
