[
  {
    "text": "Lice Poslanika, sallallahu alejhi ve sellem, smrknulo se i on se okrenuo.",
    "ayah": 1,
    "surah": 80
  },
  {
    "text": "jer mu je došao Abdullah b. Ummi Mektum da od njega traži odgovor i pravi put, a bio je slijep čovjek. Došao je u trenutku dok je Poslanik, sallallahu alejhi ve sellem, bio zauzet poglavarima mušrika, nadajući se da će krenuti Pravim putem.",
    "ayah": 2,
    "surah": 80
  },
  {
    "text": "A šta ti, o Poslaniče, znaš, možda je ovaj slijepac htio da se od grijeha očisti.",
    "ayah": 3,
    "surah": 80
  },
  {
    "text": "ili da uzme pouku iz onoga što od tebe čuje, pa da mu ona od koristi bude.",
    "ayah": 4,
    "surah": 80
  },
  {
    "text": "a što se tiče onoga ko smatra da je sebi dovoljan i da mu, zbog imetka kojeg posjeduje, ne treba vjerovanje u koje pozivaš",
    "ayah": 5,
    "surah": 80
  },
  {
    "text": "ti se prema njemu okrećeš i svoju pažnju njemu usmjeravaš.",
    "ayah": 6,
    "surah": 80
  },
  {
    "text": "tebi neće biti ništa ako se on od grijeha Allahu ne pokaje i ne očisti.",
    "ayah": 7,
    "surah": 80
  },
  {
    "text": "a kada je u pitanju onaj koji ti žureći dolazi, tražeći dobro",
    "ayah": 8,
    "surah": 80
  },
  {
    "text": "on se boji svoga Gospodara",
    "ayah": 9,
    "surah": 80
  },
  {
    "text": "ti se od njega okrećeš i pažnju svoju prema mušričkim poglavarima okrećeš.",
    "ayah": 10,
    "surah": 80
  },
  {
    "text": "Ne treba da je tako, ovo je pouka i upozorenje onome ko želi da prihvati.",
    "ayah": 11,
    "surah": 80
  },
  {
    "text": "Onaj ko želi da se sjeti Allaha, to će i učiniti i uzet će poruku iz Kur'ana.",
    "ayah": 12,
    "surah": 80
  },
  {
    "text": "Ovaj Kur'an je kod meleka na vrijednim listovima.",
    "ayah": 13,
    "surah": 80
  },
  {
    "text": "uzdignutim na visokom i čistom mjestu do kojeg ne dolazi ni nečistoća ni prljavština.",
    "ayah": 14,
    "surah": 80
  },
  {
    "text": "u rukama meleka izaslanika.",
    "ayah": 15,
    "surah": 80
  },
  {
    "text": "plemenitih kod njihova Gospodara, koji mnogo dobra čine i puno su pokorni.",
    "ayah": 16,
    "surah": 80
  },
  {
    "text": "Proklet je nevjernik. Kako je samo njegovo nevjerstvo žestoko",
    "ayah": 17,
    "surah": 80
  },
  {
    "text": "Od čega ga je Allah stvorio, pa se na Zemlji oholi i ispoljava nevjerovanje u Njega?",
    "ayah": 18,
    "surah": 80
  },
  {
    "text": "od malo tekućine ga je stvorio, pa mu oblik i izgled odredio.",
    "ayah": 19,
    "surah": 80
  },
  {
    "text": "Zatim mu je nakon toga olakšao izlazak iz utrobe majke svoje.",
    "ayah": 20,
    "surah": 80
  },
  {
    "text": "Zatim, nakon što mu je odredio životni vijek, usmrtio ga je i učinio da u kaburu bude dok se proživljenje ne desi.",
    "ayah": 21,
    "surah": 80
  },
  {
    "text": "Zatim će ga, kada bude htio, oživjeti radi obračuna, nagrade ili kazne.",
    "ayah": 22,
    "surah": 80
  },
  {
    "text": "Uistinu, nevjernik misli da je izvršio obaveze prema Allahu, a nije tako, jer on nije uradio ono čime ga je Allah obavezao.",
    "ayah": 23,
    "surah": 80
  },
  {
    "text": "Neka ovaj nevjernik u Allaha pogleda u svoju hranu koju jede i neka vidi kako do nje dolazi.",
    "ayah": 24,
    "surah": 80
  },
  {
    "text": "Dolazi nakon kiše koja se snažno spušta sa nebesa.",
    "ayah": 25,
    "surah": 80
  },
  {
    "text": "zatim dajemo da zemlja se raspukne i da iz nje iziđe bilje.",
    "ayah": 26,
    "surah": 80
  },
  {
    "text": "Pa činimo da iz zemlje niču žitarice, pšenica, kukuruz i dr.",
    "ayah": 27,
    "surah": 80
  },
  {
    "text": "i da li smo da niče grožđe i bilje koje jede vaša stoka.",
    "ayah": 28,
    "surah": 80
  },
  {
    "text": "i dali smo da niču masline i palme.",
    "ayah": 29,
    "surah": 80
  },
  {
    "text": "I dali smo da niču bašče, s puno drveća.",
    "ayah": 30,
    "surah": 80
  },
  {
    "text": "I dali smo da na njoj raste voće i trava kojom hranite vaše životinje.",
    "ayah": 31,
    "surah": 80
  },
  {
    "text": "kako biste se vi i vaša stoka koristili.",
    "ayah": 32,
    "surah": 80
  },
  {
    "text": "kada dođe veoma snažan glas, koji će biti zaglušujući, a to je, ustvari, drugo puhanje u rog.",
    "ayah": 33,
    "surah": 80
  },
  {
    "text": "toga dana će čovjek bježati od svoga brata.",
    "ayah": 34,
    "surah": 80
  },
  {
    "text": "bježat će čovjek i od majke svoje i od oca svoga.",
    "ayah": 35,
    "surah": 80
  },
  {
    "text": "bježat će i od supruge svoje i od djece svoje.",
    "ayah": 36,
    "surah": 80
  },
  {
    "text": "svako će toga Dana imati brige koje će ga od drugih odvratiti, zbog velike nedaće i straha koji će tada vladati.",
    "ayah": 37,
    "surah": 80
  },
  {
    "text": "Lica srećnih toga dana biće blistava.",
    "ayah": 38,
    "surah": 80
  },
  {
    "text": "biće sretna i radosna zbog onog što im je Allah, iz svoje milosti, pripremio.",
    "ayah": 39,
    "surah": 80
  },
  {
    "text": "Lica nesretnih toga dana biće prašinom pokrivena.",
    "ayah": 40,
    "surah": 80
  },
  {
    "text": "nad njima će biti tama i crnilo.",
    "ayah": 41,
    "surah": 80
  },
  {
    "text": "Oni koji će biti u ovakvom stanju su ljudi koji su bili nevjernici i pored toga su činili razvrat.",
    "ayah": 42,
    "surah": 80
  }
]
