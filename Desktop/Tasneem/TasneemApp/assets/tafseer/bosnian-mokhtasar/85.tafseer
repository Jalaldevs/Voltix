[
  {
    "text": "Allah se kune nebom koje obuhvata položaje Sunca, mjeseca i drugih nebeskih tijela.",
    "ayah": 1,
    "surah": 85
  },
  {
    "text": "I kune se Sudnjim danom na kojem će biti sakupljena stvorenja, kako je to obećano.",
    "ayah": 2,
    "surah": 85
  },
  {
    "text": "i kune se svakim svjedokom, poput Vjerovjesnika koji će svjedočiti protiv ummeta, i svakim posvjedočenim, kao što je ummet, protiv kojeg će svjedočiti njegov vjerovjesnik.",
    "ayah": 3,
    "surah": 85
  },
  {
    "text": "neka su prokleti oni koji su u zemlji velike rovove iskopali.",
    "ayah": 4,
    "surah": 85
  },
  {
    "text": "koji su u tim rovovima vatru zapalili, i u njih bacili žive vjernike.",
    "ayah": 5,
    "surah": 85
  },
  {
    "text": "kada su oko tih rovova napunjenih vatrom, sjedili.",
    "ayah": 6,
    "surah": 85
  },
  {
    "text": "Bili su prisutni i svjedoci onoga što su vjernicima radili od kažnjavanja.",
    "ayah": 7,
    "surah": 85
  },
  {
    "text": "Ovi nevjernici nisu se svetili vjernicima i nisu im smatrali mahanom osim to što su vjerovali u Allaha Silnog kojeg niko ne može nadvladati i Hvaljenog u svakom smislu.",
    "ayah": 8,
    "surah": 85
  },
  {
    "text": "Onaj kojem jedino pripada vast i na nebesima i vlast na Zemlji, koji je sa svime upoznat i ništa Mu što je vezano za njegove robove, nije nepoznato.",
    "ayah": 9,
    "surah": 85
  },
  {
    "text": "One koji su kažnjavali vjernike i vjernice vatrom, kako bi ih od vjerovanja u Allaha jednog odvratili, a zatim se nisu Allahu pokajali za te grijehe, čeka na Sudnjem danu džehennemska kazna i patnja vatrena, kao naknada za ono što su radili vjernicima, paleći ih vatrom.",
    "ayah": 10,
    "surah": 85
  },
  {
    "text": "Onima koji su vjerovali u Allaha i radili dobra djela, pripadaju džennetske bašče ispod čijih dvoraca i drveća teku rijeke. To je nagrada koju im je Allah pripremio i postizanje te nagrade je veliki uspjeh sa kojim se ništa ne može porediti.",
    "ayah": 11,
    "surah": 85
  },
  {
    "text": "Kažnjavanje nepravednika od strane Gospodara tvoga, o Poslaniče, zaista je žestoko, pa makar to malo i odgodio.",
    "ayah": 12,
    "surah": 85
  },
  {
    "text": "On je otpočeo stvaranje i kažnjavanje i učinit će da se ponovo dogode.",
    "ayah": 13,
    "surah": 85
  },
  {
    "text": "On prašta grijehe onim robovima koji Mu se pokaju i voli svoje bliske bogobojazne robove.",
    "ayah": 14,
    "surah": 85
  },
  {
    "text": "Vlasnik Prijestolja, Plemeniti.",
    "ayah": 15,
    "surah": 85
  },
  {
    "text": "On radi šta hoće, bilo da se radi o praštanju grijeha onome kome hoće ili kažnjavanju onoga koga hoće i Njega niko ne može prisiliti.",
    "ayah": 16,
    "surah": 85
  },
  {
    "text": "Da li je do tebe, o Poslaniče, doprla vijest o vojskama koje su se okupile radi borbe protiv istine i odvraćanja od nje?",
    "ayah": 17,
    "surah": 85
  },
  {
    "text": "o faraonu i Semudu, narodu Saliha, alejhi selam.",
    "ayah": 18,
    "surah": 85
  },
  {
    "text": "Razlog njihovog odbijanja vjerovanja nije u tome što im nisu stigle vijesti o narodima koji su poricali i njihovoj propasti, nego njihovo poricanje istine koju su donijeli njihovi poslanici, i povođenje za prohtjevima.",
    "ayah": 19,
    "surah": 85
  },
  {
    "text": "Allah ih prati i njihova djela broji, ništa Mu od toga ne promiče i On će im dati adekvatnu naknadu.",
    "ayah": 20,
    "surah": 85
  },
  {
    "text": "Kur'an nije poezija kao što to tvrde poricatelji, nego je to Kur'an plemeniti.",
    "ayah": 21,
    "surah": 85
  },
  {
    "text": "Na ploči koja se čuva od preinake, iskrivljenja, oduzimanja i dodavanja.",
    "ayah": 22,
    "surah": 85
  }
]
