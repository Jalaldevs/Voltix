[
  {
    "text": "Reci, o Poslaniče: Allah je jedinstven u božanskim osobinama i On je jedini Bog.",
    "ayah": 1,
    "surah": 112
  },
  {
    "text": "On je Gospodar Apsolutni i savršeni u svojim svojstvima i ljepoti, Onaj kome sva stvorenja teže i kod Njega utočište traže.",
    "ayah": 2,
    "surah": 112
  },
  {
    "text": "Onaj koji nikog nije rodio, niti je Njega iko rodio. On Uzvišeni nema ni djeteta ni roditelja.",
    "ayah": 3,
    "surah": 112
  },
  {
    "text": "Njemu niko od stvorenja nije sličan.",
    "ayah": 4,
    "surah": 112
  }
]
