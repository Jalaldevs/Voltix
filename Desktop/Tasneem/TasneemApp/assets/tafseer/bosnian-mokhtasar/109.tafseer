[
  {
    "text": "Reci, o Poslaniče: O vi koji ne vjerujete u Allaha.",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "Ja ni sada, a ni u budućnosti neću obožavati kipove koje vi obožavate.",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "A niti vi obožavate onoga koga je obožavam, tj. samo Allaha jedinog.",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "niti sam ja obožavalac kipova koje vi obožavate,",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "A niti vi obožavate onoga koga je obožavam, tj. samo Allaha jedinog.",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "Vama vaša vjera koju ste sami izmislili, a meni moja vjera koju mi je objavio Allah.",
    "ayah": 6,
    "surah": 109
  }
]
