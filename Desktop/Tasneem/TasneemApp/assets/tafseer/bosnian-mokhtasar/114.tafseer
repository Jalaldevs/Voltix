[
  {
    "text": "O Poslaniče, reci: Tražim zaštitu kod Gospodara ljudi i Njemu se utičem.",
    "ayah": 1,
    "surah": 114
  },
  {
    "text": "Vladaru ljudi koji čini s njima šta hoće i pored kojeg niko nema vlasti.",
    "ayah": 2,
    "surah": 114
  },
  {
    "text": "Onome koji zaslužuje da se istinski obožava, pored kojeg niko drugi to ne zaslužuje.",
    "ayah": 3,
    "surah": 114
  },
  {
    "text": "Od zla šejtana koji čovjeku donosi ružne misli kada zaboravi na Allaha, a kada Ga se sjeti, on se skrije i ne dolazi.",
    "ayah": 4,
    "surah": 114
  },
  {
    "text": "koji unosi zle misli u ljudska sca.",
    "ayah": 5,
    "surah": 114
  },
  {
    "text": "a on nekada bude ljudske, a nekada džinske vrste.",
    "ayah": 6,
    "surah": 114
  }
]
