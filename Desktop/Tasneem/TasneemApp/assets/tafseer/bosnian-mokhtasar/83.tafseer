[
  {
    "text": "Propast i gubitak čekaju one koji zakidaju.",
    "ayah": 1,
    "surah": 83
  },
  {
    "text": "to su oni koji kada žele nešto od drugih da kupe, traže svoje pravo upotpunosti, bez umanjivanja.",
    "ayah": 2,
    "surah": 83
  },
  {
    "text": "a kada drugima nešto prodaju, pa to vagaju, onda pri mjerenju zakidaju. Takvo je bilo stanje medinelija kada je Poslanik, sallallahu alejhi ve sellem, učinio hidžru.",
    "ayah": 3,
    "surah": 83
  },
  {
    "text": "zar ovi koji rade to ružno djelo ne vjeruju da će biti proživljeni pred Allahom?",
    "ayah": 4,
    "surah": 83
  },
  {
    "text": "Na dan obračuna i kazne, a to je veliki dan jer će u njemu biti mnoga iskušenja i strahote.",
    "ayah": 5,
    "surah": 83
  },
  {
    "text": "na Dan kada će ljudi ustati pred Gospodarom svih stvorenja, kako bi pred Njim račun polagali.",
    "ayah": 6,
    "surah": 83
  },
  {
    "text": "Nije tako kako razvratnici misle da neće biti proživljeni. Zapisano je i određeno da će njihovo konačno boravište biti Sidždžin, a to je tjeskoba i najniži stepen u koji će dospjeti.",
    "ayah": 7,
    "surah": 83
  },
  {
    "text": "A da li ti, o Poslaniče, znaš šta je Sidždžin?",
    "ayah": 8,
    "surah": 83
  },
  {
    "text": "Njihova knjiga je ispisana i neće nestati, na nju se ništa neće dodati, niti od nje oduzeti.",
    "ayah": 9,
    "surah": 83
  },
  {
    "text": "Propast i gubitak toga dana čeka one koji su poricali.",
    "ayah": 10,
    "surah": 83
  },
  {
    "text": "koji su poricali i negirali Dan kada će Allah suditi Svojim robovima za njihova djela na dunjaluku.",
    "ayah": 11,
    "surah": 83
  },
  {
    "text": "Ovaj dan ne negira osim onaj ko prelazi granicu koju je Allah postavio i ko mnogo griješi.",
    "ayah": 12,
    "surah": 83
  },
  {
    "text": "kada se takvoj osobi ajeti objavljeni Našem Poslaniku, čitaju, ona govori: To su samo kazivanja prijašnjih naroda, i takvo nešto nije od Allaha.",
    "ayah": 13,
    "surah": 83
  },
  {
    "text": "Nije tako kao što tvrde poricatelji, nego su njihove razume i srca prekrili grijesi, pa svojim srcima ne vide istinu.",
    "ayah": 14,
    "surah": 83
  },
  {
    "text": "Uistinu oni će biti spriječeni da na Sudnjem danu vide svoga Gospodara.",
    "ayah": 15,
    "surah": 83
  },
  {
    "text": "zatim će oni sasvim sigurno u Vatru ući, i njenu vrelinu osjetiti.",
    "ayah": 16,
    "surah": 83
  },
  {
    "text": "Zatim će im se na Sudnjem danu, kao vid ukora, kazati: Ova kazna koja vas čeka je ono što ste na dunjaluku poricali, kada vam je o tome vaš Poslanik govorio.",
    "ayah": 17,
    "surah": 83
  },
  {
    "text": "Nije tako kako misle da neće biti proživljeni i račun polagati. Zapisano je da će pokorni biti u visokim položajima.",
    "ayah": 18,
    "surah": 83
  },
  {
    "text": "A da li ti, o Poslaniče, znaš šta je Ilijjun?",
    "ayah": 19,
    "surah": 83
  },
  {
    "text": "Njihova knjiga je ispisana i neće nestati, na nju se ništa neće dodati, niti od nje oduzeti.",
    "ayah": 20,
    "surah": 83
  },
  {
    "text": "Kod te Knjige prisutni su bliski meleki na svakom nebu.",
    "ayah": 21,
    "surah": 83
  },
  {
    "text": "Oni koji mnogo budu činili dobra djela i pokorni budu, biće u vječnoj blagodati na onome svijetu.",
    "ayah": 22,
    "surah": 83
  },
  {
    "text": "Na ukrašenim sjedaljkama gledat će u svoga Gospodara i u sve ono što im donosi sreću i radost.",
    "ayah": 23,
    "surah": 83
  },
  {
    "text": "Kada ih pogledaš, na njihovih licima vidjećeš tragove tog uživanja u vidu ljepote i ozarenosti.",
    "ayah": 24,
    "surah": 83
  },
  {
    "text": "njihova posluga usluživat će ih vinom čije posude će biti zapečaćene.",
    "ayah": 25,
    "surah": 83
  },
  {
    "text": "miris miska širit će se do njegovog kraja i za ovu nagradu obavezno se trebaju natjecati svi oni koji žele da do nje dođu, kroz činjenje djela kojima je Allah zadovoljan i kroz ostavljanje onoga što dovodi do Njegove srdžbe.",
    "ayah": 26,
    "surah": 83
  },
  {
    "text": "Ovo zapečanjeno piće pomiješano će biti sa izvorom Tesnim.",
    "ayah": 27,
    "surah": 83
  },
  {
    "text": "Sa ovog izvora njegovo piće koje je čisto pit će bliski Allahovi robovi, a ostali vjernici pit će ga pomiješanog sa drugim.",
    "ayah": 28,
    "surah": 83
  },
  {
    "text": "Zaista su razvratnici koji su bili u nevjerovanju ismijavali one koji vjeruju, izrugujući im se na taj način.",
    "ayah": 29,
    "surah": 83
  },
  {
    "text": "i kada su pored vjerniika prolazili, jedni drugima su namigivali, ismijavajući im se na taj način.",
    "ayah": 30,
    "surah": 83
  },
  {
    "text": "A kad su se porodicama svojim vraćali, vraćali su se radosni zbog nevjerovanja u kojem se nalaze i šale zbijajući i ismijavajući se s vjernicima.",
    "ayah": 31,
    "surah": 83
  },
  {
    "text": "A kad bi vidjeli muslimane, rekli bi: “Ovi su, doista, zalutali s Pravog putam jer su napustili vjeru naših predaka.”",
    "ayah": 32,
    "surah": 83
  },
  {
    "text": "a oni nisu poslani od Allaha i određeni da čuvaju njihova djela, pa da govore ove riječi.",
    "ayah": 33,
    "surah": 83
  },
  {
    "text": "Na Sudnjem danu oni koji su vjerovali, nevjernicima će se podsmijavati, kao što su se nevjernici ismijavali s vjernicima na dunjaluku.",
    "ayah": 34,
    "surah": 83
  },
  {
    "text": "sa divana ukrašenih gledat će u vječne blagodati koje im je Allah pripremio.",
    "ayah": 35,
    "surah": 83
  },
  {
    "text": "Nevjernici će sigurno biti u ponižavajućoj patnju zbog svojih djela na dunjaluku.",
    "ayah": 36,
    "surah": 83
  }
]
