[
  {
    "text": "Kada nebo popuca i otvori se kako bi meleki sišli.",
    "ayah": 1,
    "surah": 84
  },
  {
    "text": "i kada posluša svoga Gospodara, pokoravajući mu se, a ono je to obavezno učiniti.",
    "ayah": 2,
    "surah": 84
  },
  {
    "text": "i kada Zemlju Allah rastegne kao što se rastegne koža.",
    "ayah": 3,
    "surah": 84
  },
  {
    "text": "i izbaci riznice i mrtvace koji su u njoj, i potpuno se isprazni, tako da niko od njih u njoj ne ostane.",
    "ayah": 4,
    "surah": 84
  },
  {
    "text": "i kada posluša svoga Gospodara, pokoravajući mu se, a ona je to obavezna učiniti.",
    "ayah": 5,
    "surah": 84
  },
  {
    "text": "O čovječe, ti radiš ili dobro ili zlo, i to ćeš naći na Sudnjem danu, kako bi te Allah prema tome nagradio ili kaznio.",
    "ayah": 6,
    "surah": 84
  },
  {
    "text": "Onome kome listovi na kojima su zapisana njegova djela budu dati u desnu ruku",
    "ayah": 7,
    "surah": 84
  },
  {
    "text": "lahak će račun kod Allaha polagati, biće mu pokazana njegova djela, ali neće za njih biti sankcionisan.",
    "ayah": 8,
    "surah": 84
  },
  {
    "text": "i svojoj porodici vratit će se sretan.",
    "ayah": 9,
    "surah": 84
  },
  {
    "text": "a onaj kome bude knjiga njegova data u lijevu ruku, iza njegovih leđa.",
    "ayah": 10,
    "surah": 84
  },
  {
    "text": "sam će svoju propast prizivati.",
    "ayah": 11,
    "surah": 84
  },
  {
    "text": "ući će u džehennemsku vatru i u njenoj vrelini gorjeti.",
    "ayah": 12,
    "surah": 84
  },
  {
    "text": "on je na dunjaluku među svojom porodicom bio radostan zbog nevjerovanja i grijeha koje je činio.",
    "ayah": 13,
    "surah": 84
  },
  {
    "text": "on je mislio da neće biti proživljen nakon što umre.",
    "ayah": 14,
    "surah": 84
  },
  {
    "text": "a hoće, vratit će ga Allah u život kao što ga je prvi put stvorio, jer njegov Gospodar dobro vidi njegovo stanje, ništa Mu nije skriveno i On će ga za njegova djela kazniti.",
    "ayah": 15,
    "surah": 84
  },
  {
    "text": "Allah se kune rumenilom koje se pojavi na horizontu, nakon zalaska Sunca.",
    "ayah": 16,
    "surah": 84
  },
  {
    "text": "i kune se noću i onim što se u njoj sakuplja.",
    "ayah": 17,
    "surah": 84
  },
  {
    "text": "i Mjesecom kada bude potpun i postane uštap.",
    "ayah": 18,
    "surah": 84
  },
  {
    "text": "vi ćete, sigurno, o ljudi, iz stanja u stanje prelaziti, tj. iz sjemena, zatim ugruška, zatim grude mesa, zatim ćete imati život, nakon njega smrt, a onda ćete ponovo biti oživljeni.",
    "ayah": 19,
    "surah": 84
  },
  {
    "text": "šta je ovim nevjernicima, pa ne vjeruju u Allaha i Sudnji dan?",
    "ayah": 20,
    "surah": 84
  },
  {
    "text": "i kada se njima Kur'an uči, oni ne čine sedždu svome Gospodaru?",
    "ayah": 21,
    "surah": 84
  },
  {
    "text": "nevjernici negiraju ono što im njihov poslanik donosi.",
    "ayah": 22,
    "surah": 84
  },
  {
    "text": "Allah najbolje zna šta njihova prsa skrivaju, jer Njemu nijedno njihovo djelo nije nepoznato.",
    "ayah": 23,
    "surah": 84
  },
  {
    "text": "O Poslaniče, kaži im da ih čeka žestoka kazna.",
    "ayah": 24,
    "surah": 84
  },
  {
    "text": "A oni koji budu vjerovali u Allaha i dobra djela činili, imat će nagradu neprekidnu, a to je Džennet.",
    "ayah": 25,
    "surah": 84
  }
]
