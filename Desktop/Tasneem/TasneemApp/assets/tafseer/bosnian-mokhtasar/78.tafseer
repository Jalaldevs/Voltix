[
  {
    "text": "O čemu se raspituju ovi mnogobošci nakon što im je Allah poslao Svoga Poslanika, sallallahu alejhi ve sellem.",
    "ayah": 1,
    "surah": 78
  },
  {
    "text": "Jedni druge su pitali o velikoj vijesti, a to je Kur'an objavljen njihovom poslaniku, u kojem se nalazi i vijest o proživljenju nakon smrti.",
    "ayah": 2,
    "surah": 78
  },
  {
    "text": "O ovom Kur'anu oni različita mišljenja imaju, pa ga opisuju raznim svojstvima. Neki govore da je sihr, neki kažu da je poezija, drugi da je vradžbina, treći da se radi o kazivanju i izmišljotinama naroda drevnih.",
    "ayah": 3,
    "surah": 78
  },
  {
    "text": "Nije tako kao što oni tvrde. Oni koji poriču istinitost Kur'ana saznat će kakva ih loš konačnica čeka zbog njihovog poricanja.",
    "ayah": 4,
    "surah": 78
  },
  {
    "text": "Zatim, to će im biti potvrđeno.",
    "ayah": 5,
    "surah": 78
  },
  {
    "text": "Zar Zemlju nismo pogodnom za boravak njihov, učinili?",
    "ayah": 6,
    "surah": 78
  },
  {
    "text": "i brda smo po njoj postavili, kao stupove koji spriječavaju da se ona pomjera i trese.",
    "ayah": 7,
    "surah": 78
  },
  {
    "text": "I Mi vas, o ljudi, stvorili u parovima, ima vas muških, a ima vas i ženskih.",
    "ayah": 8,
    "surah": 78
  },
  {
    "text": "Vaš san smo vam dali kako biste prekinulu vaše aktivnosti i odmorili se.",
    "ayah": 9,
    "surah": 78
  },
  {
    "text": "Noć smo učinili da vam svojom tamom bude prekrivač, kao što vam je odjeća prekrivač za vaša stidna mjesta.",
    "ayah": 10,
    "surah": 78
  },
  {
    "text": "Dan smo učinili period kada privređujete i opskrbu tražite.",
    "ayah": 11,
    "surah": 78
  },
  {
    "text": "Iznad vas smo sagradili sedam snažnih nebesa, precizno stvorenih.",
    "ayah": 12,
    "surah": 78
  },
  {
    "text": "Sunce smo učinili svjetiljkom koja jako plamti i svijetli.",
    "ayah": 13,
    "surah": 78
  },
  {
    "text": "Kada bude vrijeme da oblaci spuste kišu, Mi dajemo da iz njih velike količine vode spuste se.",
    "ayah": 14,
    "surah": 78
  },
  {
    "text": "da tom kišom dadnemo nicanje raznih vrsta žitarica i bilja.",
    "ayah": 15,
    "surah": 78
  },
  {
    "text": "I dajemo da niču guste bašče i vrtovi u kojima se isprepliće granje drveća.",
    "ayah": 16,
    "surah": 78
  },
  {
    "text": "Dan presude među stvorenjima je preciziran i ne mijenja se.",
    "ayah": 17,
    "surah": 78
  },
  {
    "text": "Dan kada će melek po drugi put puhnuti u rog, pa ćete, o ljudi, u skupinama dolaziti.",
    "ayah": 18,
    "surah": 78
  },
  {
    "text": "Nebo će se otvoriti, pa će imati otvore, poput otvorenih vrata.",
    "ayah": 19,
    "surah": 78
  },
  {
    "text": "i brda će se pokrenuti tako da postanu poput raspršene prašine, i pojaviće se priviđanje.",
    "ayah": 20,
    "surah": 78
  },
  {
    "text": "Džehennem je pripremljen, čeka i vreba u zasjedi.",
    "ayah": 21,
    "surah": 78
  },
  {
    "text": "on će za nepravedne biti mjesto povratka.",
    "ayah": 22,
    "surah": 78
  },
  {
    "text": "u njemu će ostati beskonačno.",
    "ayah": 23,
    "surah": 78
  },
  {
    "text": "U njemu neće imati hladnog i ugodnog zraka koji će ublažiti vrelinu u kojoj se nalaze, niti će imati piće koje će im biti ugodno.",
    "ayah": 24,
    "surah": 78
  },
  {
    "text": "oni neće kušati osim žestoko vrele vode i znoja koji će kapati sa džehennemlija.",
    "ayah": 25,
    "surah": 78
  },
  {
    "text": "to će im biti kazna prikladna nevjerovanju i zabludi koju su zastupali.",
    "ayah": 26,
    "surah": 78
  },
  {
    "text": "Oni se na dunjaluku nisu bojali polaganja računa pred Allahom na Sudnjem danu, jer nisu vjerovali u proživljenje. Da su vjerovali u proživljenje, povjerovali bi i u Allaha i činili bi dobra djela.",
    "ayah": 27,
    "surah": 78
  },
  {
    "text": "I jasno su poricali ajete koje smo spuštali našem Poslaniku.",
    "ayah": 28,
    "surah": 78
  },
  {
    "text": "Svako njihovo djelo smo zabilježili i pobrojali, i ono je zapisano u listovima njihovih djela.",
    "ayah": 29,
    "surah": 78
  },
  {
    "text": "O vi koji ste bili obijesni i nepravedni, iskusite ovu stalnu patnju, a Mi vam nećemo povećati osim još veću kaznu.",
    "ayah": 30,
    "surah": 78
  },
  {
    "text": "Oni koji se boje svoga Gospodara, provodeći Njegove naredbe i ostavljajući zabrane, doživjet će uspjeh i mjesto koje su željeli, a to je Džennet.",
    "ayah": 31,
    "surah": 78
  },
  {
    "text": "vrtove i vinove loze.",
    "ayah": 32,
    "surah": 78
  },
  {
    "text": "i djevojke koje će biti njihovih godina.",
    "ayah": 33,
    "surah": 78
  },
  {
    "text": "i pehari puni vina.",
    "ayah": 34,
    "surah": 78
  },
  {
    "text": "U Džennetu neće slušati ništavan govor, laž i jedni drugima neće lagati.",
    "ayah": 35,
    "surah": 78
  },
  {
    "text": "Sve ovo što im je Allah dao biće im dovoljno.",
    "ayah": 36,
    "surah": 78
  },
  {
    "text": "Gospodara nebesa i Zemlje i Gospodara onoga što je između njih, Milostivog na ovome i na onome svijetu. Niko ni na Zemlji ni na nebesima od Njega neće moći ništa da traži, sve dok On to ne dozvoli.",
    "ayah": 37,
    "surah": 78
  },
  {
    "text": "Na Dan kada će Džibril i meleki u redove poredani biti, neće se ni za koga zauzimati, osim onaj kome On zauzimanje dozvoli, a samo će istinu, poput riječi tevhida, govoriti.",
    "ayah": 38,
    "surah": 78
  },
  {
    "text": "Ovo što vam je opisano je dan u koji nema sumnje, pa onaj ko želi spas toga dana, od Allahove kazne, neka ide putem činjenja dobrih djela kojima je njegov Gospodar zadovoljan.",
    "ayah": 39,
    "surah": 78
  },
  {
    "text": "Mi vas, o ljudi, opominjemo na blisku kaznu, na Dan kada će čovjek gledati u ono što je na dunjaluku radio, a nevjernik će, želeći da se kazne spasi, kazati: Kamo sreće da sam postao prašina poput životinja kojima će se na Sudnjem danu kazati: Budite prašina.",
    "ayah": 40,
    "surah": 78
  }
]
