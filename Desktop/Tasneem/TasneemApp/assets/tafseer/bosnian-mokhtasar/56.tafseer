[
  {
    "text": "Kada se desi Smak svijeta, a to je neizbježno.",
    "ayah": 1,
    "surah": 56
  },
  {
    "text": "Niko neće negirati Sudnji dan, kao što je bio negiran na dunjaluku.",
    "ayah": 2,
    "surah": 56
  },
  {
    "text": "Ponizit će nevjernike i griješnike, tako što će tada biti uvedeni u Vatru, a bogobojazne vjernike uzvisit će, jer će oni u Džennet ući.",
    "ayah": 3,
    "surah": 56
  },
  {
    "text": "Kada se Zemlja snažno i jako pokrene.",
    "ayah": 4,
    "surah": 56
  },
  {
    "text": "I kada se planine u komadiće raspadnu.",
    "ayah": 5,
    "surah": 56
  },
  {
    "text": "Pa zbog toga raspadanja postanu poput prašine koja ne miruje.",
    "ayah": 6,
    "surah": 56
  },
  {
    "text": "Toga Dana vi ćete biti u tri kategorije",
    "ayah": 7,
    "surah": 56
  },
  {
    "text": "Oni zdesna uzet će knjigu svoju u desnu ruku, a kako li je uzvišen njihov stepen i položaj.",
    "ayah": 8,
    "surah": 56
  },
  {
    "text": "Oni slijeva uzet će knjigu svoju u lijevu ruku, a kako li je ružno njihovo mjesto i položaj.",
    "ayah": 9,
    "surah": 56
  },
  {
    "text": "Oni koji su prednjačili čineći dobra djela na dunjaluku, oni će i na onome svijetu prednjačiti prilikom ulaska u Džennet.",
    "ayah": 10,
    "surah": 56
  },
  {
    "text": "Oni će biti bliski kod Allaha.",
    "ayah": 11,
    "surah": 56
  },
  {
    "text": "biće u džennetskim blagodatima gdje će uživati u raznovrsnim nasladama.",
    "ayah": 12,
    "surah": 56
  },
  {
    "text": "skupina iz ove i prijašnjih zajednica.",
    "ayah": 13,
    "surah": 56
  },
  {
    "text": "A među ljudima, pred kraj svijeta biće malo onih koji će prednjačiti i biti bliski.",
    "ayah": 14,
    "surah": 56
  },
  {
    "text": "Na krevetima izvezenim zlatnim vezovima.",
    "ayah": 15,
    "surah": 56
  },
  {
    "text": "Biće naslonjeni na ovim divanima, okrenuti licima jedni prema drugima, i neće jedni drugima leđima biti okrenuti.",
    "ayah": 16,
    "surah": 56
  },
  {
    "text": "Oko njih kružit će kao posluga, vječni mladići koji nikada neće ostariti.",
    "ayah": 17,
    "surah": 56
  },
  {
    "text": "sa čašama bez poklopaca i ibricima s poklopcima, i peharom punog vina iz izvora tekućeg, koji ne prestaje.",
    "ayah": 18,
    "surah": 56
  },
  {
    "text": "Nije kao dunjalučko vino, jer od njega ni glava ne boli, niti se gubi svijest.",
    "ayah": 19,
    "surah": 56
  },
  {
    "text": "I oko njih će kružiti vječni mladići, noseći voće koje će oni da biraju.",
    "ayah": 20,
    "surah": 56
  },
  {
    "text": "I kružit će oko njih, noseći im ptičije meso koje god budu htjeli.",
    "ayah": 21,
    "surah": 56
  },
  {
    "text": "Oni će u Džennetu imati žene, krupnih i lijepih očiju.",
    "ayah": 22,
    "surah": 56
  },
  {
    "text": "One su slične kao biseri skriveni i čuvani u školjkama.",
    "ayah": 23,
    "surah": 56
  },
  {
    "text": "to će im biti nagrada za dobra djela koja će činiti na dunjaluku.",
    "ayah": 24,
    "surah": 56
  },
  {
    "text": "U Džennetu neće biti razvratnog govora, niti onoga što čovjeka vodi u grijeh.",
    "ayah": 25,
    "surah": 56
  },
  {
    "text": "Neće čuti osim selam koji će im meleki nazivati, i koji će jedni drugima nazivati.",
    "ayah": 26,
    "surah": 56
  },
  {
    "text": "A oni s desne strane, oni kojima će knjiga djela biti data u desnu ruku, kako li je samo velik njihov položaj kod Allaha.",
    "ayah": 27,
    "surah": 56
  },
  {
    "text": "Bit će među lotosovim drvećem bez bodlji i trnja, i u njemu neće imati nikakve štete.",
    "ayah": 28,
    "surah": 56
  },
  {
    "text": "Biće među plodovima banane koji će biti poredani jedni pored drugih.",
    "ayah": 29,
    "surah": 56
  },
  {
    "text": "Biće u stalnoj hladovini koja neće nestati.",
    "ayah": 30,
    "surah": 56
  },
  {
    "text": "i vode koja teče bez prestanka.",
    "ayah": 31,
    "surah": 56
  },
  {
    "text": "i među bezbrojnim voćem kojeg će biti u izobilju,",
    "ayah": 32,
    "surah": 56
  },
  {
    "text": "Nikada ga neće nestati, jer ono neće imati svoje sezone kada raste, i u bilo koje doba moći će ga ubrati, niko ih u tome neće moći spriječiti.",
    "ayah": 33,
    "surah": 56
  },
  {
    "text": "i na posteljama uzdignutim koje će biti stavljene na krevete.",
    "ayah": 34,
    "surah": 56
  },
  {
    "text": "Mi ćemo novim stvaranjem njih ponovo stvoriti.",
    "ayah": 35,
    "surah": 56
  },
  {
    "text": "Mi ćemo ih stvoriti kao djevice, koje niko prije nije dotakao.",
    "ayah": 36,
    "surah": 56
  },
  {
    "text": "Učinit ćemo ih ženama koje se umiljavaju svojim muževima, i one će biti godina istih kao i oni.",
    "ayah": 37,
    "surah": 56
  },
  {
    "text": "Mi ćemo ih stvoriti za one zdesna, koji će biti s desne strane, a to će biti znak njihove sreće.",
    "ayah": 38,
    "surah": 56
  },
  {
    "text": "Ovo je skupina iz naroda prijašnjih vjerovjesnika.",
    "ayah": 39,
    "surah": 56
  },
  {
    "text": "i skupina iz ummeta Muhammeda, sallallahu alejhi ve sellem, a to je posljednji ummet.",
    "ayah": 40,
    "surah": 56
  },
  {
    "text": "A oni s lijeve strane, kojima će knjiga djela biti data u lijevu ruku, kako li je samo ružno njihovo stanje i prebivalište.",
    "ayah": 41,
    "surah": 56
  },
  {
    "text": "Bit će u žestoko vrelim vjetrovima, i u žestoko vreloj vodi.",
    "ayah": 42,
    "surah": 56
  },
  {
    "text": "Bit će u tami crnog dima.",
    "ayah": 43,
    "surah": 56
  },
  {
    "text": "Tamo neće biti ugodnog vjetra, niti ugodnog pogleda.",
    "ayah": 44,
    "surah": 56
  },
  {
    "text": "Oni su prije ulaska u ovu patnju u dunjalučkim blagodatima uživali i nisu imali druge brige osim da prohtjeve svoje zadovolje.",
    "ayah": 45,
    "surah": 56
  },
  {
    "text": "Ustrajavali su u nevjerovanju u Allaha, i obožavanju kumira.",
    "ayah": 46,
    "surah": 56
  },
  {
    "text": "Oni su poricali proživljenje, i ismijavajući se, smatrajući da je to nemoguće, govorili su: Zar ćemo biti oživljeni nakon što postanemo prašina i kad kosti od nas ostanu.",
    "ayah": 47,
    "surah": 56
  },
  {
    "text": "I zar će čak i nači preci, koji su umrli prije nas, biti oživljeni.",
    "ayah": 48,
    "surah": 56
  },
  {
    "text": "Reci, o Poslaniče, ovima koji negiraju proživljenje: I oni ljudi koji su prije živjeli i umrli, a i oni kasniji, biće oživljeni nakon smrti.",
    "ayah": 49,
    "surah": 56
  },
  {
    "text": "Na Sudnjem danu, bez imalo sumnje, biće okupljeni kako bi račun polagali i dobili ono što su zaslužili.",
    "ayah": 50,
    "surah": 56
  },
  {
    "text": "Zatim ćete vi, o poricatelji proživljenja, koji ste skrenuli s Pravog puta, na Sudnjem danu, plodove drveta Zekkum jesti, a to je najgori i nalošiji plod.",
    "ayah": 51,
    "surah": 56
  },
  {
    "text": "Zatim ćete vi, o poricatelji proživljenja, koji ste skrenuli s Pravog puta, na Sudnjem danu, plodove drveta Zekkum jesti, a to je najgori i nalošiji plod.",
    "ayah": 52,
    "surah": 56
  },
  {
    "text": "I plodovima tog gorkog drveta punit ćete svoje prazne stomakove.",
    "ayah": 53,
    "surah": 56
  },
  {
    "text": "Nakon toga će vrelu vodu piti.",
    "ayah": 54,
    "surah": 56
  },
  {
    "text": "Mnogo će piti vodu kao što to deve čine zbog gorljive žeđi.",
    "ayah": 55,
    "surah": 56
  },
  {
    "text": "Ovom gorkom hranom i vrelom vodom biće ugošćeni na Dan obračuna.",
    "ayah": 56,
    "surah": 56
  },
  {
    "text": "O poricatelji, Mi smo vas stvorili nakon što niste bili ništa, pa zašto onda ne vjerujete da ćemo vas oživjeti nakon vaše smrti?",
    "ayah": 57,
    "surah": 56
  },
  {
    "text": "O ljudi, šta mislite da li sjemenu koje ubacujete u ženske rodnice",
    "ayah": 58,
    "surah": 56
  },
  {
    "text": "Da li vi to sjeme stvarate ili smo ga Mi stvorili?",
    "ayah": 59,
    "surah": 56
  },
  {
    "text": "Mi određujemo vašu smrt, i svako od vas ima rok kada će umrijeti, taj rok se neće ubrzati niti usporiti i Mi nismo nemoćni da to učinimo.",
    "ayah": 60,
    "surah": 56
  },
  {
    "text": "da vam izmijenimo vaše poznate izglede i da vas stvorimo i oblikujemo na način koji vam nije poznat.",
    "ayah": 61,
    "surah": 56
  },
  {
    "text": "Vama je znano kako smo vas stvorili prvi put, pa zar nećete pouku uzeti i i zar ne znate da je Onaj koji vas je stvorio prvi put, u stanju da vas proživi nakon što umrete.",
    "ayah": 62,
    "surah": 56
  },
  {
    "text": "Šta mislite o sjemenu kojeg sijete u Zemlju?",
    "ayah": 63,
    "surah": 56
  },
  {
    "text": "Da li vi činite da to sjeme iznikne ili Mi to činimo?",
    "ayah": 64,
    "surah": 56
  },
  {
    "text": "Kada bismo htjeli, Mi možemo da vaše plodove nakon što sazriju za berbu, učinimo suhim rastinjem, pa biste se vi čudili tome što vas je zadesilo.",
    "ayah": 65,
    "surah": 56
  },
  {
    "text": "Govorili biste: Mi smo izgubili ono što smo uložili.",
    "ayah": 66,
    "surah": 56
  },
  {
    "text": "Nama je opskrba uskraćena i spriječeni smo do nje da dođemo.",
    "ayah": 67,
    "surah": 56
  },
  {
    "text": "Šta mislite o vodi koju pijete kada ožednite?",
    "ayah": 68,
    "surah": 56
  },
  {
    "text": "Da li je vi iz oblaka spuštate ili Mi to činimo?",
    "ayah": 69,
    "surah": 56
  },
  {
    "text": "Kada bismo htjeli, Mi možemo da vodu veoma slanom učinilo, pa da kao takva ne bude pogodna za piće i navodnjavanje. Zašto se onda ne zahvaljujete Allahu, koji vam kao vid svoje milosti prema vama, spušta vodu pogodnu za vaše potrebe.",
    "ayah": 70,
    "surah": 56
  },
  {
    "text": "Šta mislite o vatri koju potpaljujete da biste se njome koristili?",
    "ayah": 71,
    "surah": 56
  },
  {
    "text": "Da li vi stvarate drveće kojim palite vatru ili Mi to, da bismo vam olakšali, činimo?",
    "ayah": 72,
    "surah": 56
  },
  {
    "text": "Mi smo ovu vatru dali da vas podsjeća na ahiretsku vatru, i učinili smo da se njome koriste putnici.",
    "ayah": 73,
    "surah": 56
  },
  {
    "text": "Zato ti, o Poslaniče, negiraj da Allah, tvoj Gospodar, posjeduje bilo šta što mu ne dolikuje.",
    "ayah": 74,
    "surah": 56
  },
  {
    "text": "Allah se kune mjestima i položajima zvijezda.",
    "ayah": 75,
    "surah": 56
  },
  {
    "text": "Zakletva ovim položajima je velika, kada biste vi to znali, jer se u njima nalaze mnoga znamenja i pouke koje su bezbrojne.",
    "ayah": 76,
    "surah": 56
  },
  {
    "text": "O ljudi, Kur'an koji vam se uči je plemenita knjiga, jer sa sobom nosi velike koristi i blagodati.",
    "ayah": 77,
    "surah": 56
  },
  {
    "text": "U Knjizi koja se čuva od ljudskih pogleda, a to je Levhi Mahfuz ili Ploča pomno čuvana.",
    "ayah": 78,
    "surah": 56
  },
  {
    "text": "Koju smiju dirati samo meleki čisti od grijeha i mahana.",
    "ayah": 79,
    "surah": 56
  },
  {
    "text": "Spušten je od Gospodara stvorenja, Njegovom poslaniku, Muhammedu, sallallahu alejhi ve sellem.",
    "ayah": 80,
    "surah": 56
  },
  {
    "text": "Zar ovaj govor, o mušrici, poričete i negirate njegovu istinitost.",
    "ayah": 81,
    "surah": 56
  },
  {
    "text": "I umjesto da se Allahu zahvalite na blagodatima kojima vas obasipa, vi ga negirate, pa kišu pripisujete zvijezdi i govorite: Kiša nam je darovana zbog te i te zvijezde.",
    "ayah": 82,
    "surah": 56
  },
  {
    "text": "A kada duša dođe do guše",
    "ayah": 83,
    "surah": 56
  },
  {
    "text": "I vi tada budete gledali ispred sebe osobu koja umire.",
    "ayah": 84,
    "surah": 56
  },
  {
    "text": "Mi smo Našim znanjem, moći i melekima bliži vašem umirućem od vas samih, ali vi Naše meleke ne vidite.",
    "ayah": 85,
    "surah": 56
  },
  {
    "text": "Zašto je onda, ako je istina da proživljeni nećete biti i račun za djela svoja polagati",
    "ayah": 86,
    "surah": 56
  },
  {
    "text": "ne vratite dušu koja izlazi iz vašeg umrlog, ako istinu govorite? A to ne možete učiniti.",
    "ayah": 87,
    "surah": 56
  },
  {
    "text": "Pa ako taj umrli bude od onih koji su prednjačili u dobrim djelima",
    "ayah": 88,
    "surah": 56
  },
  {
    "text": "onda će u rahatluku biti, nakon čega se neće umarati, imat će lijepu opskrbu, milost i Džennet u kojem će uživati u svemu onome što budu duše njihove željele.",
    "ayah": 89,
    "surah": 56
  },
  {
    "text": "A ako bude od onih koji će s desne strane biti, onda se za njih ne brini, jer njih čeka mir i sigurnost.",
    "ayah": 90,
    "surah": 56
  },
  {
    "text": "A ako bude od onih koji će s desne strane biti, onda se za njih ne brini, jer njih čeka mir i sigurnost.",
    "ayah": 91,
    "surah": 56
  },
  {
    "text": "A ako bude jedan od onih koji su poricali istinu koju je donio Poslanik, sallallahu alejhi ve sellem, i koji su skrenuli s Pravog puta",
    "ayah": 92,
    "surah": 56
  },
  {
    "text": "biće ugošćen vrelom vodom čija će vrelina žestoka biti.",
    "ayah": 93,
    "surah": 56
  },
  {
    "text": "I gorit će u vatrenom plamenu.",
    "ayah": 94,
    "surah": 56
  },
  {
    "text": "Ovo što smo ti kazali, o Poslaniče, sigurno je istina, bez imalo sumnje.",
    "ayah": 95,
    "surah": 56
  },
  {
    "text": "Slavi ime Gospodara tvoga Velikog i negiraj od Njega svaku mahanu.",
    "ayah": 96,
    "surah": 56
  }
]
