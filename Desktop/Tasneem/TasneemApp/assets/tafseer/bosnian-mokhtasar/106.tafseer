[
  {
    "text": "Zbog navike i običaja Kurejšija",
    "ayah": 1,
    "surah": 106
  },
  {
    "text": "navike njihove da sigurni zimi putuju u Jemen, a ljeti u Šam,",
    "ayah": 2,
    "surah": 106
  },
  {
    "text": "Neka obožavaju samo Gospodara ovog svetog hrama koji im je olakšao ovo putovanje i neka mu nikoga kao sudruga ne pripisuju.",
    "ayah": 3,
    "surah": 106
  },
  {
    "text": "Koji ih gladne hrani i od straha brani, tako što je u srcima ljudi (arapa) dao da poštuju harem i njegove stanovnike.",
    "ayah": 4,
    "surah": 106
  }
]
