[
  {
    "text": "Uči, o Poslaniče, ono što ti Allah objavljuje, otpočinjući s imenom tvoga Gospodara koji je Tvorac svih stvorenja.",
    "ayah": 1,
    "surah": 96
  },
  {
    "text": "Stvorio je čovjeka od komada zgrušane krvi nakon što je bio sjeme.",
    "ayah": 2,
    "surah": 96
  },
  {
    "text": "Uči, o Poslaniče, ono što ti Allah objavljuje, a tvoj Gospodar je najplemenitiji, čijoj plemenitosti ništa nije slično, i On je veliki dobročinitelj.",
    "ayah": 3,
    "surah": 96
  },
  {
    "text": "Onaj koji poučava pisanju perom.",
    "ayah": 4,
    "surah": 96
  },
  {
    "text": "Onaj koji je čovjeka naučio svemu što nije znao.",
    "ayah": 5,
    "surah": 96
  },
  {
    "text": "Zaista je čovjek griješnik, poput Ebu Džehla, i prelazi granice koje je Allah postavio.",
    "ayah": 6,
    "surah": 96
  },
  {
    "text": "jer se neovisnim osjeti zbog položaja i imetka kojeg posjeduje.",
    "ayah": 7,
    "surah": 96
  },
  {
    "text": "O čovječe, svome Gospodaru ćeš se vratiti, pa će On svakom dati ono što zaslužuje.",
    "ayah": 8,
    "surah": 96
  },
  {
    "text": "Vidje li ti ikog čudnijeg od Ebu Džehla koji sprečava",
    "ayah": 9,
    "surah": 96
  },
  {
    "text": "roba našeg Muhammeda, sallallahu alejhi ve sellem, da klanja kod Ka'be.",
    "ayah": 10,
    "surah": 96
  },
  {
    "text": "Šta misliš, ako taj ko je spriječen, slijedi uputu od svoga Gospodara?",
    "ayah": 11,
    "surah": 96
  },
  {
    "text": "ili ako ljudima bogobojaznost naređuje, koja se ogleda u slijeđenju Allahovih naredbi i ostavljaju zabrana. Zar takav treba da se spriječi?",
    "ayah": 12,
    "surah": 96
  },
  {
    "text": "Šta misliš, ako ovaj ko spriječava, poriče istinu koju je donio Poslanik, i okreće se od nje? Zar se on ne boji Allaha?",
    "ayah": 13,
    "surah": 96
  },
  {
    "text": "Zar onaj ko brani robu da klanja ne zna da Allah vidi šta čini, da Mu ništa nije skriveno?",
    "ayah": 14,
    "surah": 96
  },
  {
    "text": "Ne valja to kako zamišlja ovaj neznalica, jer situacija nije kako tvrdi. Ako ne prestane da uznemirava Našeg roba i da ga poriče, uzet ćemo ga i snažno dohvatiti za prednji dio glave.",
    "ayah": 15,
    "surah": 96
  },
  {
    "text": "Vlasnik te kike laže i griješne postupke radi.",
    "ayah": 16,
    "surah": 96
  },
  {
    "text": "pa neka on, kada ga uzmemo za kiku, pozove društvo svoje i neka ga spasi od kazne.",
    "ayah": 17,
    "surah": 96
  },
  {
    "text": "Mi ćemo pozvati čuvare Džehennema, snažne meleke koji ne griješe u pogledu Allahovih naredbi i rade ono što im naredi, pa neka razmisli ko je jači i moćniji.",
    "ayah": 18,
    "surah": 96
  },
  {
    "text": "Nije tako kako ovaj nepravednik misli da će ti učiniti zlo, pa mu se ne pokoravaj, nego sedždu Allahu čini i pokornošću Mu se približi, jer ona zaista Njemu približava.",
    "ayah": 19,
    "surah": 96
  }
]
