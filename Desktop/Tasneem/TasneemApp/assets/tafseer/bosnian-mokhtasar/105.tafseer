[
  {
    "text": "Zar nisi čuo, o Poslaniče, šta je s Ebrehom i njegovim drugovima, vlasnicima slona, Gospodar tvoj uradio, kada je on htio Kabu da sruši?",
    "ayah": 1,
    "surah": 105
  },
  {
    "text": "Njihove planove rušenja Kabe Allah je uništio, i oni nisu ostvarili svoj cilj da ljude od nje odvrate, niti su bilo kakav drugi plan ostvarili.",
    "ayah": 2,
    "surah": 105
  },
  {
    "text": "On je na njih poslao ptice u skupinama i jatima.",
    "ayah": 3,
    "surah": 105
  },
  {
    "text": "koje su na njih kamenje od gline pečene i tvrde bacali",
    "ayah": 4,
    "surah": 105
  },
  {
    "text": "pa ih On kao lišće koje su životinje pojele učinio.",
    "ayah": 5,
    "surah": 105
  }
]
