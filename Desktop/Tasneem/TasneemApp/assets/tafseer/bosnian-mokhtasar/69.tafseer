[
  {
    "text": "Allah Uzvišeni spominje vrijeme proživljenja koje će obuhvatiti sve.",
    "ayah": 1,
    "surah": 69
  },
  {
    "text": "Na važnost ovog događanja ukazuje se pitanjem: Šta je to Čas obistinjenja?",
    "ayah": 2,
    "surah": 69
  },
  {
    "text": "Otkud ti znaš šta je to Čas obistinjenja?",
    "ayah": 3,
    "surah": 69
  },
  {
    "text": "Semud, Salihov narod i Ad, Hudov narod, poricali su Sudnji dan, koji će ljude zastrašiti svojim strahotama.",
    "ayah": 4,
    "surah": 69
  },
  {
    "text": "Semuda je Allah uništo povikom koji je bio veoma žestok i strahovit.",
    "ayah": 5,
    "surah": 69
  },
  {
    "text": "Allah Uzvišeni uništio je Ad hladnim, oštrim i strahovitim vjetrom koji je bio silovit i poguban za njih.",
    "ayah": 6,
    "surah": 69
  },
  {
    "text": "Allah Uzvišeni poslao je taj vjetar koji je trajao sedam noći i osam dana i koji ih je potpuno uništio. Mogao si vidjeti narod u njihovim kućama uništen i na Zemlju povaljan, kao da su povaljanje palme, iščupane iz svoga korijenja.",
    "ayah": 7,
    "surah": 69
  },
  {
    "text": "Da li si mogao vidjeti da je nakon kazne iko od njih ostao živ?",
    "ayah": 8,
    "surah": 69
  },
  {
    "text": "Faraon, narodi prije njega i stanovnici naselja koja smo kaznili tako što smo ih prevrnuli, tj. narod Lutov, činili su širk i druge grijehe.",
    "ayah": 9,
    "surah": 69
  },
  {
    "text": "Svi su oni griješili prema poslaniku koji im je dolazio i poricali ga, pa ih je Allah kaznio više nego što je potrebno da budu uništeni.",
    "ayah": 10,
    "surah": 69
  },
  {
    "text": "Kada se voda podigla preko uobičajene granice, mi smo ih u lađi koju je Nuh, alejhi selam, sagradio, ponijeli.",
    "ayah": 11,
    "surah": 69
  },
  {
    "text": "To smo uradili da lađu i kazivanje o njoj učinimo opomenom koja će se koristiti kao dokaz uništenja nevjernika i spasa vjernika i da je sačuva i zapamti uho koje je čuje.",
    "ayah": 12,
    "surah": 69
  },
  {
    "text": "Kada melek koji je zadužen za to, jednom u rog puhne, a to je drugo puhanje.",
    "ayah": 13,
    "surah": 69
  },
  {
    "text": "Kada se Zemlja i brda podignu, pa se zbog jednog jakog udara Zemlja i brda raspadnu u komadiće.",
    "ayah": 14,
    "surah": 69
  },
  {
    "text": "Kada se sve to desi, biće Sudnji dan.",
    "ayah": 15,
    "surah": 69
  },
  {
    "text": "Nebo će se rascijepiti i meleki će tog dana sići. Tog dana ono će biti slabo i labavo, nakon što je bilo jako i čvrsto.",
    "ayah": 16,
    "surah": 69
  },
  {
    "text": "Meleki će biti na krajevima njenim, i taj dan će Arš (Prijesto) tvoga Gospodara nositi osam Allahu bliskih meleka.",
    "ayah": 17,
    "surah": 69
  },
  {
    "text": "O ljudi, tog dana vi ćete biti izloženi pred Gospodarem, Njemu ništa neće biti skriveno, jer On je sa svime upoznat.",
    "ayah": 18,
    "surah": 69
  },
  {
    "text": "Onaj kome knjiga njegovih djela bude data u njegovu desnu ruku, radostan i sretan će kazati: Uzmite i čitajte knjigu mojih djela.",
    "ayah": 19,
    "surah": 69
  },
  {
    "text": "Ja sam na dunjaluku znao i bio uvjeren da ću biti proživljen i da ću se susresti sa onim što sam radio.",
    "ayah": 20,
    "surah": 69
  },
  {
    "text": "Živjeće zadovoljnim životom kada vidi vječne blagodati koje ga čekaju.",
    "ayah": 21,
    "surah": 69
  },
  {
    "text": "u Džennetu koji je mjestom i statusom visok i uzvišen",
    "ayah": 22,
    "surah": 69
  },
  {
    "text": "Plodovi koji se nalaze u Džennetu biće blizu onih koji ih budu uzimali.",
    "ayah": 23,
    "surah": 69
  },
  {
    "text": "Kao vid počasti, kazat će im se: Jedite i pijte ono u čemu neće imati nikakve štete, zbog dobrih djela koja ste činili u proteklim danima na dunjaluku.",
    "ayah": 24,
    "surah": 69
  },
  {
    "text": "Onaj kome bude data knjiga njegovih djela u lijevu ruku, žestoko će se kajati i kazat će: Bolje da mi nije ni data knjiga moja, jer se u njoj nalaze loša djela zbog kojih zaslužujem kaznu.",
    "ayah": 25,
    "surah": 69
  },
  {
    "text": "Bolje da nisam ni znao kakav će biti moj obračun.",
    "ayah": 26,
    "surah": 69
  },
  {
    "text": "Kamo sreće da nakon smrti nisam nikada proživljen bio.",
    "ayah": 27,
    "surah": 69
  },
  {
    "text": "Moj imetak me neće nimalo spasiti od Allahove kazne.",
    "ayah": 28,
    "surah": 69
  },
  {
    "text": "Nestalo mi je dokaza, snage i položaja na kojeg sam se oslanjao i pouzdao.",
    "ayah": 29,
    "surah": 69
  },
  {
    "text": "Reći će se melekima: uzmite ga i skupite mu ruke prema vratu (u okove).",
    "ayah": 30,
    "surah": 69
  },
  {
    "text": "Zatim ga uvedite u Vatru, kako bi osjetio njenu vrelinu.",
    "ayah": 31,
    "surah": 69
  },
  {
    "text": "Zatim ga u lance koji su dugi sedamdeset lakata, vežite.",
    "ayah": 32,
    "surah": 69
  },
  {
    "text": "jer on u Allaha Velikog nije vjerovao",
    "ayah": 33,
    "surah": 69
  },
  {
    "text": "On druge nije podsticao da se hrane siromasi.",
    "ayah": 34,
    "surah": 69
  },
  {
    "text": "On na Sudnjem danu neće imati bliskog prijatelja koji će ga od kazne spasiti.",
    "ayah": 35,
    "surah": 69
  },
  {
    "text": "Oni neće imati druge hrane osim kapljevine sa tijela džehennemlija.",
    "ayah": 36,
    "surah": 69
  },
  {
    "text": "Takvu hranu će jesti samo griješnici.",
    "ayah": 37,
    "surah": 69
  },
  {
    "text": "Allah Uzvišeni kune se onim što vam je vidljivo.",
    "ayah": 38,
    "surah": 69
  },
  {
    "text": "I kunem se oni što vam nije vidljivo.",
    "ayah": 39,
    "surah": 69
  },
  {
    "text": "Kur'an je Allahov govor kojeg ljudima uči Njegov plemeniti Poslanik.",
    "ayah": 40,
    "surah": 69
  },
  {
    "text": "On nije govor pjesnika jer nije izrečen na način pjesništva, a vi veoma malo vjerujete.",
    "ayah": 41,
    "surah": 69
  },
  {
    "text": "Kur'an nije govor proroka, jer proročanstva su nešto suprotno Kur'anu, ali vi veoma malo razmišljate.",
    "ayah": 42,
    "surah": 69
  },
  {
    "text": "On je objava od Gospodara svega stvorenog.",
    "ayah": 43,
    "surah": 69
  },
  {
    "text": "Da je Muhammed na nas izmišljao i prenosio riječi koje nismo kazali",
    "ayah": 44,
    "surah": 69
  },
  {
    "text": "Mi bismo ga kaznili i snažno ga dohvatili.",
    "ayah": 45,
    "surah": 69
  },
  {
    "text": "a onda mu žilu kucavicu koja je spojena sa srcem, presjekli,",
    "ayah": 46,
    "surah": 69
  },
  {
    "text": "Nema niko među vama ko bi nas spriječio da to učinimo, pa je nemoguće da on na nas iznosi laži zbog vas.",
    "ayah": 47,
    "surah": 69
  },
  {
    "text": "Kur'an je opomena za bogobojazne koji se pridržavaju naredbi svoga Gospodara, i udaljavaju se od Njegovih zabrana.",
    "ayah": 48,
    "surah": 69
  },
  {
    "text": "Mi dobro znamo da među vama ima onih koji Kur'an poriču.",
    "ayah": 49,
    "surah": 69
  },
  {
    "text": "Poricanje Kur'ana donosi veliko razočarenje na Sudnjem danu.",
    "ayah": 50,
    "surah": 69
  },
  {
    "text": "Kur'an je istina u koju nema sumnje i sasvim sigurno je on od Allaha.",
    "ayah": 51,
    "surah": 69
  },
  {
    "text": "O Poslaniče, ti od Allaha negiraj sve što Mu ne priliči i spominji ime tvoga Velikog Gospodara.",
    "ayah": 52,
    "surah": 69
  }
]
