[
  {
    "text": "Šta znaš o onome koji negira Sudnji dan, kada će biti obračun ljudima.",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "To je onaj ko na grub način odbija da udovolji potrebi siročeta.",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "Ni sebe, a ni druge ne podstiče na davanje hrane siromasima.",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "Propast i kazna prijeti i klanjačima koji su prema svojim namazima nemarni i odgađaju ih van isteka vremena.",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "Propast i kazna prijeti i klanjačima koji su prema svojim namazima nemarni i odgađaju ih van isteka vremena.",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "koji se u svojim namazima i drugim djelima pred ljudima pretvaraju, tj. nisu iskreni u tome.",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "I ne pomažu drugima u onome što ne donosi štetu ako se njime pomogne.",
    "ayah": 7,
    "surah": 107
  }
]
