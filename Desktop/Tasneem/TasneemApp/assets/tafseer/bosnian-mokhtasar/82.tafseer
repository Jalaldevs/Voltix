[
  {
    "text": "Kada nebo popuca i otvori se kako bi meleki sišli",
    "ayah": 1,
    "surah": 82
  },
  {
    "text": "kada zvijezde počnu na sve strane razbacane, padati.",
    "ayah": 2,
    "surah": 82
  },
  {
    "text": "kada se morske vode preliju jedne u druge i pomiješaju.",
    "ayah": 3,
    "surah": 82
  },
  {
    "text": "i kada se zemlja kaburova ispretura kako bi mrtvi koji su u njima oživljeni bili.",
    "ayah": 4,
    "surah": 82
  },
  {
    "text": "Tada će svako znati šta je uradio, a šta je od djela propustio i izostavio.",
    "ayah": 5,
    "surah": 82
  },
  {
    "text": "O čovječe koji ne vjeruješ u svoga Gospodara, šta je to što te obmanulo pa se suprotstavljaš naredbi Allaha, kada te On ostavlja do roka određenog i ne požuruje da te kazni, kao vid počasti prema tebi?",
    "ayah": 6,
    "surah": 82
  },
  {
    "text": "Onaj koji te je stvorio nakon što nisi bio ništa i koji ti je dao skladne organe i dijelove tijela.",
    "ayah": 7,
    "surah": 82
  },
  {
    "text": "i stvorio te u obliku kakvom je htio. Blagodat je to prema tebi kad te nije stvorio u obliku magarca, majmuna, psa i dr.",
    "ayah": 8,
    "surah": 82
  },
  {
    "text": "Nije tako kao što vi, koji ste obmanuti, mislite, nego vi poričete Dan nagrade i kazne i za njega se ne pripremate.",
    "ayah": 9,
    "surah": 82
  },
  {
    "text": "a nad vama su meleki koji čuvaju vaša djela.",
    "ayah": 10,
    "surah": 82
  },
  {
    "text": "plemeniti kod Allaha, pisari vaših djela.",
    "ayah": 11,
    "surah": 82
  },
  {
    "text": "oni znaju šta vi činite, pa to zapisuju.",
    "ayah": 12,
    "surah": 82
  },
  {
    "text": "Oni koji mnogo budu činili dobra djela i pokorni budu, biće u vječnoj blagodati na onome svijetu.",
    "ayah": 13,
    "surah": 82
  },
  {
    "text": "Oni koji su razvratna djela činili biće u razbuktaloj vatri.",
    "ayah": 14,
    "surah": 82
  },
  {
    "text": "Ući će u vatru na Dan suđenja i gorjet će u njenoj vrelini.",
    "ayah": 15,
    "surah": 82
  },
  {
    "text": "Iz vatre nikada izići neće, nego će u njoj vječno da borave.",
    "ayah": 16,
    "surah": 82
  },
  {
    "text": "A da li ti znaš, o Poslaniče, šta je to Sudnji dan?",
    "ayah": 17,
    "surah": 82
  },
  {
    "text": "I još jednom: Da li ti znaš šta je to Sudnji dan?",
    "ayah": 18,
    "surah": 82
  },
  {
    "text": "Taj Dan niko nikome neće biti od koristi i i sva vlast toga Dana biće samo kod Allaha, On će činiti šta bude htio, i niko pored Njega neće moći ništa da uradi.",
    "ayah": 19,
    "surah": 82
  }
]
