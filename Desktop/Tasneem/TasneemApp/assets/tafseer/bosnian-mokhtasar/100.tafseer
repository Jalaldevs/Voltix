[
  {
    "text": "Allah se kune konjima koji trče pa se čuje njihov glas i disanje zbog brzine trčanja.",
    "ayah": 1,
    "surah": 100
  },
  {
    "text": "I kune se konjima koji trčeći snažno po kamenju prave varnice svojim kopitama.",
    "ayah": 2,
    "surah": 100
  },
  {
    "text": "I kune se konjima koji rano jutrom napadaju neprijatelja.",
    "ayah": 3,
    "surah": 100
  },
  {
    "text": "I svojim trčanjem pokreću i dižu prašinu.",
    "ayah": 4,
    "surah": 100
  },
  {
    "text": "Pa u sredinu gomile nevjernika upadaju sa svojim konjanicima.",
    "ayah": 5,
    "surah": 100
  },
  {
    "text": "Doista čovjek svojom nezahvalnošću spriječava dobro koje od Njega Gospodar želi.",
    "ayah": 6,
    "surah": 100
  },
  {
    "text": "On je svjedok toga što spriječava dobro, i zbog jasnoće toga, on to ne može negirati.",
    "ayah": 7,
    "surah": 100
  },
  {
    "text": "On je, uistinu, u ljubavi prema imetku veoma žestok, škrtareći ga.",
    "ayah": 8,
    "surah": 100
  },
  {
    "text": "A zar ovaj čovjek koji je obmanut dunjalučkim životom ne zna da, kada kaburovi budu prevrnuti i kada Allah iz njih proživi ljude radi obračuna, stanje neće biti onako kako je zamišljao.",
    "ayah": 9,
    "surah": 100
  },
  {
    "text": "i kada budu ispoljene namjere i uvjerenja koja su u srcima.",
    "ayah": 10,
    "surah": 100
  },
  {
    "text": "Toga Dana će Allah o svemu biti obaviješten, jer Njemu ništa nije skriveno i On će ih za njihove postupke obračunuti onako kako su zaslužili.",
    "ayah": 11,
    "surah": 100
  }
]
