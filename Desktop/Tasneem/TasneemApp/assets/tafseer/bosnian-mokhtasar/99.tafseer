[
  {
    "text": "Kada se Zemlja snažno pokrene i uzdrma, tada će se desiti Smak svijeta",
    "ayah": 1,
    "surah": 99
  },
  {
    "text": "I kada zemlja izbaci na površinu ono što je u njenoj utrobi, poput umrlih i dr.",
    "ayah": 2,
    "surah": 99
  },
  {
    "text": "I kada čovjek zbunjen kaže: \"Šta je sa ovom zemljom pa se ovako trese?\"",
    "ayah": 3,
    "surah": 99
  },
  {
    "text": "Toga velikog dana Zemlja će kazivati šta je na njoj od dobra i zla urađeno.",
    "ayah": 4,
    "surah": 99
  },
  {
    "text": "jer će joj to Allah Uzvišeni narediti i objaviti.",
    "ayah": 5,
    "surah": 99
  },
  {
    "text": "Toga velikog dana kada se Zemlja zatrese, ljudi će izići ka mjestu obračuna, razdvojeni, kako bi vidjeli djela koja su na dunjaluku radili.",
    "ayah": 6,
    "surah": 99
  },
  {
    "text": "Onaj ko uradi dobro djelo pa makar bilo koliko mali mrav, vidjeće ga ispred sebe.",
    "ayah": 7,
    "surah": 99
  },
  {
    "text": "A onaj ko uradi koliko i mali trun zla, vidjet će ga.",
    "ayah": 8,
    "surah": 99
  }
]
