[
  {
    "text": "Allah se kune noći kada svojom tamom prekrije sve između nebesa i Zemlje.",
    "ayah": 1,
    "surah": 92
  },
  {
    "text": "I kune se danom kada se pojavi i otkrije.",
    "ayah": 2,
    "surah": 92
  },
  {
    "text": "I kune se Tvorcem dvije vrste, muške i ženske.",
    "ayah": 3,
    "surah": 92
  },
  {
    "text": "Vaši postupci, o ljudi, doista su različiti, pa među njima ima dobrih djela koja su uzrok ulaska u Džennet, i loših djela koja su uzrok ulaska u Vatru.",
    "ayah": 4,
    "surah": 92
  },
  {
    "text": "A onome koji udjeljuje ono što mora udjeljivati, kao što je zekat, izdržavanje porodice i otkupi, i bogobojazan je, čuvajući se onoga što mu Allah zabranjuje -",
    "ayah": 5,
    "surah": 92
  },
  {
    "text": "I vjeruje u ono što mu je Allah obećao.",
    "ayah": 6,
    "surah": 92
  },
  {
    "text": "Olakšaćemo mu dobra djela i udjeljivanje na Allahovom putu.",
    "ayah": 7,
    "surah": 92
  },
  {
    "text": "A onome ko škrtari u svome imetku i ne daje tamo gdje je obavezan davati i smatra se neovisnim o Allahu, te od Njega ne traži nimalo Njegove dobrote",
    "ayah": 8,
    "surah": 92
  },
  {
    "text": "I poriče Allahovo obećanje da će dati nagradu za udjeljivanje na Allahovom putu.",
    "ayah": 9,
    "surah": 92
  },
  {
    "text": "Njemu ćemo olakšati činjenje zla, a otežati dobra djela.",
    "ayah": 10,
    "surah": 92
  },
  {
    "text": "Imetak kojeg je škrtario neće mu koristiti, kada se strovali u Vatru.",
    "ayah": 11,
    "surah": 92
  },
  {
    "text": "Mi smo dužni da pojasnimo šta je to put istine, a šta put zablude.",
    "ayah": 12,
    "surah": 92
  },
  {
    "text": "Nama pripada i onaj i ovaj svijet, i Mi činimo na njima šta hoćemo, a niko to pored nas ne može da čini.",
    "ayah": 13,
    "surah": 92
  },
  {
    "text": "Opominjem vas, o ljudi, na Vatru rasplamsalu, ako budete griješili prema Allahu.",
    "ayah": 14,
    "surah": 92
  },
  {
    "text": "Vrelinu ove vatre neće osjetiti osim nesretnik, a to je nevjernik.",
    "ayah": 15,
    "surah": 92
  },
  {
    "text": "Onaj ko bude negirao istinu koju je donio Poslanik, sallallahu alejhi ve sellem, i okretao se od pokornosti Allahovim naredbama.",
    "ayah": 16,
    "surah": 92
  },
  {
    "text": "Od Vatre će biti udaljen najbogobojazniji među ljudima, Ebu Bekr, radijallahu 'anhu.",
    "ayah": 17,
    "surah": 92
  },
  {
    "text": "Onaj ko daje svoj imetak u razne dobrotvorne svrhe, kako bi se od grijeha očistio.",
    "ayah": 18,
    "surah": 92
  },
  {
    "text": "On ne udjeljuje svoj imetak očekujući da mu se uzvrati.",
    "ayah": 19,
    "surah": 92
  },
  {
    "text": "Svojim davanjem imetka on želi steći Lice Gospodara koji je iznad svojih stvorenja.",
    "ayah": 20,
    "surah": 92
  },
  {
    "text": "I on će biti zadovoljan plemenitom nagradom koju će mu Allah dati.",
    "ayah": 21,
    "surah": 92
  }
]
