[
  {
    "text": "Mi smo tvoja prsa prostranim učinili i omilili ti prihvatanje Objave.",
    "ayah": 1,
    "surah": 94
  },
  {
    "text": "Mi smo ti oprostili tvoje ranije grijehe i uklonili poteškoću koju nosiš iz predislamskih dana u kojima si živio.",
    "ayah": 2,
    "surah": 94
  },
  {
    "text": "koje je pleća tvoja tištilo do te mjere da za malo tvoja leđa nije slomilo.",
    "ayah": 3,
    "surah": 94
  },
  {
    "text": "i uzvisili smo spomen na tebe, pa se tvoje ime spominje u ezanu, ikametu i dr.",
    "ayah": 4,
    "surah": 94
  },
  {
    "text": "Zaista s poteškoćom i teškim stanjem je olakšanje i rahatluk.",
    "ayah": 5,
    "surah": 94
  },
  {
    "text": "Zaista s poteškoćom i teškim stanjem je olakšanje i rahatluk. Ako to znaš, neka te onda ne brinu uznemiravanja tvoga naroda i neka te to ne odvraća od pozivanja Allahu.",
    "ayah": 6,
    "surah": 94
  },
  {
    "text": "Kada završiš sa svojim poslom, onda se posveti ibadetu svome Gospodaru.",
    "ayah": 7,
    "surah": 94
  },
  {
    "text": "i samo se Gospodaru svome obraćaj i svoje želje i težnje ka Njemu usmjeri.",
    "ayah": 8,
    "surah": 94
  }
]
