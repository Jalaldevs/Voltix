[
  {
    "text": "Kada Sunce kao nebesko tijelo bude skupljeno i kada nestane njegove svjetlosti.",
    "ayah": 1,
    "surah": 81
  },
  {
    "text": "kada zvijezde popadaju i njihovog sjaja nestane.",
    "ayah": 2,
    "surah": 81
  },
  {
    "text": "i kada se brda pokrenu iz svog ležišta.",
    "ayah": 3,
    "surah": 81
  },
  {
    "text": "kada steone kamile koje su najvrijedniji imetak budu ostavljenje od svojih vlasnika.",
    "ayah": 4,
    "surah": 81
  },
  {
    "text": "i kada se divlje životinje skupe zajedno s ljudima na jednom prostoru.",
    "ayah": 5,
    "surah": 81
  },
  {
    "text": "i kada se mora zapale, pa vatra postanu.",
    "ayah": 6,
    "surah": 81
  },
  {
    "text": "i kada se duše spare s onima sebi sličnim, tako da će griješnik s griješnikom, a bogobojazni s bogobojaznim biti.",
    "ayah": 7,
    "surah": 81
  },
  {
    "text": "i kada živo zakopanu djevojčicu Allah upita",
    "ayah": 8,
    "surah": 81
  },
  {
    "text": "zbog kojeg prijestupa je ubijena od strane svoga ubice?",
    "ayah": 9,
    "surah": 81
  },
  {
    "text": "I kada listovi u kojima su zapisana djela ljudi budu rašireni, kako bi svako mogao da čita svoju knjigu.",
    "ayah": 10,
    "surah": 81
  },
  {
    "text": "i kada se nebo ukloni kao kad se koža sa ovce zguli.",
    "ayah": 11,
    "surah": 81
  },
  {
    "text": "kada se vatra zapali i razbukti.",
    "ayah": 12,
    "surah": 81
  },
  {
    "text": "I kada se Džennet približi bogobojaznima.",
    "ayah": 13,
    "surah": 81
  },
  {
    "text": "Kada se sve to desi, svaki čovjek će toga dana saznati šta je radio i koja djela činio.",
    "ayah": 14,
    "surah": 81
  },
  {
    "text": "Allah se kune skrivenim zvijezdama prije nego što se pojave noću.",
    "ayah": 15,
    "surah": 81
  },
  {
    "text": "koje se kreću i plove po svemiru i skrivaju se kada jutro nastupa, kao što se antilopa skriva u svoje stanište.",
    "ayah": 16,
    "surah": 81
  },
  {
    "text": "i kune se noći kada nastupi i njenin zadnjim dijelom kada nestaje.",
    "ayah": 17,
    "surah": 81
  },
  {
    "text": "i kune se zorom kada se njena svjetlost pojavi.",
    "ayah": 18,
    "surah": 81
  },
  {
    "text": "Kur'an koji je objavljen Muhammedu, sallallahu alejhi ve sellem, uistinu je Allahov govor kojeg je dostavio povjerljivi melek, a to je Džibril, alejhi selam, kojem je Allah povjerio taj posao.",
    "ayah": 19,
    "surah": 81
  },
  {
    "text": "Vlasnik snage i velikog položaja kod Gospodara Arša.",
    "ayah": 20,
    "surah": 81
  },
  {
    "text": "stanovnici nebesa su mu pokorni, i on je povjerljiv u onome što dostavlja.",
    "ayah": 21,
    "surah": 81
  },
  {
    "text": "Muhammed, sallallahu alejhi ve sellem, koji je s vama, čiji razum, pouzdanost i iskrenost znate, nije lud, kao što to lažno tvrdite.",
    "ayah": 22,
    "surah": 81
  },
  {
    "text": "Vaš drug je vidio Džibrila u njegovom liku u kojem ga je Allah stvorio, na jasnom obzorju.",
    "ayah": 23,
    "surah": 81
  },
  {
    "text": "Vaš drug nije škrt u onome što vam dostavlja, i ne uzima naknadu za taj posao kao što je uzimaju vračari.",
    "ayah": 24,
    "surah": 81
  },
  {
    "text": "Kur'an nije govor šejtana koji je udaljen od milosti Allahove.",
    "ayah": 25,
    "surah": 81
  },
  {
    "text": "pa kuda onda idete i koji način da koristite u negiranju da je on od Allaha, nakon ovih dokaza.",
    "ayah": 26,
    "surah": 81
  },
  {
    "text": "Kur'an je samo opomena i savjet džinima i ljudima.",
    "ayah": 27,
    "surah": 81
  },
  {
    "text": "onome među vama koji želi da ide putem istine.",
    "ayah": 28,
    "surah": 81
  },
  {
    "text": "a vi ne možete ustrajati ili nešto drugo učiniti, ako to Allah, Gospodar svih stvorenja, ne želi.",
    "ayah": 29,
    "surah": 81
  }
]
