[
  {
    "text": "Allah Uzvišeni kune se zorom.",
    "ayah": 1,
    "surah": 89
  },
  {
    "text": "I kune se sa prvih deset noći mjeseca zul-hidžeta.",
    "ayah": 2,
    "surah": 89
  },
  {
    "text": "I kunem se parnim i neparnim od svake stvari.",
    "ayah": 3,
    "surah": 89
  },
  {
    "text": "I kune se noći kada dođe, traje i nestane. A razlog zakletve ovim zakletvama jeste da se potvrdi činjenica polaganja računa za djela.",
    "ayah": 4,
    "surah": 89
  },
  {
    "text": "zar ova zakletva koja je spomenuta nije zakletva koja će razumom obdarenog uvjeriti?",
    "ayah": 5,
    "surah": 89
  },
  {
    "text": "Zar ne znaš, o Poslaniče, šta je Gospodar tvoj sa Adom, Hudovim narodom, uradio, kada su oni negirali Njegova Poslanika?",
    "ayah": 6,
    "surah": 89
  },
  {
    "text": "Irem je pleme Ada koje se pripisuje svome djedu Iremu, koji su bili visoki i veoma imućni.",
    "ayah": 7,
    "surah": 89
  },
  {
    "text": "kojima slična Allah nije stvorio nigdje na zemlji.",
    "ayah": 8,
    "surah": 89
  },
  {
    "text": "Zar nisi čuo šta je tvoj Gospodar uradio i sa Semudom, Salihovim narodom, koji su klesali kamenje u brdima i od njih sebi pravili kuće u Hidžru.",
    "ayah": 9,
    "surah": 89
  },
  {
    "text": "Zar nisi čuo šta je tvoj Gospodar uradio i sa faraonom koji je imao vojsku koja je kažnjavala ljude?",
    "ayah": 10,
    "surah": 89
  },
  {
    "text": "Svi oni su prelazili mjeru u oholosti i neredu, svako u svom mjestu.",
    "ayah": 11,
    "surah": 89
  },
  {
    "text": "i na zemlji su nered činili, šireći nevjerovanje i grijehe.",
    "ayah": 12,
    "surah": 89
  },
  {
    "text": "Pa je Allah dao da ih velika patnja zadesi i sa zemlje ih je uklonio.",
    "ayah": 13,
    "surah": 89
  },
  {
    "text": "Doista tvoj Gospodar, o Poslaniče, prati ljudska djela, kako bi dobročinitelje Džennetom nagradio, a griješnike Vatrom kaznio.",
    "ayah": 14,
    "surah": 89
  },
  {
    "text": "Kada Allah dadne čovjeku blagodati u vidu imetka, djece i položaja, priroda njegova ga podstiče da misli kako je to počast od Allaha njemu, pa govori: Moj Gospodar me je počastio jer sam to zaslužio.",
    "ayah": 15,
    "surah": 89
  },
  {
    "text": "Međutim, kada ga iskuša i opskrbu mu uskrati, on pomisli da ga je njegov Gospodar ponizio, pa govori: Gospodar moj me ponizio.",
    "ayah": 16,
    "surah": 89
  },
  {
    "text": "A nije tako kao što čovjek misli, jer blagodati nisu dokaz Allahovog zadovoljstva robom, niti su iskušenja dokaz da Allah ponižava roba. Nego, istina je da vi ne vodite brigu o jetimu, dajući mu dio onoga čime vas je Allah opskrbio.",
    "ayah": 17,
    "surah": 89
  },
  {
    "text": "Vi jedan drugog ne podstičete da se siromah, koji nema dovoljno hrane, nahrani",
    "ayah": 18,
    "surah": 89
  },
  {
    "text": "I uzimate prava slabih, žena, jetima i pohlepno ga koristite, ne gledajući da li je to dozvoljeno.",
    "ayah": 19,
    "surah": 89
  },
  {
    "text": "Veoma mnogo volite imetak, pa škrtarite i ne dijelite ga, zbog pohlepe, na Allahovom putu.",
    "ayah": 20,
    "surah": 89
  },
  {
    "text": "Ne treba tako da posupate, nego se sjetite dana kada će se zemlja žestoko pokrenuti i uzdrmati.",
    "ayah": 21,
    "surah": 89
  },
  {
    "text": "I kada dođe tvoj Gospodar, o Poslaniče, kako bi presudio među Svojim robovima, i kada dođu meleki poredani u saffove.",
    "ayah": 22,
    "surah": 89
  },
  {
    "text": "Toga dana biće doveden Džehennem sa sedamdeset hiljada uzda, na svakom uzdetu biće samdeset hiljada meleka koji će ga vući. Toga dana čovjek će se sjetiti šta je propustio u pogledu obaveza prema Allahu, a prisjećanje mu tada neće biti od koristi, jer to je dan obračuna, a ne dan činjenja djela.",
    "ayah": 23,
    "surah": 89
  },
  {
    "text": "Žestoko se kajući, kazat će: Kamo sreće da sam radio dobra djela i da sam se pripremao za ovaj stvarni život.",
    "ayah": 24,
    "surah": 89
  },
  {
    "text": "Toga dana, ničija kazna neće biti kao Allahova, jer je Njegova kazna veća i vječna je.",
    "ayah": 25,
    "surah": 89
  },
  {
    "text": "I nevjernike niko u okove neće vezati, kao što će to On učiniti.",
    "ayah": 26,
    "surah": 89
  },
  {
    "text": "Čovjeku vjerniku, kada bude umirao, a i na onome svijetu, biće rečeno; O ti dušo koja si bila mirna u svome vjerovanju i koja si dobra djela činila.",
    "ayah": 27,
    "surah": 89
  },
  {
    "text": "Vrati se svome Gospodaru zadovoljna onim što te kao nagrada od Njega čeka, a i On je tome zadovoljan jer si činila dobra djela.",
    "ayah": 28,
    "surah": 89
  },
  {
    "text": "Uđi i budi među Mojim dobrim robovima.",
    "ayah": 29,
    "surah": 89
  },
  {
    "text": "I s njima se nastani u Džennetu koji sam vam pripremio.",
    "ayah": 30,
    "surah": 89
  }
]
