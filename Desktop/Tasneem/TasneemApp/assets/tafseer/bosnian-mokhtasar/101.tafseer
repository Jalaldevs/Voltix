[
  {
    "text": "Čas kada će srca biti potrošena zbog velikih strahota.",
    "ayah": 1,
    "surah": 101
  },
  {
    "text": "Šta je Čas kada će srca biti potresena zbog velikih strahota?",
    "ayah": 2,
    "surah": 101
  },
  {
    "text": "I šta ti znaš, o Poslaniče, šta je je taj čas kada će srca biti potresena zbog velikih strahota? To je Smak svijeta.",
    "ayah": 3,
    "surah": 101
  },
  {
    "text": "Toga dana kada srca ljudska zbog strahote budu potresena, ljudi će biti poput leptirova, na sve strane raštrkani.",
    "ayah": 4,
    "surah": 101
  },
  {
    "text": "Brda će biti poput vune raščupane lahka i pomjerat će se veoma jednostavno.",
    "ayah": 5,
    "surah": 101
  },
  {
    "text": "Onaj čija dobra djela prevagnu u odnosu na loša djela",
    "ayah": 6,
    "surah": 101
  },
  {
    "text": "On će živjeti ugodno u Džennetu.",
    "ayah": 7,
    "surah": 101
  },
  {
    "text": "Onaj čija loša djela prevagnu u odnosu na dobra djela.",
    "ayah": 8,
    "surah": 101
  },
  {
    "text": "Njegovo prebivalište na Sudnjem danu biće Džehennem.",
    "ayah": 9,
    "surah": 101
  },
  {
    "text": "A znaš li, o Poslaniče, šta je to?",
    "ayah": 10,
    "surah": 101
  },
  {
    "text": "To je vatra čija je vrelina veoma žestoka.",
    "ayah": 11,
    "surah": 101
  }
]
