[
  {
    "text": "Allah se kune vjetrovima koji jedan za drugim dolaze.",
    "ayah": 1,
    "surah": 77
  },
  {
    "text": "I kune se vjetrovima koji su jaki i žestoki.",
    "ayah": 2,
    "surah": 77
  },
  {
    "text": "I kune se vjetrovima koji kišu nose i rasprostiru je na sve strane.",
    "ayah": 3,
    "surah": 77
  },
  {
    "text": "I kune se melekima koji dolaze da razdvoje istinu od neistine.",
    "ayah": 4,
    "surah": 77
  },
  {
    "text": "I kune se melekima koji Objavu donose.",
    "ayah": 5,
    "surah": 77
  },
  {
    "text": "Koji od Allaha donose Objavu kao opravdanje ljudima i kao opomenu na Allahovu kaznu.",
    "ayah": 6,
    "surah": 77
  },
  {
    "text": "Proživljenje ljudi, obračun i kazna sigurno će se desiti, jer je tako obećano, i u to nema sumnje.",
    "ayah": 7,
    "surah": 77
  },
  {
    "text": "Kada svjetlost zvijezda nestane i ugasi se",
    "ayah": 8,
    "surah": 77
  },
  {
    "text": "Kada nebo popuca i otvori se kako bi meleki sišli",
    "ayah": 9,
    "surah": 77
  },
  {
    "text": "Kada se brda pomjere sa svoga mjesta i zdrobe se, pa budu poput prašine.",
    "ayah": 10,
    "surah": 77
  },
  {
    "text": "i kada se poslanici sakupe kada to bude određeno",
    "ayah": 11,
    "surah": 77
  },
  {
    "text": "To je odgođeno za Veliki dan kada će svjedočiti protiv svojih naroda",
    "ayah": 12,
    "surah": 77
  },
  {
    "text": "Do dana kada će se robovi odvojiti, razvrstat će se istina od neistine i sretni od nesretnih.",
    "ayah": 13,
    "surah": 77
  },
  {
    "text": "O Allahov poslaniče, znaš li ti koji je to dan kada će se desiti razvrstavanje?",
    "ayah": 14,
    "surah": 77
  },
  {
    "text": "Toga dana će gubitnici biti oni koji su poricali istinu koju su poslanici od Allaha donosili",
    "ayah": 15,
    "surah": 77
  },
  {
    "text": "Zar nismo uništili prijašnje narode koji su bili nevjernici u Allaha i koji su poricali poslanike.",
    "ayah": 16,
    "surah": 77
  },
  {
    "text": "Zatim smo to učinili i sa poricateljima koji su došli nakon njih, pa smo i njih uništili.",
    "ayah": 17,
    "surah": 77
  },
  {
    "text": "Kao što smo kaznili i uništili griješnike i poricatelje prijašnjih naroda, tako ćemo kazniti i poricatelje istine koju je donio Muhammed, sallallahu alejhi ve sellem.",
    "ayah": 18,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su poricali Allahovu prijetnju prijestupnicima.",
    "ayah": 19,
    "surah": 77
  },
  {
    "text": "Zar vas, o ljudi, nismo stvorili od male i bezvrijedne tekućine, tj. od sperme.",
    "ayah": 20,
    "surah": 77
  },
  {
    "text": "Tu beznačajnu tekućinu stavljamo u zaštićeno mjestio, tj. rodnicu.",
    "ayah": 21,
    "surah": 77
  },
  {
    "text": "I ona tu biva do određenog roka, tj. tokom trudnoće.",
    "ayah": 22,
    "surah": 77
  },
  {
    "text": "Mi smo odredili svojstva novorođenčeta, njegovu veličinu, boju i druge osobine, a divno li to Mi činimo.",
    "ayah": 23,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali Allahovu moć.",
    "ayah": 24,
    "surah": 77
  },
  {
    "text": "Zar mi nismo dali da se na Zemlji sakupe svi ljudi?",
    "ayah": 25,
    "surah": 77
  },
  {
    "text": "Da se živi na njoj sakupe, stanujući tu i gradeći je, a da se mrtvi kroz ukopavanje sakupe u njoj.",
    "ayah": 26,
    "surah": 77
  },
  {
    "text": "I na njoj smo postavili čvrsta brda koja se ne pomjeraju i koja su veoma visoka, i mi smo vas, o ljudi, napojili slatkim vodama. Onaj koji vas je stvorio, nije nesposoban da vas oživi.",
    "ayah": 27,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali Allahove blagodati kojim ih je obasipao.",
    "ayah": 28,
    "surah": 77
  },
  {
    "text": "Onima koji su poricali istinu koju su poslanici donosili, kazat će se: O vi koji ste poricali, idite prema kazni koju ste negirali.",
    "ayah": 29,
    "surah": 77
  },
  {
    "text": "idite prema dimu vatrenom koji će biti rasparčan u tri dijela.",
    "ayah": 30,
    "surah": 77
  },
  {
    "text": "On neće praviti hladovinu, niti će praviti štit od Vatre pa da vas od nje zaštiti.",
    "ayah": 31,
    "surah": 77
  },
  {
    "text": "Vatra će bacati plamen i iskre koje će biti veličine dvorca.",
    "ayah": 32,
    "surah": 77
  },
  {
    "text": "Ove iskre koje će se bacati po svojoj veličini i boji biće kao crne kamile.",
    "ayah": 33,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali Allahovu kaznu.",
    "ayah": 34,
    "surah": 77
  },
  {
    "text": "Toga dana oni neće ništa pričati.",
    "ayah": 35,
    "surah": 77
  },
  {
    "text": "Neće im biti dozvoljeno da se pravdaju Allahu, jer su nevjerstvo i grijehe činili.",
    "ayah": 36,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali kazivanja o ovome Danu.",
    "ayah": 37,
    "surah": 77
  },
  {
    "text": "To je dan kada ćemo razvrstati stvorenja, a vas i one prije skupit ćemo na jednom mjestu.",
    "ayah": 38,
    "surah": 77
  },
  {
    "text": "Ako budete imali kakvu spletku i način da se spasite Allahove kazne, pokušajte da je protiv Mene usmjerite.",
    "ayah": 39,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali Sudnji dan u kojem će se ravrstati stvorenja.",
    "ayah": 40,
    "surah": 77
  },
  {
    "text": "Oni koji su se bojali svoga Gospodara, sprovodeći Njegove naredbe i ostavljajući Njegove zabrane, bit će u hladu džennetskog drveća i pored izvora tekućih slatkih voda.",
    "ayah": 41,
    "surah": 77
  },
  {
    "text": "I biće među voćem koje budu htjeli jesti.",
    "ayah": 42,
    "surah": 77
  },
  {
    "text": "Njima će kazati: Jedite lijepa jela i pijte ukusna pića, prijatno vam bilo zbog onoga što ste na dunjaluku činili od dobrih djela.",
    "ayah": 43,
    "surah": 77
  },
  {
    "text": "Ovakvom nagradom počastit ćemo one koji budu dobročinitelji.",
    "ayah": 44,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali ono što je Allah za bogobojazne pripremio.",
    "ayah": 45,
    "surah": 77
  },
  {
    "text": "Onima koji su poricali, kazat će se: Jedite i uživajte kratko na ovome svijetu. Vi ste prijestupnici zbog nevjerovanja u Allaha i poricanja Njegovih poslanika.",
    "ayah": 46,
    "surah": 77
  },
  {
    "text": "Propast i kazna toga dana desit će se onima koji su negirali kaznu na Sudnjem danu.",
    "ayah": 47,
    "surah": 77
  },
  {
    "text": "Kada se ovim poricateljima kaže da radi Allaha klanjaju, oni to ne čine.",
    "ayah": 48,
    "surah": 77
  },
  {
    "text": "Toga dana će gubitnici biti oni koji su poricali istinu koju su poslanici od Allaha donosili",
    "ayah": 49,
    "surah": 77
  },
  {
    "text": "Ako oni ne vjeruju u ovaj Kur'an koji je od njihova Gospodara objavljen, pa u koji će onda govor pored njega vjerovati?",
    "ayah": 50,
    "surah": 77
  }
]
