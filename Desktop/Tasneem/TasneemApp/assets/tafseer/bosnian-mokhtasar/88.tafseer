[
  {
    "text": "Da li je doprla do tebe, o Poslaniče, vijest o Smaku svijeta koji će svojim strahotama sve ljude obuhvatiti?",
    "ayah": 1,
    "surah": 88
  },
  {
    "text": "Na Sudnjem danu ljudi će biti ili sretni ili nesretni i potišteni, a lica nesretnika biće potištena i ponižena.",
    "ayah": 2,
    "surah": 88
  },
  {
    "text": "premorena i napaćena zbog lanaca i okova kojima će biti vezani.",
    "ayah": 3,
    "surah": 88
  },
  {
    "text": "takva lica ući će u Vatru i tamo će gorjeti.",
    "ayah": 4,
    "surah": 88
  },
  {
    "text": "biće napajana sa izvora čija je voda uzavrela,",
    "ayah": 5,
    "surah": 88
  },
  {
    "text": "Oni neće imati čime da se hrane osim najružnije i najogavnije hrane i trnja sa biljke, koje kada se osuši postaje otrovno.",
    "ayah": 6,
    "surah": 88
  },
  {
    "text": "onoga ko jede to trnje neće ugojiti, niti će glad ublažiti.",
    "ayah": 7,
    "surah": 88
  },
  {
    "text": "Lica sretnika toga Dana biće blistava i sretna, zbog blagodati koje ih čekaju.",
    "ayah": 8,
    "surah": 88
  },
  {
    "text": "zadovoljna svojim dobrim djelima koj su rađena na dunjaluku i nagradom koja ih čeka.",
    "ayah": 9,
    "surah": 88
  },
  {
    "text": "u Džennetu koji je mjestom i statusom visok i uzvišen",
    "ayah": 10,
    "surah": 88
  },
  {
    "text": "U Džennetu neće čuti nikakav beskoristan govor, a posebno ne govor koji je zabranjen.",
    "ayah": 11,
    "surah": 88
  },
  {
    "text": "U Džennetu će biti voda koja izvire i oni će je usmjeravati kako budu htjeli.",
    "ayah": 12,
    "surah": 88
  },
  {
    "text": "u njemu se nalaze kreveti podignuti i skupocjeni.",
    "ayah": 13,
    "surah": 88
  },
  {
    "text": "pehari i posude postavljene i i spremne da se iz njih pije.",
    "ayah": 14,
    "surah": 88
  },
  {
    "text": "i u njemu će biti jastuci jedni do drugih postavljeni.",
    "ayah": 15,
    "surah": 88
  },
  {
    "text": "i u njemu će biti tepisi i ćilimi prostrti na sve strane.",
    "ayah": 16,
    "surah": 88
  },
  {
    "text": "Zašto oni ne gledaju kamilu, razmišljajući o tome, pa vide kako je stvorena, i potčinjena ljudima?",
    "ayah": 17,
    "surah": 88
  },
  {
    "text": "i zašto ne pogledaju u nebo pa da vide kako je podignuto i iznad njih kao svod postavljeno, sačuvano od pada na njih.",
    "ayah": 18,
    "surah": 88
  },
  {
    "text": "i zašto ne pogledaju u brda kako su postavljena i kako čuvaju Zemlju od podrhtavanja?",
    "ayah": 19,
    "surah": 88
  },
  {
    "text": "i zašto ne pogledaju u Zemlju kako ju je Allah prostro i pogodnom za život ljudi na njoj, učinio.",
    "ayah": 20,
    "surah": 88
  },
  {
    "text": "Ti, o Allahov Poslaniče, upozori ove i zaprijeti im kaznom Allahovom, jer ti si samo dužan da upozoriš, i ništa drugo, a uputa je u Allahovim rukama.",
    "ayah": 21,
    "surah": 88
  },
  {
    "text": "ti ih ne siliš da povjeruju, niti ih na to tjeraš.",
    "ayah": 22,
    "surah": 88
  },
  {
    "text": "a onoga ko se okreće od vjerovanja i ne vjeruje u Allaha i Njegova Poslanika",
    "ayah": 23,
    "surah": 88
  },
  {
    "text": "Na Sudnjem danu Allah će ga kazniti velikom kaznom, tako što će ga uvesti u Džehennem, gdje će vječno boraviti.",
    "ayah": 24,
    "surah": 88
  },
  {
    "text": "Samo Njemu će se vratiti nakon smrti.",
    "ayah": 25,
    "surah": 88
  },
  {
    "text": "A zatim ćemo samo Mi da s njima račun svodimo za njihova djela, a to nije tvoje niti bilo čije drugo.",
    "ayah": 26,
    "surah": 88
  }
]
