[
  {
    "text": "O ljudi, vas je od pokornosti Allahu zaokupilo nastojanje da što imućniji budete i da se hvališete vašim imetkom i djecom.",
    "ayah": 1,
    "surah": 102
  },
  {
    "text": "sve dok ne umrete i ne uđete u kaburove.",
    "ayah": 2,
    "surah": 102
  },
  {
    "text": "A ne treba da vas to zaokuplja od pokornosti Allahu, a saznat ćete rezultat tog vašeg zaokupljanja.",
    "ayah": 3,
    "surah": 102
  },
  {
    "text": "Zatim, saznat ćete sigurno rezultat i posljedice toga.",
    "ayah": 4,
    "surah": 102
  },
  {
    "text": "Doista, kada biste bili uvjereni da će vas Allah proživjeti i za vaša djela adekvatno tretirati, ne bi vas zaokupilo hvalisanje imetkom i djecom.",
    "ayah": 5,
    "surah": 102
  },
  {
    "text": "Tako mi Allaha, vidjet ćete Vatru na Sudnjem danu.",
    "ayah": 6,
    "surah": 102
  },
  {
    "text": "I još jednom, sasvim sigurno ćete vidjeti je, bez imalo sumnje.",
    "ayah": 7,
    "surah": 102
  },
  {
    "text": "Toga dana Allah će vas pitati o vašim blagodatima, kao što su zdravlje, bogatstvo i dr.",
    "ayah": 8,
    "surah": 102
  }
]
