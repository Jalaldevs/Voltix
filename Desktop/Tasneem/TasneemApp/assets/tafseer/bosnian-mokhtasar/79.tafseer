[
  {
    "text": "Allah Uzvišeni kune se melekima koji čupaju duše nevjernika grubo i žestoko.",
    "ayah": 1,
    "surah": 79
  },
  {
    "text": "I kune se melekima koji vade duše vjernika jednostavno i blago.",
    "ayah": 2,
    "surah": 79
  },
  {
    "text": "I kune se melekima koji plove i kreću se sa nebesa prema Zemlji, naredbom Allaha.",
    "ayah": 3,
    "surah": 79
  },
  {
    "text": "I kune se melekima koji jedni druge pretiču u ispunjavanju Allahovih naredbi.",
    "ayah": 4,
    "surah": 79
  },
  {
    "text": "I kune se melekima koji izvršavaju Allahove naredbe i odredbe, poput meleka zaduženih za ljudska djela. Svim ovim se kune potvrđujući da će ih proživjeti radi obračuna, i kazne, odnosno nagrade.",
    "ayah": 5,
    "surah": 79
  },
  {
    "text": "na Dan kada će se Zemlja zatresti, kada se prvi put u rog puhne.",
    "ayah": 6,
    "surah": 79
  },
  {
    "text": "Nakon ovog puhanja dolazi drugo.",
    "ayah": 7,
    "surah": 79
  },
  {
    "text": "Toga dana će srca nevjernika i griješnika biti strahom ispunjena.",
    "ayah": 8,
    "surah": 79
  },
  {
    "text": "Na njihovim pogledima biće vidljivi znakovi poniženja.",
    "ayah": 9,
    "surah": 79
  },
  {
    "text": "Govorili su: Zar ćemo u život biti vraćeni nakon što umremo.",
    "ayah": 10,
    "surah": 79
  },
  {
    "text": "Zar ćemo povraćeni biti, kada kosti oronule postanemo?",
    "ayah": 11,
    "surah": 79
  },
  {
    "text": "Govorili su: kada budemo vraćeno, taj povratak će propast i gubitak donijeti.",
    "ayah": 12,
    "surah": 79
  },
  {
    "text": "Pitanje proživljenja je jednostavno, to je samo jedan glas meleka zaduženog za puhanje u rog.",
    "ayah": 13,
    "surah": 79
  },
  {
    "text": "a oni će već biti živi na zemljinoj površini, nakon što su ležali mrtvi u njenoj unutrašnjosti.",
    "ayah": 14,
    "surah": 79
  },
  {
    "text": "Da li ti je stigla, o Poslaniče, vijest o Musau i njegovom Gospodaru, kao i vijest o njemu i neprijatelju njegovom, faraonu?",
    "ayah": 15,
    "surah": 79
  },
  {
    "text": "kada ga je njegov Gospodar zovnuo dok je bio u svetoj dolini Tuva.",
    "ayah": 16,
    "surah": 79
  },
  {
    "text": "Rekao mu je, između ostalog: Otiđi faraonu, jer on je prešao granicu u nepravdi i oholosti.",
    "ayah": 17,
    "surah": 79
  },
  {
    "text": "Pa mu reci: da li želiš, o faraonu, da se očistiš od nevjerovanja i griješenja?",
    "ayah": 18,
    "surah": 79
  },
  {
    "text": "i da te uputim ka tvome Gospodaru koji te stvorio i koji se o tebi brine, pa da Ga se bojiš, te da radiš djela kojima je On zadovoljan i da se kloniš onoga što izaziva Njegovu srdžbu.",
    "ayah": 19,
    "surah": 79
  },
  {
    "text": "Pa mu je Musa alejhi selam, pokazao najveće znamenje koje upućuje da je on istiniti poslanik od svoga Gospodara, a to su ruka i štap.",
    "ayah": 20,
    "surah": 79
  },
  {
    "text": "međutim, faraon je negirao taj znak i oglušio se o naredbu Musaa, alejhi selam.",
    "ayah": 21,
    "surah": 79
  },
  {
    "text": "Zatim se okrenuo od vjerovanja kojem je Musa pozivao, te se još više posvetio grijesima, negirajući istinu.",
    "ayah": 22,
    "surah": 79
  },
  {
    "text": "potom je skupio svoj narod i sljedbenike, kako bi nadvladao Musaa, pa je povikao, govoreći im:",
    "ayah": 23,
    "surah": 79
  },
  {
    "text": "Ja sam vaš uzvišeni gospodar, a vi se morate samo meni pokoravati.",
    "ayah": 24,
    "surah": 79
  },
  {
    "text": "Allah ga je kaznio na dunjaluku tako što ga je u moru potopio, a kaznit će ga i na onome svijetu, uvodeći ga u najtežu patnju.",
    "ayah": 25,
    "surah": 79
  },
  {
    "text": "U kazni kojom smo kaznili faraona na dunjaluku i na onome svijetu, poruka je za onoga ko se Allaha bude bojao, jer samo takav može uzeti koristi iz ovih kazivanja.",
    "ayah": 26,
    "surah": 79
  },
  {
    "text": "A šta je teže: vas, o poricateljii proživljenja, stvoriti ili stvoriti nebo kojeg je On sagradio?",
    "ayah": 27,
    "surah": 79
  },
  {
    "text": "dao je da svod njegov bude uzdignut visoko i da bude savršeno stvoren, bez ikakvih nedostataka.",
    "ayah": 28,
    "surah": 79
  },
  {
    "text": "dao je da noć bude tamna kada Sunce zađe, a da danju svjetlo se pojavi, kada ono iziđe.",
    "ayah": 29,
    "surah": 79
  },
  {
    "text": "Nakon što je stvorio nebesa, Zemlju je razastro i na njoj mnoge koristi dao.",
    "ayah": 30,
    "surah": 79
  },
  {
    "text": "iz nje je izvore vode koja teče dao i pašnjake je, na kojima stoka vaša pase, po njoj uspostavio.",
    "ayah": 31,
    "surah": 79
  },
  {
    "text": "i brda je na Zemlji postojanim i čvrstim učinio.",
    "ayah": 32,
    "surah": 79
  },
  {
    "text": "Sve ove koristi, o ljudi, dao je vama i stoci vašoj. Onaj koji je sve ovo stvorio, u stanju je i da vas ponovo u život vrati.",
    "ayah": 33,
    "surah": 79
  },
  {
    "text": "Kada bude drugo puhanje u rog, sve će strahom prekriti i Sudnji dan će nastupiti.",
    "ayah": 34,
    "surah": 79
  },
  {
    "text": "Kada taj dan nastupi, čovjek će se prisjetiti svih svojih postupaka koje je činio, bilo da su dobri ili loši.",
    "ayah": 35,
    "surah": 79
  },
  {
    "text": "Džehennem će se približiti i svako ko gleda, vidjeće ga.",
    "ayah": 36,
    "surah": 79
  },
  {
    "text": "Pa onaj ko je granice zablude prekoračivao",
    "ayah": 37,
    "surah": 79
  },
  {
    "text": "i davao prednost životu na ovome svijetu nad vječnim onosvjetskim životom",
    "ayah": 38,
    "surah": 79
  },
  {
    "text": "Vatru će nastaniti i u njoj boraviti.",
    "ayah": 39,
    "surah": 79
  },
  {
    "text": "Onom ko se bude bojao stajanja pred svojim Gospodarom i ko se bude čuvao povođenja za strastima koje je Alah zabranio, Džennet će biti boravište i u njega će se nastaniti.",
    "ayah": 40,
    "surah": 79
  },
  {
    "text": "Onom ko se bude bojao stajanja pred svojim Gospodarom i ko se bude čuvao povođenja za strastima koje je Alah zabranio, Džennet će biti boravište i u njega će se nastaniti.",
    "ayah": 41,
    "surah": 79
  },
  {
    "text": "Pitaju te, o Poslaniče, ovi mušrici koji poriču proživljenje: Kada će biti Sudnji dan?",
    "ayah": 42,
    "surah": 79
  },
  {
    "text": "Ti nemaš znanja o njemu, pa da im spomeneš kada će se desiti, a to nije u tvojoj moći, jer ono što je na tebi jeste da se pripremiš za taj dan.",
    "ayah": 43,
    "surah": 79
  },
  {
    "text": "Samo tvoj Gospodar zna kada će desiti Sudnji dan.",
    "ayah": 44,
    "surah": 79
  },
  {
    "text": "Ti si samo onaj ko upozorava onoga ko se boji toga Dana, jer samo takav će se okoristiti tvojim upozorenjem.",
    "ayah": 45,
    "surah": 79
  },
  {
    "text": "Kada vide Sudnji dan, misliće kao da su na dunjaluku živjeli jedno poslije podne ili jedno jutro.",
    "ayah": 46,
    "surah": 79
  }
]
