[
  {
    "text": "Teška prijetnja i kazna čeka one koji mnogo ljude ogovaraju i vrijeđaju ih.",
    "ayah": 1,
    "surah": 104
  },
  {
    "text": "onaj čija je briga kako će skupiti imetak i brojati ga, i nema druge brige i težnje osim toga.",
    "ayah": 2,
    "surah": 104
  },
  {
    "text": "i smatra da će ga imetak koji skuplja sačuvati smrti i učiniti vječnim na ovome svijetu.",
    "ayah": 3,
    "surah": 104
  },
  {
    "text": "A ne treba tako da misli taj neznalica, jer se to neće desiti! On će, sigurno, biti bačen u Vatru džehennemsku koja će progutati sve što u nju uđe.",
    "ayah": 4,
    "surah": 104
  },
  {
    "text": "A znaš li ti, o Poslaniče, šta je to Hutama, ili vatra koja će gutati sve što u nju bude bačeno.",
    "ayah": 5,
    "surah": 104
  },
  {
    "text": "Uistinu, to je Allahova vatra koja se razbuktala.",
    "ayah": 6,
    "surah": 104
  },
  {
    "text": "koja će kroz tijela ljudi prolaziti i do njihovih srca dolaziti.",
    "ayah": 7,
    "surah": 104
  },
  {
    "text": "Iznad onih koji budu vatrom kažnjavani biće zatvoreno, prekrivat će ih vatra.",
    "ayah": 8,
    "surah": 104
  },
  {
    "text": "dugim stubovima kako ne bi mogli iz nje izići.",
    "ayah": 9,
    "surah": 104
  }
]
