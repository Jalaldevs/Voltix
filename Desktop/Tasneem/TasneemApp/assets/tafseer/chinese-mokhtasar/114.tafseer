[
  {
    "text": "使者啊！你说：“我依托、求助于世人的主宰，",
    "ayah": 1,
    "surah": 114
  },
  {
    "text": "祂是世人的君王，祂依照自己所欲安排世人，除祂外再无君王，",
    "ayah": 2,
    "surah": 114
  },
  {
    "text": "祂是世人依真理所崇拜的主，除祂外再无应受世人崇拜的，",
    "ayah": 3,
    "surah": 114
  },
  {
    "text": "求祂使我免遭教唆人类忽视或故意拖延纪念真主的恶魔的毒害，",
    "ayah": 4,
    "surah": 114
  },
  {
    "text": "恶魔将教唆投入世人的心中，",
    "ayah": 5,
    "surah": 114
  },
  {
    "text": "他有来自人类的，也有来自精灵的。”",
    "ayah": 6,
    "surah": 114
  }
]
