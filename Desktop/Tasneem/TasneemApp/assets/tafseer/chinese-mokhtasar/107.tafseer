[
  {
    "text": "你知道否认复活日回报的人吗?",
    "ayah": 1,
    "surah": 107
  },
  {
    "text": "他就是当孤儿有求于他，而严厉呵斥之人，",
    "ayah": 2,
    "surah": 107
  },
  {
    "text": "是不主动，也不鼓励他人去施舍穷人之人，",
    "ayah": 3,
    "surah": 107
  },
  {
    "text": "毁灭并惩罚那些礼拜者",
    "ayah": 4,
    "surah": 107
  },
  {
    "text": "他们对自己的拜功确是疏忽的，他们不注重礼拜时间，直到时间已过，",
    "ayah": 5,
    "surah": 107
  },
  {
    "text": "他们是以其礼拜和善功而炫耀之人，他们并不虔诚为主，",
    "ayah": 6,
    "surah": 107
  },
  {
    "text": "他们在不伤自己利益时也不愿意帮助他人。",
    "ayah": 7,
    "surah": 107
  }
]
