[
  {
    "text": "使者啊！你说“不信真主的人们啊！",
    "ayah": 1,
    "surah": 109
  },
  {
    "text": "我现在和将来都不崇拜你们所崇拜的偶像，",
    "ayah": 2,
    "surah": 109
  },
  {
    "text": "你们也不崇拜我所崇拜的独一的真主，",
    "ayah": 3,
    "surah": 109
  },
  {
    "text": "我不崇拜你们崇拜的偶像，",
    "ayah": 4,
    "surah": 109
  },
  {
    "text": "你们也不崇拜我所崇拜的独一的真主，",
    "ayah": 5,
    "surah": 109
  },
  {
    "text": "你们有你们为自己创造的宗教，我有由真主降示给我的宗教。”",
    "ayah": 6,
    "surah": 109
  }
]
