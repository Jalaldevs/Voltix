[
  {
    "text": "使者啊！你说：“我求护曙光的主，我祈求祂保护我，",
    "ayah": 1,
    "surah": 113
  },
  {
    "text": "免遭被造物的毒害，",
    "ayah": 2,
    "surah": 113
  },
  {
    "text": "我求护于真主，护佑我免遭夜间出现的动物和强盗的毒害，",
    "ayah": 3,
    "surah": 113
  },
  {
    "text": "我求护于祂，使我免遭摧毁信仰的妖术家的毒害。",
    "ayah": 4,
    "surah": 113
  },
  {
    "text": "我求护于祂，使我免遭使嫉妒者产生嫉妒的毒害。”",
    "ayah": 5,
    "surah": 113
  }
]
