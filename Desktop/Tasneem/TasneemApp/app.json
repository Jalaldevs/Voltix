{
  "expo": {
    "scheme": [
      "tasneem"
    ],
    "name": "Tasneem",
    "slug": "tasneem",
    "version": "5.0.0",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.jalaldevs.tasneem",
      "supportsTablet": false,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "We need your location to show prayer times.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "icon": "./assets/images/logoScreen.png",
    "android": {
      "package": "com.jalaldevs.tasneem",
      "versionCode": 2,
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/logoScreen.png",
        "backgroundColor": "#ffffff"
      },
      "edgeToEdgeEnabled": true,
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "android.permission.RECORD_AUDIO",
        "android.permission.MODIFY_AUDIO_SETTINGS",
        "SCHEDULE_EXACT_ALARM",
        "android.permission.ACCESS_COARSE_LOCATION",
        "android.permission.ACCESS_FINE_LOCATION"
      ]
    },
    "web": {},
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-audio",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#ffffff",
          "image": "./assets/images/splashScreen.png",
          "imageWidth": 350,
          "hideStatusBar": true,
          "fadeOutDuration": 200,
          "resizeMode": "contain"
        }
      ],
      [
        "expo-build-properties",
        {
          "android": {
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "minSdkVersion": 24,
            "kotlinVersion": "2.1.20"
          }
        }
      ],
      "expo-localization",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/logoScreen.png",
          "color": "#ffffff",
          "sounds": [
            "./assets/sounds/fajr.mp3",
            "./assets/sounds/regular.mp3",
            "./assets/sounds/beep.mp3"
          ]
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "We need your location to determine the Qibla direction"
        }
      ],
      "expo-asset",
      "expo-sqlite"
    ],
    "extra": {
      "router": {},
      "sunnahPadPackName": "sunnahpack",
      "sunnahPadAutoFetch": true,
      "tafseerPadPackName": "tafseerpack",
      "tafseerPadAutoFetch": true,
      "eas": {
        "projectId": "c2ab28d0-c4e4-4afd-9382-2d60707c920c"
      }
    },
    "owner": "tasneemapp"
  }
}